# TradBOT Environment Configuration
# Copy to .env and fill in your actual values
# NEVER commit .env with real secrets!

# === API KEYS (CRITICAL - ROTATE IF EXPOSED) ===
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key-here
POLYGON_API_KEY=your-polygon-api-key-here
TWILIO_AUTH_TOKEN=your-twilio-auth-token-here
GEMINI_API_KEY=your-gemini-api-key-here

# === DATABASE ===
SUPABASE_URL=your-supabase-url-here
SUPABASE_KEY=your-supabase-anon-key-here
SUPABASE_PASSWORD=your-supabase-db-password-here
DATABASE_URL=postgresql://user:password@host:5432/tradbot

# === TRADING CONFIGURATION ===
MT5_MAX_LOSS_PER_TRADE=3.0
MT5_MAX_POSITIONS=5
MT5_ACCOUNT_LOGIN=your-mt5-account-number

# === AI SERVER ===
AI_SERVER_URL=http://localhost:8000
USE_RENDER_AI_SERVER=false
RENDER_AI_SERVER_URL=https://your-render-app.onrender.com

# === TRADINGAGENTS BRIDGE (CLI → ai_server → MT5) ===
# Chemin vers le dépôt local TradingAgents-main
AI_TRADINGAGENTS_REPO_PATH=D:\Dev\Depot Github\TradingAgents-main
# Désactivé par défaut — utiliser le script tradbot_bridge.py (mode manuel)
AI_ENABLE_TRADINGAGENTS_AUTO_LOOP=false
AI_TRADINGAGENTS_ALLOW_HTTP_RUNS=false
# Durée de vie du rapport CLI dans le cache /decision (secondes)
AI_TRADINGAGENTS_MANUAL_TTL_SEC=1800
# Poids du signal TA dans le score buy/sell de /decision (0.0–1.0)
AI_TRADINGAGENTS_CLI_WEIGHT=0.35
# Fusionner entry_price / SL / TP de TA dans la réponse /decision → MT5
AI_TRADINGAGENTS_EXEC_MERGE_ENABLED=true
AI_TRADINGAGENTS_EXEC_MERGE_MIN_CONF=0.55
AI_TRADINGAGENTS_MERGE_STOPS_FROM_TA=true
# LLM provider utilisé par le bridge (les clés API viennent du .env TradingAgents)
TRADINGAGENTS_LLM_PROVIDER=openai

# === NOTIFICATION ===
WHATSAPP_PHONE_NUMBER=your-phone-number   # ex: +2290196911346
WHATSAPP_PHONE=your-phone-number          # alias utilisé par /notify-whatsapp (MT5 → TradeManager)
PSYCHOBOT_URL=https://psychobot-1si7.onrender.com
SLACK_WEBHOOK_URL=your-slack-webhook-url

# === FEATURES ===
ENABLE_ML_TRADING=true
ENABLE_SNIPER_MODULES=true
ENABLE_DASHBOARD=true

# === DIVERGENCE STRATEGY (Deriv synthétiques → /decision → SMC_Universal) ===
ENABLE_DIVERGENCE_STRATEGY=true
DIVERGENCE_MIN_CANDLES=80
DIVERGENCE_DIV_LONG=0.15
DIVERGENCE_DIV_SHORT=-0.15
DIVERGENCE_STOP_ATR=1.5
DIVERGENCE_TP_ATR=2.5
DIVERGENCE_MIN_CONFIDENCE=0.55
DIVERGENCE_OVERRIDE_HOLD=true
DIVERGENCE_PREFER_ON_CONFLICT=false

# === LOGGING ===
LOG_LEVEL=INFO
DEBUG_MODE=false
