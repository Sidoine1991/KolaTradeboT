# TradBOT Environment Configuration
# Copy to .env and fill in your actual values
# ⚠️ NEVER commit .env with real secrets! Use .gitignore

# ============================================================
# 🔐 CRITICAL: AWS & API CREDENTIALS (ROTATE IF EXPOSED)
# ============================================================
# Get these from:
# - AWS: https://console.aws.amazon.com/iam/ (Users → Security credentials)
# - OpenAI: https://platform.openai.com/account/api-keys
# - NVIDIA: https://build.nvidia.com/

AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_REGION=us-east-1

OPENAI_API_KEY=YOUR_OPENAI_API_KEY
NVIDIA_API_KEY=YOUR_NVIDIA_API_KEY

# ============================================================
# 📊 TRADING API KEYS
# ============================================================
ALPHA_VANTAGE_API_KEY=YOUR_ALPHA_VANTAGE_KEY
POLYGON_API_KEY=YOUR_POLYGON_API_KEY
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
DERIV_APP_ID=1089
DERIV_API_TOKEN=YOUR_DERIV_API_TOKEN

# ============================================================
# 🗄️ DATABASE CREDENTIALS
# ============================================================
# AWS RDS (trading-db)
DATABASE_URL=postgresql://dbadmin:YOUR_RDS_PASSWORD@trading-db.cq9suk2wcwxh.us-east-1.rds.amazonaws.com:5432/postgres

# Supabase (optional, legacy)
SUPABASE_URL=YOUR_SUPABASE_URL
SUPABASE_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_PASSWORD=YOUR_SUPABASE_DB_PASSWORD

# ============================================================
# 📱 NOTIFICATIONS & INTEGRATIONS
# ============================================================
WHATSAPP_PHONE=+2290196911346
WHATSAPP_PHONE_NUMBER=+2290196911346
PSYCHOBOT_URL=https://psychobot-1si7.onrender.com
SLACK_WEBHOOK_URL=YOUR_SLACK_WEBHOOK_URL
EMAIL_ADDRESS=syebadokpo@gmail.com

# ============================================================
# 🤖 AI SERVER CONFIGURATION
# ============================================================
AI_SERVER_URL=http://localhost:8000
RENDER_AI_SERVER_URL=https://ai-server-xxxxx.onrender.com
USE_RENDER_AI_SERVER=false

# ============================================================
# 📈 TRADING CONFIGURATION
# ============================================================
MT5_MAX_LOSS_PER_TRADE=3.0
MT5_MAX_POSITIONS=5
MT5_ACCOUNT_LOGIN=YOUR_MT5_ACCOUNT_NUMBER

# === TRADINGAGENTS BRIDGE ===
AI_TRADINGAGENTS_REPO_PATH=D:\Dev\Depot Github\TradingAgents-main
AI_ENABLE_TRADINGAGENTS_AUTO_LOOP=false
AI_TRADINGAGENTS_ALLOW_HTTP_RUNS=false
AI_TRADINGAGENTS_MANUAL_TTL_SEC=1800
AI_TRADINGAGENTS_CLI_WEIGHT=0.35
AI_TRADINGAGENTS_EXEC_MERGE_ENABLED=true
AI_TRADINGAGENTS_EXEC_MERGE_MIN_CONF=0.55
AI_TRADINGAGENTS_MERGE_STOPS_FROM_TA=true
TRADINGAGENTS_LLM_PROVIDER=openai

# === DIVERGENCE STRATEGY ===
ENABLE_DIVERGENCE_STRATEGY=true
DIVERGENCE_MIN_CANDLES=80
DIVERGENCE_DIV_LONG=0.15
DIVERGENCE_DIV_SHORT=-0.15
DIVERGENCE_STOP_ATR=1.5
DIVERGENCE_TP_ATR=2.5
DIVERGENCE_MIN_CONFIDENCE=0.55
DIVERGENCE_OVERRIDE_HOLD=true
DIVERGENCE_PREFER_ON_CONFLICT=false

# ============================================================
# ⚙️ FEATURES
# ============================================================
ENABLE_ML_TRADING=true
ENABLE_SNIPER_MODULES=true
ENABLE_DASHBOARD=true

# ============================================================
# 📋 LOGGING
# ============================================================
LOG_LEVEL=INFO
DEBUG_MODE=false
