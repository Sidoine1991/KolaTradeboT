//@version=6
indicator("GOM KOLA — MTF Direction", shorttitle="GOM·MTF", overlay=true)

// ═══════════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════════
grp_tf = "TIMEFRAMES"
tf1 = input.timeframe("1",   "TF1", group=grp_tf)
tf2 = input.timeframe("5",   "TF2", group=grp_tf)
tf3 = input.timeframe("15",  "TF3", group=grp_tf)
tf4 = input.timeframe("60",  "TF4", group=grp_tf)
tf5 = input.timeframe("240", "TF5", group=grp_tf)
tf6 = input.timeframe("D",   "TF6", group=grp_tf)
tf7 = input.timeframe("W",   "TF7", group=grp_tf)

grp_m    = "MÉTHODE"
ema_fast = input.int(9,  "EMA Rapide", minval=2,  group=grp_m)
ema_slow = input.int(21, "EMA Lente",  minval=5,  group=grp_m)
ema_htf  = input.int(50, "EMA HTF",    minval=20, group=grp_m)
rsi_per  = input.int(14, "RSI",        minval=5,  group=grp_m)
show_bg  = input.bool(true, "Fond coloré TF actuel", group=grp_m)

// ═══════════════════════════════════════════════════════════════
// DIRECTION PAR TF
// Retourne : 1=BULL | -1=BEAR | 0=NEUT
// Critères (4 pts) : EMA9>21 | prix>EMA50 | RSI>52 | ST haussier
// ═══════════════════════════════════════════════════════════════
f_dir(tf) =>
    _c   = request.security(syminfo.tickerid, tf, close, lookahead=barmerge.lookahead_off)
    _hl2 = request.security(syminfo.tickerid, tf, hl2,   lookahead=barmerge.lookahead_off)
    _ef  = request.security(syminfo.tickerid, tf, ta.ema(close, ema_fast), lookahead=barmerge.lookahead_off)
    _es  = request.security(syminfo.tickerid, tf, ta.ema(close, ema_slow), lookahead=barmerge.lookahead_off)
    _eh  = request.security(syminfo.tickerid, tf, ta.ema(close, ema_htf),  lookahead=barmerge.lookahead_off)
    _rsi = request.security(syminfo.tickerid, tf, ta.rsi(close, rsi_per),  lookahead=barmerge.lookahead_off)
    _atr = request.security(syminfo.tickerid, tf, ta.atr(10), lookahead=barmerge.lookahead_off)
    _stb = _c > (_hl2 + 3.0 * _atr)
    _b = (_ef > _es ? 1 : 0) + (_c > _eh ? 1 : 0) + (_rsi > 52 ? 1 : 0) + (_stb ? 1 : 0)
    _s = (_ef < _es ? 1 : 0) + (_c < _eh ? 1 : 0) + (_rsi < 48 ? 1 : 0) + (not _stb ? 1 : 0)
    _d = _b >= 3 ? 1 : _s >= 3 ? -1 : 0
    [_d, _rsi]

// ═══════════════════════════════════════════════════════════════
// CALCUL 7 TFs
// ═══════════════════════════════════════════════════════════════
[d1,r1] = f_dir(tf1)
[d2,r2] = f_dir(tf2)
[d3,r3] = f_dir(tf3)
[d4,r4] = f_dir(tf4)
[d5,r5] = f_dir(tf5)
[d6,r6] = f_dir(tf6)
[d7,r7] = f_dir(tf7)

nb = (d1==1?1:0)+(d2==1?1:0)+(d3==1?1:0)+(d4==1?1:0)+(d5==1?1:0)+(d6==1?1:0)+(d7==1?1:0)
ns = (d1==-1?1:0)+(d2==-1?1:0)+(d3==-1?1:0)+(d4==-1?1:0)+(d5==-1?1:0)+(d6==-1?1:0)+(d7==-1?1:0)
nn = 7 - nb - ns
gd = nb >= 5 ? 1 : ns >= 5 ? -1 : nb > ns ? 1 : ns > nb ? -1 : 0

// ═══════════════════════════════════════════════════════════════
// FOND TF COURANT
// ═══════════════════════════════════════════════════════════════
[cur_d, cur_r] = f_dir(timeframe.period)
bgcolor(show_bg ? (cur_d==1 ? color.new(color.lime,95) : cur_d==-1 ? color.new(color.red,95) : na) : na)

// ═══════════════════════════════════════════════════════════════
// HELPERS
// ═══════════════════════════════════════════════════════════════
f_txt(d) => d==1 ? "▲ BULL" : d==-1 ? "▼ BEAR" : "◆ NEUT"
f_col(d) => d==1 ? color.lime : d==-1 ? color.red : color.orange
f_bg(d)  => d==1 ? color.new(color.lime,82) : d==-1 ? color.new(color.red,82) : color.new(color.gray,82)
f_lbl(tf) =>
    switch tf
        "1"   => "M1"
        "5"   => "M5"
        "15"  => "M15"
        "60"  => "H1"
        "240" => "H4"
        "D"   => "D1"
        "W"   => "W1"
        => tf

// ═══════════════════════════════════════════════════════════════
// TABLE — style GOM KOLA (top right)
// ═══════════════════════════════════════════════════════════════
var table T = table.new(position.top_right, 3, 10,
    bgcolor=color.new(color.black,15),
    border_color=color.new(color.gray,50), border_width=1,
    frame_color=color.new(color.gray,30), frame_width=2)

if barstate.islast
    hbg = color.new(color.navy,10)
    table.cell(T,0,0,"TF",        text_color=color.silver, text_size=size.small, bgcolor=hbg)
    table.cell(T,1,0,"DIRECTION", text_color=color.silver, text_size=size.small, bgcolor=hbg)
    table.cell(T,2,0,"RSI",       text_color=color.silver, text_size=size.small, bgcolor=hbg)

    tfs  = array.from(tf1,tf2,tf3,tf4,tf5,tf6,tf7)
    dirs = array.from(d1, d2, d3, d4, d5, d6, d7)
    rsis = array.from(r1, r2, r3, r4, r5, r6, r7)

    for i = 0 to 6
        _tf = array.get(tfs, i)
        _d  = array.get(dirs,i)
        _r  = array.get(rsis,i)
        _rw = i + 1
        _rc = _r > 60 ? color.lime : _r < 40 ? color.red : color.silver
        table.cell(T,0,_rw, f_lbl(_tf), text_color=color.white,  text_size=size.small, bgcolor=f_bg(_d))
        table.cell(T,1,_rw, f_txt(_d),  text_color=f_col(_d),    text_size=size.small, bgcolor=f_bg(_d))
        table.cell(T,2,_rw, str.tostring(math.round(_r)), text_color=_rc, text_size=size.small, bgcolor=f_bg(_d))

    sep = color.new(color.black,30)
    table.cell(T,0,8,"──────", text_color=color.new(color.gray,60), text_size=size.tiny, bgcolor=sep)
    table.cell(T,1,8,"──────", text_color=color.new(color.gray,60), text_size=size.tiny, bgcolor=sep)
    table.cell(T,2,8,"──────", text_color=color.new(color.gray,60), text_size=size.tiny, bgcolor=sep)

    gbg  = gd==1 ? color.new(color.lime,55) : gd==-1 ? color.new(color.red,55) : color.new(color.orange,65)
    gtxt = gd==1 ? "▲▲ BULL" : gd==-1 ? "▼▼ BEAR" : "◆ MIXED"
    table.cell(T,0,9, "GLOBAL " + str.tostring(nb) + "B " + str.tostring(ns) + "S",
        text_color=color.white, text_size=size.small, bgcolor=gbg)
    table.cell(T,1,9, gtxt, text_color=f_col(gd), text_size=size.normal, bgcolor=gbg)
    table.cell(T,2,9, str.tostring(nn) + " N", text_color=color.orange, text_size=size.small, bgcolor=gbg)
