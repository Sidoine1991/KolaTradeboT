
//@version=6
indicator("GOM KOLA SIDO — OB + CHoCH + Fibo + Spike + Verdict", shorttitle="GOM·KOLA", overlay=true, max_lines_count=500, max_labels_count=500, max_boxes_count=200)

// ═══════════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════════
grp_ob      = "ORDER BLOCKS"
ob_lookback = input.int(10, "Lookback OB (bougies)", minval=3, maxval=50, group=grp_ob)
ob_show     = input.bool(true, "Afficher OBs", group=grp_ob)

grp_struct  = "STRUCTURE (CHoCH / BOS)"
show_choch  = input.bool(true, "Afficher CHoCH / BOS", group=grp_struct)
struct_lb   = input.int(8, "Lookback pivots structure", minval=3, maxval=30, group=grp_struct)

grp_fib     = "FIBONACCI"
show_fib    = input.bool(true, "Afficher Fibonacci", group=grp_fib)
fib_lb      = input.int(50, "Lookback swing Fibo", minval=20, maxval=200, group=grp_fib)

grp_spike   = "SPIKE DETECTOR (GOM)"
spike_lb    = input.int(25, "Lookback spike", minval=10, maxval=60, group=grp_spike)
spike_min   = input.float(0.62, "Seuil alerte spike", minval=0.40, maxval=0.95, step=0.01, group=grp_spike)
spike_blink = input.float(0.52, "Seuil alerte précoce", minval=0.40, maxval=0.95, step=0.01, group=grp_spike)

grp_ind     = "INDICATEURS"
show_vwap   = input.bool(true, "VWAP session", group=grp_ind)
show_bb     = input.bool(true, "Bollinger Bands", group=grp_ind)
bb_period   = input.int(20, "Période BB", group=grp_ind)
bb_dev      = input.float(2.0, "Déviation BB", group=grp_ind)
show_st     = input.bool(true, "Supertrend", group=grp_ind)
st_atr_per  = input.int(10, "ATR Supertrend", group=grp_ind)
st_mult     = input.float(3.0, "Mult Supertrend", group=grp_ind)

grp_verdict = "VERDICT"
show_verdict= input.bool(true, "Afficher verdict BUY/SELL/WAIT", group=grp_verdict)

// ═══════════════════════════════════════════════════════════════
// VWAP SESSION
// ═══════════════════════════════════════════════════════════════
var float vwap_sum = 0.0
var float vwap_vol = 0.0
is_new_session = ta.change(time("D")) != 0
if is_new_session
    vwap_sum := 0.0
    vwap_vol := 0.0
typical   = (high + low + close) / 3
vwap_sum += typical * volume
vwap_vol += volume
vwap_val  = vwap_sum / vwap_vol
plot(show_vwap ? vwap_val : na, "VWAP", color=color.new(color.yellow, 0), linewidth=2)

// ═══════════════════════════════════════════════════════════════
// BOLLINGER BANDS
// ═══════════════════════════════════════════════════════════════
[bb_mid, bb_up, bb_dn] = ta.bb(close, bb_period, bb_dev)
plot(show_bb ? bb_up  : na, "BB Sup", color=color.new(color.blue, 40), linewidth=1)
plot(show_bb ? bb_mid : na, "BB Mid", color=color.new(color.silver, 50), linewidth=1, style=plot.style_circles)
plot(show_bb ? bb_dn  : na, "BB Inf", color=color.new(color.blue, 40), linewidth=1)

// ═══════════════════════════════════════════════════════════════
// SUPERTREND
// ═══════════════════════════════════════════════════════════════
atr_st  = ta.atr(st_atr_per)
up_band = hl2 - st_mult * atr_st
dn_band = hl2 + st_mult * atr_st
var float st_up  = na
var float st_dn  = na
var int   st_dir = 1
st_up := math.max(up_band, nz(st_up[1], up_band))
st_dn := math.min(dn_band, nz(st_dn[1], dn_band))
if close > nz(st_dn[1])
    st_dir := 1
else if close < nz(st_up[1])
    st_dir := -1
st_line = st_dir == 1 ? st_up : st_dn
col_st  = st_dir == 1 ? color.lime : color.red
plot(show_st ? st_line : na, "Supertrend", color=col_st, linewidth=2)

// ═══════════════════════════════════════════════════════════════
// ORDER BLOCKS
// ═══════════════════════════════════════════════════════════════
pivot_h = ta.pivothigh(high, ob_lookback, ob_lookback)
pivot_l = ta.pivotlow(low,  ob_lookback, ob_lookback)

var float ob_bear_top = na
var float ob_bear_bot = na
var int   ob_bear_bar = na
var float ob_bull_top = na
var float ob_bull_bot = na
var int   ob_bull_bar = na

if not na(pivot_h)
    ob_bear_top := high[ob_lookback + 1]
    ob_bear_bot := math.min(open[ob_lookback + 1], close[ob_lookback + 1])
    ob_bear_bar := bar_index - ob_lookback - 1

if not na(pivot_l)
    ob_bull_top := math.max(open[ob_lookback + 1], close[ob_lookback + 1])
    ob_bull_bot := low[ob_lookback + 1]
    ob_bull_bar := bar_index - ob_lookback - 1

if not na(ob_bear_top) and high >= ob_bear_bot
    ob_bear_top := na
    ob_bear_bot := na
if not na(ob_bull_bot) and low <= ob_bull_top
    ob_bull_top := na
    ob_bull_bot := na

var box ob_bear_box = na
var box ob_bull_box = na

if ob_show and not na(ob_bear_top) and not na(ob_bear_bar)
    if not na(ob_bear_box)
        box.delete(ob_bear_box)
    ob_bear_box := box.new(ob_bear_bar, ob_bear_top, bar_index + 15, ob_bear_bot,
         border_color=color.red, border_width=2, bgcolor=color.new(color.red, 85),
         text="OB Bear ✓", text_color=color.red, text_size=size.small)

if ob_show and not na(ob_bull_bot) and not na(ob_bull_bar)
    if not na(ob_bull_box)
        box.delete(ob_bull_box)
    ob_bull_box := box.new(ob_bull_bar, ob_bull_top, bar_index + 15, ob_bull_bot,
         border_color=color.lime, border_width=2, bgcolor=color.new(color.lime, 85),
         text="OB Bull ✓", text_color=color.lime, text_size=size.small)

// ═══════════════════════════════════════════════════════════════
// STRUCTURE CHoCH / BOS
// ═══════════════════════════════════════════════════════════════
ph = ta.pivothigh(high, struct_lb, struct_lb)
pl = ta.pivotlow(low,  struct_lb, struct_lb)

var float last_ph = na
var float last_pl = na
var float prev_ph = na
var float prev_pl = na

if not na(ph)
    prev_ph := last_ph
    last_ph := ph
if not na(pl)
    prev_pl := last_pl
    last_pl := pl

choch_bear = not na(last_ph) and not na(prev_ph) and not na(prev_pl) and close < prev_pl and last_ph < prev_ph
choch_bull = not na(last_pl) and not na(prev_pl) and not na(prev_ph) and close > prev_ph and last_pl > prev_pl
bos_bear   = not na(last_pl) and close < last_pl and not choch_bear
bos_bull   = not na(last_ph) and close > last_ph and not choch_bull

if show_choch
    if choch_bear
        label.new(bar_index, high, "CHoCH ↓", color=color.new(color.red, 10),
             textcolor=color.white, style=label.style_label_down, size=size.normal)
    if choch_bull
        label.new(bar_index, low, "CHoCH ↑", color=color.new(color.lime, 10),
             textcolor=color.black, style=label.style_label_up, size=size.normal)
    if bos_bear
        label.new(bar_index, high, "BOS ↓", color=color.new(color.orange, 10),
             textcolor=color.white, style=label.style_label_down, size=size.small)
    if bos_bull
        label.new(bar_index, low, "BOS ↑", color=color.new(color.teal, 10),
             textcolor=color.white, style=label.style_label_up, size=size.small)

// ═══════════════════════════════════════════════════════════════
// FIBONACCI
// ═══════════════════════════════════════════════════════════════
fib_high = ta.highest(high, fib_lb)
fib_low  = ta.lowest(low,  fib_lb)
fib_rng  = fib_high - fib_low
f236 = fib_high - 0.236 * fib_rng
f382 = fib_high - 0.382 * fib_rng
f500 = fib_high - 0.500 * fib_rng
f618 = fib_high - 0.618 * fib_rng
f786 = fib_high - 0.786 * fib_rng

plot(show_fib ? fib_high : na, "Fib 0%",    color=color.new(color.white, 40),  linewidth=1, style=plot.style_cross)
plot(show_fib ? f236     : na, "Fib 23.6%", color=color.new(color.purple, 20), linewidth=1)
plot(show_fib ? f382     : na, "Fib 38.2%", color=color.new(color.yellow, 10), linewidth=1)
plot(show_fib ? f500     : na, "Fib 50%",   color=color.new(color.orange, 0),  linewidth=2)
plot(show_fib ? f618     : na, "Fib 61.8%", color=color.new(color.red, 0),     linewidth=2)
plot(show_fib ? f786     : na, "Fib 78.6%", color=color.new(color.red, 30),    linewidth=1)
plot(show_fib ? fib_low  : na, "Fib 100%",  color=color.new(color.lime, 40),   linewidth=1, style=plot.style_cross)

// ═══════════════════════════════════════════════════════════════
// SPIKE DETECTOR — score pour verdict + barcolor discret (0 label)
// ═══════════════════════════════════════════════════════════════
candle_body  = math.abs(close - open)
candle_range = high - low
body_ratio   = candle_range > 0 ? candle_body / candle_range : 0.0

avg_range  = ta.sma(candle_range, spike_lb)
avg_volume = ta.sma(volume, spike_lb)

momentum   = math.abs(close - close[spike_lb]) / (avg_range * spike_lb + 0.0001)
vol_surge  = volume > avg_volume * 1.3 ? 1.0 : volume > avg_volume ? 0.6 : 0.2
bb_squeeze = (bb_up - bb_dn) < ta.sma(bb_up - bb_dn, 20) * 0.85 ? 0.3 : 0.0
body_score = body_ratio > 0.65 ? 0.4 : body_ratio > 0.45 ? 0.2 : 0.0
st_score   = (close > st_line and st_dir == 1) or (close < st_line and st_dir == -1) ? 0.3 : -0.1

spike_raw  = momentum * 0.35 + vol_surge * 0.30 + body_score + bb_squeeze + st_score
spike_prob = math.min(math.max(spike_raw, 0.0), 1.0)

spike_bull = close > open and close > vwap_val and st_dir == 1
spike_bear = close < open and close < vwap_val and st_dir == -1

// Coloration discrète des bougies — aucun label
barcolor(spike_prob >= spike_min and spike_bull ? color.new(color.lime,   30) :
         spike_prob >= spike_min and spike_bear ? color.new(color.red,    30) :
         spike_prob >= spike_blink              ? color.new(color.orange, 50) : na)

// ═══════════════════════════════════════════════════════════════
// VERDICT — tableau coin bas gauche uniquement
// ═══════════════════════════════════════════════════════════════
rsi14     = ta.rsi(close, 14)
macd_line = ta.ema(close, 12) - ta.ema(close, 26)
macd_sig  = ta.ema(macd_line, 9)

score_buy  = 0.0
score_sell = 0.0

score_buy  += st_dir ==  1 ? 1.5 : 0.0
score_sell += st_dir == -1 ? 1.5 : 0.0
score_buy  += close > vwap_val ? 1.0 : 0.0
score_sell += close < vwap_val ? 1.0 : 0.0
score_buy  += close > bb_mid ? 0.5 : 0.0
score_sell += close < bb_mid ? 0.5 : 0.0
score_buy  += rsi14 > 50 and rsi14 < 70 ? 1.0 : rsi14 <= 35 ? 0.5 : 0.0
score_sell += rsi14 < 50 and rsi14 > 30 ? 1.0 : rsi14 >= 65 ? 0.5 : 0.0
score_buy  += macd_line > macd_sig ? 0.8 : 0.0
score_sell += macd_line < macd_sig ? 0.8 : 0.0
score_buy  += not na(ob_bull_bot) and close >= ob_bull_bot and close <= ob_bull_top * 1.003 ? 1.5 : 0.0
score_sell += not na(ob_bear_top) and close <= ob_bear_top and close >= ob_bear_bot * 0.997 ? 1.5 : 0.0
score_buy  += spike_prob >= spike_min and spike_bull ? 2.0 : 0.0
score_sell += spike_prob >= spike_min and spike_bear ? 2.0 : 0.0

verdict_gap = math.abs(score_buy - score_sell)
is_buy  = score_buy  > score_sell and verdict_gap >= 1.2
is_sell = score_sell > score_buy  and verdict_gap >= 1.2

var table tbl = table.new(position.bottom_left, 2, 5,
     bgcolor=color.new(color.black, 20),
     border_color=color.new(color.gray, 40), border_width=1, frame_width=1)

verdict_txt = is_buy ? "BUY" : is_sell ? "SELL" : "WAIT"
verdict_col = is_buy ? color.lime : is_sell ? color.red : color.orange

if show_verdict and barstate.islast
    table.cell(tbl, 0, 0, "GOM VERDICT", text_color=color.silver, text_size=size.small, bgcolor=color.new(color.black, 30))
    table.cell(tbl, 1, 0, verdict_txt,   text_color=verdict_col,  text_size=size.normal, bgcolor=color.new(color.black, 10))
    table.cell(tbl, 0, 1, "BUY score",   text_color=color.silver, text_size=size.small)
    table.cell(tbl, 1, 1, str.tostring(math.round(score_buy  * 10) / 10), text_color=color.lime, text_size=size.small)
    table.cell(tbl, 0, 2, "SELL score",  text_color=color.silver, text_size=size.small)
    table.cell(tbl, 1, 2, str.tostring(math.round(score_sell * 10) / 10), text_color=color.red,  text_size=size.small)
    table.cell(tbl, 0, 3, "Spike %",     text_color=color.silver, text_size=size.small)
    table.cell(tbl, 1, 3, str.tostring(math.round(spike_prob * 100)) + "%",
         text_color=spike_prob >= spike_min ? color.yellow : color.gray, text_size=size.small)
    table.cell(tbl, 0, 4, "RSI / ST",    text_color=color.silver, text_size=size.small)
    table.cell(tbl, 1, 4, str.tostring(math.round(rsi14)) + " / " + (st_dir == 1 ? "↑" : "↓"),
         text_color=st_dir == 1 ? color.lime : color.red, text_size=size.small)

bgcolor(show_verdict ? (is_buy ? color.new(color.lime, 97) : is_sell ? color.new(color.red, 97) : na) : na)

// ═══════════════════════════════════════════════════════════════
// ALERTE JSON — verdict GOM envoyé à TradBOT /gom-verdict
// Créer une alerte TradingView sur ce script avec le message :
//   {{plot("__gom_json")}}   ← ou utiliser l'alerte ci-dessous
// ═══════════════════════════════════════════════════════════════
verdict_changed = ta.change(is_buy ? 1 : is_sell ? -1 : 0) != 0

gom_json = '{"symbol":"' + syminfo.ticker + '","verdict":"' + verdict_txt +
     '","score_buy":' + str.tostring(math.round(score_buy  * 10) / 10) +
     ',"score_sell":' + str.tostring(math.round(score_sell * 10) / 10) +
     ',"spike_pct":'  + str.tostring(math.round(spike_prob * 100)) + '}'

if verdict_changed
    alert(gom_json, alert.freq_once_per_bar)
