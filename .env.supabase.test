# Fichier de test pour configuration Supabase
# Copiez ce contenu dans .env.supabase avec vos vraies valeurs

# URL de votre projet Supabase (remplacez your-project-id)
SUPABASE_URL=https://your-project-id.supabase.co

# Clé API publique (anon key) depuis Supabase Settings > API
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Clé API secrète (service_role) pour les écritures
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Configuration MT5 (optionnelle pour les scripts)
MT5_LOGIN=votre-login-mt5
MT5_PASSWORD=votre-password-mt5
MT5_SERVER=votre-serveur-mt5

# Options d'analyse
ANALYSIS_BARS=1000
TOUCH_TOLERANCE=0.001
STRENGTH_THRESHOLD=50.0
