   ObjectSetInteger(0, changeLine, OBJPROP_COLOR, clrPurple);
   ObjectSetInteger(0, changeLine, OBJPROP_STYLE, STYLE_SOLID);
   ObjectSetInteger(0, changeLine, OBJPROP_WIDTH, 3);
