//| GESTION DES POSITIONS ET VARIABLES GLOBALES                    |

// Vrai si ce symbole a subi une perte rÃĐcente (SL ou autre) ? rÃĐentrÃĐe soumise Ã  conditions strictes
bool IsRecentLossOnSymbol(const string symbol)
{
   if(g_lastLossSymbol == "" || symbol == "") return false;
   if(g_lastLossSymbol != symbol) return false;
   return (TimeCurrent() - g_lastLossTime <= RECENT_LOSS_WINDOW_SEC);
}

// Autorise ou bloque une rÃĐentrÃĐe aprÃĻs perte rÃĐcente sur ce symbole.
// spikeImminent: vrai si le contexte actuel indique un spike / setup exceptionnel (dÃĐjÃ  calculÃĐ par l'appelant).
bool AllowReentryAfterRecentLoss(const string symbol, const string direction, bool spikeImminent)
{
   if(!IsRecentLossOnSymbol(symbol)) return true;

   string dir = direction;
   StringToUpper(dir);

   // Condition "exceptionnelle" minimale: confiance IA trÃĻs forte + spike imminent
   double conf = g_lastAIConfidence;
   bool iaStrong = (conf >= 0.90) &&
                   (g_lastAIAction == "BUY" || g_lastAIAction == "buy" ||
                    g_lastAIAction == "SELL" || g_lastAIAction == "sell");

   // Si l'appelant n'a pas son propre flag spikeImminent, utiliser la proba locale
   if(!spikeImminent)
   {
      double p = CalculateSpikeProbability();
      spikeImminent = (p >= 0.80);
   }

   if(iaStrong && spikeImminent)
   {
      Print("? RÃĐentrÃĐe aprÃĻs perte autorisÃĐe sur ", symbol,
            " - conditions strictes remplies (conf IA ",
            DoubleToString(conf*100, 1), "% + spike/setup fort)");
      return true;
   }

   Print("?? RÃĐentrÃĐe aprÃĻs perte sur ", symbol,
         " bloquÃĐe (ÃĐviter 2e perte consÃĐcutive - exiger conf IA ?90% + spike/setup fort)");
   return false;
}

// Lot minimal broker brut pour le symbole (sans surcharge interne)
double GetMinLotForSymbol(const string symbol)
{
   double minLot = SymbolInfoDouble(symbol, SYMBOL_VOLUME_MIN);
   if(minLot <= 0.0)
   {
      Print("â MIN LOT INDISPONIBLE pour ", symbol, " - blocage trade pour ÃĐviter Invalid volume");
      return 0.0;
   }
   return minLot;
}

// Recovery: aprÃĻs une perte sur un symbole, le prochain trade sur un AUTRE symbole peut utiliser 2Ã le lot min broker
// pour compenser â uniquement si RecoveryLotOnlyHighConviction: confiance IA + score setup au-dessus des seuils (sinon lot normal, g_lastLossSymbol conservÃĐ).
double ApplyRecoveryLot(double baseLot, const string tradeDirection)
{
   if(baseLot <= 0.0)
      return baseLot;

   // Politique volume stricte: ne jamais dÃĐpasser le lot minimum broker.
   // Le "recovery lot" est donc dÃĐsactivÃĐ pour garantir un lot toujours minimal.
   double minLot = NormalizeVolumeForSymbol(GetMinLotForSymbol(_Symbol));
   if(minLot > 0.0)
      return minLot;

   return baseLot;
}

// VÃĐrifie si, pour ce symbole, la dÃĐcision IA est suffisamment forte
// ET alignÃĐe en direction (jamais contre-tendance IA) pour autoriser
// l'ouverture d'une nouvelle position (hors Boom/Crash).
bool IsAITradeAllowedForDirection(const string direction)
{
   if(!UseAIServer) return true; // Pas d'IA requise si serveur dÃĐsactivÃĐ
   
   ENUM_SYMBOL_CATEGORY cat = SMC_GetSymbolCategory(_Symbol);
   // Sur Boom/Crash, on garde la logique actuelle DERIV ARROW + rÃĻgles spÃĐcifiques
   if(cat == SYM_BOOM_CRASH) return true;
   
   // Seuil FIXE Ã  85% pour les autres symboles :
   // on ne trade QUE si l'IA est clairement BUY ou SELL avec trÃĻs forte confiance.
   double minConf = 0.85;
   if(g_lastAIAction == "" || g_lastAIConfidence < minConf)
   {
      Print("?? TRADE BLOQUÃ - Pas de dÃĐcision IA forte (conf: ",
            DoubleToString(g_lastAIConfidence*100, 1), "% < ",
            DoubleToString(minConf*100, 1), "%) sur ", _Symbol);
      return false;
   }
   
   if(g_lastAIAction == "HOLD" || g_lastAIAction == "hold")
   {
      Print("?? TRADE BLOQUÃ - IA en HOLD sur ", _Symbol, " (", DoubleToString(g_lastAIConfidence*100,1), "%)");
      return false;
   }

   // Ne jamais trader CONTRE la direction IA:
   // - Si IA = BUY, seules les entrÃĐes BUY sont autorisÃĐes
   // - Si IA = SELL, seules les entrÃĐes SELL sont autorisÃĐes
   string iaDir = g_lastAIAction;
   StringToUpper(iaDir);

   // On ne laisse trader que si l'IA est clairement BUY ou SELL
   if(iaDir != "BUY" && iaDir != "SELL")
   {
      Print("?? TRADE BLOQUÃ - DÃĐcision IA non directionnelle (", iaDir,
            ") ou incompatible pour ", _Symbol,
            " (conf: ", DoubleToString(g_lastAIConfidence*100,1), "%)");
      return false;
   }

   string dir = direction;
   StringToUpper(dir);

   if((iaDir == "BUY"  && dir != "BUY") ||
      (iaDir == "SELL" && dir != "SELL"))
   {
      Print("?? TRADE BLOQUÃ - Direction '", dir,
            "' contraire au signal IA '", iaDir,
            "' (conf: ", DoubleToString(g_lastAIConfidence*100,1), "%) sur ", _Symbol);
      return false;
   }

   return true;
}

