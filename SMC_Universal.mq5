//+------------------------------------------------------------------+
//| MODE ULTRA SÃLECTIF : VALIDATION AVANT ENTRÃE                  |
//+------------------------------------------------------------------+

// Calculer la probabilitÃĐ de gain d'un trade
double CalculateWinProbability(string direction, double entryPrice, double stopLoss, double takeProfit)
{
   if(!UseUltraSelectiveMode) return 100.0; // Mode normal
   
   double winProbability = 50.0; // Base 50%
   
   // 1. Ratio Risque/Rendement
   double risk = MathAbs(entryPrice - stopLoss);
   double reward = MathAbs(takeProfit - entryPrice);
   double rrRatio = reward / risk;
   
   if(rrRatio >= 3.0) winProbability += 25.0;      // Excellent RR
   else if(rrRatio >= 2.0) winProbability += 20.0; // Bon RR
   else if(rrRatio >= 1.5) winProbability += 15.0; // Acceptable RR
   else if(rrRatio >= 1.0) winProbability += 10.0; // RR minimum
   else winProbability -= 20.0;                    // Mauvais RR
   
   // 2. Alignement avec tendance EMA
   string trendDirection = GetCurrentTrendDirection();
   if((direction == "BUY" && trendDirection == "UPTREND") ||
      (direction == "SELL" && trendDirection == "DOWNTREND"))
   {
      winProbability += 20.0; // Alignement parfait
   }
   else if(trendDirection == "SIDEWAYS")
   {
      winProbability -= 10.0; // MarchÃĐ latÃĐral = moins fiable
   }
   
   // 3. Distance par rapport aux niveaux clÃĐs
   double currentPrice = SymbolInfoDouble(_Symbol, (direction == "BUY") ? SYMBOL_ASK : SYMBOL_BID);
   double distanceToEntry = MathAbs(currentPrice - entryPrice) / currentPrice * 100.0;
   
   if(distanceToEntry <= 0.1) winProbability += 15.0; // TrÃĻs proche du niveau
   else if(distanceToEntry <= 0.2) winProbability += 10.0; // Proche du niveau
   else if(distanceToEntry > 0.5) winProbability -= 15.0; // Trop loin du niveau
   
   // 4. Confiance IA (g_lastAIConfidence est en unitÃĐ 0..1 une fois normalisÃĐ)
   double iaU = NormalizeAIConfidenceUnit();
   if(iaU >= 0.90) winProbability += 15.0; // TrÃĻs haute confiance
   else if(iaU >= 0.80) winProbability += 10.0; // Haute confiance
   else if(iaU >= 0.70) winProbability += 5.0;  // Confiance moyenne
   else if(iaU < 0.60) winProbability -= 20.0; // Faible confiance
   
   // 5. Volume et spread
   double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   double spread = SymbolInfoInteger(_Symbol, SYMBOL_SPREAD) * point;
   double avgSpread = 0.0005; // Spread moyen pour Boom/Crash
   
   if(spread <= avgSpread * 0.5) winProbability += 10.0; // Spread trÃĻs bas
   else if(spread >= avgSpread * 2.0) winProbability -= 15.0; // Spread ÃĐlevÃĐ
   
   // 6. VolatilitÃĐ actuelle
   double atr = iATR(_Symbol, PERIOD_M1, 14);
   double atrPercent = atr / currentPrice * 100.0;
   
   if(atrPercent >= 0.3 && atrPercent <= 0.8) winProbability += 10.0; // VolatilitÃĐ idÃĐale
   else if(atrPercent > 1.5) winProbability -= 15.0; // VolatilitÃĐ excessive
   
   // Limiter entre 0% et 100%
   if(winProbability < 0.0) winProbability = 0.0;
   if(winProbability > 100.0) winProbability = 100.0;
   
   return winProbability;
}

// Valider si un trade respecte les critÃĻres ultra sÃĐlectifs
bool IsTradeUltraSelective(string direction, double entryPrice, double stopLoss, double takeProfit)
{
   if(!UseUltraSelectiveMode) return true;
   
   // 1. VÃĐrifier la probabilitÃĐ de gain
   double winProb = CalculateWinProbability(direction, entryPrice, stopLoss, takeProfit);
   if(winProb < MinWinProbability)
   {
      Print("ðŦ TRADE ULTRA SÃLECTIF BLOQUÃ - ProbabilitÃĐ: ", DoubleToString(winProb, 1), "% < ", DoubleToString(MinWinProbability, 1), "%");
      return false;
   }
   
   // 2. VÃĐrifier le profit potentiel minimum
   double potentialProfit = MathAbs(takeProfit - entryPrice) * GetMinLotForSymbol(_Symbol);
   if(potentialProfit < MinProfitPerTrade)
   {
      Print("ðŦ TRADE ULTRA SÃLECTIF BLOQUÃ - Profit potentiel: ", DoubleToString(potentialProfit, 2), "$ < ", DoubleToString(MinProfitPerTrade, 2), "$");
      return false;
   }
   
   // 3. VÃĐrifier la perte maximale autorisÃĐe
   double potentialLoss = MathAbs(entryPrice - stopLoss) * GetMinLotForSymbol(_Symbol);
   if(potentialLoss > MaxAllowedLossPerTrade)
   {
      Print("ðŦ TRADE ULTRA SÃLECTIF BLOQUÃ - Perte potentielle: ", DoubleToString(potentialLoss, 2), "$ > ", DoubleToString(MaxAllowedLossPerTrade, 2), "$");
      return false;
   }
   
   // 4. VÃĐrifier le nombre de trades journaliers (basÃĐ sur les ouvertures rÃĐelles du jour)
   datetime nowT = TimeCurrent();
   MqlDateTime md;
   TimeToStruct(nowT, md);
   md.hour = 0; md.min = 0; md.sec = 0;
   datetime dayStart = StructToTime(md);
   int openedToday = CountTodayOpenedTradesEASymbol(dayStart, nowT, _Symbol);
   if(openedToday >= MaxDailyTrades)
   {
      Print("ðŦ TRADE ULTRA SÃLECTIF BLOQUÃ - Limite journaliÃĻre atteinte pour ", _Symbol, ": ", openedToday, "/", MaxDailyTrades);
      return false;
   }
   
   // 5. VÃĐrifier l'espacement entre ouvertures de trades
   datetime lastOpenTime = 0;
   if(HistorySelect(dayStart, nowT))
   {
      int deals = HistoryDealsTotal();
      for(int i = deals - 1; i >= 0; i--)
      {
         ulong dealTicket = HistoryDealGetTicket(i);
         if(dealTicket == 0) continue;
         if((long)HistoryDealGetInteger(dealTicket, DEAL_MAGIC) != InpMagicNumber) continue;
         if((ENUM_DEAL_ENTRY)HistoryDealGetInteger(dealTicket, DEAL_ENTRY) != DEAL_ENTRY_IN) continue;
         ENUM_DEAL_TYPE dt = (ENUM_DEAL_TYPE)HistoryDealGetInteger(dealTicket, DEAL_TYPE);
         if(dt != DEAL_TYPE_BUY && dt != DEAL_TYPE_SELL) continue;
         lastOpenTime = (datetime)HistoryDealGetInteger(dealTicket, DEAL_TIME);
         break;
      }
   }
   if(lastOpenTime > 0)
   {
      int minutesSinceLastTrade = (int)(nowT - lastOpenTime) / 60;
      if(minutesSinceLastTrade < 5) // Minimum 5 minutes entre trades
      {
         Print("ðŦ TRADE ULTRA SÃLECTIF BLOQUÃ - Trop rapprochÃĐ: ", minutesSinceLastTrade, " min depuis dernier trade");
         return false;
      }
   }
   
   Print("â TRADE ULTRA SÃLECTIF VALIDÃ - ProbabilitÃĐ: ", DoubleToString(winProb, 1), "%");
   Print("   ð° Profit potentiel: ", DoubleToString(potentialProfit, 2), "$");
   Print("   ðĄïļ Perte potentielle: ", DoubleToString(potentialLoss, 2), "$");
   Print("   ð Trades journaliers: ", openedToday + 1, "/", MaxDailyTrades);
   
   return true;
}

// Enregistrer un trade dans les statistiques
void RecordTradeInStatistics(ulong ticket, bool isOpening)
{
   if(!EnableStatisticsTracking) return;
   
   if(isOpening)
   {
      // Enregistrement Ã  l'ouverture
      if(g_todayTradeIndex < ArraySize(g_todayTrades))
      {
         TradeRecord record;
         record.openTime = TimeCurrent();
         record.closeTime = 0;
         record.openPrice = PositionGetDouble(POSITION_PRICE_OPEN);
         record.closePrice = 0.0;
         record.profit = 0.0;
         record.symbol = PositionGetString(POSITION_SYMBOL);
         record.direction = (PositionGetInteger(POSITION_TYPE) == POSITION_TYPE_BUY) ? "BUY" : "SELL";
         record.lotSize = PositionGetDouble(POSITION_VOLUME);
         record.isWin = false;
         record.holdingTimeSeconds = 0;
         
         g_todayTrades[g_todayTradeIndex] = record;
      }
   }
   else
   {
      // Mise Ã  jour Ã  la fermeture
      for(int i = 0; i < ArraySize(g_todayTrades); i++)
      {
         if(g_todayTrades[i].closeTime == 0) // Trade non encore fermÃĐ
         {
            g_todayTrades[i].closeTime = TimeCurrent();
            g_todayTrades[i].closePrice = PositionGetDouble(POSITION_PRICE_CURRENT);
            g_todayTrades[i].profit = PositionGetDouble(POSITION_PROFIT);
            g_todayTrades[i].isWin = (g_todayTrades[i].profit > 0);
            g_todayTrades[i].holdingTimeSeconds = (int)(g_todayTrades[i].closeTime - g_todayTrades[i].openTime);
            
            // Mettre Ã  jour les statistiques journaliÃĻres
            g_dailyTradeCount++;
            g_dailyLastTradeTime = TimeCurrent();
            
            if(g_todayTrades[i].isWin)
            {
               g_dailyWinCount++;
               g_dailyTotalProfit += g_todayTrades[i].profit;
               if(g_todayTrades[i].profit > g_dailyMaxProfit)
                  g_dailyMaxProfit = g_todayTrades[i].profit;
            }
            else
            {
               g_dailyLossCount++;
               g_dailyTotalLoss += MathAbs(g_todayTrades[i].profit);
               if(g_todayTrades[i].profit < g_dailyMaxLoss)
                  g_dailyMaxLoss = g_todayTrades[i].profit;
            }
            
            // Log du trade
            Print("ð TRADE ENREGISTRÃ - ", g_todayTrades[i].direction, " ", g_todayTrades[i].symbol);
            Print("   ð° P&L: ", DoubleToString(g_todayTrades[i].profit, 2), "$");
            Print("   âąïļ DurÃĐe: ", g_todayTrades[i].holdingTimeSeconds, " secondes");
            Print("   ð Stats jour: ", g_dailyWinCount, "W/", g_dailyLossCount, "L | Net: ", DoubleToString(g_dailyTotalProfit - g_dailyTotalLoss, 2), "$");
            
            break;
         }
      }
   }
}

// Afficher les statistiques journaliÃĻres sur le graphique
void DisplayDailyStatisticsOnChart()
{
   if(!EnableStatisticsTracking) return;
   
   string statsText = "ââââââââââââââââââââââââââ\n";
   statsText += "ð Trades: " + IntegerToString(g_dailyTradeCount) + "/" + IntegerToString(MaxDailyTrades) + "\n";
   statsText += "â Gagnants: " + IntegerToString(g_dailyWinCount) + "\n";
   statsText += "â Perdants: " + IntegerToString(g_dailyLossCount) + "\n";
   
   if(g_dailyTradeCount > 0)
   {
      double winRate = (double)g_dailyWinCount / g_dailyTradeCount * 100.0;
      statsText += "ðŊ Taux gain: " + DoubleToString(winRate, 1) + "%\n";
   }
   
   statsText += "ð° Profit total: " + DoubleToString(g_dailyTotalProfit, 2) + "$\n";
   statsText += "ð Perte totale: " + DoubleToString(g_dailyTotalLoss, 2) + "$\n";
   statsText += "ð Net: " + DoubleToString(g_dailyTotalProfit - g_dailyTotalLoss, 2) + "$\n";
   
   if(g_dailyMaxProfit > 0)
      statsText += "ð Max profit: " + DoubleToString(g_dailyMaxProfit, 2) + "$\n";
   
   if(g_dailyMaxLoss < 0)
      statsText += "ð Max perte: " + DoubleToString(g_dailyMaxLoss, 2) + "$\n";
   
   // CrÃĐer l'objet texte sur le graphique
   string objName = "DailyStats_" + IntegerToString(TimeCurrent());
   if(ObjectCreate(0, objName, OBJ_LABEL, 0, 0, 0))
   {
      ObjectSetString(0, objName, OBJPROP_TEXT, statsText);
      ObjectSetInteger(0, objName, OBJPROP_XDISTANCE, 10);
      ObjectSetInteger(0, objName, OBJPROP_YDISTANCE, 850); // Position en bas complÃĻtement
      ObjectSetInteger(0, objName, OBJPROP_COLOR, clrWhite);
      ObjectSetInteger(0, objName, OBJPROP_BGCOLOR, clrBlack);
      ObjectSetInteger(0, objName, OBJPROP_BORDER_COLOR, clrGray);
      ObjectSetInteger(0, objName, OBJPROP_FONTSIZE, 9);
      ObjectSetString(0, objName, OBJPROP_FONT, "Courier New");
   }
}

// Fermeture forcÃĐe de toutes les positions Boom/Crash avant nouvelle entrÃĐe
void ForceCloseAllBoomCrashPositions()
{
   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      if(!posInfo.SelectByIndex(i)) continue;
      if(posInfo.Magic() != InpMagicNumber) continue;
      
      string symbol = posInfo.Symbol();
      ENUM_SYMBOL_CATEGORY cat = SMC_GetSymbolCategory(symbol);
      
      // Uniquement Boom/Crash
      if(cat != SYM_BOOM_CRASH) continue;
      
      ulong ticket = posInfo.Ticket();
      double profit = posInfo.Profit() + posInfo.Swap() + posInfo.Commission();
      
      Print("?? FERMETURE FORCÃE AVANT NOUVELLE ENTRÃE - ", symbol, 
            " | Ticket: ", ticket, 
            " | Profit: ", DoubleToString(profit, 2), "$");
      
      if(PositionCloseWithLog(ticket, "Fermeture forcÃĐe avant nouvelle entrÃĐe"))
      {
         Print("?? Position fermÃĐe avec succÃĻs - ", symbol, " | ticket=", ticket);
      }
      else
      {
         int err = GetLastError();
         Print("?? ÃCHEC FERMETURE FORCÃE - ", symbol, " | ticket=", ticket, " | erreur=", err);
      }
   }
}

// VÃĐrifier et fermer les positions avant nouvelle entrÃĐe
void CheckAndClosePositionsBeforeNewEntry()
{
   // Si des positions Boom/Crash existent dÃĐjÃ , les fermer d'abord
   int boomCrashPositions = 0;
   for(int i = 0; i < PositionsTotal(); i++)
   {
      if(!posInfo.SelectByIndex(i)) continue;
      if(posInfo.Magic() != InpMagicNumber) continue;
      
      string symbol = posInfo.Symbol();
      ENUM_SYMBOL_CATEGORY cat = SMC_GetSymbolCategory(symbol);
      
      if(cat == SYM_BOOM_CRASH)
      {
         boomCrashPositions++;
         break;
      }
   }
   
   if(boomCrashPositions > 0)
   {
      Print("?? DÃTECTION POSITION(S) EXISTANTE(S) - Fermeture forcÃĐe avant nouvelle entrÃĐe");
      ForceCloseAllBoomCrashPositions();
      
      // Attendre un court instant pour que la fermeture soit effective
      Sleep(1000);
   }
}

// Calculer la probabilitÃĐ d'un setup OTE
double CalculateOTESetupProbability(const string direction)
{
   double probability = 50.0; // Base de 50%
   
   // 1. Confiance IA (unitÃĐ 0..1)
   double iaU = NormalizeAIConfidenceUnit();
   if(iaU >= 0.90) probability += 20.0;
   else if(iaU >= 0.80) probability += 15.0;
   else if(iaU >= 0.70) probability += 10.0;
   else if(iaU < 0.60) probability -= 20.0;
   
   // 2. Alignement tendance EMA
   double emaFast = iMA(_Symbol, PERIOD_M1, 9, 0, MODE_EMA, PRICE_CLOSE);
   double emaSlow = iMA(_Symbol, PERIOD_M1, 21, 0, MODE_EMA, PRICE_CLOSE);
   double currentPrice = (direction == "BUY") ? SymbolInfoDouble(_Symbol, SYMBOL_ASK) : SymbolInfoDouble(_Symbol, SYMBOL_BID);
   
   if(direction == "BUY")
   {
      if(currentPrice > emaFast && emaFast > emaSlow) probability += 15.0; // Uptrend
      else if(currentPrice < emaFast && emaFast < emaSlow) probability -= 15.0; // Downtrend
   }
   else // SELL
   {
      if(currentPrice < emaFast && emaFast < emaSlow) probability += 15.0; // Downtrend
      else if(currentPrice > emaFast && emaFast > emaSlow) probability -= 15.0; // Uptrend
   }
   
   // 3. VolatilitÃĐ actuelle
   double atr = iATR(_Symbol, PERIOD_M1, 14);
   double atrPercent = atr / currentPrice * 100.0;
   
   if(atrPercent >= 0.3 && atrPercent <= 0.8) probability += 10.0; // VolatilitÃĐ idÃĐale
   else if(atrPercent > 1.5) probability -= 15.0; // VolatilitÃĐ excessive
   
   // 4. Distance aux niveaux clÃĐs
   double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   double spread = SymbolInfoInteger(_Symbol, SYMBOL_SPREAD) * point;
   double avgSpread = 0.0005;
   
   if(spread <= avgSpread * 0.5) probability += 10.0; // Spread trÃĻs bas
   else if(spread >= avgSpread * 2.0) probability -= 15.0; // Spread ÃĐlevÃĐ
   
   // 5. Momentum RSI
   double rsi = iRSI(_Symbol, PERIOD_M1, 14, PRICE_CLOSE);
   if(direction == "BUY")
   {
      if(rsi >= 30 && rsi <= 50) probability += 10.0; // Pas surachat
      else if(rsi >= 70) probability -= 20.0; // Surachat
   }
   else // SELL
   {
      if(rsi >= 50 && rsi <= 70) probability += 10.0; // Pas survente
      else if(rsi <= 30) probability -= 20.0; // Survente
   }
   
   // Limiter la probabilitÃĐ entre 0 et 100%
   if(probability > 100.0) probability = 100.0;
   if(probability < 0.0) probability = 0.0;
   
   return probability;
}

// ParamÃĻtres de prÃĐservation des gains
input bool   UseGainPreservationSystem     = true;  // Activer le systÃĻme de prÃĐservation des gains
input double DailyGainProtectionThreshold    = 8.0;   // Seuil de gain journalier pour activer la protection ($)
input double MaxDrawdownAfterProtection     = 2.0;   // Perte maximale autorisÃĐe aprÃĻs protection ($)
input int    ProtectionCooldownMinutes       = 30;    // Temps de refroidissement aprÃĻs protection (minutes)
input double MinExpectancyThreshold        = 0.15;  // EspÃĐrance mathÃĐmatique minimum pour trader
input bool   OTE_BypassExpectancyAndICTOnHighAI = true;  // IA forte + direction alignÃĐe avec OTE â ne pas bloquer sur espÃĐrance / ICT / contre-tendance (ShouldExecuteOTETrade)
input double OTE_HighAIConfidenceUnit          = 0.78;   // Seuil confiance normalisÃĐe 0..1 (ex. 0.78 = 78%) pour le bypass ci-dessus et lâespÃĐrance finale (ExecuteFutureOTETrade)

// NOUVEAUX PARAMÃTRES : ULTRA SÃLECTIF
input bool   UseUltraSelectiveMode        = true;  // Mode ultra sÃĐlectif (uniquement trades gagnants sÃŧrs)
input double MinWinProbability          = 75.0;  // ProbabilitÃĐ de gain minimum (%)
input int    MaxHoldingTimeSeconds       = 300;   // Temps de dÃĐtention maximum (5 minutes)
input bool   EnableStatisticsTracking     = true;  // Activer le suivi des statistiques journaliÃĻres
input int    MaxDailyTradesOld        = 20;    // [OBSOLETE] remplacÃĐ par timing timing section
input double MinProfitPerTrade           = 1.0;   // Profit minimum par trade ($)
input double MaxAllowedLossPerTrade      = 0.5;   // Perte maximale autorisÃĐe par trade ($)
input bool   UsePreOTEEntry                 = true;  // Entrer avant l'OTE pour capturer les spikes
input double PreOTEEntryDistancePercent    = 0.3;   // Distance avant l'OTE pour entrer (0.3% = agressif)
input bool   PreOTE_LimitOnly              = true;  // PrÃĐ-OTE: placer uniquement un ordre LIMIT (ÃĐvite entrÃĐe au marchÃĐ Ã  l'arrivÃĐe du spike)
input int    PreOTE_LimitExpireMinutes     = 180;   // Expiration ordre LIMIT prÃĐ-OTE (0 = GTC)
input bool   OTE_RequireRealEntryPrecision = true;  // Exiger une entrÃĐe proche du coeur de la zone OTE (ÃĐvite faux touch en bord de zone)
input double OTE_RealEntryMaxDistanceZoneRatio = 0.35; // Distance max au milieu de zone OTE (ratio de la largeur de zone)
input bool   OTE_UseFibSwingEquilibriumFilter = false; // Renfort SMC: ÃĐquilibre Fib 0.5 = milieu du range rÃĐcent (extrÃĐmitÃĐs structure) â BUY seulement sous ce niveau, SELL seulement au-dessus
input ENUM_TIMEFRAMES OTE_FibSwingEquilibriumTF = PERIOD_M15; // Timeframe du range pour le 0.5
input int    OTE_FibSwingEquilibriumLookback = 80; // Nb bougies pour high/low du range
input int    OTE_FibSwingEquilibriumTolPts = 12; // TolÃĐrance en points (ÃĐvite blocage sur le niveau exact)
input double SpikeNoArrivalEarlyCutLossUSD = 3.5;  // Coupe anticipÃĐe hors SL si spike n'arrive pas (ÃĐquitÃĐ faible)
input double SpikeNoArrivalAllowSLAboveEquityUSD = 20.0; // Si ÃĐquitÃĐ >= ce seuil, laisser le SL broker gÃĐrer (pas de coupe anticipÃĐe)
input bool   CancelOTEOnSetupInvalidation   = false;  // Annuler les ordres si le setup OTE disparaÃŪt (dÃĐsactivÃĐ par dÃĐfaut pour conserver les setups)
input bool   CloseOTEPositionsWhenSetupGoneFromChart = false; // Fermer positions OTE si plus aucun dessin setup sur le graphique (dÃĐsactivÃĐ par dÃĐfaut)
input int    OTEChartSetupGoneCloseHoldSec   = 4;     // Secondes sans objet OTE sur chart avant fermeture (ÃĐvite flash au redessin)
input bool   ExecuteMarketOnOTETouch        = true;  // ExÃĐcuter au marchÃĐ au toucher du niveau OTE
input bool   ExecuteMarketOnCurrentOTETouchWhenIAFor = true; // Si IA "FOR" et touch zone OTE courante (SMC_OTE_CUR/SMC_OTE_CURR), exÃĐcuter scalp marchÃĐ auto
input double CurrentOTETouchIAForMinConfidence = 0.75; // Seuil "FOR" (0..1 ou %) - plus agressif pour scalp
input int    CurrentOTETouchCooldownSeconds = 15; // Cooldown anti-duplication rÃĐduit pour saisir plus d'opportunitÃĐs
input bool   ExecuteMarketOnOTEAppearance   = true;  // ExÃĐcuter au marchÃĐ dÃĻs l'apparition de l'OTE Entry (DrawOTESetup)
input double OTESetupMarketMinAIConfidencePercent = 60.0; // Confiance IA min (%) pour exÃĐcuter OTE setup au marchÃĐ
input bool   OTE_BlockExecutionOnCorrectionZone = true; // Bloquer l'exÃĐcution OTE si le prix entre en "correction" (bande ÃĐquilibre)
input bool   OTE_DeferImbalanceExecuteUntilTrendResumes = true; // Setup OTE+Imbalance en zone correction: attendre sortie zone + reprise tendance (EMA) avant notify/exÃĐcution
input int    OTE_DeferImbalanceTimeoutMinutes = 240;   // 0 = pas de timeout; abandon du pending aprÃĻs N minutes
input int    OTEAppearanceCooldownSeconds   = 120;   // Anti-duplication: 1 exÃĐcution max / N sec par symbole+direction+entry
input bool   EnableOTEApproachAnnouncement  = true;  // Annoncer l'approche de l'OTE avant le touch
input int    OTEApproachDistancePoints      = 90;    // Distance max (points) pour annoncer l'arrivÃĐe de l'OTE
input int    OTEApproachAnnouncementCooldownSeconds = 45; // Cooldown des annonces OTE (anti-spam)
input bool   OTE_EarlyEntryOnEMA20EMA23Impulse = true; // EntrÃĐe OTE anticipÃĐe: rebond M1 sur EMA20/23 + impulsion H1 alignÃĐe
input int    OTE_EarlyEMATouchTolerancePoints = 35;    // TolÃĐrance touch EMA20/23 en points (M1)
input double OTE_EarlyH1BodyAtrMult = 0.55;           // Impulsion H1 min: corps bougie >= ATR(H1) * multiplicateur
input double OTE_EarlyMinAIConfidencePercent = 60.0;  // IA min (%) pour l'entrÃĐe OTE anticipÃĐe (0=ignore IA)
input bool   OTE_UseStructuralMidForEntry = true;    // EntrÃĐe / affichage sur milieu zone Fib (ÃĐvite marchÃĐ au bid aprÃĻs spike)
input bool   OTE_PlaceLimitWhenStructuralBetter = true; // SELL/BUY LIMIT si niveau structurel plus favorable que le cours
input int    OTE_StructuralMinDistancePts = 2;       // Ãcart min (points) pour tenter un ordre limite vs marchÃĐ
input bool   OTE_LimitPreTouchRevalidate       = true;  // Avant exÃĐcution: revÃĐrifier IA/structure dans une zone proche du prix limite
input int    OTE_LimitPreTouchPoints           = 120;   // Distance max (points) entre cours et niveau limite pour lancer la revÃĐrification
input int    OTE_LimitPreTouchMinDelaySeconds  = 3;     // DÃĐlai min aprÃĻs entrÃĐe dans la zone avant la 1re vÃĐrif (~quelques secondes avant touch)
input int    OTE_LimitPreTouchRecheckSeconds   = 15;    // Si encore invalide temporairement, rÃĐessayer au plus toutes les N secondes

