   ObjectSetInteger(0, txtName, OBJPROP_HIDDEN, false);
   ObjectSetInteger(0, txtName, OBJPROP_BACK, false);
   ObjectSetInteger(0, txtName, OBJPROP_ZORDER, MathMax(101, DashboardLabelZOrder + 1));
}

