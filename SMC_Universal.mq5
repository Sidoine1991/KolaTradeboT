   ObjectCreate(0, chochZone, OBJ_RECTANGLE, 0, changeTime, 
                changePrice - SymbolInfoDouble(_Symbol, SYMBOL_POINT) * 3,
                futureTime, changePrice + SymbolInfoDouble(_Symbol, SYMBOL_POINT) * 3);
