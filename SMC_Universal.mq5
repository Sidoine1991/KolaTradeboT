void HMS_GfxRectangle(const string name, const datetime t1, const double p1, const datetime t2, const double p2,
                      const color border, const color fill, const int width, const string tip)
{
   if(ObjectFind(0, name) >= 0)
      ObjectDelete(0, name);
   if(!ObjectCreate(0, name, OBJ_RECTANGLE, 0, t1, p1, t2, p2))
      return;
   ObjectSetInteger(0, name, OBJPROP_COLOR, border);
   ObjectSetInteger(0, name, OBJPROP_BGCOLOR, fill);
   ObjectSetInteger(0, name, OBJPROP_STYLE, STYLE_SOLID);
   ObjectSetInteger(0, name, OBJPROP_WIDTH, width);
   ObjectSetInteger(0, name, OBJPROP_FILL, false);
   ObjectSetInteger(0, name, OBJPROP_BACK, false);
   ObjectSetInteger(0, name, OBJPROP_SELECTABLE, false);
   ObjectSetInteger(0, name, OBJPROP_TIMEFRAMES, OBJ_ALL_PERIODS);
   ObjectSetInteger(0, name, OBJPROP_ZORDER, 2);
   ObjectSetString(0, name, OBJPROP_TOOLTIP, tip);
}

void HMS_GfxTrendSeg(const string name, const datetime t1, const datetime t2, const double price,
                     const color col, const int width, const string tip)
{
   if(ObjectFind(0, name) >= 0)
      ObjectDelete(0, name);
   if(!ObjectCreate(0, name, OBJ_TREND, 0, t1, price, t2, price))
      return;
   ObjectSetInteger(0, name, OBJPROP_COLOR, col);
   ObjectSetInteger(0, name, OBJPROP_WIDTH, width);
   ObjectSetInteger(0, name, OBJPROP_STYLE, STYLE_DASH);
   ObjectSetInteger(0, name, OBJPROP_RAY_RIGHT, false);
   ObjectSetInteger(0, name, OBJPROP_BACK, true);
   ObjectSetInteger(0, name, OBJPROP_SELECTABLE, false);
   ObjectSetInteger(0, name, OBJPROP_TIMEFRAMES, OBJ_ALL_PERIODS);
   ObjectSetString(0, name, OBJPROP_TOOLTIP, tip);
}

void HMS_GfxText(const string name, const datetime t, const double price, const string txt,
                 const color col, const int fs)
{
   if(ObjectFind(0, name) >= 0)
      ObjectDelete(0, name);
   if(!ObjectCreate(0, name, OBJ_TEXT, 0, t, price))
      return;
   ObjectSetString(0, name, OBJPROP_TEXT, txt);
   ObjectSetInteger(0, name, OBJPROP_COLOR, col);
   ObjectSetInteger(0, name, OBJPROP_FONTSIZE, fs);
   ObjectSetInteger(0, name, OBJPROP_ANCHOR, ANCHOR_CENTER);
   ObjectSetInteger(0, name, OBJPROP_BACK, false);
   ObjectSetInteger(0, name, OBJPROP_SELECTABLE, false);
   ObjectSetInteger(0, name, OBJPROP_TIMEFRAMES, OBJ_ALL_PERIODS);
}

//+------------------------------------------------------------------+
//| HMS â zones automatiques (range, support, ÃĐquilibre, cibles)      |
//| InspirÃĐ du cadre ÂŦ entrÃĐe support / SL sous zone / TP ÃĐquilibre Âŧ |
//+------------------------------------------------------------------+
void DrawHMSZonesOnChart()
{
   ObjectsDeleteAll(0, "SMC_HMS_");

   if(!ShowHMSZonesOnChart)
      return;

   const ENUM_TIMEFRAMES tf = HMS_StructuralTimeframe;
   int n = HMS_LookbackBars;
   if(n < 20)
      n = 20;
   if(n > 500)
      n = 500;

   MqlRates r[];
   ArraySetAsSeries(r, true);
   if(CopyRates(_Symbol, tf, 0, n, r) < n)
      return;

   const int w = MathMax(2, MathMin(8, HMS_FractalHalfWidth));
   int iH = -1, iL = -1;
   double bestH = -DBL_MAX;
   double bestL = DBL_MAX;

   for(int i = w; i < n - w; i++)
   {
      bool isFH = true;
      bool isFL = true;
      for(int k = 1; k <= w; k++)
      {
         if(r[i].high < r[i - k].high || r[i].high < r[i + k].high)
            isFH = false;
         if(r[i].low > r[i - k].low || r[i].low > r[i + k].low)
            isFL = false;
      }
      if(isFH && r[i].high > bestH)
      {
         bestH = r[i].high;
         iH = i;
      }
      if(isFL && r[i].low < bestL)
      {
         bestL = r[i].low;
         iL = i;
      }
   }

   if(iH < 0)
   {
      bestH = r[0].high;
      iH = 0;
      for(int i = 1; i < n; i++)
      {
         if(r[i].high > bestH)
         {
            bestH = r[i].high;
            iH = i;
         }
      }
   }
   if(iL < 0)
   {
      bestL = r[0].low;
      iL = 0;
      for(int i = 1; i < n; i++)
      {
         if(r[i].low < bestL)
         {
            bestL = r[i].low;
            iL = i;
         }
      }
   }

   double rangeHigh = bestH;
   double rangeLow = bestL;
   if(rangeHigh < rangeLow)
   {
      double t = rangeHigh;
      rangeHigh = rangeLow;
      rangeLow = t;
      int ti = iH;
      iH = iL;
      iL = ti;
   }

   const double rng = rangeHigh - rangeLow;
   if(rng <= SymbolInfoDouble(_Symbol, SYMBOL_POINT) * 3.0)
      return;

   double atr = 0.0;
   {
      int hAtr = iATR(_Symbol, tf, MathMax(5, HMS_ATRPeriod));
      if(hAtr != INVALID_HANDLE)
      {
         double ab[];
         ArraySetAsSeries(ab, true);
         if(CopyBuffer(hAtr, 0, 0, 1, ab) >= 1)
            atr = ab[0];
         IndicatorRelease(hAtr);
      }
   }
   if(atr <= 0.0)
      atr = rng * 0.02;

   const double eq = NormalizeDouble(rangeLow + rng * 0.5, _Digits);
   const double supPct = MathMax(2.0, MathMin(45.0, HMS_SupportBandPctOfRange)) / 100.0;
   const double tgtPct = MathMax(2.0, MathMin(45.0, HMS_TargetBandPctOfRange)) / 100.0;

   double supTop = rangeLow + MathMax(rng * supPct, atr * 0.35);
   supTop = MathMin(supTop, eq - SymbolInfoDouble(_Symbol, SYMBOL_POINT) * 5.0);
   if(supTop <= rangeLow)
      supTop = rangeLow + rng * 0.05;

   double tgtBot = rangeHigh - MathMax(rng * tgtPct, atr * 0.40);
   tgtBot = MathMax(tgtBot, eq + SymbolInfoDouble(_Symbol, SYMBOL_POINT) * 5.0);
   if(tgtBot >= rangeHigh)
      tgtBot = rangeHigh - rng * 0.05;

   datetime tLeft = r[iH].time;
   if(r[iL].time < tLeft)
      tLeft = r[iL].time;
   tLeft -= (datetime)((long)PeriodSeconds(tf) * 2);

   int fwd = MathMax(5, MathMin(300, HMS_ForwardBars));
   datetime tRight = TimeCurrent() + (datetime)((long)PeriodSeconds(tf) * fwd);

   const uchar aD = (uchar)MathMax(0, MathMin(255, HMS_FillAlphaDiscount));
   const uchar aP = (uchar)MathMax(0, MathMin(255, HMS_FillAlphaPremium));
   const uchar aS = (uchar)MathMax(0, MathMin(255, HMS_FillAlphaSupport));
   const uchar aT = (uchar)MathMax(0, MathMin(255, HMS_FillAlphaTarget));
   const color cDisc = (color)ColorToARGB(clrDeepSkyBlue, aD);
   const color cPrem = (color)ColorToARGB(clrOrchid, aP);
   const color cSup = (color)ColorToARGB(clrSpringGreen, aS);
   const color cTgt = (color)ColorToARGB(clrOrange, aT);
   const color cOte = (color)ColorToARGB(clrGold, 55);

   HMS_GfxRectangle("SMC_HMS_DISCOUNT", tLeft, eq, tRight, rangeLow, cDisc, cDisc, 2,
                    "HMS â Discount (achats favoris sous lâÃĐquilibre)");
   HMS_GfxRectangle("SMC_HMS_PREMIUM", tLeft, rangeHigh, tRight, eq, cPrem, cPrem, 2,
                    "HMS â Premium (ventes favoris au-dessus de lâÃĐquilibre)");
   HMS_GfxRectangle("SMC_HMS_SUPPORT", tLeft, supTop, tRight, rangeLow, cSup, cSup, 2,
                    "HMS â Zone support (entrÃĐe type)");
   HMS_GfxRectangle("SMC_HMS_TARGET", tLeft, rangeHigh, tRight, tgtBot, cTgt, cTgt, 2,
                    "HMS â Zone cible / vente (haut de range)");

   if(HMS_DrawOtePocket)
   {
      const double oteLo = rangeLow + rng * 0.618;
      const double oteHi = rangeLow + rng * 0.786;
      if(oteHi > oteLo && oteLo < eq)
         HMS_GfxRectangle("SMC_HMS_OTE_BUY", tLeft, oteHi, tRight, oteLo, cOte, cOte, 1,
                          "HMS â Poche OTE (61.8â78.6 %) depuis le creux");
   }
   if(HMS_DrawOtePocketFromTop)
   {
      const double oteSellHi = rangeHigh - rng * 0.618;
      const double oteSellLo = rangeHigh - rng * 0.786;
      if(oteSellHi > oteSellLo && oteSellLo > eq)
         HMS_GfxRectangle("SMC_HMS_OTE_SELL", tLeft, oteSellHi, tRight, oteSellLo, cOte, cOte, 1,
                          "HMS â Poche OTE vente (symÃĐtrique depuis le sommet)");
   }

   if(ObjectCreate(0, "SMC_HMS_EQUILIBRIUM", OBJ_HLINE, 0, 0, eq))
   {
      ObjectSetInteger(0, "SMC_HMS_EQUILIBRIUM", OBJPROP_COLOR, clrWhite);
      ObjectSetInteger(0, "SMC_HMS_EQUILIBRIUM", OBJPROP_STYLE, STYLE_SOLID);
      ObjectSetInteger(0, "SMC_HMS_EQUILIBRIUM", OBJPROP_WIDTH, 2);
      ObjectSetInteger(0, "SMC_HMS_EQUILIBRIUM", OBJPROP_BACK, false);
      ObjectSetString(0, "SMC_HMS_EQUILIBRIUM", OBJPROP_TOOLTIP,
                      "HMS â Ãquilibre du range (Fib 0.5 / cadre psychologique)");
   }

   const double stopGuide = rangeLow - atr * MathMax(0.05, HMS_StopLineAtrMult);
   if(ObjectCreate(0, "SMC_HMS_STOP_GUIDE", OBJ_HLINE, 0, 0, stopGuide))
   {
      ObjectSetInteger(0, "SMC_HMS_STOP_GUIDE", OBJPROP_COLOR, clrTomato);
      ObjectSetInteger(0, "SMC_HMS_STOP_GUIDE", OBJPROP_STYLE, STYLE_DOT);
      ObjectSetInteger(0, "SMC_HMS_STOP_GUIDE", OBJPROP_WIDTH, 1);
      ObjectSetString(0, "SMC_HMS_STOP_GUIDE", OBJPROP_TOOLTIP,
                      "HMS â Guide SL typique (sous le support structurel)");
   }

   if(HMS_DrawMidFibGuides)
   {
      const double p382 = rangeLow + rng * 0.382;
      const double p618 = rangeLow + rng * 0.618;
      HMS_GfxTrendSeg("SMC_HMS_FIB382", tLeft, tRight, p382, clrDodgerBlue, 1, "HMS â 38.2 %");
      HMS_GfxTrendSeg("SMC_HMS_FIB618", tLeft, tRight, p618, clrOrange, 1, "HMS â 61.8 %");
   }

   {
      const datetime tMid = tLeft + (datetime)((long)(tRight - tLeft) / 2L);
      HMS_GfxText("SMC_HMS_LBL_EQ", tMid, eq,
                  "HMS â Ãquilibre (0.5) Â· cible cadre", clrWhite, 9);
      HMS_GfxText("SMC_HMS_LBL_SUP", tMid, (rangeLow + supTop) * 0.5,
                  "Support propre", clrWhite, 8);
      HMS_GfxText("SMC_HMS_LBL_TGT", tMid, (tgtBot + rangeHigh) * 0.5,
                  "Zone vente / TP haut", clrWhite, 8);
      HMS_GfxText("SMC_HMS_LBL_DISC", tMid, (rangeLow + eq) * 0.5,
                  "Discount", clrDeepSkyBlue, 8);
      HMS_GfxText("SMC_HMS_LBL_PREM", tMid, (eq + rangeHigh) * 0.5,
                  "Premium", clrOrchid, 8);
   }

   if(HMS_DrawSwingMarkers)
   {
      if(ObjectCreate(0, "SMC_HMS_MK_HIGH", OBJ_ARROW, 0, r[iH].time, rangeHigh))
      {
         ObjectSetInteger(0, "SMC_HMS_MK_HIGH", OBJPROP_ARROWCODE, 233);
         ObjectSetInteger(0, "SMC_HMS_MK_HIGH", OBJPROP_COLOR, clrOrangeRed);
         ObjectSetInteger(0, "SMC_HMS_MK_HIGH", OBJPROP_WIDTH, 2);
         ObjectSetInteger(0, "SMC_HMS_MK_HIGH", OBJPROP_ANCHOR, ANCHOR_BOTTOM);
      }
      if(ObjectCreate(0, "SMC_HMS_MK_LOW", OBJ_ARROW, 0, r[iL].time, rangeLow))
      {
         ObjectSetInteger(0, "SMC_HMS_MK_LOW", OBJPROP_ARROWCODE, 234);
         ObjectSetInteger(0, "SMC_HMS_MK_LOW", OBJPROP_COLOR, clrDeepSkyBlue);
         ObjectSetInteger(0, "SMC_HMS_MK_LOW", OBJPROP_WIDTH, 2);
         ObjectSetInteger(0, "SMC_HMS_MK_LOW", OBJPROP_ANCHOR, ANCHOR_TOP);
      }
   }

   if(HMS_DrawVerticalNowLine)
   {
      if(ObjectCreate(0, "SMC_HMS_VNOW", OBJ_VLINE, 0, TimeCurrent(), 0))
      {
         ObjectSetInteger(0, "SMC_HMS_VNOW", OBJPROP_COLOR, clrSilver);
         ObjectSetInteger(0, "SMC_HMS_VNOW", OBJPROP_STYLE, STYLE_DOT);
         ObjectSetInteger(0, "SMC_HMS_VNOW", OBJPROP_WIDTH, 1);
         ObjectSetString(0, "SMC_HMS_VNOW", OBJPROP_TOOLTIP, "HMS â maintenant");
      }
   }

   if(HMS_DrawInfoPanel)
   {
      string pnl = "HMS " + EnumToString(tf) + "\nRange " + DoubleToString(rangeLow, _Digits) + " â " +
                   DoubleToString(rangeHigh, _Digits) + "\nEq 0.5 Â· " + DoubleToString(eq, _Digits) +
                   "\nÎ " + DoubleToString(rng / SymbolInfoDouble(_Symbol, SYMBOL_POINT), 0) + " pts";
      const string bgName = "SMC_HMS_PANEL_BG";
      if(ObjectFind(0, bgName) >= 0)
         ObjectDelete(0, bgName);
      if(ObjectCreate(0, bgName, OBJ_RECTANGLE_LABEL, 0, 0, 0))
      {
         ObjectSetInteger(0, bgName, OBJPROP_CORNER, CORNER_LEFT_UPPER);
         ObjectSetInteger(0, bgName, OBJPROP_XDISTANCE, 8);
         ObjectSetInteger(0, bgName, OBJPROP_YDISTANCE, 18);
         ObjectSetInteger(0, bgName, OBJPROP_XSIZE, 210);
         ObjectSetInteger(0, bgName, OBJPROP_YSIZE, 72);
         ObjectSetInteger(0, bgName, OBJPROP_BGCOLOR, (color)ColorToARGB(clrBlack, 160));
         ObjectSetInteger(0, bgName, OBJPROP_BORDER_TYPE, BORDER_FLAT);
         ObjectSetInteger(0, bgName, OBJPROP_COLOR, clrDimGray);
         ObjectSetInteger(0, bgName, OBJPROP_WIDTH, 1);
         ObjectSetInteger(0, bgName, OBJPROP_BACK, false);
         ObjectSetInteger(0, bgName, OBJPROP_SELECTABLE, false);
      }
      const string txName = "SMC_HMS_PANEL_TXT";
      if(ObjectFind(0, txName) >= 0)
         ObjectDelete(0, txName);
      if(ObjectCreate(0, txName, OBJ_LABEL, 0, 0, 0))
      {
         ObjectSetInteger(0, txName, OBJPROP_CORNER, CORNER_LEFT_UPPER);
         ObjectSetInteger(0, txName, OBJPROP_XDISTANCE, 16);
         ObjectSetInteger(0, txName, OBJPROP_YDISTANCE, 24);
         ObjectSetString(0, txName, OBJPROP_TEXT, pnl);
         ObjectSetString(0, txName, OBJPROP_FONT, "Consolas");
         ObjectSetInteger(0, txName, OBJPROP_FONTSIZE, 8);
         ObjectSetInteger(0, txName, OBJPROP_COLOR, clrSilver);
         ObjectSetInteger(0, txName, OBJPROP_BACK, false);
         ObjectSetInteger(0, txName, OBJPROP_SELECTABLE, false);
      }
   }
}

void DrawSignalArrow()
{
   if(g_lastAIAction != "buy" && g_lastAIAction != "BUY" && g_lastAIAction != "sell" && g_lastAIAction != "SELL") return;
   MqlRates r[];
   ArraySetAsSeries(r, true);
   if(CopyRates(_Symbol, PERIOD_CURRENT, 0, 1, r) < 1) return;
   double arrowPrice = r[0].close;
   datetime arrowTime = r[0].time;
   bool isBuy = (g_lastAIAction == "buy" || g_lastAIAction == "BUY");
   string arrowName = "SMC_DERIV_ARROW_" + _Symbol;
   if(ObjectFind(0, arrowName) < 0)
      ObjectCreate(0, arrowName, OBJ_ARROW, 0, arrowTime, arrowPrice);
   ObjectSetInteger(0, arrowName, OBJPROP_TIME, 0, arrowTime);
   ObjectSetDouble(0, arrowName, OBJPROP_PRICE, 0, arrowPrice);
   ObjectSetInteger(0, arrowName, OBJPROP_COLOR, isBuy ? clrLime : clrRed);
   ObjectSetInteger(0, arrowName, OBJPROP_WIDTH, 4);
   ObjectSetInteger(0, arrowName, OBJPROP_ARROWCODE, isBuy ? 233 : 234);
   ObjectSetInteger(0, arrowName, OBJPROP_BACK, false);
   g_lastDerivSignalArrowUtc = TimeCurrent();
}

void UpdateSignalArrowBlink()
{
   if(g_lastAIAction != "buy" && g_lastAIAction != "BUY" && g_lastAIAction != "sell" && g_lastAIAction != "SELL")
   {
      // Ne plus supprimer la flÃĻche immÃĐdiatement lorsque l'IA repasse en HOLD.
      // On garde simplement l'ÃĐtat actuel (flÃĻche figÃĐe) pour que le trader la voie.
      return;
   }
   string arrowName = "SMC_DERIV_ARROW_" + _Symbol;
   string notifyArrow = "SMC_DERIV_NOTIFY_ARROW_" + _Symbol;
   bool hasMain = (ObjectFind(0, arrowName) >= 0);
   bool hasNotify = (ObjectFind(0, notifyArrow) >= 0);
   if(!hasMain && !hasNotify) return;
   datetime now = TimeCurrent();
   if(now - g_arrowBlinkTime >= 500)
   {
      g_arrowBlinkTime = now;
      g_arrowVisible = !g_arrowVisible;
   }
   if(hasMain)
      ObjectSetInteger(0, arrowName, OBJPROP_TIMEFRAMES, g_arrowVisible ? OBJ_ALL_PERIODS : OBJ_NO_PERIODS);
   if(hasNotify)
      ObjectSetInteger(0, notifyArrow, OBJPROP_TIMEFRAMES, g_arrowVisible ? OBJ_ALL_PERIODS : OBJ_NO_PERIODS);

   // Expiration visuelle de la flÃĻche (si signal expirÃĐ)
   int visExpire = MathMax(8, SMCDerivArrowMaxAgeBars * PeriodSeconds(PERIOD_M1));
   if(g_lastDerivSignalArrowUtc > 0 && (TimeCurrent() - g_lastDerivSignalArrowUtc) > visExpire)
   {
      if(hasNotify) ObjectDelete(0, notifyArrow);
   }
}

// Avertisseur clignotant pour l'arrivÃĐe imminente d'un spike Boom/Crash
void UpdateSpikeWarningBlink()
{
   if(!g_spikeWarningActive) return;
   if(StringFind(_Symbol, "Boom") < 0 && StringFind(_Symbol, "Crash") < 0) return;
   
   datetime now = TimeCurrent();
   
   // Supprimer l'avertisseur aprÃĻs 2 minutes ou si l'objet n'existe plus
   if(now - g_spikeWarningStart > 120 || ObjectFind(0, "SMC_Spike_Warning") < 0)
   {
      ObjectDelete(0, "SMC_Spike_Warning");
      g_spikeWarningActive = false;
      return;
   }
   
   // Clignotement toutes les 0.7 seconde
   if(now - g_spikeBlinkTime >= 1)
   {
      g_spikeBlinkTime = now;
      g_spikeWarningVisible = !g_spikeWarningVisible;
      
      if(ObjectFind(0, "SMC_Spike_Warning") >= 0)
      {
         color c = g_spikeWarningVisible ? clrYellow : clrNONE;
         ObjectSetInteger(0, "SMC_Spike_Warning", OBJPROP_COLOR, c);
      }
   }
}

// EntrÃĐe automatique quand le prix touche les niveaux SH/SL prÃĐdits (canal ML)
void CheckPredictedSwingTriggers()
{
   long chId = ChartID();
   if(chId <= 0) return;
   
   if(g_lastAIAction == "HOLD" || g_lastAIAction == "hold") return;
   
   ENUM_SYMBOL_CATEGORY cat = SMC_GetSymbolCategory(_Symbol);
   if(cat == SYM_BOOM_CRASH) return;
   
   if(IsPriceInRange()) return;
   
   if(IsMaxPositionsReached()) return;
   
   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   if(!MathIsValidNumber(bid) || !MathIsValidNumber(ask) || bid <= 0 || ask <= 0) return;
   
   int total = (int)ObjectsTotal(chId, -1, -1);
   if(total <= 0 || total > 2000) return; // Limite sÃĐcuritÃĐ
   
   for(int i = total - 1; i >= 0; i--)
   {
      string name = ObjectName(chId, i);
      if(StringLen(name) == 0) continue;
      
      bool isPredSH = (StringFind(name, "SMC_Pred_SH_") == 0 || StringFind(name, "SMC_Dyn_SH_") == 0 || StringFind(name, "SMC_Prec_SH_") == 0);
      bool isPredSL = (StringFind(name, "SMC_Pred_SL_") == 0 || StringFind(name, "SMC_Dyn_SL_") == 0 || StringFind(name, "SMC_Prec_SL_") == 0);
      
      if(isPredSH)
      {
         double level = ObjectGetDouble(chId, name, OBJPROP_PRICE);
         if(!MathIsValidNumber(level) || level <= 0) continue;
         if(bid >= level)
         {
            SMC_Signal sig;
            sig.action = "SELL";
            sig.entryPrice = bid;
            sig.reasoning = "Predicted SH touch";
            sig.concept = "Pred-SH";
            sig.stopLoss = 0;
            sig.takeProfit = 0;
            ExecuteSignal(sig);
            ObjectDelete(chId, name);
            break;
         }
      }
      else if(isPredSL)
      {
         double level = ObjectGetDouble(chId, name, OBJPROP_PRICE);
         if(!MathIsValidNumber(level) || level <= 0) continue;
         if(ask <= level)
         {
            SMC_Signal sig;
            sig.action = "BUY";
            sig.entryPrice = ask;
            sig.reasoning = "Predicted SL touch";
            sig.concept = "Pred-SL";
            sig.stopLoss = 0;
            sig.takeProfit = 0;
            ExecuteSignal(sig);
            ObjectDelete(chId, name);
            break;
         }
      }
   }
}

void DrawPredictedSwingPoints()
{
   long chId = ChartID();
   if(chId <= 0) return; // Pas de chart valide = ÃĐviter crash/dÃĐtachement
   if(!g_channelValid) return;
   // Validation des donnÃĐes du canal (ÃĐviter NaN/infini ? dÃĐtachement)
   if(!MathIsValidNumber(g_chUpperStart) || !MathIsValidNumber(g_chLowerStart) ||
      !MathIsValidNumber(g_chUpperEnd) || !MathIsValidNumber(g_chLowerEnd))
      return;
   ObjectsDeleteAll(chId, "SMC_Pred_SH_");
   ObjectsDeleteAll(chId, "SMC_Pred_SL_");
   datetime tNow = iTime(_Symbol, PERIOD_M1, 0);
   if(tNow <= 0) tNow = TimeCurrent();
   int periodSec = 60;
   int predBars = MathMax(1, MathMin(PredictionChannelBars, 5000)); // Limiter pour ÃĐviter overflow
   double slopeUpper = (g_chUpperEnd - g_chUpperStart) / (double)predBars;
   double slopeLower = (g_chLowerEnd - g_chLowerStart) / (double)predBars;
   int step = MathMax(1, predBars / 10);
   for(int k = 1; k <= 10; k++)
   {
      int barsAhead = MathMin(k * step, 5000); // Limiter pour ÃĐviter overflow datetime
      datetime t = tNow + (datetime)(barsAhead * periodSec);
      double minsFromStart = (g_chTimeStart > 0 && periodSec > 0) ? (double)(t - g_chTimeStart) / (double)periodSec : (double)barsAhead;
      double upPrice = g_chUpperStart + slopeUpper * minsFromStart;
      double loPrice = g_chLowerStart + slopeLower * minsFromStart;
      if(!MathIsValidNumber(upPrice) || !MathIsValidNumber(loPrice)) continue;
      string nameSH = "SMC_Pred_SH_" + IntegerToString(k);
      string nameSL = "SMC_Pred_SL_" + IntegerToString(k);
      if(ObjectCreate(chId, nameSH, OBJ_ARROW, 0, t, upPrice))
      {
         ObjectSetInteger(chId, nameSH, OBJPROP_ARROWCODE, 159);
         ObjectSetInteger(chId, nameSH, OBJPROP_COLOR, clrRed);
         ObjectSetInteger(chId, nameSH, OBJPROP_WIDTH, 2);
      }
      if(ObjectCreate(chId, nameSL, OBJ_ARROW, 0, t, loPrice))
      {
         ObjectSetInteger(chId, nameSL, OBJPROP_ARROWCODE, 159);
         ObjectSetInteger(chId, nameSL, OBJPROP_COLOR, clrLime);
         ObjectSetInteger(chId, nameSL, OBJPROP_WIDTH, 2);
      }
   }
}

void DrawSMCChannelsMultiTF()
{
   // Tracer les canaux SMC (upper/lower) depuis H1, M30, M5 projetÃĐs sur M1
   datetime currentTime = TimeCurrent();
   
   // Timeframes Ã  analyser
   ENUM_TIMEFRAMES tfs[] = {PERIOD_H1, PERIOD_M30, PERIOD_M5};
   string tfNames[] = {"H1", "M30", "M5"};
   color tfColors[] = {clrBlue, clrPurple, clrGreen};
   
   for(int i = 0; i < ArraySize(tfs); i++)
   {
      string prefix = "SMC_CH_" + tfNames[i] + "_";
      ObjectsDeleteAll(0, prefix);
      
      // RÃĐcupÃĐrer les donnÃĐes du timeframe
      MqlRates rates[];
      ArraySetAsSeries(rates, true);
      if(CopyRates(_Symbol, tfs[i], 0, 200, rates) < 50) continue;
      
      // Calculer les hauts et bas pour le canal
      double upper = rates[0].high;
      double lower = rates[0].low;
      
      for(int j = 1; j < 100; j++) // Analyser les 100 derniÃĻres bougies
      {
         if(rates[j].high > upper) upper = rates[j].high;
         if(rates[j].low < lower) lower = rates[j].low;
      }
      
      // Projeter sur 5000 bougies M1 futures
      datetime startTime = currentTime;
      datetime endTime = currentTime + (datetime)(SMCChannelFutureBars * 60); // 5000 bougies M1 = 5000 minutes
      
      // Tracer la ligne supÃĐrieure du canal
      string upperName = prefix + "UPPER";
      ObjectCreate(0, upperName, OBJ_TREND, 0, startTime, upper, endTime, upper);
      ObjectSetInteger(0, upperName, OBJPROP_COLOR, tfColors[i]);
      ObjectSetInteger(0, upperName, OBJPROP_WIDTH, 2);
      ObjectSetInteger(0, upperName, OBJPROP_STYLE, STYLE_SOLID);
      ObjectSetInteger(0, upperName, OBJPROP_RAY_RIGHT, true);
      ObjectSetInteger(0, upperName, OBJPROP_BACK, false);
      ObjectSetString(0, upperName, OBJPROP_TOOLTIP, "Canal SMC " + tfNames[i] + " - Upper");
      
      // Tracer la ligne infÃĐrieure du canal
      string lowerName = prefix + "LOWER";
      ObjectCreate(0, lowerName, OBJ_TREND, 0, startTime, lower, endTime, lower);
      ObjectSetInteger(0, lowerName, OBJPROP_COLOR, tfColors[i]);
      ObjectSetInteger(0, lowerName, OBJPROP_WIDTH, 2);
      ObjectSetInteger(0, lowerName, OBJPROP_STYLE, STYLE_SOLID);
      ObjectSetInteger(0, lowerName, OBJPROP_RAY_RIGHT, true);
      ObjectSetInteger(0, lowerName, OBJPROP_BACK, false);
      ObjectSetString(0, lowerName, OBJPROP_TOOLTIP, "Canal SMC " + tfNames[i] + " - Lower");
      
      // Ajouter un label
      string labelName = prefix + "LABEL";
      ObjectCreate(0, labelName, OBJ_TEXT, 0, startTime, upper);
      ObjectSetString(0, labelName, OBJPROP_TEXT, "SMC " + tfNames[i]);
      ObjectSetInteger(0, labelName, OBJPROP_COLOR, tfColors[i]);
      ObjectSetInteger(0, labelName, OBJPROP_FONTSIZE, 8);
      ObjectSetInteger(0, labelName, OBJPROP_ANCHOR, ANCHOR_LEFT_UPPER);
   }
}

/*
// FONCTION SUPPRIMÃE - PLUS DE PLACEMENT D'ORDRES LIMIT CANAL
// Place un ordre limite "sniper" entre le prix actuel et le canal SMC (upper/lower)
// Un seul ordre limit SMC par symbole. L'IA sert de filtre directionnel:
// - si IA forte et opposÃĐe au sens naturel (Boom=BUY / Crash=SELL), on NE trade pas
// - si IA HOLD ou faible confiance, on autorise quand mÃŠme le trade canal.
void PlaceSMCChannelLimitOrder()
{
   // FONCTION DÃSACTIVÃE - Les ordres LIMIT canal ne sont plus placÃĐs automatiquement
   Print("ðŦ FONCTION DÃSACTIVÃE - PlaceSMCChannelLimitOrder() supprimÃĐ");
   return;
   
   // Ancien code conservÃĐ pour rÃĐfÃĐrence mais non exÃĐcutÃĐ
   bool isBoom  = (StringFind(_Symbol, "Boom")  >= 0);
   bool isCrash = (StringFind(_Symbol, "Crash") >= 0);
   if(!isBoom && !isCrash) return;
   
   // ANTI-DUPLICATION: VÃĐrifier s'il y a dÃĐjÃ  des ordres LIMIT pour ce symbole
   if(CountOpenLimitOrdersForSymbol(_Symbol) > 0)
   {
      Print("ðŦ ORDRE LIMIT DÃJÃ EXISTANT - Aucun nouvel ordre SMC canal sur ", _Symbol);
      return;
   }

   // RÃGLE STRICTE: Si filtre activÃĐ, uniquement les symboles prioritaires peuvent avoir des ordres LIMIT
   if(UsePropiceSymbolsFilter && !g_currentSymbolIsPropice)
   {
      Print("ðŦ SYMBOLE NON PRIORITAIRE - Aucun ordre SMC canal autorisÃĐ sur ", _Symbol);
      return;
   }

   // RÃGLE STRICTE: Si filtre activÃĐ, uniquement si lignes M5 actives
   if(UsePropiceSymbolsFilter && g_currentSymbolIsPropice)
   {
      if(!g_m5BuyLevelActive && !g_m5SellLevelActive)
      {
         Print("ðŦ PAS DE LIGNES M5 ACTIVES - Aucun ordre SMC canal autorisÃĐ sur ", _Symbol);
         return;
      }
   }
   
   // BLOCAGE SÃCURITÃ: NE PAS PLACER D'ORDRES SI IA EST EN HOLD
   string aiAction = g_lastAIAction;
   StringToUpper(aiAction);
   if(aiAction == "HOLD")
   {
      Print("?? ORDRE SMC CANAL BLOQUÃ - IA en HOLD sur ", _Symbol, " - SÃĐcuritÃĐ activÃĐe");
      return;
   }
   
   const double MIN_CONF_SMC_ORDER = 0.75;
   if(aiAction == "buy") aiAction = "BUY";
   if(aiAction == "sell") aiAction = "SELL";
   bool iaStrong = (aiAction == "BUY" || aiAction == "SELL") && g_lastAIConfidence >= MIN_CONF_SMC_ORDER;
   
   // Direction naturelle du trade canal (Boom = BUY, Crash = SELL)
   string channelDir = isBoom ? "BUY" : "SELL";
   
   // RÃGLE STRICTE: BLOQUER TOUS LES ORDRES BUY SUR BOOM SI IA = SELL
   if(isBoom && aiAction == "SELL")
   {
   // RÃĐduire la frÃĐquence des logs de trading pour ÃĐviter la surcharge
   static datetime lastTradingLog = 0;
   if(TimeCurrent() - lastTradingLog >= 60) // Log toutes les 60 secondes maximum
   {
      Print("?? ORDRE SMC BOOM BLOQUÃ - IA = SELL (", DoubleToString(g_lastAIConfidence*100, 1), "%) | Attendre signal BUY avant de placer ordre BUY");
      lastTradingLog = TimeCurrent();
   }
      return;
   }
   
   // RÃGLE STRICTE: BLOQUER TOUS LES ORDRES SELL SUR CRASH SI IA = BUY
   if(isCrash && aiAction == "BUY")
   {
   // RÃĐduire la frÃĐquence des logs de trading pour ÃĐviter la surcharge
   static datetime lastTradingLog = 0;
   if(TimeCurrent() - lastTradingLog >= 60) // Log toutes les 60 secondes maximum
   {
      Print("?? ORDRE SMC CRASH BLOQUÃ - IA = BUY (", DoubleToString(g_lastAIConfidence*100, 1), "%) | Attendre signal SELL avant de placer ordre SELL");
      lastTradingLog = TimeCurrent();
   }
      return;
   }
   
   // Si IA forte et opposÃĐe Ã  la direction naturelle, ne pas placer d'ordre canal
   if(iaStrong && aiAction != channelDir)
   {
      Print("?? ORDRE SMC BLOQUÃ - IA forte (", DoubleToString(g_lastAIConfidence*100, 1), "%) opposÃĐe Ã  direction naturelle (", channelDir, ")");
      return;
   }
   
   // RÃĐentrÃĐe aprÃĻs perte sur ce symbole: exiger conditions exceptionnelles (IA ?90% + spike/setup fort)
   if(!AllowReentryAfterRecentLoss(_Symbol, channelDir, false))
      return;
   
   // Une fois placÃĐ, un ordre limit SMC n'est plus annulÃĐ automatiquement ici.
   // Il sera gÃĐrÃĐ par le SL/TP naturel ou manuellement par l'utilisateur.
   
   // Un seul ordre LIMIT canal SMC par symbole
   int chanLimits = CountChannelLimitOrdersForSymbol(_Symbol);
   if(chanLimits >= 1) return;
   
   // Limite globale: maximum 2 ordres LIMIT par symbole
   int totalLimits = CountOpenLimitOrdersForSymbol(_Symbol);
   // Pour Boom/Crash: un seul LIMIT proche Ã  la fois
   if(totalLimits >= 1) return;
   
   if(CountPositionsForSymbol(_Symbol) > 0) return; // Pas de nouvel ordre si dÃĐjÃ  en position
   if(!TryAcquireOpenLock()) return;
   
   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   if(bid <= 0 || ask <= 0) { ReleaseOpenLock(); return; }
   
   // RÃĐcupÃĐrer le canal SMC H1
   string upperName = "SMC_CH_H1_UPPER";
   string lowerName = "SMC_CH_H1_LOWER";
   if(ObjectFind(0, upperName) < 0 || ObjectFind(0, lowerName) < 0)
   {
      ReleaseOpenLock();
      return;
   }
   
   // Les canaux SMC H1 sont des lignes horizontales: prix identique sur toute la ligne.
   double upperPrice = ObjectGetDouble(0, upperName, OBJPROP_PRICE);
   double lowerPrice = ObjectGetDouble(0, lowerName, OBJPROP_PRICE);
   if(upperPrice <= 0 || lowerPrice <= 0) { ReleaseOpenLock(); return; }
   
   MqlTradeRequest req;
   MqlTradeResult  res;
   ZeroMemory(req);
   ZeroMemory(res);
   req.action = TRADE_ACTION_PENDING;
   req.symbol = _Symbol;
   req.magic  = InpMagicNumber;
   
   double lot = CalculateLotSizeForPendingOrders();
   if(lot <= 0) { ReleaseOpenLock(); return; }
   req.volume = lot;
   
   // Boom: BUY LIMIT avec logique de proximitÃĐ intelligente
   if(isBoom)
   {
      if(bid <= lowerPrice) { ReleaseOpenLock(); return; }
      
      // Calculer la distance au canal
      double distanceToCanal = bid - lowerPrice;
      double atrVal = 0.0;
      if(atrHandle != INVALID_HANDLE)
      {
         double atrBuf[];
         ArraySetAsSeries(atrBuf, true);
         if(CopyBuffer(atrHandle, 0, 0, 1, atrBuf) > 0)
            atrVal = atrBuf[0];
      }
      if(atrVal <= 0) atrVal = SymbolInfoDouble(_Symbol, SYMBOL_POINT) * 100;
      
      double entry = 0.0;
      string entryType = "";
      bool usedML = false;

      // PRIORITÃ: SuperTrend support (ordre unique et proche)
      double stSupp = 0.0, stRes = 0.0;
      double tmpS = 0.0, tmpR = 0.0;
      if(GetSuperTrendLevel(PERIOD_M5, tmpS, tmpR) && tmpS > 0) stSupp = tmpS;
      else if(GetSuperTrendLevel(PERIOD_H1, tmpS, tmpR) && tmpS > 0) stSupp = tmpS;
      if(stSupp > 0 && stSupp < bid)
      {
         double buffer = atrVal * 0.15;
         double candidate = stSupp + buffer; // au-dessus du support
         double maxDist = atrVal * MaxDistanceLimitATR;
         if((bid - candidate) <= maxDist && candidate < bid)
         {
            entry = candidate;
            entryType = "SUPER TREND SUPPORT";
            usedML = true; // on considÃĻre ST comme source prioritaire
         }
      }
      
      // 1) Essayer d'utiliser la DERNIÃRE INTERSECTION avec le canal ML (et sa projection)
      if(g_channelValid)
      {
         double recentML, projML;
         datetime recentTime, projTime;
         if(GetRecentAndProjectedMLChannelIntersection("BUY", recentML, recentTime, projML, projTime))
         {
            double candidate = projML;
            // VÃĐrifier que la projection est bien sous le prix actuel (BUY LIMIT) et pas trop loin du canal H1
            if(candidate <= 0 || candidate >= bid || MathAbs(candidate - lowerPrice) > atrVal * 6.0)
               candidate = recentML;
            
            if(candidate > 0 && candidate < bid && MathAbs(candidate - lowerPrice) <= atrVal * 6.0)
            {
               entry = candidate;
               entryType = "ML INTERSECTION";
               usedML = true;
            }
         }
      }
      
      // 2) Fallback: logique de proximitÃĐ classique sur le canal H1
      if(!usedML)
      {
         // LOGIQUE DE PROXIMITÃ INTELLIGENTE
         if(distanceToCanal <= atrVal * 2.0) // Canal proche (? 2 ATR)
         {
            entry = lowerPrice; // Utiliser le canal directement
            entryType = "CANAL PROCHE";
         }
         else if(distanceToCanal <= atrVal * 4.0) // Canal moyen (2-4 ATR)
         {
            entry = lowerPrice + (atrVal * 0.5); // Mi-chemin entre prix et canal
            entryType = "CANAL MOYEN";
         }
         else // Canal loin (> 4 ATR) ? on prÃĐfÃĻre NE PAS entrer plutÃīt qu'entrer trop tÃīt
         {
            ReleaseOpenLock();
            Print("?? SMC BOOM - Canal trop loin (>4 ATR), aucune entrÃĐe pour ÃĐviter une entrÃĐe trop prÃĐcoce");
            return;
         }
      }
      
      if(entry >= bid) { ReleaseOpenLock(); return; }
      req.type  = ORDER_TYPE_BUY_LIMIT;
      req.price = entry;
      if(!IsOrderTypeAllowedForBoomCrash(_Symbol, req.type))
      {
         ReleaseOpenLock();
         Print("ðŦ SMC_CH BUY LIMIT BLOQUÃ - Type interdit pour ", _Symbol);
         return;
      }
      
      Print("?? SMC BOOM - ", entryType, " | Distance canal: ", DoubleToString(distanceToCanal/atrVal, 1), " ATR | Entry: ", DoubleToString(entry, _Digits));
   }
   // Crash: SELL LIMIT avec logique de proximitÃĐ intelligente
   else if(isCrash)
   {
      if(ask >= upperPrice) { ReleaseOpenLock(); return; }
      
      // Calculer la distance au canal
      double distanceToCanal = upperPrice - ask;
      double atrVal = 0.0;
      if(atrHandle != INVALID_HANDLE)
      {
         double atrBuf[];
         ArraySetAsSeries(atrBuf, true);
         if(CopyBuffer(atrHandle, 0, 0, 1, atrBuf) > 0)
            atrVal = atrBuf[0];
      }
      if(atrVal <= 0) atrVal = SymbolInfoDouble(_Symbol, SYMBOL_POINT) * 100;
      
      double entry = 0.0;
      string entryType = "";
      bool usedML = false;

      // PRIORITÃ: SuperTrend rÃĐsistance (ordre unique et proche)
      double stSupp = 0.0, stRes = 0.0;
      double tmpS = 0.0, tmpR = 0.0;
      if(GetSuperTrendLevel(PERIOD_M5, tmpS, tmpR) && tmpR > 0) stRes = tmpR;
      else if(GetSuperTrendLevel(PERIOD_H1, tmpS, tmpR) && tmpR > 0) stRes = tmpR;
      if(stRes > 0 && stRes > ask)
      {
         double buffer = atrVal * 0.15;
         double candidate = stRes - buffer; // en-dessous de la rÃĐsistance
         double maxDist = atrVal * MaxDistanceLimitATR;
         if((candidate - ask) <= maxDist && candidate > ask)
         {
            entry = candidate;
            entryType = "SUPER TREND RESISTANCE";
            usedML = true;
         }
      }
      
      // 1) Essayer d'utiliser la DERNIÃRE INTERSECTION avec le canal ML (et sa projection)
      if(g_channelValid)
      {
         double recentML, projML;
         datetime recentTime, projTime;
         if(GetRecentAndProjectedMLChannelIntersection("SELL", recentML, recentTime, projML, projTime))
         {
            double candidate = projML;
            // VÃĐrifier que la projection est bien au-dessus du prix actuel (SELL LIMIT) et pas trop loin du canal H1
            if(candidate <= ask || MathAbs(candidate - upperPrice) > atrVal * 6.0)
               candidate = recentML;
            
            if(candidate > ask && MathAbs(candidate - upperPrice) <= atrVal * 6.0)
            {
               entry = candidate;
               entryType = "ML INTERSECTION";
               usedML = true;
            }
         }
      }
      
      // 2) Fallback: logique de proximitÃĐ classique sur le canal H1
      if(!usedML)
      {
         // LOGIQUE DE PROXIMITÃ INTELLIGENTE
         if(distanceToCanal <= atrVal * 2.0) // Canal proche (? 2 ATR)
         {
            entry = upperPrice; // Utiliser le canal directement
            entryType = "CANAL PROCHE";
         }
         else if(distanceToCanal <= atrVal * 4.0) // Canal moyen (2-4 ATR)
