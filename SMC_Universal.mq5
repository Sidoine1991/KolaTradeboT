//| INPUTS                                                            |
input group "=== GÃNÃRAL ==="
input bool   UseMinLotOnly     = true;   // Toujours lot minimum (le plus bas)
input double InpLotSize         = 0.2;   // Taille de lot par dÃĐfaut
input bool   EnableTrading      = true;   // Activer/DÃĐsactiver le trading
input int    MaxPositionsTerminal = 2;   // Nombre max de positions (tout le terminal MT5) - LIMITÃ Ã 2 pour protÃĐger le capital
input bool   OnePositionPerSymbol = true; // Une seule position par symbole - MAINTENU pour ÃĐviter duplication
input int    InpMagicNumber       = 202502; // Magic Number
input double MaxTotalLossDollars = 10.0;   // Perte maximale totale en dollars avant de couper toutes les positions
input double HoldAutoCloseLossDefaultDollars = 2.0; // Seuil perte ($) pour auto-fermeture quand IA passe en HOLD
input double HoldAutoCloseLossFxVol40Dollars = 3.5; // Exception FX VOL 40: seuil perte HOLD plus large
input double DailyProfitTarget = 20.0;     // Objectif de profit journalier en dollars
input int    PauseAfterProfitHours = 4;    // DurÃĐe de la pause en heures aprÃĻs avoir atteint l'objectif de profit la plus perdante
input double MaxLossPerSpikeTradeDollars = 3.0;  // Perte max par trade Spike Boom/Crash ($) - lot rÃĐduit si dÃĐpassement
input double MaxLossPerSymbolDollars = 4.0;   // Perte maximale par symbole avant blocage complet de ce symbole
input double MaxRiskPerTradePercent   = 1.5;  // Risque normal par trade (% de l'ÃĐquitÃĐ)
input double MaxDailyDrawdownPercent  = 10.0; // Drawdown max journalier (%) avant blocage des nouvelles entrÃĐes
input double DailyProfitTargetDollars = 20.0; // Gain journalier max ($) - stop trading jusqu'Ã  fin de journÃĐe
input double MaxDailyLossDollars      = 10.0; // Perte journaliÃĻre max ($) - pause 2h
input double CumulativeLossPauseThresholdDollars = 5.0; // Pertes consÃĐcutives cumulÃĐes ($) avant pause
input int    CumulativeLossPauseMinutes = 30; // DurÃĐe de pause aprÃĻs pertes consÃĐcutives (min)
input bool   EnableProfitLock             = true;  // Stop si gros giveback aprÃĻs gros gain
input double ProfitLockStartDollars       = 10.0;  // Active aprÃĻs ce gain max journalier ($)
input double ProfitLockMaxGivebackDollars = 5.0;   // Giveback max depuis le pic d'ÃĐquitÃĐ ($)
input bool   ProfitLockClosePositions     = true;  // Fermer positions + supprimer pending lors du stop
input bool   UsePerSymbolDailyObjectiveOnly = true; // Objectif journÃĐe: pause par symbole uniquement (pas de stop global)
input bool   UseHighConfidenceFilterWhenSomeSymbolsProfitLocked = true; // Quand des symboles sont dÃĐjÃ  "verrouillÃĐs" par profit, exiger plus de probabilitÃĐ
input int    LockedSymbolsMinCountForFilter = 1; // Seuil du nombre de symboles dÃĐjÃ  verrouillÃĐs pour activer le filtre
input double ExtraMinAIConfidenceWhenLockedPercent = 10.0; // +% confiance minimale (en plus des seuils internes)
input double ExtraMinSetupScoreWhenLocked = 10.0; // +score minimum setup (0-100) quand des symboles sont verrouillÃĐs
input bool   EnableHighVolatilityCapitalGate = true; // Bloquer certains symboles trÃĻs volatils si capital trop faible
