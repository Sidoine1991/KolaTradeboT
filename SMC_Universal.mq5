bool PushChartTechStateToAIServer(bool force = false)
{
   if(!UseAIServer || !EnableChartTechStateSync) return false;
   UpdateChartPatternContext(false);

   int intervalSec = MathMax(30, ChartTechStateSyncIntervalSec);
   datetime now = TimeCurrent();
   if(!force && g_lastChartTechSyncUtc > 0 && (now - g_lastChartTechSyncUtc) < intervalSec)
      return false;
   g_lastChartTechSyncUtc = now;

   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   double close = (bid > 0.0 ? bid : ask);
   if(close <= 0.0) close = SymbolInfoDouble(_Symbol, SYMBOL_LAST);

   // EMA M1 (9/21/50)
   double ema9 = 0.0, ema21 = 0.0, ema50 = 0.0;
   int hEma9 = iMA(_Symbol, PERIOD_M1, 9, 0, MODE_EMA, PRICE_CLOSE);
   int hEma21 = iMA(_Symbol, PERIOD_M1, 21, 0, MODE_EMA, PRICE_CLOSE);
   int hEma50 = iMA(_Symbol, PERIOD_M1, 50, 0, MODE_EMA, PRICE_CLOSE);
   if(hEma9 != INVALID_HANDLE) { double b[]; ArraySetAsSeries(b, true); if(CopyBuffer(hEma9, 0, 0, 1, b) >= 1) ema9 = b[0]; IndicatorRelease(hEma9); }
   if(hEma21 != INVALID_HANDLE) { double b[]; ArraySetAsSeries(b, true); if(CopyBuffer(hEma21, 0, 0, 1, b) >= 1) ema21 = b[0]; IndicatorRelease(hEma21); }
   if(hEma50 != INVALID_HANDLE) { double b[]; ArraySetAsSeries(b, true); if(CopyBuffer(hEma50, 0, 0, 1, b) >= 1) ema50 = b[0]; IndicatorRelease(hEma50); }

   // RSI / MACD M1
   double rsi = 50.0, macdMain = 0.0, macdSignal = 0.0;
   int hRsi = iRSI(_Symbol, PERIOD_M1, 14, PRICE_CLOSE);
   if(hRsi != INVALID_HANDLE)
   {
      double b[]; ArraySetAsSeries(b, true);
      if(CopyBuffer(hRsi, 0, 0, 1, b) >= 1) rsi = b[0];
      IndicatorRelease(hRsi);
   }
   int hMacd = iMACD(_Symbol, PERIOD_M1, 12, 26, 9, PRICE_CLOSE);
   if(hMacd != INVALID_HANDLE)
   {
      double m[], s[]; ArraySetAsSeries(m, true); ArraySetAsSeries(s, true);
      if(CopyBuffer(hMacd, 0, 0, 1, m) >= 1) macdMain = m[0];
      if(CopyBuffer(hMacd, 1, 0, 1, s) >= 1) macdSignal = s[0];
      IndicatorRelease(hMacd);
   }

   // ATR M15
   double atr = GetATRValue(PERIOD_M15, 14);
   if(atr <= 0.0)
      atr = GetATRValue(PERIOD_M1, 14);

   // Ratio volume tick M1 (bougie courante vs moyenne rÃĐcentes)
   double volRatio = 1.0;
   long tv[];
   ArraySetAsSeries(tv, true);
   if(CopyTickVolume(_Symbol, PERIOD_M1, 0, 12, tv) >= 12)
   {
      double curr = (double)tv[0];
      double avg = 0.0;
      for(int i = 1; i < 11; i++) avg += (double)tv[i];
      avg /= 10.0;
      if(avg > 0.0) volRatio = curr / avg;
   }

   bool inCorrection = IsInEquilibriumCorrectionZone();
   bool inDiscount = IsInDiscountZone();
   bool inPremium = IsInPremiumZone();

   string tf = EnumToString(_Period);
   string bCorr = inCorrection ? "true" : "false";
   string bDisc = inDiscount ? "true" : "false";
   string bPrem = inPremium ? "true" : "false";

   string payload = StringFormat(
      "{\"symbol\":\"%s\",\"timeframe\":\"%s\",\"indicators\":{\"close\":%.10f,\"ema9\":%.10f,\"ema21\":%.10f,\"ema50\":%.10f,\"rsi\":%.6f,\"macd\":%.10f,\"macd_signal\":%.10f,\"atr\":%.10f,\"volume_ratio\":%.6f,\"in_correction_zone\":%s,\"in_discount_zone\":%s,\"in_premium_zone\":%s},\"chart_pattern\":{\"name\":\"%s\",\"direction\":\"%s\",\"score\":%.4f,\"zone_low\":%.10f,\"zone_high\":%.10f,\"proj1\":%.10f,\"proj2\":%.10f,\"proj3\":%.10f}}",
      _Symbol, tf, close, ema9, ema21, ema50, rsi, macdMain, macdSignal, atr, volRatio, bCorr, bDisc, bPrem,
      g_lastChartPatternName, g_lastChartPatternDirection, g_lastChartPatternScore, g_lastChartPatternZoneLow, g_lastChartPatternZoneHigh,
      g_lastChartPatternProj1, g_lastChartPatternProj2, g_lastChartPatternProj3
   );
   g_lastChartTechPayloadSummary = StringFormat(
      "SEND[%s/%s] C=%.1f E9=%.1f E21=%.1f E50=%.1f RSI=%.1f MACD=%.2f/%.2f ATR=%.1f VR=%.2f Z(c/d/p)=%s/%s/%s",
      _Symbol, tf, close, ema9, ema21, ema50, rsi, macdMain, macdSignal, atr, volRatio,
      inCorrection ? "1" : "0", inDiscount ? "1" : "0", inPremium ? "1" : "0"
   );

   char post[], result[];
   string headers = "Content-Type: application/json\r\n";
   string resultHeaders = "";
   StringToCharArray(payload, post, 0, WHOLE_ARRAY, CP_UTF8);

   string baseUrl = UseRenderAsPrimary ? AI_ServerRender : AI_ServerURL;
   string fallbackUrl = UseRenderAsPrimary ? AI_ServerURL : AI_ServerRender;
   string path = "/ml/chart-tech-state";

   int res = WebRequest("POST", baseUrl + path, headers, AI_Timeout_ms, post, result, resultHeaders);
   if(res != 200)
   {
      res = WebRequest("POST", fallbackUrl + path, headers, AI_Timeout_ms2, post, result, resultHeaders);
      if(res != 200)
      {
         Print("â ïļ CHART TECH STATE sync ÃĐchouÃĐe - HTTP ", res, " | ", _Symbol);
         return false;
      }
   }

   string json = CharArrayToString(result, 0, -1, CP_UTF8);
   string action = ExtractJsonValue(json, "action");
   string conf = ExtractJsonValue(json, "confidence");
   string sp = ExtractJsonValue(json, "spike_probability");
   string trend = ExtractJsonValue(json, "trend_score");
   string mom = ExtractJsonValue(json, "momentum_score");

   if(action != "") g_lastChartTechAction = action;
   if(conf != "") g_lastChartTechConfidence = StringToDouble(conf);
   if(sp != "")
   {
      g_lastChartTechSpikeProbability = StringToDouble(sp);
      if(ApplyChartTechSpikeBoost)
      {
         g_lastSpikeProbability = MathMax(g_lastSpikeProbability, g_lastChartTechSpikeProbability);
         g_lastSpikeUpdate = TimeCurrent();
      }
   }
   g_lastChartTechResponseSummary = StringFormat(
      "RECV act=%s conf=%.1f%% spike=%.1f%% trend=%s mom=%s",
      g_lastChartTechAction,
      g_lastChartTechConfidence * 100.0,
      g_lastChartTechSpikeProbability * 100.0,
      (trend == "" ? "n/a" : trend),
      (mom == "" ? "n/a" : mom)
   );
   g_lastChartTechResponseUtc = TimeCurrent();

   return true;
}

void ProcessAIDecision_Legacy(string jsonData)
{
   // Parser la rÃĐponse JSON du serveur IA
   // Format attendu: {"action": "BUY/SELL/HOLD", "confidence": 0.85, "alignment": "75%", "coherence": "82%"}
   
   g_lastAIUpdate = TimeCurrent();
   
   // Extraire l'action
   if(StringFind(jsonData, "\"action\":") >= 0)
   {
      int start = StringFind(jsonData, "\"action\":") + 9;
      int end = StringFind(jsonData, ",", start);
      if(end < 0) end = StringFind(jsonData, "}", start);
      
      if(end > start)
      {
         string action = StringSubstr(jsonData, start, end - start);
         StringReplace(action, "\"", "");
         StringReplace(action, " ", "");
         g_lastAIAction = action;
      }
   }
   
   // Extraire la confiance
   if(StringFind(jsonData, "\"confidence\":") >= 0)
   {
      int start = StringFind(jsonData, "\"confidence\":") + 13;
      int end = StringFind(jsonData, ",", start);
      if(end < 0) end = StringFind(jsonData, "}", start);
      
      if(end > start)
      {
         string confStr = StringSubstr(jsonData, start, end - start);
         g_lastAIConfidence = StringToDouble(confStr);
         NormalizeStoredAIConfidenceInPlace();
      }
   }
   
   // Extraire l'alignement
   if(StringFind(jsonData, "\"alignment\":") >= 0)
   {
      int start = StringFind(jsonData, "\"alignment\":") + 12;
      int end = StringFind(jsonData, ",", start);
      if(end < 0) end = StringFind(jsonData, "}", start);
      
      if(end > start)
      {
         string alignStr = StringSubstr(jsonData, start, end - start);
         StringReplace(alignStr, "\"", "");
         g_lastAIAlignment = alignStr;
      }
   }
   
   // Extraire la cohÃĐrence
   if(StringFind(jsonData, "\"coherence\":") >= 0)
   {
      int start = StringFind(jsonData, "\"coherence\":") + 13;
      int end = StringFind(jsonData, ",", start);
      if(end < 0) end = StringFind(jsonData, "}", start);
      
      if(end > start)
      {
         string cohStr = StringSubstr(jsonData, start, end - start);
         StringReplace(cohStr, "\"", "");
         g_lastAICoherence = cohStr;
      }
   }
   
   // Si aucune donnÃĐe trouvÃĐe, valeurs par dÃĐfaut
   if(g_lastAIAction == "") g_lastAIAction = "HOLD";
   NormalizeStoredAIConfidenceInPlace();
   if(g_lastAIConfidence == 0) g_lastAIConfidence = 0.5;
   if(g_lastAIAlignment == "") g_lastAIAlignment = "50%";
   if(g_lastAICoherence == "") g_lastAICoherence = "50%";
}


//| GESTION DES POSITIONS ET VARIABLES GLOBALES                    |

// FONCTIONS SUPPRIMÃES - PLUS D'ORDRES LIMIT
// - PlaceScalpingLimitOrders() supprimÃĐe
// - DrawLimitOrderLevels() supprimÃĐe
// - PlaceHistoricalBasedScalpingOrders() supprimÃĐe
// - PlaceReturnMovementLimitOrder() supprimÃĐe
// - AdjustEMAScalpingLimitOrder() supprimÃĐe
// - ShouldReplaceLimitOrder() supprimÃĐe
// - ReplaceLimitOrder() supprimÃĐe
// - GuardPendingLimitOrdersWithAI_Enhanced() supprimÃĐe

// Fonctions utilitaires de comptage d'ordres (conservÃĐes pour compatibilitÃĐ)
int CountOpenLimitOrdersForSymbol(const string symbol)
{
   int count = 0;
   for(int i = OrdersTotal() - 1; i >= 0; i--)
   {
      ulong ticket = OrderGetTicket(i);
      if(ticket == 0) continue;
      if(OrderGetString(ORDER_SYMBOL) != symbol) continue;
      if(OrderGetInteger(ORDER_MAGIC) != InpMagicNumber) continue;
      
      ENUM_ORDER_TYPE t = (ENUM_ORDER_TYPE)OrderGetInteger(ORDER_TYPE);
      if(t == ORDER_TYPE_BUY_LIMIT || t == ORDER_TYPE_SELL_LIMIT)
         count++;
   }
   return count;
}
      
      /* // Si le symbole est propice mais pas sur de graphique, bloquer les ordres LIMIT
      if(!symbolFoundOnChart)
      {
         Print("ðŦ ORDRES LIMIT BLOQUÃS - Symbole propice ", _Symbol, " non listÃĐ sur aucun graphique");
         Print("   ðĄ Ce symbole est considÃĐrÃĐ comme propice mais n'est pas affichÃĐ dans Market Watch");
         Print("   ð Veuillez ajouter ", _Symbol, " Ã  un graphique pour permettre les ordres LIMIT");
         return;
      }
      // (dÃĐsactivation terminator prÃĐmaturÃĐe) le commentaire multi-ligne continue jusqu'au fin
   }

   // IA/ML doit ÃŠtre favorable (direction + forte confiance)
   string aiDir = g_lastAIAction;
   StringToUpper(aiDir);
   
   // BLOCAGE SÃCURITÃ: NE PAS PLACER D'ORDRES SI IA EST EN HOLD
   if(aiDir == "HOLD")
   {
      Print("?? ORDRES SCALPING LIMIT BLOQUÃS - IA en HOLD sur ", _Symbol, " - SÃĐcuritÃĐ activÃĐe");
      return;
   }
   
   if(aiDir != "BUY" && aiDir != "SELL") return;
   if(!IsAITradeAllowedForDirection(aiDir))
      return; // log dÃĐjÃ  fait dans IsAITradeAllowedForDirection()

   // Anti-duplication: 1 seul pending LIMIT par symbole (sur notre magic)
   if(CountOpenLimitOrdersForSymbol(_Symbol) >= 1)
      return;

   // Filtre "conditions rÃĐunies": indicateurs classiques (EMA/RSI/MACD/BB/VWAP/Pivots/Ichimoku/OBV)
   string classicSummary = "";
   if(!IsClassicIndicatorsAligned(aiDir, classicSummary))
   {
      Print("?? LIMIT STRAT BLOQUÃ - Indicateurs classiques non alignÃĐs (", aiDir, ") ", classicSummary);
      return;
   }

   if(currentATR <= 0.0)
      return;

   double price = currentPrice;
   if(price <= 0.0)
      price = (aiDir == "BUY") ? SymbolInfoDouble(_Symbol, SYMBOL_BID) : SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   if(price <= 0.0) return;

   string src = "";
   double entry = 0.0;
   ENUM_ORDER_TYPE orderType = ORDER_TYPE_BUY_LIMIT;
   if(aiDir == "BUY")
   {
      entry = GetClosestBuyLevel(price, currentATR, MaxDistanceLimitATR, src);
      orderType = ORDER_TYPE_BUY_LIMIT;
   }
   else
   {
      entry = GetClosestSellLevel(price, currentATR, MaxDistanceLimitATR, src);
      orderType = ORDER_TYPE_SELL_LIMIT;
   }

   if(entry <= 0.0)
      return;

   double sl = 0.0, tp = 0.0;
   if(orderType == ORDER_TYPE_BUY_LIMIT)
   {
      sl = entry - currentATR * SL_ATRMult;
      tp = entry + currentATR * TP_ATRMult;
   }
   else
   {
      sl = entry + currentATR * SL_ATRMult;
      tp = entry - currentATR * TP_ATRMult;
   }

   MqlTradeRequest req = {};
   MqlTradeResult  res = {};
   req.action = TRADE_ACTION_PENDING;
   req.symbol = _Symbol;
   req.volume = CalculateLotSizeForPendingOrders();
   if(req.volume <= 0.0) return;
   req.type   = orderType;
   req.price  = entry;
   req.sl     = sl;
   req.tp     = tp;
   req.magic  = InpMagicNumber;
   req.comment = "STRAT " + aiDir + " LIMIT (" + src + ")";

   if(!ValidateAndAdjustLimitPrice(req.price, req.sl, req.tp, orderType))
      return;

   if(OrderSend(req, res))
   {
      Print("?? LIMIT STRAT OK - ", aiDir, " @ ", DoubleToString(req.price, _Digits),
            " src=", src,
            " | Vol=", DoubleToString(req.volume, 2),
            " | SL=", DoubleToString(req.sl, _Digits),
            " | TP=", DoubleToString(req.tp, _Digits),
            " | Classic=", classicSummary);
   }
}
*/


/*
// Place les LIMIT "prÃĐdits" (Protected future points) exactement au mÃŠme prix que ceux affichÃĐs au dashboard.
// Cible: uniquement Boom/Crash.
void PlaceFutureProtectedLimitsExact_BoomCrash(double currentATR)
{
   // FONCTION DÃSACTIVÃE - Les ordres LIMIT ne sont plus placÃĐs automatiquement
   Print("ðŦ FONCTION DÃSACTIVÃE - PlaceFutureProtectedLimitsExact_BoomCrash() supprimÃĐ");
   return;
   
   // Ancien code conservÃĐ pour rÃĐfÃĐrence mais non exÃĐcutÃĐ
   // Throttle: ÃĐviter spam
   static datetime lastPlace = 0;
   datetime now = TimeCurrent();
   if(now - lastPlace < 60) return;
   lastPlace = now;

   if(SMC_GetSymbolCategory(_Symbol) != SYM_BOOM_CRASH) return;
   // currentATR peut ÃŠtre 0 sur certains contextes: ValidateLimitPriceExactEntry ajustera SL/TP

   // IA directionnelle (pas HOLD)
   string aiAction = g_lastAIAction;
   StringToUpper(aiAction);
   if(aiAction == "HOLD" || aiAction == "") return;
   // Pour les LIMIT "future protected points", on ne bloque pas sur la confiance
   // : le but est de placer les pending aux niveaux prÃĐdits (sinon tu ne vois jamais ces ordres).

   // Anti-duplication stricte: 1 seul LIMIT par symbole (EA)
   // On nettoie les autres LIMIT du symbole avant de poursuivre.
   int totalLimits = CountOpenLimitOrdersForSymbol(_Symbol);
   // IMPORTANT: ne pas return ici.
   // On veut supprimer les doublons (ou limiter Ã  1 seul) avant de placer/modifier l'ordre future.
   double futureSupport = 0.0, futureResistance = 0.0;
   bool hasFutureLevels = GetFutureProtectedPointLevels(futureSupport, futureResistance);
   if(!hasFutureLevels) return;

   bool isBoom = IsBoomSymbol(_Symbol);
   bool isCrash = IsCrashSymbol(_Symbol);
   if(!isBoom && !isCrash) return;

   // Diagnostic: afficher les niveaux rÃĐellement utilisÃĐs pour le pending
   // (une fois/minute car la fonction est dÃĐjÃ  throttlÃĐe)
   Print("ð§Đ FUTURE LIMIT EXACT - ", _Symbol,
         " | ai=", aiAction,
         " conf=", DoubleToString(g_lastAIConfidence*100.0, 1), "%",
         " | ATR=", DoubleToString(currentATR, _Digits),
         " | futureSupport=", DoubleToString(futureSupport, _Digits),
         " | futureResistance=", DoubleToString(futureResistance, _Digits),
         " | totalLimits=", IntegerToString(totalLimits));

   ENUM_ORDER_TYPE orderType;
   double entry;
   double sl;
   double tp;
   string side;

   if(isBoom)
   {
      // Boom: BUY_LIMIT uniquement
      if(futureSupport <= 0.0)
      {
         Print("ð FUTURE LIMIT EXACT - Boom mais futureSupport<=0.0 sur ", _Symbol);
         return;
      }
      orderType = ORDER_TYPE_BUY_LIMIT;
      side = "BUY";
      entry = futureSupport;
      sl = entry - currentATR * SL_ATRMult;
      // TP >= 3 fois la distance SL positive (ici: ATR*SL_ATRMult)
      tp = entry + (currentATR * SL_ATRMult * MathMax(3.0, InpRiskReward));
   }
   else // Crash
   {
      // Crash: SELL_LIMIT uniquement
      if(futureResistance <= 0.0)
      {
         Print("ð FUTURE LIMIT EXACT - Crash mais futureResistance<=0.0 sur ", _Symbol);
         return;
      }
      orderType = ORDER_TYPE_SELL_LIMIT;
      side = "SELL";
      entry = futureResistance;
      sl = entry + currentATR * SL_ATRMult;
      // TP >= 3 fois la distance SL positive (ici: ATR*SL_ATRMult)
      tp = entry - (currentATR * SL_ATRMult * MathMax(3.0, InpRiskReward));
   }

   double tickSize = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_SIZE);
   if(tickSize <= 0.0) tickSize = SymbolInfoDouble(_Symbol, SYMBOL_POINT);

   string ourCmtPrefix = "FUTURE_PROTECTED_LIMIT_EXACT_";
   ulong existingTicket = 0;
   double existingPrice = 0.0;

   // Chercher le pending futur existant (1 seul par symbole souhaitÃĐ)
   // et supprimer tous les autres LIMIT sur ce symbole.
   for(int oi = OrdersTotal() - 1; oi >= 0; oi--)
   {
      ulong oticket = OrderGetTicket(oi);
      if(oticket == 0) continue;
      if(OrderGetInteger(ORDER_MAGIC) != InpMagicNumber) continue;
      if(OrderGetString(ORDER_SYMBOL) != _Symbol) continue;

      ENUM_ORDER_TYPE ot = (ENUM_ORDER_TYPE)OrderGetInteger(ORDER_TYPE);
      if(ot != ORDER_TYPE_BUY_LIMIT && ot != ORDER_TYPE_SELL_LIMIT) continue;

      string cmt = OrderGetString(ORDER_COMMENT);
      bool isOurFuture = (StringFind(cmt, ourCmtPrefix) == 0);
      if(isOurFuture)
      {
         // On en garde le plus rÃĐcent (ticket max) dans existingTicket
         if(oticket > existingTicket)
         {
            existingTicket = oticket;
            existingPrice = OrderGetDouble(ORDER_PRICE_OPEN);
         }
      }
      else
      {
         // RÃĻgle utilisateur: pas deux LIMIT sur le mÃŠme symbole -> annuler l'ancien/autre.
         MqlTradeRequest rdelOther = {};
         MqlTradeResult  rresOther = {};
         rdelOther.action = TRADE_ACTION_REMOVE;
         rdelOther.order  = oticket;
         rdelOther.symbol = _Symbol;
         if(OrderSend(rdelOther, rresOther))
         {
            Print("?? LIMIT supprimÃĐ (unicitÃĐ symbole) | ", _Symbol,
                  " | ticket=", IntegerToString((int)oticket),
                  " | comment=", cmt);
         }
         else
         {
            Print("? Ãchec suppression LIMIT (unicitÃĐ symbole) | ", _Symbol,
                  " | ticket=", IntegerToString((int)oticket),
                  " | retcode=", IntegerToString(rresOther.retcode));
         }
      }
   }

   // S'il existe plusieurs LIMIT au total, ne conserver qu'un seul future-limit (le plus rÃĐcent)
   // et supprimer les doublons "future protected" restants.
   if(totalLimits > 1 && existingTicket != 0)
   {
      for(int oi = OrdersTotal() - 1; oi >= 0; oi--)
      {
         ulong oticket = OrderGetTicket(oi);
         if(oticket == 0 || oticket == existingTicket) continue;
         if(OrderGetInteger(ORDER_MAGIC) != InpMagicNumber) continue;
         if(OrderGetString(ORDER_SYMBOL) != _Symbol) continue;
         ENUM_ORDER_TYPE ot = (ENUM_ORDER_TYPE)OrderGetInteger(ORDER_TYPE);
         if(ot != ORDER_TYPE_BUY_LIMIT && ot != ORDER_TYPE_SELL_LIMIT) continue;
         string cmt = OrderGetString(ORDER_COMMENT);
         if(StringFind(cmt, ourCmtPrefix) != 0) continue;

         MqlTradeRequest rdelDup = {};
         MqlTradeResult  rresDup = {};
         rdelDup.action = TRADE_ACTION_REMOVE;
         rdelDup.order  = oticket;
         rdelDup.symbol = _Symbol;
         if(!OrderSend(rdelDup, rresDup))
         {
            Print("â Erreur suppression ordre dupliquÃĐ: ", rresDup.retcode, " | ", rresDup.comment);
         }
      }
   }

   // Validation exacte avant toute action (entry ne doit pas bouger).
   if(!ValidateLimitPriceExactEntry(entry, sl, tp, orderType))
      return;

   bool needReplace = true;
   if(existingTicket != 0)
   {
      // Ne remplacer que si le prix a vraiment changÃĐ (sinon on laisse le pending tranquille)
      if(MathAbs(existingPrice - entry) <= tickSize * 0.5)
         needReplace = false;
   }

   // Si un pending existe et que le prix a changÃĐ: MODIFY sinon remove+recreate.
   if(existingTicket != 0 && needReplace)
   {
      // Tentative: modifier le pending (prix/SL/TP)
      MqlTradeRequest req = {};
      MqlTradeResult  res = {};
      req.action = TRADE_ACTION_MODIFY;
      req.order  = existingTicket;
      req.symbol = _Symbol;
      req.price  = entry;
      req.sl     = sl;
      req.tp     = tp;
      req.magic  = InpMagicNumber;

      if(OrderSend(req, res) && (res.retcode == TRADE_RETCODE_DONE || res.retcode == 10009))
      {
         Print("?? FUTURE LIMIT EXACT MODIFIÃ | ", _Symbol,
               " | ", side, " @ ", DoubleToString(entry, _Digits),
               " | SL=", DoubleToString(sl, _Digits),
               " | TP=", DoubleToString(tp, _Digits),
               " | oldTicket=", IntegerToString((int)existingTicket));
         return;
      }

      // Sinon: remove + resend
      MqlTradeRequest rdel = {};
      MqlTradeResult  rres = {};
      rdel.action = TRADE_ACTION_REMOVE;
      rdel.order  = existingTicket;
      rdel.symbol = _Symbol;
      if(!OrderSend(rdel, rres))
      {
         Print("? FUTURE LIMIT EXACT remove ÃCHEC | ", _Symbol,
               " | oldTicket=", IntegerToString((int)existingTicket),
               " | retcode=", IntegerToString(rres.retcode));
         // On tente malgrÃĐ tout de recrÃĐer
      }
   }

   // (Re)crÃĐer le pending s'il n'existe pas ou aprÃĻs remove
   MqlTradeRequest req2 = {};
   MqlTradeResult  res2 = {};
   req2.action = TRADE_ACTION_PENDING;
   req2.symbol = _Symbol;
   req2.volume = CalculateLotSizeForPendingOrders();
   if(req2.volume <= 0.0) return;
   req2.type   = orderType;
   req2.price  = entry;
   req2.sl     = sl;
   req2.tp     = tp;
   req2.magic  = InpMagicNumber;
   req2.comment = ourCmtPrefix + side;

   if(OrderSend(req2, res2))
   {
      Print("?? FUTURE LIMIT EXACT (re)crÃĐÃĐ | ", _Symbol, " | ", side,
            " @ ", DoubleToString(entry, _Digits),
            " | SL=", DoubleToString(sl, _Digits),
            " | TP=", DoubleToString(tp, _Digits),
            " | retcode=", IntegerToString(res2.retcode));
   }
   else
   {
      Print("? FUTURE LIMIT EXACT ÃCHEC (re)crÃĐation | ", _Symbol, " | ", side,
            " @ ", DoubleToString(entry, _Digits),
            " | retcode=", IntegerToString(res2.retcode),
            " | comment=", res2.comment);
   }
}

void PlaceHistoricalBasedScalpingOrders(MqlRates &rates[], int futureBars, double currentPrice, double currentATR, double trendSlope, int existingLimitOrders)
   {
      // VÃRIFICATION ANTI-DUPLICATION - Si position dÃĐjÃ  en cours, ne pas placer d'ordres
      int existingPositionsOnSymbol = CountPositionsForSymbol(_Symbol);
      
      // CORRECTION: Utiliser les prix EXACTS des Protected Points 500 bougies (ceux affichÃĐs au dashboard)
      double futureSupport = 0.0, futureResistance = 0.0;
      
      // Obtenir les Protected Points projetÃĐs 500 bougies (ceux affichÃĐs au tableau de bord)
      MqlRates futureRates[];
      ArraySetAsSeries(futureRates, true);
      bool hasFutureLevels = false;
      
      if(CopyRates(_Symbol, PERIOD_M15, 0, 200, futureRates) >= 100)
      {
         double currentPrice = futureRates[0].close;
         datetime currentTime = futureRates[0].time;
         
         // Trouver le Protected Low Point le plus rÃĐcent (celui projetÃĐ 500 bougies)
         for(int i = 5; i < 50; i++)
         {
            bool isProtectedLow = true;
            double currentLow = futureRates[i].low;
            
            // VÃĐrifier si c'est un low protÃĐgÃĐ
            for(int j = i - 5; j >= 0 && j >= i - 10; j--)
            {
               if(futureRates[j].low < currentLow)
               {
                  isProtectedLow = false;
                  break;
               }
            }
            
            if(isProtectedLow && currentLow < currentPrice)
            {
               futureSupport = currentLow; // PRIX EXACT affichÃĐ au dashboard
               hasFutureLevels = true;
               break; // Prendre le plus rÃĐcent
            }
         }
         
         // Trouver le Protected High Point le plus rÃĐcent (celui projetÃĐ 500 bougies)
         for(int i = 5; i < 50; i++)
         {
            bool isProtectedHigh = true;
            double currentHigh = futureRates[i].high;
            
            // VÃĐrifier si c'est un high protÃĐgÃĐ
            for(int j = i - 5; j >= 0 && j >= i - 10; j--)
            {
               if(futureRates[j].high > currentHigh)
               {
                  isProtectedHigh = false;
                  break;
               }
            }
            
            if(isProtectedHigh && currentHigh > currentPrice)
            {
               futureResistance = currentHigh; // PRIX EXACT affichÃĐ au dashboard
               hasFutureLevels = true;
               break; // Prendre le plus rÃĐcent
            }
         }
      }
      
      // LOG DES PRÃDICTIONS POUR ORDRES LIMITES
      if(hasFutureLevels)
      {
         static datetime lastLimitOrderLog = 0;
         if(TimeCurrent() - lastLimitOrderLog >= 300) // Log toutes les 5 minutes
         {
            Print("ðŊ PRÃDICTIONS FUTURES POUR ORDRES LIMITES - ", _Symbol);
            Print("   ð Support futur: ", (futureSupport > 0 ? DoubleToString(futureSupport, _Digits) : "N/A"));
            Print("   ð RÃĐsistance future: ", (futureResistance > 0 ? DoubleToString(futureResistance, _Digits) : "N/A"));
            Print("   ðĄ Utilisation pour placement stratÃĐgique d'ordres limites");
            lastLimitOrderLog = TimeCurrent();
         }
      }
      if(existingPositionsOnSymbol > 0)
      {
         Print("?? ORDRES HISTORIQUES BLOQUÃS - ", existingPositionsOnSymbol, " position(s) dÃĐjÃ  en cours sur ", _Symbol, " - Attente fermeture");
         return;
      }
      
      // BLOCAGE SÃCURITÃ: NE PAS PLACER D'ORDRES SI IA EST EN HOLD
      string aiAction = g_lastAIAction;
      StringToUpper(aiAction);
      if(aiAction == "HOLD")
      {
         Print("?? ORDRES HISTORIQUES BLOQUÃS - IA en HOLD sur ", _Symbol, " - SÃĐcuritÃĐ activÃĐe");
         return;
      }
      
      // POUR TOUS LES MARCHÃS HORS BOOM/CRASH: n'autoriser les ordres que si IA ? 80% et alignÃĐe
      ENUM_SYMBOL_CATEGORY cat = SMC_GetSymbolCategory(_Symbol);
      if(cat != SYM_BOOM_CRASH && !IsAITradeAllowedForDirection(g_lastAIAction))
      {
         // IsAITradeAllowedForDirection loggue dÃĐjÃ  la raison prÃĐcise
         return;
      }
      
      // Anti-duplication: 1 seul pending LIMIT par symbole
      {
         int totalLimits = CountOpenLimitOrdersForSymbol(_Symbol);
         if(totalLimits >= 1)
         {
            Print("?? ORDRES HISTORIQUES BLOQUÃS - DUP LIMIT sur ", _Symbol);
            return;
         }
      }
      
      // RÃGLE STRICTE: BLOQUER TOUS LES ORDRES BUY SUR BOOM SI IA = SELL
      bool isBoom = (StringFind(_Symbol, "Boom") >= 0);
      bool isCrash = (StringFind(_Symbol, "Crash") >= 0);
      if(aiAction == "buy") aiAction = "BUY";
      if(aiAction == "sell") aiAction = "SELL";
      
      if(isBoom && aiAction == "SELL")
      {
         Print("?? ORDRES HISTORIQUES BOOM BLOQUÃS - IA = SELL (", DoubleToString(g_lastAIConfidence*100, 1), "%) | Attendre signal BUY avant de placer ordres BUY");
         return;
      }
      
      if(isCrash && aiAction == "BUY")
      {
         Print("?? ORDRES HISTORIQUES CRASH BLOQUÃS - IA = BUY (", DoubleToString(g_lastAIConfidence*100, 1), "%) | Attendre signal SELL avant de placer ordres SELL");
         return;
      }
      
      // 1) STRATÃGIE EMA SMC (200, 100, 50, 31, 21) AVEC IA FORTE
      int ordersToPlace = MathMax(0, 1 - existingLimitOrders); // Anti-duplication: max 1
      if(ordersToPlace > 0 && ema21LTF != INVALID_HANDLE && ema31LTF != INVALID_HANDLE &&
         ema50LTF != INVALID_HANDLE && ema100LTF != INVALID_HANDLE && ema200LTF != INVALID_HANDLE)
      {
         double emaBuf[];
         ArraySetAsSeries(emaBuf, true);
         ArrayResize(emaBuf, 1);
      double ema21 = 0, ema31 = 0, ema50 = 0, ema100 = 0, ema200 = 0;
      if(CopyBuffer(ema21LTF, 0, 0, 1, emaBuf) >= 1) ema21 = emaBuf[0];
      if(CopyBuffer(ema31LTF, 0, 0, 1, emaBuf) >= 1) ema31 = emaBuf[0];
      if(CopyBuffer(ema50LTF, 0, 0, 1, emaBuf) >= 1) ema50 = emaBuf[0];
      if(CopyBuffer(ema100LTF, 0, 0, 1, emaBuf) >= 1) ema100 = emaBuf[0];
      if(CopyBuffer(ema200LTF, 0, 0, 1, emaBuf) >= 1) ema200 = emaBuf[0];
      
      double closePrice = rates[0].close;
      bool emaOk = (ema21 > 0 && ema31 > 0 && ema50 > 0 && ema100 > 0 && ema200 > 0);
      
      if(emaOk)
      {
         // DÃĐterminer la tendance EMA sur LTF
         bool uptrend = (closePrice > ema200 && ema21 > ema31 && ema31 > ema50 && ema50 > ema100 && ema100 > ema200);
         bool downtrend = (closePrice < ema200 && ema21 < ema31 && ema31 < ema50 && ema50 < ema100 && ema100 < ema200);
         
         string aiDir = g_lastAIAction;
         StringToUpper(aiDir);
         
         // STRATÃGIE UNIQUE: BOOM = BUY LIMIT exact au support futur, CRASH = SELL LIMIT exact Ã  la rÃĐsistance future
         
         // LOGS DE DÃBOGAGE DÃTAILLÃS POUR DIAGNOSTIC
         Print("ð DIAGNOSTIC ORDRE LIMIT BOOM - ", _Symbol);
         Print("   ð isBoom: ", (isBoom ? "OUI" : "NON"));
         Print("   ð hasFutureLevels: ", (hasFutureLevels ? "OUI" : "NON"));
         Print("   ð futureSupport: ", (futureSupport > 0 ? DoubleToString(futureSupport, _Digits) : "0.0"));
         Print("   ð ordersToPlace: ", IntegerToString(ordersToPlace));
         Print("   ð currentPrice: ", DoubleToString(closePrice, _Digits));
         Print("   ð currentATR: ", DoubleToString(currentATR, _Digits));
         
         if(isBoom && hasFutureLevels && futureSupport > 0 && ordersToPlace > 0)
         {
            Print("â Toutes les conditions rÃĐunies pour BUY LIMIT BOOM");
            
            // BOOM: Placer BUY LIMIT EXACTEMENT au prix affichÃĐ au tableau de bord
            double exactSupportPrice = futureSupport; // Prix exact affichÃĐ au dashboard
            
            Print("ðŊ PRIX DU BUY LIMIT: ", DoubleToString(exactSupportPrice, _Digits));
            Print("   ð Position par rapport au prix actuel: ", DoubleToString(closePrice - exactSupportPrice, _Digits), " points");
            
            // Placer BUY LIMIT au prix exact du support futur
            MqlTradeRequest req = {};
            MqlTradeResult res = {};
            req.action = TRADE_ACTION_PENDING;
            req.symbol = _Symbol;
            req.volume = CalculateLotSizeForPendingOrders();
            Print("ðĶ Volume calculÃĐ: ", DoubleToString(req.volume, 2));
            if(req.volume <= 0.0) 
            {
               Print("â VOLUME INVALIDE - Ordre annulÃĐ");
               return;
            }
            req.type = ORDER_TYPE_BUY_LIMIT;
            req.price = exactSupportPrice; // PRIX EXACT affichÃĐ au tableau de bord
            req.sl = exactSupportPrice - (currentATR * SL_ATRMult);
            // TP doit ÃŠtre >= 3 fois la distance SL positive
            req.tp = exactSupportPrice + (currentATR * SL_ATRMult * MathMax(3.0, InpRiskReward));
            req.magic = InpMagicNumber;
            req.comment = "BOOM EXACT_FUTURE_SUPPORT";
            
            Print("ð DÃTAILS ORDRE AVANT ENVOI:");
            Print("   ð Type: BUY_LIMIT");
            Print("   ð° Prix: ", DoubleToString(req.price, _Digits));
            Print("   ðĶ Volume: ", DoubleToString(req.volume, 2));
            Print("   ðĄïļ SL: ", DoubleToString(req.sl, _Digits));
            Print("   ðŊ TP: ", DoubleToString(req.tp, _Digits));
            Print("   ðŪ Magic: ", IntegerToString(req.magic));
            
            // Validation "exact entry": on doit garder le prix affichÃĐ (futureSupport) identique.
            bool validationOk = ValidateLimitPriceExactEntry(req.price, req.sl, req.tp, ORDER_TYPE_BUY_LIMIT);
            Print("ð Validation prix: ", (validationOk ? "OK" : "ÃCHEC"));
            if(!validationOk)
            {
               Print("â VALIDATION PRIX ÃCHOUÃE - Ordre annulÃĐ");
               return;
            }
            
            bool orderSent = OrderSend(req, res);
            Print("ð Envoi ordre: ", (orderSent ? "SUCCÃS" : "ÃCHEC"));
            Print("   ð Code retour: ", IntegerToString(res.retcode));
            Print("   ð Commentaire: ", res.comment);
            
            if(orderSent)
            {
               Print("â BOOM BUY LIMIT PLACÃ AU PRIX EXACT DU TABLEAU DE BORD - ", _Symbol);
               Print("   ðŊ PRIX EXACT dashboard: ", DoubleToString(exactSupportPrice, _Digits));
               Print("   ð Prix ordre: ", DoubleToString(req.price, _Digits), " | Lot: ", DoubleToString(req.volume, 2));
               Print("   ðĄïļ SL: ", DoubleToString(req.sl, _Digits), " | ðŊ TP: ", DoubleToString(req.tp, _Digits));
               Print("   â CORRESPONDANCE PARFAITE avec l'affichage");
            }
            else
            {
               Print("â ÃCHEC BOOM BUY LIMIT - Erreur: ", res.retcode, " - ", res.comment);
            }
            return; // Sortir aprÃĻs avoir placÃĐ l'ordre
         }
         else
         {
            Print("â CONDITIONS NON RÃUNIES POUR BUY LIMIT BOOM");
            if(!isBoom) Print("   â Symbole non-BOOM dÃĐtectÃĐ");
            if(!hasFutureLevels) Print("   â Pas de niveaux futurs disponibles");
            if(futureSupport <= 0) Print("   â Support futur invalide: ", DoubleToString(futureSupport, _Digits));
            if(ordersToPlace <= 0) Print("   â Plus d'ordres Ã  placer: ", IntegerToString(ordersToPlace));
         }
         
         if(isCrash && hasFutureLevels && futureResistance > 0 && ordersToPlace > 0)
         {
            // CRASH: Placer SELL LIMIT EXACTEMENT au prix affichÃĐ au tableau de bord
            double exactResistancePrice = futureResistance; // Prix exact affichÃĐ au dashboard
            
            // Placer SELL LIMIT au prix exact de la rÃĐsistance future
            MqlTradeRequest req = {};
            MqlTradeResult res = {};
            req.action = TRADE_ACTION_PENDING;
            req.symbol = _Symbol;
            req.volume = CalculateLotSizeForPendingOrders();
            if(req.volume <= 0.0) return;
            req.type = ORDER_TYPE_SELL_LIMIT;
            req.price = exactResistancePrice; // PRIX EXACT affichÃĐ au tableau de bord
            req.sl = exactResistancePrice + (currentATR * SL_ATRMult);
            // TP doit ÃŠtre >= 3 fois la distance SL positive
            req.tp = exactResistancePrice - (currentATR * SL_ATRMult * MathMax(3.0, InpRiskReward));
            req.magic = InpMagicNumber;
            req.comment = "CRASH EXACT_FUTURE_RESISTANCE";
            
            // Validation "exact entry": on doit garder le prix affichÃĐ (futureResistance) identique.
            if(!ValidateLimitPriceExactEntry(req.price, req.sl, req.tp, ORDER_TYPE_SELL_LIMIT))
               return;
            
            if(OrderSend(req, res))
            {
               Print("â CRASH SELL LIMIT PLACÃ AU PRIX EXACT DU TABLEAU DE BORD - ", _Symbol);
               Print("   ðŊ PRIX EXACT dashboard: ", DoubleToString(exactResistancePrice, _Digits));
               Print("   ð Prix ordre: ", DoubleToString(req.price, _Digits), " | Lot: ", DoubleToString(req.volume, 2));
               Print("   ðĄïļ SL: ", DoubleToString(req.sl, _Digits), " | ðŊ TP: ", DoubleToString(req.tp, _Digits));
               Print("   â CORRESPONDANCE PARFAITE avec l'affichage");
            }
            else
            {
               Print("â ÃCHEC CRASH SELL LIMIT - Erreur: ", res.retcode, " - ", res.comment);
            }
            return; // Sortir aprÃĻs avoir placÃĐ l'ordre
         }
         
         // LOGIQUE SUPPRIMÃE - PLUS D'ORDRES LIMIT AUTRES QUE PRÃDICTIONS FUTURES
// Seuls les ordres BOOM/CRASH basÃĐs sur les prÃĐdictions futures sont conservÃĐs
      }
   }
   
   // ANALYSE DES SH/SL HISTORIQUES POUR PRÃDIRE LES MOUVEMENTS FUTURS
   double recentSwingHighs[], recentSwingLows[];
   ArrayResize(recentSwingHighs, 10);
   ArrayResize(recentSwingLows, 10);
   int swingHighCount = 0, swingLowCount = 0;
   
   // DÃĐtecter les SH/SL historiques rÃĐcents (derniÃĻres 100 bougies)
   for(int i = 10; i < 100 && (swingHighCount < 10 || swingLowCount < 10); i++)
   {
      // DÃĐtection de Swing High historique
      bool isHistoricalSH = true;
      for(int j = MathMax(0, i-5); j <= MathMin(ArraySize(rates)-1, i+5); j++)
      {
         if(j != i && rates[j].high >= rates[i].high)
         {
            isHistoricalSH = false;
            break;
         }
      }
      
      if(isHistoricalSH && rates[i].high > rates[i].close)
      {
         recentSwingHighs[swingHighCount] = rates[i].high;
         swingHighCount++;
      }
      
      // DÃĐtection de Swing Low historique
      bool isHistoricalSL = true;
      for(int j = MathMax(0, i-5); j <= MathMin(ArraySize(rates)-1, i+5); j++)
      {
         if(j != i && rates[j].low <= rates[i].low)
         {
            isHistoricalSL = false;
            break;
         }
      }
      
      if(isHistoricalSL && rates[i].low < rates[i].close)
      {
         recentSwingLows[swingLowCount] = rates[i].low;
         swingLowCount++;
      }
   }
   
   // STRATÃGIE BASÃE SUR L'ANALYSE HISTORIQUE
   // Si on a rÃĐcemment touchÃĐ un SL, le prix a tendance Ã  monter ? BUY LIMIT au niveau exact du SL
   // Si on a rÃĐcemment touchÃĐ un SH, le prix a tendance Ã  baisser ? SELL LIMIT au niveau exact du SH
   
   // Il reste ÃĐventuellement des ordres Ã  placer sur la base de l'historique
   
   // ORDRE 1: BASÃ SUR LE DERNIER SL HISTORIQUE (STRATÃGIE BUY)
   if(swingLowCount > 0 && ordersToPlace > 0)
   {
      double lastSL = recentSwingLows[0]; // Le SL le plus rÃĐcent
      double buyLimitPrice = lastSL; // Ordre placÃĐ directement au niveau du SL
      double tpPrice = buyLimitPrice + currentATR * 1.5; // TP plus proche pour scalping
      
      // Ne placer un ordre que si le SL est relativement proche (max 0.5 ATR pour petits mouvements)
      if(MathAbs(buyLimitPrice - currentPrice) <= currentATR * 0.5)
      {
         // Si le SL est trop proche (< 0.1 ATR), ajuster pour ÃĐviter les ordres trop prÃĻs
         if(MathAbs(buyLimitPrice - currentPrice) < currentATR * 0.1)
         {
            buyLimitPrice = currentPrice - (currentATR * 0.15); // 15% de l'ATR sous le prix
            tpPrice = buyLimitPrice + (currentATR * 0.3); // TP plus proche pour petits mouvements
         }
         
         MqlTradeRequest request = {};
         MqlTradeResult result = {};
         
         request.action = TRADE_ACTION_PENDING;
         request.symbol = _Symbol;
         request.volume = CalculateLotSizeForPendingOrders();
         if(request.volume <= 0.0) return;
         request.type = ORDER_TYPE_BUY_LIMIT;
         request.price = buyLimitPrice;
         request.sl = buyLimitPrice - (currentATR * 0.5); // SL plus proche pour petits mouvements
         request.tp = tpPrice;
         request.magic = InpMagicNumber;
         request.comment = "HIST SL BUY - PETITS MOUVEMENTS";
         
         // VALIDATION ET AJUSTEMENT DES PRIX AVANT ENVOI
         if(!ValidateAndAdjustLimitPrice(request.price, request.sl, request.tp, ORDER_TYPE_BUY_LIMIT))
         {
            Print("? Ãchec validation prix BUY LIMIT - Ordre annulÃĐ");
            return;
         }
         
         if(OrderSend(request, result))
         {
            Print("?? ORDRE BUY PETITS MOUVEMENTS - Prix: ", request.price, " | Vol=", DoubleToString(request.volume, 2),
                  " | TP: ", request.tp, " | SL: ", request.sl, " | Distance: ", MathAbs(request.price - currentPrice), " points");
            ordersToPlace--;
         }
      }
      else
      {
         Print("?? SL trop loin (", MathAbs(lastSL - currentPrice), " > 0.5 ATR) - Ordre BUY annulÃĐ pour petits mouvements");
      }
   }
   
   // ORDRE 2: BASÃ SUR LE DERNIER SH HISTORIQUE (STRATÃGIE SELL)
   if(swingHighCount > 0 && ordersToPlace > 0)
   {
      double lastSH = recentSwingHighs[0]; // Le SH le plus rÃĐcent
      double sellLimitPrice = lastSH; // Ordre placÃĐ directement au niveau du SH
      double tpPrice = sellLimitPrice - currentATR * 1.5; // TP plus proche pour scalping
      
      // Ne placer un ordre que si le SH est relativement proche (max 0.5 ATR pour petits mouvements)
      if(MathAbs(sellLimitPrice - currentPrice) <= currentATR * 0.5)
      {
         // Si le SH est trop proche (< 0.1 ATR), ajuster pour ÃĐviter les ordres trop prÃĻs
         if(MathAbs(sellLimitPrice - currentPrice) < currentATR * 0.1)
         {
            sellLimitPrice = currentPrice + (currentATR * 0.15); // 15% de l'ATR au-dessus du prix
            tpPrice = sellLimitPrice - (currentATR * 0.3); // TP plus proche pour petits mouvements
         }
         
         MqlTradeRequest request = {};
         MqlTradeResult result = {};
         
         request.action = TRADE_ACTION_PENDING;
         request.symbol = _Symbol;
         request.volume = CalculateLotSizeForPendingOrders();
         if(request.volume <= 0.0) return;
         request.type = ORDER_TYPE_SELL_LIMIT;
         request.price = sellLimitPrice;
         request.sl = sellLimitPrice + (currentATR * 0.5); // SL plus proche pour petits mouvements
         request.tp = tpPrice;
         request.magic = InpMagicNumber;
         request.comment = "HIST SH SELL - PETITS MOUVEMENTS";
         
         // VALIDATION ET AJUSTEMENT DES PRIX AVANT ENVOI
         if(!ValidateAndAdjustLimitPrice(request.price, request.sl, request.tp, ORDER_TYPE_SELL_LIMIT))
         {
            Print("? Ãchec validation prix SELL LIMIT - Ordre annulÃĐ");
            return;
         }
         
         if(OrderSend(request, result))
         {
            Print("?? ORDRE SELL PETITS MOUVEMENTS - Prix: ", request.price, " | Vol=", DoubleToString(request.volume, 2),
