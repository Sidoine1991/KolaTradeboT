//| ENVOI DE FEEDBACK DE TRADES Ã L'IA SERVER                        |
void OnTradeTransaction(const MqlTradeTransaction &trans,
                        const MqlTradeRequest &request,
                        const MqlTradeResult &result)
{
   // Ne traiter que les transactions de clÃīture de positions
   if(trans.type != TRADE_TRANSACTION_POSITION)
      return;

   // Pour les transactions de position, vÃĐrifier si c'est une clÃīture
   // En MQL5, on vÃĐrifie si la position existe encore
   CPositionInfo pos;
   if(!pos.SelectByTicket(trans.position))
   {
      // La position n'existe plus = elle a ÃĐtÃĐ fermÃĐe
      // RÃĐinitialiser le maxProfit pour cette position
      g_maxProfit = 0;
      
      // On doit rÃĐcupÃĐrer les informations depuis l'historique des deals
      if(HistorySelectByPosition(trans.position))
      {
         // RÃĐcupÃĐrer le dernier deal de cette position
         int deals = HistoryDealsTotal();
         for(int i = deals - 1; i >= 0; i--)
         {
            ulong deal_ticket = HistoryDealGetTicket(i);
            if(deal_ticket > 0)
            {
               CDealInfo deal;
               if(deal.SelectByIndex(i) && deal.PositionId() == trans.position)
               {
                  if(deal.Entry() != DEAL_ENTRY_OUT)
                     continue;

                  // C'est le deal de clÃīture de notre position
                  // VÃĐrifier que c'est notre robot (magic number)
                  if(deal.Magic() != InpMagicNumber)
                     return;

                  // Extraire les donnÃĐes du trade
                  string symbol = deal.Symbol();
                  double profit = deal.Profit() + deal.Swap() + deal.Commission();
                  bool is_win = (profit > 0);
                  string side = (deal.Entry() == DEAL_ENTRY_IN) ? "BUY" : "SELL";

                  // MÃĐmoriser perte rÃĐcente par symbole (ÃĐviter 2e perte consÃĐcutive sans conditions strictes)
                  if(profit < 0)
                  {
                     g_lastLossSymbol = symbol;
                     g_lastLossTime   = (datetime)deal.Time();
                  }
                  else if(symbol == g_lastLossSymbol)
                  {
                     g_lastLossSymbol = "";
                     g_lastLossTime   = 0;
                  }

                  if(profit > 0.0)
                     StairPostLossClearSrMode(symbol);
                  else if(profit < 0.0 && HistoryPositionHadStairEntry(trans.position))
                     StairPostLossArmSrMode(symbol, (datetime)deal.Time());

                  // Timestamps (convertir en millisecondes pour compatibilitÃĐ JSON)
                  long open_time = (long)deal.Time() * 1000;  // Time of the deal
                  long close_time = (long)deal.Time() * 1000;

                  // Utiliser la derniÃĻre confiance IA connue
                  double ai_confidence = g_lastAIConfidence;

                  // CrÃĐer le payload JSON
                  string json_payload = StringFormat(
                     "{"
                     "\"symbol\":\"%s\","
                     "\"timeframe\":\"M1\","
                     "\"profit\":%.2f,"
                     "\"is_win\":%s,"
                     "\"ai_confidence\":%.4f,"
                     "\"side\":\"%s\","
                     "\"open_time\":%lld,"
                     "\"close_time\":%lld"
                     "}",
                     symbol,
                     profit,
                     is_win ? "true" : "false",
                     ai_confidence,
                     side,
                     open_time,
                     close_time
                  );

                  // Envoyer Ã  l'IA server (essayer primaire puis secondaire)
                  string url1 = UseRenderAsPrimary ? (AI_ServerRender + "/trades/feedback") : (AI_ServerURL + "/trades/feedback");
                  string url2 = UseRenderAsPrimary ? (AI_ServerURL + "/trades/feedback") : (AI_ServerRender + "/trades/feedback");
                  
                  Print("?? ENVOI FEEDBACK IA - URL1: ", url1);
                  Print("?? ENVOI FEEDBACK IA - URL2: ", url2);
                  Print("?? ENVOI FEEDBACK IA - DonnÃĐes: symbol=", symbol, " profit=", DoubleToString(profit, 2), " ai_conf=", DoubleToString(ai_confidence, 2));

                  string headers = "Content-Type: application/json\r\n";
                  char post_data[];
                  char result_data[];
                  string result_headers;

                  // Convertir string JSON en array de char
                  StringToCharArray(json_payload, post_data, 0, StringLen(json_payload));

                  // Premier essai
                  int http_result = WebRequest("POST", url1, headers, AI_Timeout_ms, post_data, result_data, result_headers);

                  // Si ÃĐchec, essayer le serveur secondaire
                  if(http_result != 200)
                  {
                     http_result = WebRequest("POST", url2, headers, AI_Timeout_ms, post_data, result_data, result_headers);
                  }

                  // Log du rÃĐsultat
                  if(http_result == 200)
                  {
                     Print("? FEEDBACK IA ENVOYÃ: ", symbol, " ", side, " Profit: ", DoubleToString(profit, 2), " IA Conf: ", DoubleToString(ai_confidence, 2));
                  }
                  else
                  {
                     Print("? ÃCHEC ENVOI FEEDBACK IA: HTTP ", http_result, " pour ", symbol, " ", side);
                  }

                  break; // On a trouvÃĐ le deal de clÃīture, sortir de la boucle
               }
            }
         }
      }
   }
}

//| RÃĐcupÃĐrer les donnÃĐes de l'endpoint Decision                        |
bool GetAISignalData()
{
   static datetime lastAPICall = 0;
   static string lastCachedResponse = "";
   
   datetime currentTime = TimeCurrent();
   
   // Cache API: ÃĐviter les appels trop frÃĐquents (toutes les 30 secondes)
   if((currentTime - lastAPICall) < 30 && lastCachedResponse != "")
   {
      // Utiliser la rÃĐponse en cache
      if(StringFind(lastCachedResponse, "\"action\":") >= 0)
      {
         int actionStart = StringFind(lastCachedResponse, "\"action\":");
         actionStart = StringFind(lastCachedResponse, "\"", actionStart + 9) + 1;
         int actionEnd = StringFind(lastCachedResponse, "\"", actionStart);
         if(actionEnd > actionStart)
         {
            g_lastAIAction = StringSubstr(lastCachedResponse, actionStart, actionEnd - actionStart);
            return true;
         }
      }
   }
   
   // Endpoint POST /decision sur Render ou serveur local
   string base = UseRenderAsPrimary ? AI_ServerRender : AI_ServerURL;
   string url  = base + "/decision";
   string headers = "Content-Type: application/json\r\n";
   char post[];
   uchar response[];
   
   // PrÃĐparer les donnÃĐes de marchÃĐ de base
   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   
   // ATR via handle principal (si disponible)
   double atr = 0.0;
   double atrBuf[];
   ArraySetAsSeries(atrBuf, true);
   if(atrHandle != INVALID_HANDLE && CopyBuffer(atrHandle, 0, 0, 1, atrBuf) > 0)
      atr = atrBuf[0];
   
   // Calcul d'un RSI M15 pour alimenter le backend simplifiÃĐ
   double rsi = 50.0;
   MqlRates rsiRates[];
   ArraySetAsSeries(rsiRates, true);
   if(CopyRates(_Symbol, PERIOD_M15, 0, 50, rsiRates) >= 15)
   {
      // Utilise la fonction ComputeRSI dÃĐjÃ  dÃĐfinie (pÃĐriode 14)
      rsi = ComputeRSI(rsiRates, 14, 14);
   }
   // SÃĐcuritÃĐ supplÃĐmentaire : clamp 0-100 pour l'envoi JSON
   if(rsi < 0.0) rsi = 0.0;
   if(rsi > 100.0) rsi = 100.0;
   
   // RÃĐcupÃĐrer les EMA rapides/lentes via les handles existants (M1, M5, H1)
   double emaFastM1Val = 0.0, emaSlowM1Val = 0.0;
   double emaFastM5Val = 0.0, emaSlowM5Val = 0.0;
   double emaFastH1Val = 0.0, emaSlowH1Val = 0.0;
   double bufFast[], bufSlow[];
   ArraySetAsSeries(bufFast, true);
   ArraySetAsSeries(bufSlow, true);
   
   // M1
   if(emaFastM1 != INVALID_HANDLE && CopyBuffer(emaFastM1, 0, 0, 1, bufFast) > 0)
      emaFastM1Val = bufFast[0];
   if(emaSlowM1 != INVALID_HANDLE && CopyBuffer(emaSlowM1, 0, 0, 1, bufSlow) > 0)
      emaSlowM1Val = bufSlow[0];
   
   // M5
   if(emaFastM5 != INVALID_HANDLE && CopyBuffer(emaFastM5, 0, 0, 1, bufFast) > 0)
      emaFastM5Val = bufFast[0];
   if(emaSlowM5 != INVALID_HANDLE && CopyBuffer(emaSlowM5, 0, 0, 1, bufSlow) > 0)
      emaSlowM5Val = bufSlow[0];
   
   // H1
   if(emaFastH1 != INVALID_HANDLE && CopyBuffer(emaFastH1, 0, 0, 1, bufFast) > 0)
      emaFastH1Val = bufFast[0];
   if(emaSlowH1 != INVALID_HANDLE && CopyBuffer(emaSlowH1, 0, 0, 1, bufSlow) > 0)
      emaSlowH1Val = bufSlow[0];
   
   // Construire la requÃŠte JSON enrichie pour /decision (compatible decision_simplified)
   // Ajouter les indicateurs de dÃĐtection de spike avancÃĐe - VERSION OPTIMISÃE
   double volCompression = 1.0; // Valeur par dÃĐfaut
   double priceAccel = 0.0;
   bool volumeSpike = false;
   double spikeProb = 0.5; // Valeur neutre par dÃĐfaut
   
   // Calcul rapide avec protection
   if(atrHandle != INVALID_HANDLE)
   {
      // Compression ATR rapide
      double buffer[];
      ArraySetAsSeries(buffer, true);
      if(CopyBuffer(atrHandle, 0, 0, 10, buffer) >= 5)
      {
         double recentATR = buffer[0];
         double avgATR = 0.0;
         for(int i = 0; i < 5; i++) avgATR += buffer[i];
         avgATR /= 5.0;
         if(avgATR > 0) volCompression = recentATR / avgATR;
      }
      
      // AccÃĐlÃĐration prix rapide
      MqlRates rates[];
      ArraySetAsSeries(rates, true);
      if(CopyRates(_Symbol, PERIOD_M1, 0, 3, rates) >= 2)
      {
         double change1 = (rates[0].close - rates[1].close) / rates[1].close;
         double change2 = (rates[1].close - rates[2].close) / rates[2].close;
         priceAccel = (change1 - change2) / 2.0;
      }
      
      // Volume spike rapide
      long volume[];
      ArraySetAsSeries(volume, true);
      if(CopyTickVolume(_Symbol, PERIOD_M1, 0, 5, volume) >= 3)
      {
         double recentVolume = (double)volume[0];
         double avgVolume = 0.0;
         for(int i = 1; i < 3; i++) avgVolume += (double)volume[i];
         avgVolume /= 2.0;
         volumeSpike = (recentVolume > avgVolume * 1.5);
      }
      
      // ProbabilitÃĐ spike rapide - AJUSTÃ pour 70% de certitude
      spikeProb = 0.0;
      if(volCompression < 0.7) spikeProb += 0.4; // Compression forte (< 70%)
      if(MathAbs(priceAccel) > 0.001) spikeProb += 0.3; // AccÃĐlÃĐration notable
      if(volumeSpike) spikeProb += 0.3; // Volume spike confirmÃĐ
      spikeProb = MathMin(spikeProb, 1.0);

      // MÃĐmoriser la probabilitÃĐ locale de spike pour rÃĐutilisation (CheckImminentSpike, filtres ML, etc.)
      g_lastSpikeProbability = spikeProb;
      g_lastSpikeUpdate      = TimeCurrent();
   }
   
   string jsonRequest = StringFormat(
      "{\"symbol\":\"%s\",\"bid\":%.5f,\"ask\":%.5f,"
      "\"atr\":%.5f,\"rsi\":%.2f,"
      "\"ema_fast_m1\":%.5f,\"ema_slow_m1\":%.5f,"
      "\"ema_fast_m5\":%.5f,\"ema_slow_m5\":%.5f,"
      "\"ema_fast_h1\":%.5f,\"ema_slow_h1\":%.5f,"
      "\"volatility_compression\":%.3f,"
      "\"price_acceleration\":%.6f,"
      "\"volume_spike\":%s,"
      "\"chart_pattern_name\":\"%s\","
      "\"chart_pattern_direction\":\"%s\","
      "\"chart_pattern_score\":%.4f,"
      "\"chart_pattern_zone_low\":%.10f,"
      "\"chart_pattern_zone_high\":%.10f,"
      "\"spike_probability\":%.3f,"
      "\"timestamp\":\"%s\"}",
      _Symbol, bid, ask, atr, rsi,
      emaFastM1Val, emaSlowM1Val,
      emaFastM5Val, emaSlowM5Val,
      emaFastH1Val, emaSlowH1Val,
      volCompression,
      priceAccel,
      volumeSpike ? "true" : "false",
      g_lastChartPatternName,
      g_lastChartPatternDirection,
      g_lastChartPatternScore,
      g_lastChartPatternZoneLow,
      g_lastChartPatternZoneHigh,
      spikeProb,
      TimeToString(TimeCurrent())
   );
   
   Print("?? ENVOI IA: ", jsonRequest);
   
   StringToCharArray(jsonRequest, post);
   
   // Timeout rÃĐduit pour ÃĐviter le dÃĐtachement
   int res = WebRequest("POST", url, headers, 2000, post, response, headers);
   
      if(res == 200)
      {
         string jsonResponse = CharArrayToString(response);
         Print("?? RÃPONSE IA: ", jsonResponse);
         
         // Mettre Ã  jour le cache
         lastAPICall = currentTime;
         lastCachedResponse = jsonResponse;
         
         // Parser la rÃĐponse JSON
         int actionStart = StringFind(jsonResponse, "\"action\":");
         if(actionStart >= 0)
         {
            actionStart = StringFind(jsonResponse, "\"", actionStart + 9) + 1;
            int actionEnd = StringFind(jsonResponse, "\"", actionStart);
            if(actionEnd > actionStart)
            {
               g_lastAIAction = StringSubstr(jsonResponse, actionStart, actionEnd - actionStart);
               
               int confStart = StringFind(jsonResponse, "\"confidence\":");
               if(confStart >= 0)
               {
                  confStart = StringFind(jsonResponse, ":", confStart) + 1;
                  int confEnd = StringFind(jsonResponse, ",", confStart);
                  if(confEnd < 0) confEnd = StringFind(jsonResponse, "}", confStart);
                  if(confEnd > confStart)
                  {
                     string confStr = StringSubstr(jsonResponse, confStart, confEnd - confStart);
                     g_lastAIConfidence = StringToDouble(confStr);
                     NormalizeStoredAIConfidenceInPlace();
                  }
               }

               // Extraire la probabilitÃĐ de spike renvoyÃĐe par le modÃĻle ML (si disponible)
               int spikeStart = StringFind(jsonResponse, "\"spike_probability\"");
               if(spikeStart >= 0)
               {
                  spikeStart = StringFind(jsonResponse, ":", spikeStart) + 1;
                  int spikeEnd = StringFind(jsonResponse, ",", spikeStart);
                  if(spikeEnd < 0) spikeEnd = StringFind(jsonResponse, "}", spikeStart);
                  if(spikeEnd > spikeStart)
                  {
                     string spikeStr = StringSubstr(jsonResponse, spikeStart, spikeEnd - spikeStart);
                     double spikeVal = StringToDouble(spikeStr);
                     
                     // Accepter 0?1 ou 0?100%
                     if(spikeVal > 1.0)
                        spikeVal /= 100.0;
                     
                     if(spikeVal >= 0.0 && spikeVal <= 1.0)
                     {
                        g_lastSpikeProbability = spikeVal;
                        g_lastSpikeUpdate      = TimeCurrent();
                     }
                  }
               }
               
               // Extraire alignement et cohÃĐrence
            int alignStart = StringFind(jsonResponse, "\"alignment\":");
            if(alignStart >= 0)
            {
               alignStart = StringFind(jsonResponse, "\"", alignStart + 12) + 1;
               int alignEnd = StringFind(jsonResponse, "\"", alignStart);
               if(alignEnd > alignStart)
               {
                  g_lastAIAlignment = StringSubstr(jsonResponse, alignStart, alignEnd - alignStart);
               }
            }
            
            int cohStart = StringFind(jsonResponse, "\"coherence\":");
            if(cohStart >= 0)
            {
               cohStart = StringFind(jsonResponse, "\"", cohStart + 13) + 1;
               int cohEnd = StringFind(jsonResponse, "\"", cohStart);
               if(cohEnd > cohStart)
               {
                  g_lastAICoherence = StringSubstr(jsonResponse, cohStart, cohEnd - cohStart);
               }
            }
            
            // Validation scientifique multi-timeframes (D1 -> M1) pour renforcer/filtrer la dÃĐcision serveur.
            string serverAction = g_lastAIAction;
            StringToUpper(serverAction);
            double serverConf = g_lastAIConfidence; // dÃĐjÃ  0..1 via NormalizeStoredAIConfidenceInPlace

            string taAction = "HOLD", taReport = "";
            double taConf = 0.50, taAlign = 50.0, taCoh = 50.0;
            if(ComputeScientificMultiTFConsensus(_Symbol, taAction, taConf, taAlign, taCoh, taReport))
            {
               if(serverAction != "BUY" && serverAction != "SELL" && serverAction != "HOLD")
                  serverAction = "HOLD";
               if(serverConf <= 0.0) serverConf = 0.50;

               string finalAction = serverAction;
               double finalConf = serverConf;

               if(serverAction == taAction && taAction != "HOLD")
               {
                  finalAction = taAction;
                  finalConf = MathMin(0.99, serverConf * 0.55 + taConf * 0.45);
               }
               else if(taAction == "HOLD")
               {
                  // Confluence technique insuffisante => prioritÃĐ Ã  la prudence.
                  finalAction = "HOLD";
                  finalConf = MathMax(0.45, MathMin(serverConf, taConf));
               }
               else if(serverAction == "HOLD")
               {
                  // Le serveur hÃĐsite: n'autoriser BUY/SELL que si consensus technique fort.
                  if(taConf >= 0.72)
                  {
                     finalAction = taAction;
                     finalConf = MathMin(0.95, taConf * 0.90);
                  }
                  else
                  {
                     finalAction = "HOLD";
                     finalConf = MathMax(0.45, taConf * 0.85);
                  }
               }
               else
               {
                  // Conflit serveur vs technique => neutraliser pour ÃĐviter des entrÃĐes non robustes.
                  finalAction = "HOLD";
                  finalConf = MathMax(0.45, MathMin(serverConf, taConf));
               }

               g_lastAIAction = finalAction;
               g_lastAIConfidence = finalConf;
               NormalizeStoredAIConfidenceInPlace();
               g_lastAIAlignment = DoubleToString(taAlign, 1) + "%";
               g_lastAICoherence = DoubleToString(taCoh, 1) + "%";

               static datetime lastTaLog = 0;
               datetime nowTa = TimeCurrent();
               if(nowTa - lastTaLog >= 20)
               {
                  Print("ð§  IA+TA VALIDATION ", _Symbol,
                        " | Serveur=", serverAction, "(", DoubleToString(serverConf*100.0, 1), "%)",
                        " | TA=", taAction, "(", DoubleToString(taConf*100.0, 1), "%)",
                        " | Final=", g_lastAIAction, "(", DoubleToString(g_lastAIConfidence*100.0, 1), "%)",
                        " | Align=", g_lastAIAlignment, " | Coh=", g_lastAICoherence,
                        " | ", taReport);
                  lastTaLog = nowTa;
               }
            }

            g_lastAIUpdate = TimeCurrent();
            g_aiConnected = true;
            
            Print("? IA MISE Ã JOUR: ", g_lastAIAction, " | ", DoubleToString(g_lastAIConfidence*100,1), "% | ", g_lastAIAlignment, " | ", g_lastAICoherence);
            
            return true;
         }
      }
   }
   else
   {
      Print("? ERREUR IA: HTTP ", res);
      g_aiConnected = false;
      
      // FALLBACK: Le fallback sera gÃĐrÃĐ par OnTick directement
      // GenerateFallbackAIDecision(); // DÃĐplacÃĐ dans OnTick
   }
   
   return false;
}

bool ComputeScientificMultiTFConsensus(const string symbol, string &actionOut, double &confidenceOut, double &alignmentOut, double &coherenceOut, string &reportOut)
{
   ENUM_TIMEFRAMES tfs[6] = {PERIOD_D1, PERIOD_H4, PERIOD_H1, PERIOD_M15, PERIOD_M5, PERIOD_M1};
   double weights[6]      = {0.26,      0.20,      0.18,      0.14,       0.12,      0.10};

   double buyScore = 0.0, sellScore = 0.0, holdScore = 0.0;
   double totalWeight = 0.0;
   int validTf = 0;
   int alignedTf = 0;

   for(int k = 0; k < 6; k++)
   {
      ENUM_TIMEFRAMES tf = tfs[k];
      double w = weights[k];
      MqlRates rr[];
      ArraySetAsSeries(rr, false); // oldest -> newest
      int copied = CopyRates(symbol, tf, 0, 260, rr);
      if(copied < 220)
         continue;

      int idx = copied - 1;
      int idxPrev = copied - 2;
      if(idxPrev < 1) continue;

      double ema21 = ComputeEMA(rr, 21, idx);
      double ema50 = ComputeEMA(rr, 50, idx);
      double ema200 = ComputeEMA(rr, 200, idx);
      double ema200Prev = ComputeEMA(rr, 200, idxPrev);
      double rsi14 = ComputeRSI(rr, 14, idx);
      double macdNow = ComputeMACD(rr, 12, 26, 9, idx);
      double macdPrev = ComputeMACD(rr, 12, 26, 9, idxPrev);

      double closeNow = rr[idx].close;
      if(closeNow <= 0.0) continue;

      double tfBuy = 0.0, tfSell = 0.0, tfHold = 0.0;

      // Trend structure: prix + empilement EMA + pente long terme
      bool trendUp = (closeNow > ema50 && ema21 > ema50 && ema50 > ema200 && ema200 >= ema200Prev);
      bool trendDn = (closeNow < ema50 && ema21 < ema50 && ema50 < ema200 && ema200 <= ema200Prev);
      if(trendUp) tfBuy += 1.25;
      else if(trendDn) tfSell += 1.25;
      else tfHold += 0.70;

      // Momentum RSI
      if(rsi14 >= 55.0 && rsi14 <= 72.0) tfBuy += 0.75;
      else if(rsi14 <= 45.0 && rsi14 >= 28.0) tfSell += 0.75;
      else tfHold += 0.55;

      // MACD direction + acceleration
      if(macdNow > 0.0 && macdNow >= macdPrev) tfBuy += 0.70;
      else if(macdNow < 0.0 && macdNow <= macdPrev) tfSell += 0.70;
      else tfHold += 0.40;

      // Volatility regime (ÃĐviter dÃĐcisions fortes en compression extrÃŠme)
      double atrLike = 0.0;
      for(int i = idx - 14; i <= idx; i++)
         atrLike += (rr[i].high - rr[i].low);
      atrLike /= 15.0;
      double atrPct = (atrLike / closeNow) * 100.0;
      if(atrPct < 0.010)
         tfHold += 0.55;

      buyScore += tfBuy * w;
      sellScore += tfSell * w;
      holdScore += tfHold * w;
      totalWeight += w;
      validTf++;

      if((tfBuy > tfSell && tfBuy > tfHold) || (tfSell > tfBuy && tfSell > tfHold))
         alignedTf++;
   }

   if(validTf <= 0 || totalWeight <= 0.0)
   {
      actionOut = "HOLD";
      confidenceOut = 0.50;
      alignmentOut = 50.0;
      coherenceOut = 45.0;
      reportOut = "consensus=NO_DATA";
      return false;
   }

   double total = buyScore + sellScore + holdScore;
   if(total <= 0.0) total = 1.0;
   double pBuy = buyScore / total;
   double pSell = sellScore / total;
   double pHold = holdScore / total;

   double top = pBuy;
   string topAction = "BUY";
   if(pSell > top) { top = pSell; topAction = "SELL"; }
   if(pHold > top) { top = pHold; topAction = "HOLD"; }

   double second = 0.0;
   if(topAction == "BUY") second = MathMax(pSell, pHold);
   else if(topAction == "SELL") second = MathMax(pBuy, pHold);
   else second = MathMax(pBuy, pSell);

   double edge = top - second;
   double coherence = (validTf > 0) ? (100.0 * alignedTf / validTf) : 50.0;
   double confidence = MathMin(0.95, MathMax(0.45, top * 0.75 + edge * 0.90));

   // Garde-fou scientifique: si l'ÃĐcart est faible, forcer HOLD.
   if(edge < 0.10 || top < 0.42)
      topAction = "HOLD";

   actionOut = topAction;
   confidenceOut = confidence;
   alignmentOut = MathMin(99.0, MathMax(40.0, top * 100.0));
   coherenceOut = MathMin(99.0, MathMax(35.0, coherence));
   reportOut = "D1-M1 pBUY=" + DoubleToString(pBuy * 100.0, 1) +
               "% pSELL=" + DoubleToString(pSell * 100.0, 1) +
               "% pHOLD=" + DoubleToString(pHold * 100.0, 1) +
               "% edge=" + DoubleToString(edge * 100.0, 1) + "%";
   return true;
}

void ApplyMTFConsensusToAIDecision(const bool force = false)
{
   datetime now = TimeCurrent();
   int refreshSec = MathMax(2, MTFConsensusRefreshSeconds);
   if(!force && g_lastAIMTFUpdate > 0 && (now - g_lastAIMTFUpdate) < refreshSec)
      return;

   string action = "HOLD";
   double conf = 0.50;
   double align = 50.0, coh = 50.0;
   string report = "";
   bool ok = ComputeScientificMultiTFConsensus(_Symbol, action, conf, align, coh, report);
   if(!ok) return;

   g_lastAIMTFAction = action;
   g_lastAIMTFConfidence = conf;
   g_lastAIMTFReport = report;
   g_lastAIMTFUpdate = now;

   // Si actif, le consensus MTF devient la direction IA reelle utilisee par le robot.
   if(UseMTFConsensusAsPrimaryAI)
   {
      g_lastAIAction = action;
      g_lastAIConfidence = conf;
      g_lastAIAlignment = DoubleToString(align, 1) + "%";
      g_lastAICoherence = DoubleToString(coh, 1) + "%";
      g_lastAIUpdate = now;
   }
}

//| GÃĐnÃĐrer une dÃĐcision IA de fallback basÃĐe sur les donnÃĐes de marchÃĐ |
void GenerateFallbackAIDecision()
{
   string action = "HOLD";
   double confidence = 0.5;
   double alignment = 50.0;
   double coherence = 50.0;
   string report = "";

   ComputeScientificMultiTFConsensus(_Symbol, action, confidence, alignment, coherence, report);

   g_lastAIAction = action;
   g_lastAIConfidence = confidence;
   g_lastAIAlignment = DoubleToString(alignment, 1) + "%";
   g_lastAICoherence = DoubleToString(coherence, 1) + "%";
   g_lastAIUpdate = TimeCurrent();
   
   Print("?? IA SMC-EMA SCIENTIFIQUE - Action: ", action,
         " | Conf: ", FormatAIConfidencePct(), " | Align: ",
         g_lastAIAlignment, " | CohÃĐr: ", g_lastAICoherence,
         " | ", report);
}

// Petit helper de debug pour inspecter rapidement la derniÃĻre dÃĐcision IA
void DebugPrintAIDecision()
{
   Print("?? DEBUG IA - Symbole: ", _Symbol,
         " | Action: ", g_lastAIAction,
         " | Confiance: ", FormatAIConfidencePct(),
         " | Alignement: ", g_lastAIAlignment,
         " | CohÃĐrence: ", g_lastAICoherence);
}

//| DÃTECTION SWING HIGH/LOW SPÃCIALE BOOM/CRASH (LOGIQUE TRADING) |
bool DetectBoomCrashSwingPoints()
{
   MqlRates rates[];
   ArraySetAsSeries(rates, true);
   int barsToAnalyze = 100;
   
   if(CopyRates(_Symbol, PERIOD_M1, 0, barsToAnalyze, rates) < barsToAnalyze)
      return false;
   
   // Nettoyer les anciens objets Boom/Crash
   ObjectsDeleteAll(0, "SMC_BC_SH_");
   ObjectsDeleteAll(0, "SMC_BC_SL_");
   
   double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   double avgMove = 0;
   
   // Calculer le mouvement moyen pour dÃĐtecter les spikes
   for(int i = 1; i < barsToAnalyze; i++)
   {
      double move = MathAbs(rates[i-1].close - rates[i].close);
      avgMove += move;
   }
   avgMove /= (barsToAnalyze - 1);
   
   // Seuil de spike (8x le mouvement normal pour Boom/Crash)
   double spikeThreshold = avgMove * 8.0;
   
   // RÃĐduire la frÃĐquence des logs BOOM/CRASH pour ÃĐviter la superposition
   static datetime lastBoomCrashLog = 0;
   if(TimeCurrent() - lastBoomCrashLog >= 120) // Log toutes les 2 minutes maximum
   {
      Print("?? BOOM/CRASH - ", _Symbol, " | Mouvement: ", DoubleToString(avgMove, _Digits), " | Seuil spike: ", DoubleToString(spikeThreshold, _Digits));
      lastBoomCrashLog = TimeCurrent();
   }
   
   bool isBoom = (StringFind(_Symbol, "Boom") >= 0);
   bool isCrash = (StringFind(_Symbol, "Crash") >= 0);
   
   // DÃTECTION DES SPIKES D'ABORD
   for(int i = 5; i < barsToAnalyze - 5; i++)
   {
      double priceChange = MathAbs(rates[i].close - rates[i-1].close);
      bool isSpike = (priceChange > spikeThreshold);
      
      if(!isSpike) continue;
      
      // Limiter les logs de spike pour ÃĐviter la surcharge
      static datetime lastSpikeLog = 0;
      if(TimeCurrent() - lastSpikeLog >= 30) // Log toutes les 30 secondes maximum
      {
         Print("?? SPIKE DÃTECTÃ - ", _Symbol, " | Barre ", i, " | Mouvement: ", DoubleToString(priceChange, _Digits), " | Type: ", isBoom ? "BOOM" : "CRASH");
         lastSpikeLog = TimeCurrent();
      }
      
      // LOGIQUE BOOM : SH APRÃS SPIKE (pour annoncer le sell)
      if(isBoom)
      {
         // Chercher le Swing High APRÃS le spike (confirmation de retournement)
         for(int j = MathMax(0, i - 8); j <= MathMax(0, i - 2); j++) // 2-8 barres aprÃĻs le spike
         {
            double currentHigh = rates[j].high;
            
            // VÃĐrifier si c'est un swing high local
            bool isPotentialSH = true;
            for(int k = MathMax(0, j - 3); k <= MathMin(barsToAnalyze - 1, j + 3); k++)
            {
               if(k != j && rates[k].high >= currentHigh)
               {
                  isPotentialSH = false;
                  break;
               }
            }
            
            // Confirmation : le SH doit ÃŠtre plus bas que le pic du spike
            if(isPotentialSH && currentHigh < rates[i].high)
            {
               // Confirmer que c'est bien aprÃĻs le spike
               bool confirmedAfterSpike = true;
               for(int k = j + 1; k <= MathMin(barsToAnalyze - 1, j + 3); k++)
               {
                  if(rates[k].high > currentHigh)
                  {
                     confirmedAfterSpike = false;
                     break;
                  }
               }
               
               if(confirmedAfterSpike)
               {
                  string shName = "SMC_BC_SH_" + IntegerToString(j);
                  if(ObjectCreate(0, shName, OBJ_ARROW, 0, rates[j].time, currentHigh))
                  {
                     ObjectSetInteger(0, shName, OBJPROP_COLOR, clrRed);
                     ObjectSetInteger(0, shName, OBJPROP_STYLE, STYLE_SOLID);
                     ObjectSetInteger(0, shName, OBJPROP_WIDTH, 6);
                     ObjectSetInteger(0, shName, OBJPROP_ARROWCODE, 233);
                     ObjectSetString(0, shName, OBJPROP_TOOLTIP, 
                                   "SH APRÃS SPIKE BOOM (Signal SELL): " + DoubleToString(currentHigh, _Digits) + " | Spike: " + DoubleToString(rates[i].high, _Digits));
                     
                     // Ligne horizontale
                     string lineName = shName + "_Line";
                     if(ObjectCreate(0, lineName, OBJ_HLINE, 0, rates[j].time, currentHigh))
                     {
                        ObjectSetInteger(0, lineName, OBJPROP_COLOR, clrRed);
                        ObjectSetInteger(0, lineName, OBJPROP_STYLE, STYLE_DASH);
                        ObjectSetInteger(0, lineName, OBJPROP_WIDTH, 3);
                        ObjectSetInteger(0, lineName, OBJPROP_BACK, true);
                     }
                     
                     Print("?? SH APRÃS SPIKE BOOM (Signal SELL) - Prix: ", DoubleToString(currentHigh, _Digits), " | Spike: ", DoubleToString(rates[i].high, _Digits), " | Time: ", TimeToString(rates[j].time));
                  }
                  break; // Prendre le premier SH valide aprÃĻs le spike
               }
            }
         }
      }
      
      // LOGIQUE CRASH : SL AVANT SPIKE (pour annoncer le crash)
      if(isCrash)
      {
         // Chercher le Swing Low AVANT le spike (prÃĐparation du crash)
         for(int j = i + 2; j <= MathMin(barsToAnalyze - 1, i + 8); j++) // 2-8 barres avant le spike
         {
            double currentLow = rates[j].low;
            
            // VÃĐrifier si c'est un swing low local
            bool isPotentialSL = true;
            for(int k = MathMax(0, j - 3); k <= MathMin(barsToAnalyze - 1, j + 3); k++)
            {
               if(k != j && rates[k].low <= currentLow)
               {
                  isPotentialSL = false;
                  break;
               }
            }
            
            // Confirmation : le SL doit ÃŠtre plus haut que le creux du spike
            if(isPotentialSL && currentLow > rates[i].low)
            {
               // Confirmer que c'est bien avant le spike
               bool confirmedBeforeSpike = true;
               for(int k = MathMax(0, j - 3); k <= j - 1; k++)
               {
                  if(rates[k].low < currentLow)
                  {
                     confirmedBeforeSpike = false;
                     break;
                  }
               }
               
               if(confirmedBeforeSpike)
               {
                  string slName = "SMC_BC_SL_" + IntegerToString(j);
                  if(ObjectCreate(0, slName, OBJ_ARROW, 0, rates[j].time, currentLow))
                  {
                     ObjectSetInteger(0, slName, OBJPROP_COLOR, clrBlue);
                     ObjectSetInteger(0, slName, OBJPROP_STYLE, STYLE_SOLID);
                     ObjectSetInteger(0, slName, OBJPROP_WIDTH, 6);
                     ObjectSetInteger(0, slName, OBJPROP_ARROWCODE, 234);
                     ObjectSetString(0, slName, OBJPROP_TOOLTIP, 
                                   "SL AVANT SPIKE CRASH (Signal CRASH): " + DoubleToString(currentLow, _Digits) + " | Spike: " + DoubleToString(rates[i].low, _Digits));
                     
                     // Ligne horizontale
                     string lineName = slName + "_Line";
                     if(ObjectCreate(0, lineName, OBJ_HLINE, 0, rates[j].time, currentLow))
                     {
                        ObjectSetInteger(0, lineName, OBJPROP_COLOR, clrBlue);
                        ObjectSetInteger(0, lineName, OBJPROP_STYLE, STYLE_DASH);
                        ObjectSetInteger(0, lineName, OBJPROP_WIDTH, 3);
                        ObjectSetInteger(0, lineName, OBJPROP_BACK, true);
                     }
                     
                     Print("?? SL AVANT SPIKE CRASH (Signal CRASH) - Prix: ", DoubleToString(currentLow, _Digits), " | Spike: ", DoubleToString(rates[i].low, _Digits), " | Time: ", TimeToString(rates[j].time));
                  }
                  break; // Prendre le premier SL valide avant le spike
               }
            }
         }
      }
   }
   
   return true;
}

//| DÃTECTION SWING HIGH/LOW NON-REPAINTING (ANTI-REPAINT)          |
struct SwingPoint {
   double price;
   datetime time;
   bool isHigh;
   int confirmedBar; // Barre oÃđ le swing est confirmÃĐ
};

SwingPoint swingPoints[100]; // Buffer pour stocker les SH/SL confirmÃĐs
int swingPointCount = 0;

//| DÃĐtecter les Swing High/Low sans repaint (confirmation requise)    |
bool DetectNonRepaintingSwingPoints()
{
   MqlRates rates[];
   ArraySetAsSeries(rates, true);
   int barsToAnalyze = 200;
   
   if(CopyRates(_Symbol, PERIOD_M1, 0, barsToAnalyze, rates) < barsToAnalyze)
      return false;
   
   // Nettoyer les anciens points non confirmÃĐs
   for(int i = 0; i < swingPointCount; i++)
   {
      if(swingPoints[i].confirmedBar > 10) // Garder seulement les 10 derniÃĻres barres
      {
         for(int j = i; j < swingPointCount - 1; j++)
            swingPoints[j] = swingPoints[j + 1];
         swingPointCount--;
         i--;
      }
   }
   
   // Analyser les barres pour dÃĐtecter les swings potentiels
   for(int i = 10; i < barsToAnalyze - 10; i++) // Ãviter les bords
   {
      // DÃTECTION SWING HIGH (NON-REPAINTING)
      bool isPotentialSH = true;
      double currentHigh = rates[i].high;
      
      // VÃĐrifier si c'est le plus haut sur au moins 5 barres de chaque cÃītÃĐ
      for(int j = MathMax(0, i - 5); j <= MathMin(barsToAnalyze - 1, i + 5); j++)
      {
         if(j != i && rates[j].high >= currentHigh)
         {
            isPotentialSH = false;
            break;
         }
      }
      
      // CONFIRMATION SWING HIGH : Attendre 3 barres aprÃĻs le point potentiel
      if(isPotentialSH && i >= 13) // Assez de barres pour confirmer
      {
         bool confirmed = true;
         
         // VÃĐrifier que les 3 barres suivantes n'ont pas dÃĐpassÃĐ ce high
         for(int j = i - 3; j >= MathMax(0, i - 5); j--) // 3 barres aprÃĻs le point
         {
            if(rates[j].high > currentHigh)
            {
               confirmed = false;
               break;
            }
         }
         
         // VÃĐrifier que ce n'est pas dÃĐjÃ  enregistrÃĐ
         if(confirmed)
         {
            bool alreadyRecorded = false;
            for(int k = 0; k < swingPointCount; k++)
            {
               if(swingPoints[k].isHigh && 
                  MathAbs(swingPoints[k].price - currentHigh) < SymbolInfoDouble(_Symbol, SYMBOL_POINT) * 5 &&
                  MathAbs(swingPoints[k].time - rates[i].time) <= 300) // 5 minutes tolerance
               {
                  alreadyRecorded = true;
                  break;
               }
            }
            
            if(!alreadyRecorded && swingPointCount < 100)
            {
               swingPoints[swingPointCount].price = currentHigh;
               swingPoints[swingPointCount].time = rates[i].time;
               swingPoints[swingPointCount].isHigh = true;
               swingPoints[swingPointCount].confirmedBar = i;
               swingPointCount++;
               
   // RÃĐduire la frÃĐquence des logs SWING pour ÃĐviter la superposition
   static datetime lastSwingLog = 0;
   if(TimeCurrent() - lastSwingLog >= 60) // Log toutes les 60 secondes maximum
   {
      Print("?? SWING HIGH CONFIRMÃ - ", _Symbol, " | Prix: ", DoubleToString(currentHigh, _Digits), " | Time: ", TimeToString(rates[i].time));
      lastSwingLog = TimeCurrent();
   }
            }
         }
      }
      
      // DÃTECTION SWING LOW (NON-REPAINTING)
      bool isPotentialSL = true;
      double currentLow = rates[i].low;
      
      // VÃĐrifier si c'est le plus bas sur au moins 5 barres de chaque cÃītÃĐ
      for(int j = MathMax(0, i - 5); j <= MathMin(barsToAnalyze - 1, i + 5); j++)
      {
         if(j != i && rates[j].low <= currentLow)
         {
            isPotentialSL = false;
            break;
         }
      }
      
      // CONFIRMATION SWING LOW : Attendre 3 barres aprÃĻs le point potentiel
      if(isPotentialSL && i >= 13) // Assez de barres pour confirmer
      {
         bool confirmed = true;
         
         // VÃĐrifier que les 3 barres suivantes n'ont pas dÃĐpassÃĐ ce low
         for(int j = i - 3; j >= MathMax(0, i - 5); j--) // 3 barres aprÃĻs le point
         {
            if(rates[j].low < currentLow)
            {
               confirmed = false;
               break;
            }
         }
         
         // VÃĐrifier que ce n'est pas dÃĐjÃ  enregistrÃĐ
         if(confirmed)
         {
            bool alreadyRecorded = false;
            for(int k = 0; k < swingPointCount; k++)
            {
               if(!swingPoints[k].isHigh && 
                  MathAbs(swingPoints[k].price - currentLow) < SymbolInfoDouble(_Symbol, SYMBOL_POINT) * 5 &&
                  MathAbs(swingPoints[k].time - rates[i].time) <= 300) // 5 minutes tolerance
               {
                  alreadyRecorded = true;
                  break;
               }
            }
            
            if(!alreadyRecorded && swingPointCount < 100)
            {
               swingPoints[swingPointCount].price = currentLow;
               swingPoints[swingPointCount].time = rates[i].time;
               swingPoints[swingPointCount].isHigh = false;
               swingPoints[swingPointCount].confirmedBar = i;
               swingPointCount++;
               
   // RÃĐduire la frÃĐquence des logs SWING pour ÃĐviter la superposition
   static datetime lastSwingLog = 0;
   if(TimeCurrent() - lastSwingLog >= 60) // Log toutes les 60 secondes maximum
   {
      Print("?? SWING LOW CONFIRMÃ - ", _Symbol, " | Prix: ", DoubleToString(currentLow, _Digits), " | Time: ", TimeToString(rates[i].time));
      lastSwingLog = TimeCurrent();
   }
            }
         }
      }
   }
   
   return true;
}

//| Obtenir les derniers Swing High/Low confirmÃĐs (non-repainting)     |
void GetLatestConfirmedSwings(double &lastSH, datetime &lastSHTime, double &lastSL, datetime &lastSLTime)
{
   lastSH = 0;
   lastSHTime = 0;
   lastSL = 999999;
   lastSLTime = 0;
   
   // Parcourir tous les points pour trouver les plus rÃĐcents
   for(int i = 0; i < swingPointCount; i++)
   {
      if(swingPoints[i].isHigh && swingPoints[i].time > lastSHTime)
      {
         lastSH = swingPoints[i].price;
         lastSHTime = swingPoints[i].time;
      }
      else if(!swingPoints[i].isHigh && swingPoints[i].time > lastSLTime)
      {
         lastSL = swingPoints[i].price;
         lastSLTime = swingPoints[i].time;
      }
   }
}

//| Dessiner les Swing Points confirmÃĐs (non-repainting)              |
// LimitÃĐ Ã  25 points pour ÃĐviter trop d'objets graphiques ? dÃĐtachement
#define MAX_SWING_POINTS_DRAWN 25

void DrawConfirmedSwingPoints()
{
   long chId = ChartID();
   if(chId <= 0) return;
   
   ObjectsDeleteAll(chId, "SMC_Confirmed_SH_");
   ObjectsDeleteAll(chId, "SMC_Confirmed_SL_");
   
   // Limiter le nombre de points affichÃĐs pour ÃĐviter saturation objets ? dÃĐtachement
   int toDraw = MathMin(swingPointCount, MAX_SWING_POINTS_DRAWN);
   int futureBars = (SMCChannelFutureBars > 0 && SMCChannelFutureBars <= 5000) ? SMCChannelFutureBars : 5000;
   
   for(int i = 0; i < toDraw; i++)
   {
      if(!MathIsValidNumber(swingPoints[i].price) || swingPoints[i].time <= 0) continue;
      
      string objName;
      color objColor;
      int objCode;
      
      if(swingPoints[i].isHigh)
      {
         objName = "SMC_Confirmed_SH_" + IntegerToString(i);
         objColor = clrRed;
         objCode = 233;
      }
      else
      {
         objName = "SMC_Confirmed_SL_" + IntegerToString(i);
         objColor = clrBlue;
         objCode = 234;
      }
      
      if(ObjectCreate(chId, objName, OBJ_ARROW, 0, swingPoints[i].time, swingPoints[i].price))
      {
         ObjectSetInteger(chId, objName, OBJPROP_COLOR, objColor);
         ObjectSetInteger(chId, objName, OBJPROP_STYLE, STYLE_SOLID);
         ObjectSetInteger(chId, objName, OBJPROP_WIDTH, 4);
         ObjectSetInteger(chId, objName, OBJPROP_ARROWCODE, objCode);
         ObjectSetString(chId, objName, OBJPROP_TOOLTIP, 
                       swingPoints[i].isHigh ? "SH ConfirmÃĐ: " + DoubleToString(swingPoints[i].price, _Digits) 
                                            : "SL ConfirmÃĐ: " + DoubleToString(swingPoints[i].price, _Digits));
         
         string lineName = objName + "_Line";
         datetime startTime = TimeCurrent();
         datetime endTime = startTime + (datetime)((long)futureBars * 60);
         
         if(MathIsValidNumber(swingPoints[i].price) && 
            ObjectCreate(chId, lineName, OBJ_TREND, 0, startTime, swingPoints[i].price, endTime, swingPoints[i].price))
         {
            ObjectSetInteger(chId, lineName, OBJPROP_COLOR, objColor);
            ObjectSetInteger(chId, lineName, OBJPROP_STYLE, STYLE_DASH);
            ObjectSetInteger(chId, lineName, OBJPROP_WIDTH, 2);
            ObjectSetInteger(chId, lineName, OBJPROP_BACK, true);
            ObjectSetInteger(chId, lineName, OBJPROP_RAY_RIGHT, true);
            ObjectSetInteger(chId, lineName, OBJPROP_RAY_LEFT, false);
         }
      }
   }
}

//| VÃRIFICATION ET EXÃCUTION IMMÃDIATE DU DERIV ARROW               |
void CheckAndExecuteDerivArrowTrade()
{
   // Expiration du mode recovery M5->flÃĻche (Boom BUY).
   if(g_boomM5BuyArrowRecoveryArmed && g_lastBoomM5BuyTouchTime > 0)
   {
      if((TimeCurrent() - g_lastBoomM5BuyTouchTime) > M5TouchArrowRecoveryWindowSec)
      {
         g_boomM5BuyArrowRecoveryArmed = false;
         g_lastBoomM5BuyTouchTime = 0;
      }
   }

   // DEBUG: Log pour voir si la fonction est appelÃĐe
   static datetime lastLog = 0;
   if(TimeCurrent() - lastLog >= 10) // Log toutes les 10 secondes maximum
   {
      Print("?? DEBUG - CheckAndExecuteDerivArrowTrade appelÃĐe pour: ", _Symbol, " | Time: ", TimeToString(TimeCurrent(), TIME_SECONDS));
      lastLog = TimeCurrent();
   }
   
   // RÃGLE FONDAMENTALE: Boom/Crash + Volatility (avec conditions)
   ENUM_SYMBOL_CATEGORY cat = SMC_GetSymbolCategory(_Symbol);
   string catStr = "";
   switch(cat)
   {
      case SYM_BOOM_CRASH: catStr = "BOOM_CRASH"; break;
      case SYM_VOLATILITY: catStr = "VOLATILITY"; break;
      case SYM_WELTRADE_SYNTH: catStr = "WELTRADE_SYNTH"; break;
      case SYM_FOREX: catStr = "FOREX"; break;
      default: catStr = "UNKNOWN"; break;
   }
   
   // Autoriser Boom/Crash ET Volatility (avec conditions diffÃĐrentes)
   bool isBoomCrash = (cat == SYM_BOOM_CRASH);
   bool isVolatility = (cat == SYM_VOLATILITY || cat == SYM_WELTRADE_SYNTH);
   
   if(!isBoomCrash && !isVolatility)
   {
      return; // Ignorer les autres symboles
   }

   // Boom/Crash: une seule position Ã  la fois (attendre spike captÃĐ puis nouveau signal).
   // Volatility: garder comportement existant (jusqu'Ã  2 positions).
   int posCount = CountPositionsForSymbol(_Symbol);
   if(isBoomCrash && posCount >= 1)
      return;
   if(isVolatility && posCount >= 2)
   {
      Print("?? DERIV ARROW - Limite positions atteinte (>=2) sur ", _Symbol, " -> skip");
      return;
   }
   
   // Confirmer le type de symbole
   // RÃĐduire la frÃĐquence des logs DEBUG de symbole pour ÃĐviter la surcharge
   static datetime lastDebugSymbolLog = 0;
   if(TimeCurrent() - lastDebugSymbolLog >= 300) // Log toutes les 5 minutes maximum
   {
      Print("? DEBUG - Symbole validÃĐ: ", _Symbol, " = ", catStr);
      lastDebugSymbolLog = TimeCurrent();
   }
   
   // VALIDATION IA: Boom/Crash = uniquement si IA serveur connectÃĐe et non HOLD
   if(UseAIServer && isBoomCrash && !g_aiConnected)
      return;
   if(UseAIServer && (g_lastAIAction == "HOLD" || g_lastAIAction == "hold"))
   {
      // Weltrade: si escalier M1 + confiance serveur âĨ seuil Weltrade, continuer (flÃĻche / logique locale)
      bool bypassHoldPreArrow = false;
      if(IsWeltradeGainSynthSymbol(_Symbol))
      {
         double c = g_lastAIConfidence * 100.0;
         if(c >= StairEntryWeltradeMinAIConfidencePercent && IsSyntheticStairPatternM1("BUY"))
            bypassHoldPreArrow = true;
      }
      else if(IsWeltradePainSynthSymbol(_Symbol))
      {
         double c = g_lastAIConfidence * 100.0;
         if(c >= StairEntryWeltradeMinAIConfidencePercent && IsSyntheticStairPatternM1("SELL"))
            bypassHoldPreArrow = true;
      }
      if(!bypassHoldPreArrow)
      {
         Print("?? TRADE BLOQUÃ - IA en HOLD sur ", _Symbol);
         return;
      }
      static datetime s_lastWeltradeHoldBypassLog = 0;
      if(TimeCurrent() - s_lastWeltradeHoldBypassLog >= 25)
      {
         Print("â WELTRADE+STAIR - Bypass HOLD prÃĐ-flÃĻche (escalier M1 + conf âĨ ",
               DoubleToString(StairEntryWeltradeMinAIConfidencePercent, 1), "%) | ", _Symbol);
         s_lastWeltradeHoldBypassLog = TimeCurrent();
      }
   }
   
   // NOUVEAU: DÃTECTION DES FLÃCHES DERIV ARROW EXISTANTES
   // Boom/Crash: armer l'entrÃĐe quand le prix touche la future protected zone (low=Boom, high=Crash)
   if(isBoomCrash && RequireFutureProtectTouchForBoomCrashDerivArrow)
   {
      bool isBoom = (StringFind(_Symbol, "Boom") >= 0);
      bool isCrash = (StringFind(_Symbol, "Crash") >= 0);
      datetime now = TimeCurrent();

      // Expirer les arming si trop vieux
      if(g_boomFutureProtectTouchTime > 0 && (now - g_boomFutureProtectTouchTime) > FutureProtectTouchArmSeconds)
      {
         g_boomFutureProtectTouchTime = 0;
         g_boomFutureProtectTouchLevel = 0.0;
      }
      if(g_crashFutureProtectTouchTime > 0 && (now - g_crashFutureProtectTouchTime) > FutureProtectTouchArmSeconds)
      {
         g_crashFutureProtectTouchTime = 0;
         g_crashFutureProtectTouchLevel = 0.0;
      }

      if(UseSR20TouchEntryForBoomCrashDerivArrow)
      {
         if(g_boomSR20TouchTime > 0 && (now - g_boomSR20TouchTime) > FutureProtectTouchArmSeconds)
         {
            g_boomSR20TouchTime = 0;
            g_boomSR20TouchLevel = 0.0;
         }
         if(g_crashSR20TouchTime > 0 && (now - g_crashSR20TouchTime) > FutureProtectTouchArmSeconds)
         {
            g_crashSR20TouchTime = 0;
            g_crashSR20TouchLevel = 0.0;
         }
      }

      // Throttle calcul touch (ÃĐvite d'appeler GetFutureProtectedPointLevels Ã  chaque tick)
      if(g_lastFutureProtectTouchCalc == 0 || (now - g_lastFutureProtectTouchCalc) >= FutureProtectTouchCheckIntervalSec)
      {
         double futureSupport = 0.0, futureResistance = 0.0;
         bool hasFutureLevels = GetFutureProtectedPointLevels(futureSupport, futureResistance);
         if(hasFutureLevels && (isBoom || isCrash))
         {
            double atrM15 = GetATRValue(PERIOD_M15, 14);
            if(atrM15 <= 0.0)
               atrM15 = SymbolInfoDouble(_Symbol, SYMBOL_BID) * 0.002; // fallback
            double tol = atrM15 * FutureProtectTouchToleranceATRMult;
            if(tol <= 0.0)
               tol = SymbolInfoDouble(_Symbol, SYMBOL_POINT) * 100.0;

            double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
            double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);

            if(isBoom && futureSupport > 0.0)
            {
               bool touchedLow = (bid >= futureSupport - tol && bid <= futureSupport + tol);
               if(touchedLow)
               {
                  g_boomFutureProtectTouchTime = now;
                  g_boomFutureProtectTouchLevel = futureSupport;
                  Print("?? BOOM - Touch future protect low armÃĐ | level=", DoubleToString(futureSupport, _Digits),
                        " | tol=", DoubleToString(tol, _Digits));
               }
            }

            if(isCrash && futureResistance > 0.0)
            {
               bool touchedHigh = (ask >= futureResistance - tol && ask <= futureResistance + tol);
               if(touchedHigh)
               {
                  g_crashFutureProtectTouchTime = now;
                  g_crashFutureProtectTouchLevel = futureResistance;
                  Print("?? CRASH - Touch future protect high armÃĐ | level=", DoubleToString(futureResistance, _Digits),
                        " | tol=", DoubleToString(tol, _Digits));
               }
            }

           // SR20 support/resistance: alternative Ã  future protect
           if(UseSR20TouchEntryForBoomCrashDerivArrow)
           {
              double srSupport = GetSupportLevel(20);     // support 20 bars (M1)
              double srResistance = GetResistanceLevel(20); // resistance 20 bars (M1)
              if(srSupport > 0.0 || srResistance > 0.0)
              {
                 double atrSR = GetATRValue(PERIOD_M1, SR20TouchATRPeriod);
                 if(atrSR <= 0.0) atrSR = SymbolInfoDouble(_Symbol, SYMBOL_BID) * 0.002;
                 double srTol = atrSR * SR20TouchToleranceATRMult;
                 if(srTol <= 0.0) srTol = SymbolInfoDouble(_Symbol, SYMBOL_POINT) * 100.0;

                 double bidNow = SymbolInfoDouble(_Symbol, SYMBOL_BID);
                 double askNow = SymbolInfoDouble(_Symbol, SYMBOL_ASK);

                 if(isBoom && srSupport > 0.0)
                 {
                    bool touchedSR = (bidNow >= srSupport - srTol && bidNow <= srSupport + srTol);
                    if(touchedSR)
                    {
                       g_boomSR20TouchTime = now;
                       g_boomSR20TouchLevel = srSupport;
                       Print("?? BOOM - Touch SR20 support armÃĐ | level=", DoubleToString(srSupport, _Digits),
                             " | tol=", DoubleToString(srTol, _Digits));
                    }
                 }
                 if(isCrash && srResistance > 0.0)
                 {
                    bool touchedSR = (askNow >= srResistance - srTol && askNow <= srResistance + srTol);
                    if(touchedSR)
                    {
                       g_crashSR20TouchTime = now;
                       g_crashSR20TouchLevel = srResistance;
                       Print("?? CRASH - Touch SR20 resistance armÃĐ | level=", DoubleToString(srResistance, _Digits),
                             " | tol=", DoubleToString(srTol, _Digits));
                    }
                 }
              }
           }
         }
         g_lastFutureProtectTouchCalc = now;
      }
   }

   // Boom/Crash en mode touch-entry:
   // - entrÃĐe marchÃĐ au touch future protect (low=Boom / high=Crash)
   // - aucune autre entrÃĐe dans cette fonction (sortie scalp gÃĐrÃĐe ailleurs sur flÃĻche)
   if(isBoomCrash && RequireFutureProtectTouchForBoomCrashDerivArrow)
   {
      datetime now = TimeCurrent();
      bool isBoomSym = (StringFind(_Symbol, "Boom") >= 0);
      bool isCrashSym = (StringFind(_Symbol, "Crash") >= 0);

      bool armedBoomFuture = isBoomSym && g_boomFutureProtectTouchTime > 0 &&
                              (now - g_boomFutureProtectTouchTime) <= FutureProtectTouchArmSeconds;
      bool armedCrashFuture = isCrashSym && g_crashFutureProtectTouchTime > 0 &&
                               (now - g_crashFutureProtectTouchTime) <= FutureProtectTouchArmSeconds;

      bool armedBoomSR20 = false;
      bool armedCrashSR20 = false;
      if(UseSR20TouchEntryForBoomCrashDerivArrow)
      {
         armedBoomSR20 = isBoomSym && g_boomSR20TouchTime > 0 &&
                         (now - g_boomSR20TouchTime) <= FutureProtectTouchArmSeconds;
         armedCrashSR20 = isCrashSym && g_crashSR20TouchTime > 0 &&
                          (now - g_crashSR20TouchTime) <= FutureProtectTouchArmSeconds;
      }

      bool armedBoom = armedBoomFuture || armedBoomSR20;
      bool armedCrash = armedCrashFuture || armedCrashSR20;

      // Cooldown anti-boucle sur la mÃŠme zone
      if(armedBoom && g_boomTouchReentryCooldownUntil > 0 && now < g_boomTouchReentryCooldownUntil)
         return;
      if(armedCrash && g_crashTouchReentryCooldownUntil > 0 && now < g_crashTouchReentryCooldownUntil)
         return;

      if(armedBoom || armedCrash)
      {
         // Ne pas consommer l'arm si on est en zone de correction: on retentera sur le prochain tick.
         if(IsInEquilibriumCorrectionZone())
            return;

         if(!HasAnyExposureForSymbol(_Symbol))
         {
            string dir = armedBoom ? "BUY" : "SELL";
            Print("?? TOUCH (future protect / SR20) => entrÃĐe marchÃĐ immÃĐdiate (", dir, ") sur ", _Symbol,
                  " | level=", armedBoom
                                 ? DoubleToString((armedBoomFuture ? g_boomFutureProtectTouchLevel : g_boomSR20TouchLevel), _Digits)
                                 : DoubleToString((armedCrashFuture ? g_crashFutureProtectTouchLevel : g_crashSR20TouchLevel), _Digits));
            ExecuteDerivArrowTrade(dir); // garde toutes les validations existantes (IA/ML/zones/anti-dup)
         }
      }

      // Consommer l'arm: attendre un nouveau touch pour une nouvelle entrÃĐe
      g_boomFutureProtectTouchTime = 0;
      g_crashFutureProtectTouchTime = 0;
      g_boomFutureProtectTouchLevel = 0.0;
      g_crashFutureProtectTouchLevel = 0.0;

      g_boomSR20TouchTime = 0;
      g_crashSR20TouchTime = 0;
      g_boomSR20TouchLevel = 0.0;
      g_crashSR20TouchLevel = 0.0;

      return;
   }

   string arrowDirection = "";
   bool hasDerivArrow = GetDerivArrowDirection(arrowDirection);
   
   if(hasDerivArrow)
   {
      Print("?? FLÃCHE DERIV ARROW DÃTECTÃE - Direction: ", arrowDirection, " sur ", _Symbol);
      // Ne pas notifier ici: on notifie aprÃĻs exÃĐcution rÃĐelle de l'ordre (NotifyTradeEvent).

      // ExÃĐcution Ã  l'apparition: ne traiter que les nouvelles flÃĻches (par heure OBJPROP_TIME).
      if(ExecuteMarketOnDerivArrowAppearance)
      {
         datetime at = 0;
         if(!GetLatestColoredSignalArrowTimeForBoomCrashDir(arrowDirection, at))
            at = (datetime)ObjectGetInteger(0, "SMC_DERIV_ARROW_" + _Symbol, OBJPROP_TIME, 0);
         if(at <= 0) at = TimeCurrent();

         static datetime s_lastBuyArrowTime = 0;
         static datetime s_lastSellArrowTime = 0;
         static datetime s_lastBuyExec = 0;
         static datetime s_lastSellExec = 0;
         datetime now = TimeCurrent();
         int cd = MathMax(3, DerivArrowAppearanceCooldownSeconds);

         if(arrowDirection == "BUY")
         {
            if(at > s_lastBuyArrowTime && (s_lastBuyExec == 0 || (now - s_lastBuyExec) >= cd))
            {
               s_lastBuyArrowTime = at;
               double minC = DerivArrowAppearanceMinAIConfidence;
               if(minC > 1.0) minC /= 100.0;
               if(minC <= 0.0) minC = 0.80;
               if(NormalizeAIConfidenceUnit() + 1e-9 >= minC)
               {
                  g_derivArrowAppearanceFastMode = true;
                  ExecuteDerivArrowTrade("BUY");
                  g_derivArrowAppearanceFastMode = false;
                  s_lastBuyExec = now;
                  return;
               }
            }
         }
         else if(arrowDirection == "SELL")
         {
            if(at > s_lastSellArrowTime && (s_lastSellExec == 0 || (now - s_lastSellExec) >= cd))
            {
               s_lastSellArrowTime = at;
               double minC = DerivArrowAppearanceMinAIConfidence;
               if(minC > 1.0) minC /= 100.0;
               if(minC <= 0.0) minC = 0.80;
               if(NormalizeAIConfidenceUnit() + 1e-9 >= minC)
               {
                  g_derivArrowAppearanceFastMode = true;
                  ExecuteDerivArrowTrade("SELL");
                  g_derivArrowAppearanceFastMode = false;
                  s_lastSellExec = now;
                  return;
               }
            }
         }
      }
      
      // Validation stricte: Boom = BUY uniquement, Crash = SELL uniquement
      bool isBoom = (StringFind(_Symbol, "Boom") >= 0);
      bool isCrash = (StringFind(_Symbol, "Crash") >= 0);
      
      if(isBoom && arrowDirection == "BUY")
      {
         int posBefore = CountPositionsForSymbol(_Symbol);
         Print("? FLÃCHE VERTE + BOOM = COMPATIBLE - ExÃĐcution BUY autorisÃĐe");

         bool recoveryBypass = (g_boomM5BuyArrowRecoveryArmed &&
                                g_lastBoomM5BuyTouchTime > 0 &&
                                (TimeCurrent() - g_lastBoomM5BuyTouchTime) <= M5TouchArrowRecoveryWindowSec);
         g_allowBoomM5ArrowRecoveryBypass = recoveryBypass;
         if(recoveryBypass)
            Print("âĄ RECOVERY BUY actif - exÃĐcution flÃĻche verte avec bypass IA strict");

         ExecuteDerivArrowTrade("BUY");
         g_allowBoomM5ArrowRecoveryBypass = false;

         int posAfter = CountPositionsForSymbol(_Symbol);
         if(posAfter > posBefore)
         {
            if(recoveryBypass)
            {
               g_boomM5BuyArrowRecoveryArmed = false;
               g_lastBoomM5BuyTouchTime = 0;
               Print("â RECOVERY BUY consommÃĐ aprÃĻs entrÃĐe flÃĻche sur ", _Symbol);
            }
         }
         return;
      }
      else if(isCrash && arrowDirection == "SELL")
      {
         int posBefore = CountPositionsForSymbol(_Symbol);
         Print("? FLÃCHE ROUGE + CRASH = COMPATIBLE - ExÃĐcution SELL autorisÃĐe");
         ExecuteDerivArrowTrade("SELL");
         int posAfter = CountPositionsForSymbol(_Symbol);
         if(posAfter > posBefore)
         {
            // On ne dÃĐpend plus du "touch arm" pour entrer sur flÃĻche.
         }
         return;
      }
      else if(IsWeltradeGainSynthSymbol(_Symbol) && arrowDirection == "BUY")
      {
         Print("? FLÃCHE VERTE + GAINX = COMPATIBLE - ExÃĐcution BUY autorisÃĐe");
         ExecuteDerivArrowTrade("BUY");
         return;
      }
      else if(IsWeltradePainSynthSymbol(_Symbol) && arrowDirection == "SELL")
      {
         Print("? FLÃCHE ROUGE + PAINX = COMPATIBLE - ExÃĐcution SELL autorisÃĐe");
         ExecuteDerivArrowTrade("SELL");
         return;
      }
      else
      {
         Print("?? FLÃCHE DERIV ARROW INCOMPATIBLE - ", arrowDirection, " sur ", _Symbol,
               " (rÃĻgle Boom/Crash / PainX-GainX)");
         return;
      }
   }
   
   // RÃGLE STRICTE: BLOQUER TOUS LES TRADES BUY SUR BOOM SI IA = SELL
   bool isBoom = (StringFind(_Symbol, "Boom") >= 0);
   bool isCrash = (StringFind(_Symbol, "Crash") >= 0);
   string aiAction = g_lastAIAction;
   if(aiAction == "buy") aiAction = "BUY";
   if(aiAction == "sell") aiAction = "SELL";
   
   if(isBoom && aiAction == "SELL")
   {
   // RÃĐduire la frÃĐquence des logs de trading pour ÃĐviter la surcharge
   static datetime lastTradingLog = 0;
   if(TimeCurrent() - lastTradingLog >= 60) // Log toutes les 60 secondes maximum
   {
      Print("?? DERIV ARROW BOOM BLOQUÃ - IA = SELL (", DoubleToString(g_lastAIConfidence*100, 1), "%) | Attendre signal BUY avant de placer trade BUY");
      lastTradingLog = TimeCurrent();
   }
      return;
   }
   
   if(isCrash && aiAction == "BUY")
   {
   // RÃĐduire la frÃĐquence des logs de trading pour ÃĐviter la surcharge
   static datetime lastTradingLog = 0;
   if(TimeCurrent() - lastTradingLog >= 60) // Log toutes les 60 secondes maximum
   {
      Print("?? DERIV ARROW CRASH BLOQUÃ - IA = BUY (", DoubleToString(g_lastAIConfidence*100, 1), "%) | Attendre signal SELL avant de placer trade SELL");
      lastTradingLog = TimeCurrent();
   }
      return;
   }
   
   bool isGainSynth = IsWeltradeGainSynthSymbol(_Symbol);
   bool isPainSynth = IsWeltradePainSynthSymbol(_Symbol);
   if(isGainSynth && aiAction == "SELL")
   {
   static datetime lastGainIaLog = 0;
   if(TimeCurrent() - lastGainIaLog >= 60)
   {
      Print("?? DERIV ARROW GAINX BLOQUÃ - IA = SELL (", DoubleToString(g_lastAIConfidence*100, 1), "%) | Attendre signal BUY (pas de SELL sur GainX)");
      lastGainIaLog = TimeCurrent();
   }
      return;
   }
   if(isPainSynth && aiAction == "BUY")
   {
   static datetime lastPainIaLog = 0;
   if(TimeCurrent() - lastPainIaLog >= 60)
   {
      Print("?? DERIV ARROW PAINX BLOQUÃ - IA = BUY (", DoubleToString(g_lastAIConfidence*100, 1), "%) | Attendre signal SELL (pas de BUY sur PainX)");
      lastPainIaLog = TimeCurrent();
   }
      return;
   }
   
   // VALIDATION IA: Confiance minimum diffÃĐrente selon le type ET la zone ICT (Premium/Discount)
   // Objectif: ÃĐviter de prendre des positions avec une confiance IA faible,
   // surtout lorsque la dÃĐcision IA est CONTRAIRE Ã  la zone Premium/Discount.
   bool inDiscount = IsInDiscountZone();
   bool inPremium  = IsInPremiumZone();
   
   double requiredConfidence = 0.0;
   if(isBoomCrash)
   {
      // Sur Boom/Crash: exiger au minimum 80% ("IA serveur fort")
      double baseBoomConf = MathMax(MinAIConfidence, 0.80);
      requiredConfidence = baseBoomConf;
      
      // Si l'IA est SELL en zone Discount (achat) ou BUY en zone Premium (vente),
      // augmenter encore l'exigence de confiance (trade "contre-zone").
      bool contrarianToZone = (aiAction == "SELL" && inDiscount) || (aiAction == "BUY" && inPremium);
      if(contrarianToZone)
         requiredConfidence = MathMax(requiredConfidence, 0.80);
   }
   else
   {
      // Pour Volatility: garder un seuil fixe plus ÃĐlevÃĐ
      requiredConfidence = 0.85;
   }

   // Filtre "peu probable" si des symboles ont dÃĐjÃ  atteint leur profit target (donc on sÃĐcurise les gains)
   if(UseHighConfidenceFilterWhenSomeSymbolsProfitLocked)
   {
      int lockedCount = CountProfitTargetLockedSymbols();
      if(lockedCount >= LockedSymbolsMinCountForFilter)
      {
         double extraConf = ExtraMinAIConfidenceWhenLockedPercent / 100.0;
         requiredConfidence = MathMin(0.99, requiredConfidence + extraConf);
      }
   }
   
   if(UseAIServer && g_lastAIConfidence < requiredConfidence)
   {
      string zoneStr = "Equilibre";
      if(inDiscount) zoneStr = "Discount";
      else if(inPremium) zoneStr = "Premium";
      
      Print("?? TRADE BLOQUÃ - Confiance IA insuffisante sur ", _Symbol, " | Zone: ", zoneStr,
            " | ", DoubleToString(g_lastAIConfidence*100, 1), "% < ", DoubleToString(requiredConfidence*100, 1), "%");
      return;
   }
   
   // DÃTECTION DIFFÃRENCIÃE: Spike requis pour Boom/Crash, signal IA fort pour Volatility
   bool spikeDetected = false;
   bool shouldTrade = false;
   
   if(isBoomCrash)
   {
      // Boom/Crash: deux modes possibles
      // - Mode "prÃĐ-spike only" : entrer dÃĻs que le prix est dans la zone SMC / prÃĐ?spike (avant le 1er spike)
      // - Mode "spike confirmÃĐ" : attendre un spike rÃĐcent + proba ML suffisante (avec option prÃĐ?spike strict)
      bool preSpike = IsPreSpikePattern();
      spikeDetected = DetectRecentSpike();
      
      // Filtre supplÃĐmentaire basÃĐ sur la probabilitÃĐ ML de spike (si activÃĐ)
      double spikeProbML = g_lastSpikeProbability;
      bool probaOk = true;
      if(UseSpikeMLFilter)
      {
         // Toujours calculer/rafraÃŪchir une probabilitÃĐ locale (ÃĐviter le cas "0%/N/A" qui court-circuite le filtre)
         if(g_lastSpikeUpdate == 0 || (TimeCurrent() - g_lastSpikeUpdate) > 300)
            spikeProbML = CalculateSpikeProbability();
         probaOk = (spikeProbML >= SpikeML_MinProbability);
      }
      
      if(SpikeUsePreSpikeOnlyForBoomCrash)
      {
         // Entrer AVANT le premier spike: pattern prÃĐ?spike + proba ML OK
         shouldTrade = (preSpike && probaOk);
      }
      else
      {
         // Mode par dÃĐfaut: spike rÃĐcent + proba ML OK, avec option prÃĐ?spike strict
         shouldTrade = (spikeDetected && probaOk && (!SpikeRequirePreSpikePattern || preSpike));
      }
      
      // Bypass: signal IA fort (>=80%) pour autoriser l'entrÃĐe et capter les spikes
      // mÃŠme si preSpike/spike rÃĐcent/proba ML ne sont pas remplis (ÃĐvite de rater une forte tendance)
      if(!shouldTrade && g_lastAIConfidence >= 0.80)
      {
         if((isBoom && aiAction == "BUY") || (isCrash && aiAction == "SELL"))
         {
            shouldTrade = true;
            Print("? Boom/Crash - EntrÃĐe autorisÃĐe par confiance IA forte (>=80%) (", DoubleToString(g_lastAIConfidence*100, 1), "%) - capture spikes/tendance");
         }
      }
      // Rebond canal: Boom ? BUY quand prix touche low_chan; Crash ? SELL quand prix touche upper chan
      if(!shouldTrade && isBoom && aiAction == "BUY" && PriceTouchesLowerChannel())
      {
         shouldTrade = true;
         Print("? Boom - EntrÃĐe autorisÃĐe (prix touche canal bas ? rebond haussier attendu)");
      }
      if(!shouldTrade && isCrash && aiAction == "SELL" && PriceTouchesUpperChannel())
      {
         shouldTrade = true;
         Print("? Crash - EntrÃĐe autorisÃĐe (prix touche canal haut ? rebond baissier attendu)");
      }
      // AprÃĻs une perte sur ce symbole: exiger conditions meilleures + spike imminant pour ÃĐviter 2e perte consÃĐcutive
      if(shouldTrade && !AllowReentryAfterRecentLoss(_Symbol,
                                                     (isBoom ? "BUY" : "SELL"),
                                                     spikeDetected && (preSpike || spikeProbML >= 0.75)))
         shouldTrade = false;
      
      Print("?? DEBUG - Boom/Crash SNIPER - PreSpike: ", preSpike ? "OUI" : "NON",
            " | Spike rÃĐcent: ", spikeDetected ? "OUI" : "NON",
            " | Proba ML spike: ",
            (spikeProbML > 0.0 ? DoubleToString(spikeProbML*100.0, 1) + "%" : "N/A"),
            " (min ",
            (UseSpikeMLFilter ? DoubleToString(SpikeML_MinProbability*100.0, 1) + "%" : "N/A"),
            ")",
            " | Mode prÃĐ-spike only: ", SpikeUsePreSpikeOnlyForBoomCrash ? "OUI" : "NON",
            " | Mode prÃĐ-spike strict: ", SpikeRequirePreSpikePattern ? "OUI" : "NON",
            " | AutorisÃĐ: ", shouldTrade ? "OUI" : "NON");
   }
   else if(isVolatility)
   {
      // Volatility: Pas de spike requis, seulement signal IA fort (80%+)
      spikeDetected = false; // Non applicable
      shouldTrade = true; // Trade autorisÃĐ si IA forte (dÃĐjÃ  validÃĐ ci-dessus)
      
      Print("?? DEBUG - Volatility - Trade autorisÃĐ (confiance IA: ", DoubleToString(g_lastAIConfidence*100, 1), "%)");
   }
   
   if(!shouldTrade)
   {
      if(isBoomCrash)
         Print("? Conditions spike non remplies - trade Boom/Crash ignorÃĐ (Spike rÃĐcent requis",
               SpikeRequirePreSpikePattern ? " + PrÃĐ-spike" : "",
               UseSpikeMLFilter ? " + Filtre proba" : "",
               ")");
      else
         Print("? Conditions non remplies - trade Volatility ignorÃĐ");
      return;
   }
   
   // DÃTERMINER LA DIRECTION basÃĐe sur le signal IA et le type de symbole
   string direction = "";
   string iaDirection = "";
   
   // RÃĐcupÃĐrer la direction de l'IA
   if(g_lastAIAction == "BUY" || g_lastAIAction == "buy")
      iaDirection = "BUY";
   else if(g_lastAIAction == "SELL" || g_lastAIAction == "sell")
      iaDirection = "SELL";
   else
   {
      Print("? Aucun signal IA clair (", g_lastAIAction, ") - trade ignorÃĐ");
      return;
   }
   
   // VÃĐrifier la compatibilitÃĐ entre le signal IA et le type de symbole
   if(isBoomCrash)
   {
      // RÃĻgles Boom/Crash: directions spÃĐcifiques
      if(StringFind(_Symbol, "Boom") >= 0)
      {
         if(iaDirection == "BUY")
         {
            direction = "BUY"; // Boom + IA BUY = OK
         }
         else
         {
            Print("? CONFLIT: IA dit ", iaDirection, " mais Boom n'accepte que BUY - trade ignorÃĐ");
            return;
         }
      }
      else if(StringFind(_Symbol, "Crash") >= 0)
      {
         if(iaDirection == "SELL")
         {
            direction = "SELL"; // Crash + IA SELL = OK
         }
         else
         {
            Print("? CONFLIT: IA dit ", iaDirection, " mais Crash n'accepte que SELL - trade ignorÃĐ");
            return;
         }
      }
   }
   else if(isVolatility)
   {
      // Weltrade PainX / GainX : directions fixes (comme Crash / Boom), pas la volatilitÃĐ classique
      if(IsWeltradeGainSynthSymbol(_Symbol))
      {
         if(iaDirection != "BUY")
         {
            Print("? CONFLIT: IA dit ", iaDirection, " mais GainX n'accepte que BUY - trade ignorÃĐ");
            return;
         }
         direction = "BUY";
         Print("? GainX - Direction IA BUY acceptÃĐe sur ", _Symbol);
      }
      else if(IsWeltradePainSynthSymbol(_Symbol))
      {
         if(iaDirection != "SELL")
         {
            Print("? CONFLIT: IA dit ", iaDirection, " mais PainX n'accepte que SELL - trade ignorÃĐ");
            return;
         }
         direction = "SELL";
         Print("? PainX - Direction IA SELL acceptÃĐe sur ", _Symbol);
      }
      else
      {
         // Volatility: BUY et SELL autorisÃĐs (suivre l'IA)
         direction = iaDirection;
         Print("? Volatility - Direction IA acceptÃĐe: ", direction, " sur ", _Symbol);
      }
   }
   
   Print("? Signal IA validÃĐ: ", iaDirection, " compatible avec ", _Symbol, " ? Direction: ", direction);

   // VÃĐrifier l'alignement avec les indicateurs techniques classiques (TradingView-like)
   string classicSummary;
   bool classicOk = IsClassicIndicatorsAligned(direction, classicSummary);

   Print("?? DEBUG - Indicateurs classiques (", direction, ") => ", classicOk ? "ALIGNÃS" : "NON ALIGNÃS",
         " | ", classicSummary);

   if(!classicOk)
   {
      if(UseClassicIndicatorsFilter)
      {
         Print("?? TRADE SPIKE BLOQUÃ - Indicateurs classiques insuffisants (min ",
               ClassicMinConfirmations, " confirmations) sur ", _Symbol);
         return;
      }
   }

   // Protection capital: en zone d'achat au bord infÃĐrieur ? SELL seulement si confiance IA >= 85%
   if(direction == "SELL" && IsAtDiscountLowerEdge() && g_lastAIConfidence < 0.85)
   {
      Print("?? TRADE BLOQUÃ - Zone Discount au bord infÃĐrieur: SELL autorisÃĐ seulement si confiance IA ? 85% (actuel: ",
            DoubleToString(g_lastAIConfidence*100, 1), "%)");
      return;
   }
   // Protection capital: en zone premium au bord supÃĐrieur (Boom / GainX) ? BUY seulement si confiance IA >= 85%
   if(direction == "BUY" && (isBoom || isGainSynth) && IsAtPremiumUpperEdge() && g_lastAIConfidence < 0.85)
   {
      Print("?? TRADE BLOQUÃ - Zone Premium au bord supÃĐrieur (Boom/GainX): BUY autorisÃĐ seulement si confiance IA ? 85% (actuel: ",
            DoubleToString(g_lastAIConfidence*100, 1), "%)");
      return;
   }

   // RÃĐentrÃĐe aprÃĻs perte sur ce symbole (hors Boom/Crash): exiger conditions exceptionnelles
   if(!AllowReentryAfterRecentLoss(_Symbol, direction, spikeDetected))
      return;

   Print("?? SPIKE DÃTECTÃ - Direction: ", direction, " | Symbole: ", _Symbol);

   // EXÃCUTION DU TRADE avec les mÃŠmes validations que prÃĐcÃĐdemment
   ExecuteSpikeTrade(direction);
}

//| DÃTECTER SI UNE FLÃCHE DERIV ARROW EST PRÃSENTE SUR LE GRAPHIQUE |
bool IsDerivArrowPresent()
{
   // Chercher les objets flÃĻche sur le graphique avec des noms typiques
   for(int i = ObjectsTotal(0, -1, OBJ_ARROW) - 1; i >= 0; i--)
   {
      string objName = ObjectName(0, i, -1, OBJ_ARROW);
      
      // VÃĐrifier si c'est une flÃĻche Deriv Arrow (noms communs)
      if(StringFind(objName, "DERIV") >= 0 || StringFind(objName, "Deriv") >= 0 || 
         StringFind(objName, "ARROW") >= 0 || StringFind(objName, "Arrow") >= 0 ||
         StringFind(objName, "SIGNAL") >= 0 || StringFind(objName, "Signal") >= 0)
      {
         // VÃĐrifier que l'objet est visible et sur la bougie rÃĐcente
         datetime objTime = (datetime)ObjectGetInteger(0, objName, OBJPROP_TIME, 0);
         datetime currentTime = TimeCurrent();
         
         // La flÃĻche doit ÃŠtre sur les 5 derniÃĻres bougies maximum
         if(currentTime - objTime <= PeriodSeconds() * 5)
         {
            return true;
         }
      }
   }
   
   return false;
}

// DÃĐtecte une tendance "escalier" sur Boom/Crash en M1 (utile quand la flÃĻche n'apparaÃŪt pas).
// Heuristique simple: mouvement net suffisant + majoritÃĐ de bougies dans le sens + drawdown contenu.
bool IsBoomCrashTrendStaircase(const string direction)
{
   string dir = direction;
   StringToUpper(dir);
   if(dir != "BUY" && dir != "SELL") return false;

   int n = MathMax(20, BoomCrashTrendLookbackBarsM1);
   if(Bars(_Symbol, PERIOD_M1) < (n + 2)) return false;

   double startClose = iClose(_Symbol, PERIOD_M1, n);
   double endClose   = iClose(_Symbol, PERIOD_M1, 1);
   if(startClose <= 0.0 || endClose <= 0.0) return false;

   double netMove = endClose - startClose;
   if(dir == "SELL") netMove = -netMove;
   double netMovePct = (MathAbs(netMove) / endClose) * 100.0;
   if(netMove <= 0.0) return false;
   if(netMovePct < BoomCrashTrendMinMovePct) return false;

   int aligned = 0;
   double peak = (dir == "BUY") ? -DBL_MAX : DBL_MAX;
   double worstDrawdown = 0.0; // en prix, dans le sens opposÃĐ

   for(int i = n; i >= 1; i--)
   {
      double o = iOpen(_Symbol, PERIOD_M1, i);
      double c = iClose(_Symbol, PERIOD_M1, i);
      double h = iHigh(_Symbol, PERIOD_M1, i);
      double l = iLow(_Symbol, PERIOD_M1, i);
      if(o <= 0.0 || c <= 0.0 || h <= 0.0 || l <= 0.0) continue;

      bool isAligned = (dir == "BUY") ? (c >= o) : (c <= o);
      if(isAligned) aligned++;

      if(dir == "BUY")
      {
         if(h > peak) peak = h;
         double dd = peak - l; // retracement depuis le peak
         if(dd > worstDrawdown) worstDrawdown = dd;
      }
      else
      {
         if(l < peak) peak = l;
         double dd = h - peak; // retracement depuis le trough
         if(dd > worstDrawdown) worstDrawdown = dd;
      }
   }

   double alignedRatio = (double)aligned / (double)n;
   if(alignedRatio < BoomCrashTrendMinBullishCandleRatio) return false;

   double maxAllowedDD = MathAbs(netMove) * BoomCrashTrendMaxDrawdownPct;
   if(worstDrawdown > maxAllowedDD) return false;

   return true;
}

// MÃŠme logique que lâescalier ÂŦ long Âŧ mais fenÃŠtre M1 plus courte et seuils assouplis (escalier naissant).
bool IsBoomCrashEarlyStaircaseM1(const string direction)
{
   string dir = direction;
   StringToUpper(dir);
   if(dir != "BUY" && dir != "SELL") return false;
   if(!StairUseEarlyRelaxedM1) return false;

   int n = MathMax(15, StairEarlyLookbackBarsM1);
   if(Bars(_Symbol, PERIOD_M1) < (n + 2)) return false;

   double startClose = iClose(_Symbol, PERIOD_M1, n);
   double endClose   = iClose(_Symbol, PERIOD_M1, 1);
   if(startClose <= 0.0 || endClose <= 0.0) return false;

   double netMove = endClose - startClose;
   if(dir == "SELL") netMove = -netMove;
   double netMovePct = (MathAbs(netMove) / endClose) * 100.0;
   if(netMove <= 0.0) return false;
   if(netMovePct < StairEarlyMinMovePct) return false;

   int aligned = 0;
   double peak = (dir == "BUY") ? -DBL_MAX : DBL_MAX;
   double worstDrawdown = 0.0;

   for(int i = n; i >= 1; i--)
   {
      double o = iOpen(_Symbol, PERIOD_M1, i);
      double c = iClose(_Symbol, PERIOD_M1, i);
      double h = iHigh(_Symbol, PERIOD_M1, i);
      double l = iLow(_Symbol, PERIOD_M1, i);
      if(o <= 0.0 || c <= 0.0 || h <= 0.0 || l <= 0.0) continue;

      bool isAligned = (dir == "BUY") ? (c >= o) : (c <= o);
      if(isAligned) aligned++;

      if(dir == "BUY")
      {
         if(h > peak) peak = h;
         double dd = peak - l;
         if(dd > worstDrawdown) worstDrawdown = dd;
      }
      else
      {
         if(l < peak) peak = l;
         double dd = h - peak;
         if(dd > worstDrawdown) worstDrawdown = dd;
      }
   }

   double alignedRatio = (double)aligned / (double)n;
   if(alignedRatio < StairEarlyMinAlignedRatio) return false;

   double maxAllowedDD = MathAbs(netMove) * StairEarlyMaxDrawdownPct;
   if(worstDrawdown > maxAllowedDD) return false;

   return true;
}

// Tendance contextuelle sur M1 + derniÃĻres bougies ÂŦ serrÃĐes Âŧ (marche / consolidation avant spike).
bool IsSyntheticStairFormingPhaseM1(const string direction)
{
   string dir = direction;
   StringToUpper(dir);
   if(dir != "BUY" && dir != "SELL") return false;
   if(!StairUseFormingPhaseM1) return false;

   int ctx = MathMax(20, StairFormingContextBarsM1);
   int w = MathMax(4, StairFormingStepBarsM1);
   if(w >= ctx) return false;
   if(Bars(_Symbol, PERIOD_M1) < (ctx + 2)) return false;

   double cEnd = iClose(_Symbol, PERIOD_M1, 1);
   double cCtx = iClose(_Symbol, PERIOD_M1, ctx);
   if(cEnd <= 0.0 || cCtx <= 0.0) return false;

   double netCtx = cEnd - cCtx;
   if(dir == "SELL") netCtx = -netCtx;
   if(netCtx <= 0.0) return false;
   double netPct = MathAbs(cEnd - cCtx) / cEnd * 100.0;
   if(netPct < StairFormingMinContextMovePct) return false;

   double hiStep = -DBL_MAX;
   double loStep = DBL_MAX;
   for(int i = 1; i <= w; i++)
   {
      double h = iHigh(_Symbol, PERIOD_M1, i);
      double l = iLow(_Symbol, PERIOD_M1, i);
      if(h <= 0.0 || l <= 0.0) return false;
      if(h > hiStep) hiStep = h;
      if(l < loStep) loStep = l;
   }
   double rangeStep = hiStep - loStep;

   double hiCtx = -DBL_MAX;
   double loCtx = DBL_MAX;
   for(int j = 1; j <= ctx; j++)
   {
      double h = iHigh(_Symbol, PERIOD_M1, j);
      double l = iLow(_Symbol, PERIOD_M1, j);
      if(h <= 0.0 || l <= 0.0) return false;
      if(h > hiCtx) hiCtx = h;
      if(l < loCtx) loCtx = l;
   }
   double rangeCtx = hiCtx - loCtx;
   if(rangeCtx <= 0.0) return false;

   if(rangeStep / rangeCtx > StairFormingMaxEndRangeVsContext) return false;

   double atrVal = 0.0;
   double ab[];
   ArraySetAsSeries(ab, true);
   if(atrM1 != INVALID_HANDLE && CopyBuffer(atrM1, 0, 0, 1, ab) >= 1)
      atrVal = ab[0];
   if(atrVal <= 0.0)
      atrVal = rangeCtx / (double)ctx;
   if(rangeStep > atrVal * StairFormingMaxStepRangeAtrMult) return false;

   if(dir == "SELL" && StairFormingUseRsiPullbackSell)
   {
      int b = MathMax(2, StairFormingRsiPullbackBars);
      double rs[];
      ArraySetAsSeries(rs, true);
      if(rsi14M1 == INVALID_HANDLE || CopyBuffer(rsi14M1, 0, 0, b + 1, rs) < b + 1)
         return true;
      if(!(rs[1] > rs[b]))
         return false;
   }

   return true;
}

// DÃĐtection escalier synthÃĐtique M1 : lookback classique OU jeune OU phase ÂŦ marche Âŧ (forming).
bool IsSyntheticStairPatternM1(const string direction)
{
   if(IsBoomCrashTrendStaircase(direction)) return true;
   if(IsBoomCrashEarlyStaircaseM1(direction)) return true;
   if(IsSyntheticStairFormingPhaseM1(direction)) return true;
   return false;
}

// Canal de prÃĐdiction ML (g_ch*): vÃĐrifier pente cohÃĐrente avec Boom BUY (haussier) ou Crash SELL (baissier).
// UtilisÃĐ pour entrer avant touch future protect / flÃĻche quand le canal est dÃĐjÃ  clair.
bool IsMlChannelTrendAlignedForBoomCrash(const string direction)
{
   if(!g_channelValid) return false;

   int predBars = MathMax(1, PredictionChannelBars);
   double slopeUpper = (g_chUpperEnd - g_chUpperStart) / (double)predBars;
   double slopeLower = (g_chLowerEnd - g_chLowerStart) / (double)predBars;

   double atrVal = 0.0;
   if(atrHandle != INVALID_HANDLE)
   {
      double ab[];
      ArraySetAsSeries(ab, true);
      if(CopyBuffer(atrHandle, 0, 0, 1, ab) >= 1)
         atrVal = ab[0];
   }
   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   if(atrVal <= 0.0 && bid > 0.0)
      atrVal = bid * 0.001;
   if(atrVal <= 0.0)
      return false;

   string dir = direction;
   StringToUpper(dir);

   datetime tNow = iTime(_Symbol, PERIOD_M1, 0);
   if(tNow <= 0)
      tNow = TimeCurrent();
   double minsFromStart = (g_chTimeStart > 0) ? (double)(tNow - g_chTimeStart) / 60.0 : 0.0;
   double u0 = g_chUpperStart + slopeUpper * minsFromStart;
   double l0 = g_chLowerStart + slopeLower * minsFromStart;
   double chH = u0 - l0;
   if(chH <= 0.0)
      return false;

   double minS = atrVal * MlChannelMinSlopeVsAtr;

   if(dir == "BUY" && (IsBoomSymbol(_Symbol) || IsWeltradeGainSynthSymbol(_Symbol)))
   {
      if(slopeUpper < minS || slopeLower < minS)
         return false;
      double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
      if(ask <= 0.0)
         return false;
      double pos = (ask - l0) / chH;
      if(pos > MlChannelBoomMaxPosInChannel)
         return false;
      return true;
   }

   if(dir == "SELL" && (IsCrashSymbol(_Symbol) || IsWeltradePainSynthSymbol(_Symbol)))
   {
      if(slopeUpper > -minS || slopeLower > -minS)
         return false;
      double bid2 = SymbolInfoDouble(_Symbol, SYMBOL_BID);
      if(bid2 <= 0.0)
         return false;
      double posFromBottom = (bid2 - l0) / chH;
      if(posFromBottom < MlChannelCrashMinPosFromBottom)
         return false;
      return true;
   }

   return false;
}

// Scalping rapide: dÃĐtecter un BUY/SELL "fort" via EMA(1)/EMA(5) sur M1.
// Objectif: permettre l'entrÃĐe quand la flÃĻche SMC_DERIV_ARROW n'arrive pas assez vite.
bool IsEMA1EMA5Strong(const string direction)
{
   if(!AllowScalpEntryByEMA1EMA5WithoutDerivArrow) return false;
   if(direction != "BUY" && direction != "SELL") return false;

   if(ema1M1 == INVALID_HANDLE || ema5M1 == INVALID_HANDLE) return false;
   if(IsInEquilibriumCorrectionZone()) return false;

   double e1[2], e5[2];
   // e1/e5 sont des tableaux statiques (taille fixe), donc ArraySetAsSeries() n'est pas autorisÃĐ ici.

   if(CopyBuffer(ema1M1, 0, 0, 2, e1) < 2) return false;
   if(CopyBuffer(ema5M1, 0, 0, 2, e5) < 2) return false;

   double ema1 = e1[0];
   double ema5 = e5[0];
   double ema1Prev = e1[1];

   if(ema1 <= 0.0 || ema5 <= 0.0) return false;

   // Gap minimum entre EMA1 et EMA5 (en %)
   double gapPct = MathAbs(ema1 - ema5) / ema5 * 100.0;
   if(gapPct < EMA1EMA5StrongMinGapPct) return false;

   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);

   if(direction == "BUY")
   {
      if(!(ema1 > ema5 && bid > ema1 && ema1 > ema1Prev)) return false;
   }
   else // SELL
   {
      if(!(ema1 < ema5 && bid < ema1 && ema1 < ema1Prev)) return false;
   }

   return true;
}

// Exige la prÃĐsence rÃĐcente de la flÃĻche SMC_DERIV_ARROW_<symbol> avant d'exÃĐcuter un ordre au marchÃĐ.
// Direction: "BUY" ou "SELL" (insensible Ã  la casse).
bool HasRecentSMCDerivArrowForDirection(string direction)
{
   if(!RequireSMCDerivArrowForMarketOrders) return true;

   string dir = direction;
   StringToUpper(dir);
   if(dir != "BUY" && dir != "SELL") return false;

   // Bypass scalping: si EMA(1) et EMA(5) sont fortement alignÃĐes sur M1,
   // alors on n'attend pas la flÃĻche DERIV Ã  temps.
   if(AllowScalpEntryByEMA1EMA5WithoutDerivArrow)
   {
      if(IsEMA1EMA5Strong(dir))
      {
         Print("âĄ BYPASS flÃĻche DERIV - EMA(1)/EMA(5) M1 fort => autoriser ", dir, " sur ", _Symbol);
         return true;
      }
   }

   // Exception Boom/Crash + Weltrade: tendance escalier + confiance, autoriser sans flÃĻche
   if(g_cfgAllowBoomCrashTrendEntryWithoutArrow &&
      (SMC_GetSymbolCategory(_Symbol) == SYM_BOOM_CRASH || SMC_GetSymbolCategory(_Symbol) == SYM_WELTRADE_SYNTH))
   {
      double confPct = g_lastAIConfidence * 100.0;
      double minTrendPct = (SMC_GetSymbolCategory(_Symbol) == SYM_WELTRADE_SYNTH)
                           ? StairEntryWeltradeMinAIConfidencePercent
                           : g_cfgBoomCrashTrendEntryMinConfidencePct;
      if(DirectionMatchesBoomCrashOrWeltradeSynth(_Symbol, dir) &&
         confPct >= minTrendPct && IsSyntheticStairPatternM1(dir))
      {
         Print("BYPASS FLECHE - Tendance escalier + conf ", DoubleToString(confPct, 1),
               "% >= ", DoubleToString(minTrendPct, 1), "% | Dir=", dir, " | ", _Symbol);
         return true;
      }
   }

   // Canal ML confirmÃĐ (Boom/Gainâ ou Crash/Painâ): entrÃĐe plus tÃīt sans flÃĻche DERIV
   if(UseMlChannelEarlySpikeEntry &&
      (SMC_GetSymbolCategory(_Symbol) == SYM_BOOM_CRASH || SMC_GetSymbolCategory(_Symbol) == SYM_WELTRADE_SYNTH))
   {
      double confPct = g_lastAIConfidence * 100.0;
      double mlMin = MlChannelEarlyMinConfPctForSymbol(_Symbol);
      if(DirectionMatchesBoomCrashOrWeltradeSynth(_Symbol, dir) &&
         confPct >= mlMin && IsMlChannelTrendAlignedForBoomCrash(dir))
      {
         static datetime lastMlChBypassLog = 0;
         if(TimeCurrent() - lastMlChBypassLog >= 25)
         {
            Print("âĄ BYPASS flÃĻche DERIV â canal ML ", dir, " alignÃĐ | conf ", DoubleToString(confPct, 1), "% | ", _Symbol);
            lastMlChBypassLog = TimeCurrent();
         }
         return true;
      }
   }

   // stairEntry: M1 escalier + M1/M5 EMA (Boom BUY / Crash SELL / GainX BUY / PainX SELL)
   if(UseStairEntry &&
      (SMC_GetSymbolCategory(_Symbol) == SYM_BOOM_CRASH || SMC_GetSymbolCategory(_Symbol) == SYM_WELTRADE_SYNTH))
   {
      double confPct = g_lastAIConfidence * 100.0;
      double stairMin = StairEntryEffectiveMinAiPctForSymbol(_Symbol);
      if(DirectionMatchesBoomCrashOrWeltradeSynth(_Symbol, dir) &&
         confPct >= stairMin &&
         (!StairEntryRequireStrongM1M5EMA || IsStrongM1M5TrendByEMAs(dir)) &&
         (!StairEntryUseM1StairDetector || IsSyntheticStairPatternM1(dir)))
      {
         static datetime lastStairDerivLog = 0;
         if(TimeCurrent() - lastStairDerivLog >= 25)
         {
            Print("âĄ BYPASS flÃĻche DERIV â stairEntry ", dir, " | conf ", DoubleToString(confPct, 1), "% | ", _Symbol);
            lastStairDerivLog = TimeCurrent();
         }
         return true;
      }
   }

   string arrowName = "SMC_DERIV_ARROW_" + _Symbol;
   string foundName = arrowName;
   if(ObjectFind(0, arrowName) < 0)
   {
      // Fallback: certains modules peuvent nommer diffÃĐremment. On prend la plus rÃĐcente des flÃĻches SMC_DERIV_ARROW*.
      datetime bestTime = 0;
      string bestName = "";
      for(int i = ObjectsTotal(0, -1, OBJ_ARROW) - 1; i >= 0; i--)
      {
         string objName = ObjectName(0, i, -1, OBJ_ARROW);
         if(StringFind(objName, "SMC_DERIV_ARROW") < 0) continue;
         if(StringFind(objName, _Symbol) < 0) continue; // rester strict: flÃĻche du symbole courant
         datetime t = (datetime)ObjectGetInteger(0, objName, OBJPROP_TIME, 0);
         if(t > bestTime)
         {
            bestTime = t;
            bestName = objName;
         }
      }
      if(bestName == "")
      {
         if(DebugDerivArrowCapture)
            Print("ARROW DEBUG - aucune flÃĻche SMC_DERIV_ARROW trouvÃĐe pour ", _Symbol);
         return false;
      }
      foundName = bestName;
   }

   // VÃĐrifier que la flÃĻche est rÃĐcente (N bougies max sur timeframe courant)
   datetime arrowTime = (datetime)ObjectGetInteger(0, foundName, OBJPROP_TIME, 0);
   int maxAgeBars = MathMax(1, SMCDerivArrowMaxAgeBars);
   int maxAgeSec = PeriodSeconds(PERIOD_CURRENT) * maxAgeBars;
   if(maxAgeSec <= 0) maxAgeSec = 60 * maxAgeBars;
   int ageSec = (int)(TimeCurrent() - arrowTime);
   if(ageSec > maxAgeSec)
   {
      if(DebugDerivArrowCapture)
         Print("ARROW DEBUG - flÃĻche trop vieille: name=", foundName, " ageSec=", ageSec, " > maxAgeSec=", maxAgeSec, " | sym=", _Symbol);
      return false;
   }

   // VÃĐrifier direction via le code de flÃĻche
   int arrowCode = (int)ObjectGetInteger(0, foundName, OBJPROP_ARROWCODE);
   bool isBuyArrow = (arrowCode == 233);
   bool isSellArrow = (arrowCode == 234);
   if(DebugDerivArrowCapture)
      Print("ARROW DEBUG - found=", foundName, " code=", arrowCode, " ageSec=", ageSec, " dirNeed=", dir, " buy=", isBuyArrow, " sell=", isSellArrow);
   if(dir == "BUY" && !isBuyArrow) return false;
   if(dir == "SELL" && !isSellArrow) return false;

   return true;
}

// VÃĐrifie que le setup STAIR est effectivement affichÃĐ sur le graphique,
// et qu'il correspond Ã  la direction demandÃĐe.
bool IsStairSetupDisplayedOnChartForDirection(const string direction)
{
   string dir = direction;
   StringToUpper(dir);
   if(dir != "BUY" && dir != "SELL") return false;

   if(ObjectFind(0, "STAIR_SETUP_ENTRY_LINE") < 0) return false;
   if(ObjectFind(0, "STAIR_SETUP_TITLE") < 0) return false;

   string labelTxt = "";
   if(ObjectFind(0, "STAIR_SETUP_ENTRY_LABEL") >= 0)
      labelTxt = ObjectGetString(0, "STAIR_SETUP_ENTRY_LABEL", OBJPROP_TEXT);
   string titleTxt = ObjectGetString(0, "STAIR_SETUP_TITLE", OBJPROP_TEXT);
   StringToUpper(labelTxt);
   StringToUpper(titleTxt);

   return (StringFind(labelTxt, dir) >= 0 || StringFind(titleTxt, dir) >= 0);
}

//| VARIABLES GLOBALES POUR ORDRES LIMIT POST-HOLD |
static bool g_postHoldLimitOrderPending = false;
static datetime g_lastHoldCloseTime = 0;

//| PLACER ORDRE LIMIT POST-HOLD APRÃS PERTE 2,0$ |
void PlacePostHoldLimitOrder(string closedSymbol, ENUM_POSITION_TYPE closedType, double closedProfit)
{
   Print("?? DEBUG POST-HOLD - DÃĐbut fonction");
   Print("   ?? Symbole: ", closedSymbol, " | Type: ", (closedType == POSITION_TYPE_BUY ? "BUY" : "SELL"), " | Profit: ", DoubleToString(closedProfit, 2), "$");
   
   // VÃĐrifier si la fermeture ÃĐtait bien due Ã  HOLD avec perte ? 2,0$
   if(closedProfit > -2.0)
   {
      Print("?? POST-HOLD - Perte insuffisante: ", DoubleToString(closedProfit, 2), "$ > -2.00$");
      return;
   }
   Print("? POST-HOLD - Perte suffisante: ", DoubleToString(closedProfit, 2), "$ ? -2.00$");
   
   // VÃĐrifier si c'est bien Boom/Crash
   bool isBoom = (StringFind(closedSymbol, "Boom") >= 0);
   bool isCrash = (StringFind(closedSymbol, "Crash") >= 0);
   
   if(!isBoom && !isCrash)
   {
      Print("?? POST-HOLD - Symbole non Boom/Crash: ", closedSymbol);
      return;
   }
   Print("? POST-HOLD - Symbole valide - Boom: ", isBoom, " | Crash: ", isCrash);
   
   // VÃĐrifier si un ordre limit est dÃĐjÃ  en attente
   if(g_postHoldLimitOrderPending)
   {
      Print("?? POST-HOLD - Ordre limit dÃĐjÃ  en attente, annulation");
      return;
   }
   Print("? POST-HOLD - Aucun ordre limit en attente");

   // Anti-duplication: si un pending LIMIT existe dÃĐjÃ  sur ce symbole (mÃŠme magic), ne pas en recrÃĐer un second
   if(CountOpenLimitOrdersForSymbol(closedSymbol) >= 1)
   {
      Print("?? POST-HOLD - Pending LIMIT dÃĐjÃ  existant sur ", closedSymbol, " -> skip anti-duplication");
      return;
   }
   
   // DÃĐtecter si nous ÃĐtions en zone Premium (vente) ou Discount (achat)
   bool inDiscount = IsInDiscountZone();
   bool inPremium = IsInPremiumZone();
   
   Print("?? POST-HOLD - Zones SMC - Discount: ", inDiscount, " | Premium: ", inPremium);
   
   // Conditions dÃĐtaillÃĐes pour ordre limit
   bool shouldPlaceLimit = false;
   ENUM_ORDER_TYPE limitType = WRONG_VALUE;
   double limitPrice = 0.0;
   string limitReason = "";
   
   if(isBoom && inDiscount && closedType == POSITION_TYPE_BUY)
   {
      // Boom en zone Discount avec position BUY fermÃĐe ? ordre BUY limit au support
      limitType = ORDER_TYPE_BUY_LIMIT;
      limitPrice = GetSupportLevel(20); // Support sur 20 barres
      limitReason = "Boom Discount - Support 20 bars (post-HOLD)";
      shouldPlaceLimit = true;
      Print("?? POST-HOLD - Condition Boom+Discount+BUY remplie");
   }
   else if(isCrash && inPremium && closedType == POSITION_TYPE_SELL)
   {
      // Crash en zone Premium avec position SELL fermÃĐe ? ordre SELL limit Ã  la rÃĐsistance
      limitType = ORDER_TYPE_SELL_LIMIT;
      limitPrice = GetResistanceLevel(20); // RÃĐsistance sur 20 barres
      limitReason = "Crash Premium - Resistance 20 bars (post-HOLD)";
      shouldPlaceLimit = true;
      Print("?? POST-HOLD - Condition Crash+Premium+SELL remplie");
   }
   
   if(!shouldPlaceLimit)
   {
      Print("?? POST-HOLD - Conditions non remplies pour ordre limit");
      Print("   ?? Symbole: ", closedSymbol, " | Type: ", (closedType == POSITION_TYPE_BUY ? "BUY" : "SELL"));
      Print("   ?? Zones - Discount: ", inDiscount, " | Premium: ", inPremium);
      Print("   ?? Attendu: (Boom+Discount+BUY) ou (Crash+Premium+SELL)");
      return;
   }
   
   Print("? POST-HOLD - Conditions validÃĐes - Calcul niveau de prix...");
   
   // Placer l'ordre limit
   double lot = CalculateLotSize();
   MqlTradeRequest request = {};
   MqlTradeResult result = {};
   
   request.action = TRADE_ACTION_PENDING;
   request.symbol = closedSymbol;
   request.volume = lot;
   request.type = limitType;
   request.price = limitPrice;
   // Toujours dÃĐmarrer avec SL/TP
   string dirPH = (limitType == ORDER_TYPE_BUY_LIMIT) ? "BUY" : "SELL";
   double atrPH = GetCurrentATR();
   if(atrPH <= 0.0)
      atrPH = 300.0 * SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   double slPH = 0.0;
   double tpPH = 0.0;
   if(dirPH == "BUY")
   {
      slPH = limitPrice - atrPH * 1.5;
      tpPH = limitPrice + (limitPrice - slPH) * MathMax(1.0, InpRiskReward);
   }
   else
   {
      slPH = limitPrice + atrPH * 1.5;
      tpPH = limitPrice - (slPH - limitPrice) * MathMax(1.0, InpRiskReward);
   }
   ValidateAndAdjustStopLossTakeProfit(dirPH, limitPrice, slPH, tpPH);
   request.sl = NormalizeDouble(slPH, _Digits);
   request.tp = NormalizeDouble(tpPH, _Digits);
   request.deviation = 10;
   request.magic = InpMagicNumber;
   request.comment = "POST-HOLD Limit - " + limitReason;
   request.type_time = ORDER_TIME_GTC; // Good till cancelled
   request.expiration = 0;
   
   Print("?? POST-HOLD - RequÃŠte ordre limit prÃĐparÃĐe:");
   Print("   ?? Type: ", (limitType == ORDER_TYPE_BUY_LIMIT ? "BUY LIMIT" : "SELL LIMIT"));
   Print("   ?? Prix: ", DoubleToString(limitPrice, _Digits), " | Lot: ", DoubleToString(lot, 2));
   Print("   ?? Raison: ", limitReason);
   
   if(OrderSend(request, result))
   {
      g_postHoldLimitOrderPending = true;
      g_lastHoldCloseTime = TimeCurrent();
      Print("? POST-HOLD - Ordre limit placÃĐ avec succÃĻs");
      Print("   ?? Symbole: ", closedSymbol, " | Type: ", (limitType == ORDER_TYPE_BUY_LIMIT ? "BUY LIMIT" : "SELL LIMIT"));
      Print("   ?? Prix: ", DoubleToString(limitPrice, _Digits), " | Lot: ", DoubleToString(lot, 2));
      Print("   ?? Raison: ", limitReason);
      Print("   ?? Ticket: ", result.order);
   }
   else
   {
      Print("? POST-HOLD - Ãchec placement ordre limit");
      Print("   ?? Erreur: ", result.retcode, " - ", result.comment);
      Print("   ?? Code erreur: ", GetLastError());
   }
}

//| OBTENIR NIVEAU DE SUPPORT (20 BARRES) |
double GetSupportLevel(int bars)
{
   MqlRates rates[];
   ArraySetAsSeries(rates, true);
   
   if(CopyRates(_Symbol, PERIOD_M1, 0, bars + 1, rates) < bars + 1)
   {
      Print("? Impossible de copier les rates pour support");
      return 0.0;
   }
   
   double support = rates[0].low;
   for(int i = 1; i <= bars; i++)
   {
      if(rates[i].low < support)
         support = rates[i].low;
   }
   
   return support;
}

//| OBTENIR NIVEAU DE RÃSISTANCE (20 BARRES) |
double GetResistanceLevel(int bars)
{
   MqlRates rates[];
   ArraySetAsSeries(rates, true);
   
   if(CopyRates(_Symbol, PERIOD_M1, 0, bars + 1, rates) < bars + 1)
   {
      Print("? Impossible de copier les rates pour rÃĐsistance");
      return 0.0;
   }
   
   double resistance = rates[0].high;
   for(int i = 1; i <= bars; i++)
   {
      if(rates[i].high > resistance)
         resistance = rates[i].high;
   }
   
   return resistance;
}
static string g_lastAIActionPrevious = ""; // Action IA prÃĐcÃĐdente

//| SURVEILLER ET FERMER POSITIONS SI IA DEVIENT HOLD |
void MonitorAndClosePositionsOnHold()
{
   if(!UseAIServer) return; // Seulement si serveur IA actif
   
   // VÃĐrifier si l'IA est passÃĐe de BUY/SELL Ã  HOLD
   if(g_lastAIActionPrevious != "" && g_lastAIActionPrevious != "HOLD" && g_lastAIActionPrevious != "hold" &&
      (g_lastAIAction == "HOLD" || g_lastAIAction == "hold"))
   {
      Print("?? CHANGEMENT IA DÃTECTÃ - ", g_lastAIActionPrevious, " ? HOLD");
      Print("   ?? SURVEILLANCE DES POSITIONS - Fermeture si perte >= seuil (dÃĐfaut ",
            DoubleToString(HoldAutoCloseLossDefaultDollars, 2), "$, FX VOL 40 ",
            DoubleToString(HoldAutoCloseLossFxVol40Dollars, 2), "$)");
      
      // Parcourir toutes les positions ouvertes
      int totalPositions = PositionsTotal();
      for(int i = totalPositions - 1; i >= 0; i--)
      {
         if(PositionGetTicket(i) > 0)
         {
            string posSymbol = PositionGetString(POSITION_SYMBOL);
            ENUM_POSITION_TYPE posType = (ENUM_POSITION_TYPE)PositionGetInteger(POSITION_TYPE);
            ulong posTicket = PositionGetInteger(POSITION_TICKET);
            double posProfit = PositionGetDouble(POSITION_PROFIT);
            string cmt = PositionGetString(POSITION_COMMENT);

            // Recovery exceptionnel: on laisse la fermeture "5 petites bougies M1" gÃĐrer le trade
            if(StringFind(cmt, "EXC_RECOVERY_") >= 0)
               continue;
            
            // VÃĐrifier si la position correspond Ã  l'action prÃĐcÃĐdente
            bool shouldClose = false;
            if(g_lastAIActionPrevious == "BUY" && posType == POSITION_TYPE_BUY)
            {
               shouldClose = true;
               Print("   ?? SURVEILLANCE BUY - ", posSymbol, " | Ticket: ", posTicket, " | Profit: ", DoubleToString(posProfit, 2), "$");
            }
            else if(g_lastAIActionPrevious == "SELL" && posType == POSITION_TYPE_SELL)
            {
               shouldClose = true;
               Print("   ?? SURVEILLANCE SELL - ", posSymbol, " | Ticket: ", posTicket, " | Profit: ", DoubleToString(posProfit, 2), "$");
            }
            
            if(shouldClose)
            {
               double holdLossThreshold = GetHoldAutoCloseLossThresholdForSymbol(posSymbol);
               if(posProfit <= -holdLossThreshold)
               {
                  Print("   ?? SEUIL DE PERTE ATTEINT - ", DoubleToString(posProfit, 2), "$ <= -",
                        DoubleToString(holdLossThreshold, 2), "$");
                  Print("   ?? FERMETURE AUTOMATIQUE sur HOLD - seuil ", DoubleToString(holdLossThreshold, 2), "$");
                  
                  // Fermer la position
                  MqlTradeRequest request = {};
                  MqlTradeResult result = {};
                  
                  request.action = TRADE_ACTION_DEAL;
                  request.position = posTicket;
                  request.symbol = posSymbol;
                  request.volume = PositionGetDouble(POSITION_VOLUME);
                  request.type = (posType == POSITION_TYPE_BUY) ? ORDER_TYPE_SELL : ORDER_TYPE_BUY;
                  request.price = (posType == POSITION_TYPE_BUY) ? SymbolInfoDouble(posSymbol, SYMBOL_BID) : SymbolInfoDouble(posSymbol, SYMBOL_ASK);
                  request.deviation = 10;
                  request.magic = InpMagicNumber;
                  request.comment = "IA HOLD Auto-Close (Loss <= -" + DoubleToString(holdLossThreshold, 2) + "$)";
                  
                  if(OrderSend(request, result))
                  {
                     Print("? POSITION FERMÃE - ", posSymbol, " | Ticket: ", posTicket, " | Profit: ", DoubleToString(posProfit, 2), "$");
                     
                     // Disabled: PlacePostHoldLimitOrder() peut crÃĐer des pending
                     // LIMIT (BUY_LIMIT/SELL_LIMIT). Objectif: aucune limite,
                     // uniquement market via touch M5.
                     // PlacePostHoldLimitOrder(posSymbol, posType, posProfit);
                  }
                  else
                  {
                     Print("? ERREUR FERMETURE - ", posSymbol, " | Erreur: ", result.comment);
                  }
               }
               else
               {
                  Print("   ? SURVEILLANCE CONTINUE - Perte: ", DoubleToString(posProfit, 2), "$ > -",
                        DoubleToString(holdLossThreshold, 2), "$ (seuil non atteint)");
                  Print("   ?? Attente HOLD - Position maintenue jusqu'Ã  perte <= -",
                        DoubleToString(holdLossThreshold, 2), "$");
               }
            }
         }
      }
   }
   
   // Mettre Ã  jour l'action prÃĐcÃĐdente
   g_lastAIActionPrevious = g_lastAIAction;
}
bool IsMaxPositionsReached()
{
   // NOUVEAU: Limite de 1 position OU ordre par symbole
   if(CountPositionsForSymbol(_Symbol) + CountOrdersForSymbol(_Symbol) >= 1)
   {
      static datetime lastSymbolLog = 0;
      if(TimeCurrent() - lastSymbolLog >= 60)
      {
         Print("â LIMITE ATTEINTE: DÃĐjÃ  1 position ou ordre ouvert sur ", _Symbol);
         lastSymbolLog = TimeCurrent();
      }
      return true;
   }

   int totalPositions = PositionsTotal();
   
   // NOUVEAU: Protection capital faible - Si < 20$, limiter Ã  1 position seulement
   double accountEquity = AccountInfoDouble(ACCOUNT_EQUITY);
   int maxAllowedPositions = (accountEquity < 20.0) ? 1 : MaxPositionsTerminal;
   
   // Si on a dÃĐjÃ  le nombre maximum de positions autorisÃĐes, bloquer les nouveaux trades
   if(totalPositions >= maxAllowedPositions)
   {
      // Si exactement le nombre maximum, log d'information
      if(totalPositions == maxAllowedPositions)
      {
         static datetime lastLog = 0;
         if(TimeCurrent() - lastLog >= 60) // Log toutes les minutes maximum
         {
            if(accountEquity < 20.0)
            {
               Print("?? CAPITAL FAIBLE - ÃquitÃĐ: ", DoubleToString(accountEquity, 2), "$ < 20.00$");
               Print("   ?? LIMITATION Ã 1 POSITION SEULEMENT pour protÃĐger le capital");
            }
            else
            {
               Print("??? PROTECTION CAPITAL - ", totalPositions, "/", maxAllowedPositions, " positions atteintes (sur symboles diffÃĐrents)");
            }
            
            Print("   ?? Positions actuelles :");
            for(int i = 0; i < totalPositions; i++)
            {
               if(PositionGetTicket(i) > 0)
               {
                  string posSymbol = PositionGetString(POSITION_SYMBOL);
                  double posProfit = PositionGetDouble(POSITION_PROFIT);
                  ENUM_POSITION_TYPE posType = (ENUM_POSITION_TYPE)PositionGetInteger(POSITION_TYPE);
                  ulong posTicket = PositionGetInteger(POSITION_TICKET);
                  
                  Print("   - ", posType == POSITION_TYPE_BUY ? "BUY" : "SELL", " ", posSymbol, 
                        " | Ticket: ", posTicket, " | Profit: ", DoubleToString(posProfit, 2), "$");
               }
            }
            
            if(accountEquity < 20.0)
            {
               Print("   ?? NOUVEAUX TRADES BLOQUÃS - Capital faible, 1 position max");
            }
            else
            {
               Print("   ?? NOUVEAUX TRADES BLOQUÃS jusqu'Ã  libÃĐration d'une position");
               Print("   ?? RÃĻgle: Max ", maxAllowedPositions, " positions sur symboles diffÃĐrents autorisÃĐes");
            }
            lastLog = TimeCurrent();
         }
      }
      return true; // Bloquer les nouveaux trades
   }
   
   return false; // Autoriser les trades
}

//| OBTENIR LA DIRECTION DE LA FLÃCHE DERIV ARROW |
bool GetDerivArrowDirection(string &direction)
{
   direction = "";
   
   // NOUVEAU: MÃMOIRE DES FLÃCHES DÃJÃ DÃTECTÃES
   static string lastDetectedArrow = "";
   static datetime lastDetectedTime = 0;
   
   // Chercher les objets flÃĻche sur le graphique
   for(int i = ObjectsTotal(0, -1, OBJ_ARROW) - 1; i >= 0; i--)
   {
      string objName = ObjectName(0, i, -1, OBJ_ARROW);
      
      // VÃĐrifier si c'est une flÃĻche Deriv Arrow - PLUS SPÃCIFIQUE
      bool isDerivArrow = false;
      if(StringFind(objName, "DERIV") >= 0 || StringFind(objName, "Deriv") >= 0 || 
         StringFind(objName, "ARROW") >= 0 || StringFind(objName, "Arrow") >= 0 ||
         StringFind(objName, "SIGNAL") >= 0 || StringFind(objName, "Signal") >= 0)
      {
         isDerivArrow = true;
      }
      
      // VÃRIFICATION SUPPLÃMENTAIRE: chercher les grandes flÃĻches typiques
      if(!isDerivArrow)
      {
         // Noms de grandes flÃĻches trading
         if(StringFind(objName, "BUY") >= 0 || StringFind(objName, "SELL") >= 0 ||
            StringFind(objName, "ENTRY") >= 0 || StringFind(objName, "Entry") >= 0 ||
            StringFind(objName, "TRADE") >= 0 || StringFind(objName, "Trade") >= 0)
         {
            isDerivArrow = true;
         }
      }
      
      if(!isDerivArrow) continue;
      
      datetime objTime = (datetime)ObjectGetInteger(0, objName, OBJPROP_TIME, 0);
      datetime currentTime = TimeCurrent();
      
      // La flÃĻche doit ÃŠtre sur les 3 derniÃĻres bougies maximum (plus rÃĐactif)
      if(currentTime - objTime <= PeriodSeconds() * 3)
      {
         // VÃĐrifier que la flÃĻche est VRAIMENT visible (propriÃĐtÃĐs visuelles)
         color arrowColor = (color)ObjectGetInteger(0, objName, OBJPROP_COLOR);
         int arrowWidth = (int)ObjectGetInteger(0, objName, OBJPROP_WIDTH);
         bool arrowVisible = (bool)ObjectGetInteger(0, objName, OBJPROP_TIME, 0) > 0;
         
         // IGNORER les flÃĻches trop petites ou invisibles
         if(arrowWidth < 2 || !arrowVisible)
         {
            Print("?? FlÃĻche ignorÃĐe - Trop petite ou invisible: ", objName, " | Width: ", arrowWidth);
            continue;
         }
         
         // CrÃĐer une clÃĐ unique pour cette flÃĻche
         string arrowKey = _Symbol + "_" + objName + "_" + TimeToString(objTime, TIME_MINUTES);
         
         // VÃĐrifier si cette flÃĻche a dÃĐjÃ  ÃĐtÃĐ dÃĐtectÃĐe
         if(lastDetectedArrow == arrowKey && (currentTime - lastDetectedTime) < 300) // 5 minutes
         {
            continue; // Ignorer cette flÃĻche dÃĐjÃ  traitÃĐe
         }
         
         // Vert = BUY, Rouge = SELL
         if(arrowColor == clrGreen || arrowColor == clrLime || arrowColor == clrForestGreen)
         {
            direction = "BUY";
            Print("?? GRANDE FLÃCHE VERTE DÃTECTÃE - Signal BUY sur ", _Symbol, 
                  " | Objet: ", objName, 
                  " | Width: ", arrowWidth,
                  " | Time: ", TimeToString(objTime, TIME_SECONDS));
            
            // MÃMORISER CETTE FLÃCHE COMME DÃTECTÃE
            lastDetectedArrow = arrowKey;
            lastDetectedTime = currentTime;
            return true;
         }
         else if(arrowColor == clrRed || arrowColor == clrCrimson || arrowColor == clrIndianRed)
         {
            direction = "SELL";
            Print("?? GRANDE FLÃCHE ROUGE DÃTECTÃE - Signal SELL sur ", _Symbol,
                  " | Objet: ", objName,
                  " | Width: ", arrowWidth,
                  " | Time: ", TimeToString(objTime, TIME_SECONDS));
            
            // MÃMORISER CETTE FLÃCHE COMME DÃTECTÃE
            lastDetectedArrow = arrowKey;
            lastDetectedTime = currentTime;
            return true;
         }
         else
         {
            // Si la couleur n'est pas claire, essayer de deviner par le code de la flÃĻche
            long arrowCode = ObjectGetInteger(0, objName, OBJPROP_ARROWCODE);
            
            // Codes de flÃĻche UP (BUY) - plus de codes pour les grandes flÃĻches
            if(arrowCode == 241 || arrowCode == 242 || arrowCode == 233 || arrowCode == 225 ||
               arrowCode == 67 || arrowCode == 68 || arrowCode == 71 || arrowCode == 72) // Codes grandes flÃĻches
            {
               direction = "BUY";
               Print("?? GRANDE FLÃCHE UP DÃTECTÃE - Signal BUY sur ", _Symbol, 
                     " (code: ", arrowCode, ") | Objet: ", objName,
                     " | Width: ", arrowWidth);
               
               // MÃMORISER CETTE FLÃCHE COMME DÃTECTÃE
               lastDetectedArrow = arrowKey;
               lastDetectedTime = currentTime;
               return true;
            }
            // Codes de flÃĻche DOWN (SELL) - plus de codes pour les grandes flÃĻches
            else if(arrowCode == 240 || arrowCode == 243 || arrowCode == 234 || arrowCode == 226 ||
                     arrowCode == 76 || arrowCode == 77 || arrowCode == 78 || arrowCode == 79) // Codes grandes flÃĻches
            {
               direction = "SELL";
               Print("?? GRANDE FLÃCHE DOWN DÃTECTÃE - Signal SELL sur ", _Symbol,
                     " (code: ", arrowCode, ") | Objet: ", objName,
                     " | Width: ", arrowWidth);
               
               // MÃMORISER CETTE FLÃCHE COMME DÃTECTÃE
               lastDetectedArrow = arrowKey;
               lastDetectedTime = currentTime;
               return true;
            }
            else
            {
               Print("?? FlÃĻche ignorÃĐe - Code non reconnu: ", arrowCode, " | Objet: ", objName);
            }
         }
      }
   }
   
   return false;
}

//| Scan graphique: flÃĻche DERIV visible maintenant (sans cache lastDetected â pour push apparition/disparition) |
bool ScanChartForDerivArrowDirectionRaw(string &directionOut)
{
   directionOut = "";
   for(int i = ObjectsTotal(0, -1, OBJ_ARROW) - 1; i >= 0; i--)
   {
      string objName = ObjectName(0, i, -1, OBJ_ARROW);

      bool isDerivArrow = false;
      if(StringFind(objName, "DERIV") >= 0 || StringFind(objName, "Deriv") >= 0 ||
         StringFind(objName, "ARROW") >= 0 || StringFind(objName, "Arrow") >= 0 ||
         StringFind(objName, "SIGNAL") >= 0 || StringFind(objName, "Signal") >= 0)
         isDerivArrow = true;
      if(!isDerivArrow)
      {
         if(StringFind(objName, "BUY") >= 0 || StringFind(objName, "SELL") >= 0 ||
            StringFind(objName, "ENTRY") >= 0 || StringFind(objName, "Entry") >= 0 ||
            StringFind(objName, "TRADE") >= 0 || StringFind(objName, "Trade") >= 0)
            isDerivArrow = true;
      }
      if(!isDerivArrow) continue;

      // FlÃĻche EA clignotante: ne pas traiter comme ÂŦ disparue Âŧ quand elle est masquÃĐe une frame
      if(StringFind(objName, "SMC_DERIV_ARROW") >= 0)
      {
         long tfVis = ObjectGetInteger(0, objName, OBJPROP_TIMEFRAMES);
         if(tfVis == OBJ_NO_PERIODS)
            continue;
      }

      datetime objTime = (datetime)ObjectGetInteger(0, objName, OBJPROP_TIME, 0);
      datetime currentTime = TimeCurrent();
      if(currentTime - objTime > PeriodSeconds() * 3)
         continue;

      color arrowColor = (color)ObjectGetInteger(0, objName, OBJPROP_COLOR);
      int arrowWidth = (int)ObjectGetInteger(0, objName, OBJPROP_WIDTH);
      bool arrowVisible = (ObjectGetInteger(0, objName, OBJPROP_TIME, 0) > 0);
      if(arrowWidth < 2 || !arrowVisible)
         continue;

      if(arrowColor == clrGreen || arrowColor == clrLime || arrowColor == clrForestGreen)
      {
         directionOut = "BUY";
         return true;
      }
      if(arrowColor == clrRed || arrowColor == clrCrimson || arrowColor == clrIndianRed)
      {
         directionOut = "SELL";
         return true;
      }

      long arrowCode = ObjectGetInteger(0, objName, OBJPROP_ARROWCODE);
      if(arrowCode == 241 || arrowCode == 242 || arrowCode == 233 || arrowCode == 225 ||
         arrowCode == 67 || arrowCode == 68 || arrowCode == 71 || arrowCode == 72)
      {
         directionOut = "BUY";
         return true;
      }
      if(arrowCode == 240 || arrowCode == 243 || arrowCode == 234 || arrowCode == 226 ||
         arrowCode == 76 || arrowCode == 77 || arrowCode == 78 || arrowCode == 79)
      {
         directionOut = "SELL";
         return true;
      }
   }
   return false;
}

// DÃĐtection tolÃĐrante pour IA80: toute flÃĻche M1 rÃĐcente verte/rouge (ou code flÃĻche), sans filtre sur le nom dâobjet
bool ChartHasColoredSignalArrowForBoomCrashDir(const string needDir)
{
   string nd = needDir;
   StringToUpper(nd);
   if(nd != "BUY" && nd != "SELL") return false;

   int lb = MathMax(3, IA80ArrowLookbackM1Bars);
   int maxAgeSec = (int)(PeriodSeconds(PERIOD_M1) * lb);
   int minW = MathMax(1, IA80ArrowMinObjWidth);

   for(int i = ObjectsTotal(0, -1, OBJ_ARROW) - 1; i >= 0; i--)
   {
      string objName = ObjectName(0, i, -1, -1);
      if(objName == "") continue;

      if(StringFind(objName, "SMC_DERIV_ARROW") >= 0)
      {
         long tfVis = ObjectGetInteger(0, objName, OBJPROP_TIMEFRAMES);
         if(tfVis == OBJ_NO_PERIODS) continue;
      }

      datetime objTime = (datetime)ObjectGetInteger(0, objName, OBJPROP_TIME, 0);
      if(objTime <= 0) continue;
      if((int)(TimeCurrent() - objTime) > maxAgeSec) continue;

      int arrowWidth = (int)ObjectGetInteger(0, objName, OBJPROP_WIDTH);
      if(arrowWidth < minW) continue;

      string found = "";
      color arrowColor = (color)ObjectGetInteger(0, objName, OBJPROP_COLOR);
      if(arrowColor == clrGreen || arrowColor == clrLime || arrowColor == clrForestGreen ||
         arrowColor == clrSpringGreen || arrowColor == clrAqua)
         found = "BUY";
      else if(arrowColor == clrRed || arrowColor == clrCrimson || arrowColor == clrIndianRed ||
              arrowColor == clrTomato || arrowColor == clrOrangeRed)
         found = "SELL";
      else
      {
         long arrowCode = ObjectGetInteger(0, objName, OBJPROP_ARROWCODE);
         if(arrowCode == 241 || arrowCode == 242 || arrowCode == 233 || arrowCode == 225 ||
            arrowCode == 67 || arrowCode == 68 || arrowCode == 71 || arrowCode == 72)
            found = "BUY";
         else if(arrowCode == 240 || arrowCode == 243 || arrowCode == 234 || arrowCode == 226 ||
                 arrowCode == 76 || arrowCode == 77 || arrowCode == 78 || arrowCode == 79)
            found = "SELL";
      }

      if(found == nd) return true;
   }
   return false;
}

// FlÃĻche ÂŦ pure Âŧ Boom/Crash: vert = BUY (sans aqua/cyan), rouge = SELL (sans orange/tomato) â pas de fallback code flÃĻche.
bool ChartHasPureColorArrowForBoomCrashDir(const string needDir)
{
   string nd = needDir;
   StringToUpper(nd);
   if(nd != "BUY" && nd != "SELL") return false;

   int lb = MathMax(3, IA80ArrowLookbackM1Bars);
   int maxAgeSec = (int)(PeriodSeconds(PERIOD_M1) * lb);
   int minW = MathMax(1, IA80ArrowMinObjWidth);

   for(int i = ObjectsTotal(0, -1, OBJ_ARROW) - 1; i >= 0; i--)
   {
      string objName = ObjectName(0, i, -1, -1);
      if(objName == "") continue;

      if(StringFind(objName, "SMC_DERIV_ARROW") >= 0)
      {
         long tfVis = ObjectGetInteger(0, objName, OBJPROP_TIMEFRAMES);
         if(tfVis == OBJ_NO_PERIODS) continue;
      }

      datetime objTime = (datetime)ObjectGetInteger(0, objName, OBJPROP_TIME, 0);
      if(objTime <= 0) continue;
      if((int)(TimeCurrent() - objTime) > maxAgeSec) continue;

      int arrowWidth = (int)ObjectGetInteger(0, objName, OBJPROP_WIDTH);
      if(arrowWidth < minW) continue;

      color arrowColor = (color)ObjectGetInteger(0, objName, OBJPROP_COLOR);
      if(nd == "BUY")
      {
         if(arrowColor == clrGreen || arrowColor == clrLime || arrowColor == clrForestGreen)
            return true;
      }
      else
      {
         if(arrowColor == clrRed || arrowColor == clrCrimson || arrowColor == clrIndianRed)
            return true;
      }
   }
   return false;
}

// Heure (OBJPROP_TIME) de la flÃĻche colorÃĐe la plus rÃĐcente alignÃĐe avec needDir (mÃŠmes critÃĻres que ChartHasColoredSignalArrowForBoomCrashDir)
bool GetLatestColoredSignalArrowTimeForBoomCrashDir(const string needDir, datetime &timeOut)
{
   timeOut = 0;
   string nd = needDir;
   StringToUpper(nd);
   if(nd != "BUY" && nd != "SELL") return false;

   int lb = MathMax(3, IA80ArrowLookbackM1Bars);
   int maxAgeSec = (int)(PeriodSeconds(PERIOD_M1) * lb);
   int minW = MathMax(1, IA80ArrowMinObjWidth);

   datetime best = 0;
   for(int i = ObjectsTotal(0, -1, OBJ_ARROW) - 1; i >= 0; i--)
   {
      string objName = ObjectName(0, i, -1, -1);
      if(objName == "") continue;

      if(StringFind(objName, "SMC_DERIV_ARROW") >= 0)
      {
         long tfVis = ObjectGetInteger(0, objName, OBJPROP_TIMEFRAMES);
         if(tfVis == OBJ_NO_PERIODS) continue;
      }

      datetime objTime = (datetime)ObjectGetInteger(0, objName, OBJPROP_TIME, 0);
      if(objTime <= 0) continue;
      if((int)(TimeCurrent() - objTime) > maxAgeSec) continue;

      int arrowWidth = (int)ObjectGetInteger(0, objName, OBJPROP_WIDTH);
      if(arrowWidth < minW) continue;

      string found = "";
      color arrowColor = (color)ObjectGetInteger(0, objName, OBJPROP_COLOR);
      if(arrowColor == clrGreen || arrowColor == clrLime || arrowColor == clrForestGreen ||
         arrowColor == clrSpringGreen || arrowColor == clrAqua)
         found = "BUY";
      else if(arrowColor == clrRed || arrowColor == clrCrimson || arrowColor == clrIndianRed ||
              arrowColor == clrTomato || arrowColor == clrOrangeRed)
         found = "SELL";
      else
      {
         long arrowCode = ObjectGetInteger(0, objName, OBJPROP_ARROWCODE);
         if(arrowCode == 241 || arrowCode == 242 || arrowCode == 233 || arrowCode == 225 ||
            arrowCode == 67 || arrowCode == 68 || arrowCode == 71 || arrowCode == 72)
            found = "BUY";
         else if(arrowCode == 240 || arrowCode == 243 || arrowCode == 234 || arrowCode == 226 ||
                 arrowCode == 76 || arrowCode == 77 || arrowCode == 78 || arrowCode == 79)
            found = "SELL";
      }

      if(found == nd && objTime > best)
         best = objTime;
   }

   if(best <= 0) return false;
   timeOut = best;
   return true;
}

//| EXÃCUTER UN TRADE BASÃ SUR LA FLÃCHE DERIV ARROW |
void ExecuteDerivArrowTrade(string direction)
{
   if(!IsHighVolatilityCapitalGatePassed(_Symbol, "DERIV ARROW"))
      return;

   if(!IsTrendAlignedEntry(direction))
   {
      Print("ðŦ DERIV ARROW BLOQUÃ - Filtre de tendance SMC sur ", _Symbol, " : ", direction);
      return;
   }

   if(!IsDirectionAllowedForBoomCrash(_Symbol, direction))
   {
      Print("ðŦ DERIV ARROW BLOQUÃ - Direction interdite sur ", _Symbol, " : ", direction);
      return;
   }

   if(!IsBoomCrashDirectionAllowedByIA(_Symbol, direction))
   {
      Print("ðŦ DERIV ARROW BLOQUÃ - Direction vs IA (Boom/Crash) sur ", _Symbol, " : ", direction);
      return;
   }

   Print("?? DÃBUT ANALYSE FLÃCHE DERIV ARROW - Direction: ", direction, " | Symbole: ", _Symbol);

   // Ãviter de trader en "correction" (zone d'ÃĐquilibre ICT)
   if(IsInEquilibriumCorrectionZone())
   {
      Print("ðŦ DERIV ARROW bloquÃĐ - Zone de correction autour de l'ÃĐquilibre sur ", _Symbol);
      return;
   }

   if(!IsSpreadAcceptable()) return;
   if(!(g_derivArrowAppearanceFastMode && DerivArrowAppearanceBypassEntryCooldown) && IsEntryCooldownActive()) return;
   if(!(g_derivArrowAppearanceFastMode && DerivArrowAppearanceBypassLastCandleConfirm) && !IsLastCandleConfirmingDirection(direction)) return;

   if(!PassReflectiveEntryGate(direction, "DERIV_ARROW", false))
      return;
   
   // NOUVEAU: VÃRIFICATION PROTECTION CAPITAL - MAX 2 POSITIONS
   if(IsMaxPositionsReached())
   {
      Print("?? FLÃCHE DERIV ARROW BLOQUÃE - Protection capital activÃĐe (max ", MaxPositionsTerminal, " positions)");
      return;
   }
   Print("? Protection capital OK");
   
   // NOUVEAU: VÃRIFICATION CONFIANCE IA MINIMALE
   bool isBoomRecoveryBypass = (g_allowBoomM5ArrowRecoveryBypass && IsBoomSymbol(_Symbol) && direction == "BUY");

   // Boom/Crash: rÃĻgle demandÃĐe = IA serveur alignÃĐe avec confiance >= 70%
   double minArrowConf = 0.75;
   if(IsBoomCrashOrWeltradeDirectionalSynth(_Symbol))
      minArrowConf = 0.70;

   if(!IsAIConfidenceAtLeast(minArrowConf, "DERIV ARROW", false))
      return;

   if(UseAIServer && !isBoomRecoveryBypass)
   {
      double aiConfidenceUnit = NormalizeAIConfidenceUnit();
      // Boom/Crash sur flÃĻche: appliquer STRICTEMENT le seuil demandÃĐ (70%) sans surcouche "catÃĐgorie".
      // Sinon, un seuil catÃĐgorie (ex: 75%) peut bloquer un signal valide Ã  71%.
      double minAiConfUnit = (IsBoomCrashOrWeltradeDirectionalSynth(_Symbol))
                             ? minArrowConf
                             : GetCategoryMinAIConfidencePercent(_Symbol);
      // MinAIConfidencePercent peut ÃŠtre fourni en % (65) ou en unitÃĐ (0.65)
      if(minAiConfUnit > 1.0)
         minAiConfUnit /= 100.0;

      // Ajustement optionnel par filtre propice (extra en % ou unitÃĐ)
      // (dÃĐsactivÃĐ pour Boom/Crash sur flÃĻche: la rÃĻgle spike prime)
      if(!(IsBoomCrashOrWeltradeDirectionalSynth(_Symbol)) &&
         UsePropiceSymbolsFilter && PropiceAllowMarketOrdersOnAllPropiceSymbols &&
         g_currentSymbolIsPropice && g_currentSymbolPriority > 0)
      {
         double extra = (double)g_currentSymbolPriority * PropiceNonTopExtraMinAIConfidencePercentPerRank;
         if(PropiceNonTopExtraMinAIConfidencePercentPerRank > 1.0)
            extra /= 100.0;
         minAiConfUnit += extra;
      }

      // Respecter le minimum global, mais Boom/Crash demandÃĐ Ã  70%
      minAiConfUnit = MathMax(minAiConfUnit, minArrowConf);

      Print("?? VÃĐrification IA - Confiance: ", DoubleToString(aiConfidenceUnit * 100.0, 1),
            "% | Action: ", g_lastAIAction);

      if(aiConfidenceUnit < minAiConfUnit)
      {
         Print("?? FLÃCHE DERIV ARROW BLOQUÃE - Confiance IA insuffisante: ", 
               DoubleToString(aiConfidenceUnit * 100.0, 1), "% < ",
               DoubleToString(minAiConfUnit * 100.0, 1), "% minimum");
         Print("   ?? IA Action: ", g_lastAIAction);
         return;
      }
      else
      {
         Print("â CONFIANCE IA VALIDÃE - ", DoubleToString(aiConfidenceUnit * 100.0, 1), "% âĨ ", 
               DoubleToString(minAiConfUnit * 100.0, 1), "% minimum");
      }
   }
   else if(UseAIServer && isBoomRecoveryBypass)
   {
      Print("âĄ DERIV ARROW recovery bypass actif (Boom BUY aprÃĻs touch M5 ratÃĐ) - IA stricte assouplie");
   }
   else
   {
      Print("?? Serveur IA dÃĐsactivÃĐ - Utilisation flÃĻche uniquement");
   }

   // Boom/Crash sur flÃĻche: ne pas bloquer ici sur fiabilitÃĐ ML locale (IA serveur + flÃĻche = autoritÃĐ).
   if(!(IsBoomCrashOrWeltradeDirectionalSynth(_Symbol)))
   {
      if(!IsMLModelTrustedForCurrentSymbol(direction))
      {
         Print("ðŦ FLÃCHE DERIV ARROW BLOQUÃE - ModÃĻle ML non fiable pour ", _Symbol);
         return;
      }
   }
   
   // Validation : Boom = BUY ; Crash = SELL ; GainX = BUY ; PainX = SELL
   bool isBoom = IsBoomSymbol(_Symbol);
   bool isCrash = IsCrashSymbol(_Symbol);
   bool isGainSym = IsWeltradeGainSynthSymbol(_Symbol);
   bool isPainSym = IsWeltradePainSynthSymbol(_Symbol);
   
   Print("?? Validation symbole - Boom: ", isBoom, " | Crash: ", isCrash,
         " | GainX: ", isGainSym, " | PainX: ", isPainSym, " | Direction: ", direction);
   
   if(isBoom && direction != "BUY")
   {
      Print("?? FLÃCHE DERIV ARROW IGNOREE - ", direction, " sur Boom (seul BUY autorisÃĐ)");
      return;
   }
   
   if(isCrash && direction != "SELL")
   {
      Print("?? FLÃCHE DERIV ARROW IGNOREE - ", direction, " sur Crash (seul SELL autorisÃĐ)");
      return;
   }
   if(isGainSym && direction != "BUY")
   {
      Print("?? FLÃCHE DERIV ARROW IGNOREE - ", direction, " sur GainX (seul BUY autorisÃĐ)");
      return;
   }
   if(isPainSym && direction != "SELL")
   {
      Print("?? FLÃCHE DERIV ARROW IGNOREE - ", direction, " sur PainX (seul SELL autorisÃĐ)");
      return;
   }
   Print("? Validation symbole OK");
   
   // VÃĐrifier que l'IA n'est pas en HOLD
   if(UseAIServer && (g_lastAIAction == "HOLD" || g_lastAIAction == "hold"))
   {
      Print("?? FLÃCHE DERIV ARROW BLOQUÃE - IA en HOLD sur ", _Symbol);
      return;
   }
   Print("? IA non-HOLD OK");

   // DÃĐcision finale = ML + stratÃĐgie interne: la direction de la flÃĻche doit ÃŠtre cohÃĐrente avec la dÃĐcision ML
   if(UseAIServer && !isBoomRecoveryBypass)
   {
      string mlAction = g_lastAIAction;
      StringToUpper(mlAction);
      if(mlAction != direction)
      {
         Print("ðŦ FLÃCHE DERIV ARROW BLOQUÃE - Direction flÃĻche (", direction, ") != dÃĐcision ML (", mlAction, ") sur ", _Symbol);
         return;
      }
   }
   
   // Boom/Crash sur flÃĻche: ne pas bloquer sur Premium/Discount (spikes peuvent arriver en transition).
   if(!(IsBoomCrashOrWeltradeDirectionalSynth(_Symbol)))
   {
      bool inDiscount = IsInDiscountZone();
      bool inPremium  = IsInPremiumZone();
      
      Print("?? Zones SMC - Discount: ", inDiscount, " | Premium: ", inPremium);
      
      if(!inDiscount && !inPremium)
      {
         Print("?? FLÃCHE DERIV ARROW BLOQUÃE - Prix dans zone d'ÃĐquilibre sur ", _Symbol, 
               " (ni Premium ni Discount) - Trade non autorisÃĐ");
         return;
      }
      Print("? Zone SMC OK (ni Premium ni Discount)");
   }
   
   // Protection capital: zone d'achat au bord infÃĐrieur ? SELL seulement si confiance IA >= 85%
   if(direction == "SELL" && IsAtDiscountLowerEdge() && g_lastAIConfidence < 0.85)
   {
      Print("?? FLÃCHE DERIV ARROW BLOQUÃE - Zone Discount au bord infÃĐrieur: SELL autorisÃĐ seulement si confiance IA ? 85% (actuel: ",
            DoubleToString(g_lastAIConfidence*100, 1), "%)");
      return;
   }
   // Protection capital: zone premium au bord supÃĐrieur (Boom / GainX) ? BUY seulement si confiance IA >= 85%
   if(direction == "BUY" && (isBoom || isGainSym) && IsAtPremiumUpperEdge() && g_lastAIConfidence < 0.85)
   {
      Print("?? FLÃCHE DERIV ARROW BLOQUÃE - Zone Premium au bord supÃĐrieur (Boom/GainX): BUY autorisÃĐ seulement si confiance IA ? 85% (actuel: ",
            DoubleToString(g_lastAIConfidence*100, 1), "%)");
      return;
   }
   
   // PROTECTION CONTRE LES PERTES PAR SYMBOLE - VÃĐrifier avant tout
   if(CheckSymbolLossProtection())
   {
      Print("ðĻ FLÃCHE DERIV ARROW BLOQUÃE - Protection symbole activÃĐe sur ", _Symbol);
      Print("   ð° Perte actuelle: ", DoubleToString(g_symbolCurrentLoss, 2), "$ > Limite: ", DoubleToString(MaxLossPerSymbolDollars, 2), "$");
      return;
   }
   
   // FILTRE PRIORITÃ SYMBOLES PROPICES - ignorer pour Boom/Crash sur flÃĻche (capture spike).
   if(UsePropiceSymbolsFilter && !(IsBoomCrashOrWeltradeDirectionalSynth(_Symbol)))
   {
      if(!g_currentSymbolIsPropice && !PreferBestSymbolWithoutBlocking)
      {
         Print("ðŦ FLÃCHE DERIV ARROW BLOQUÃE - Symbole non 'propice': ", _Symbol);
         Print("   Heure UTC: ", TimeToString(TimeCurrent(), TIME_SECONDS), " | Top propices: ", g_propiceTopSymbolsText);
         Print("   ðŦ BLOCAGE TOTAL - Aucun trade autorisÃĐ sur les symboles non propices");
         return;
      }
      else if(!g_currentSymbolIsPropice && PreferBestSymbolWithoutBlocking)
      {
         Print("â ïļ FLÃCHE DERIV ARROW - symbole non propice mais autorisÃĐ (mode opportunitÃĐs max): ", _Symbol);
      }
      
      // Avant: blocage total si pas rang 0.
      // Maintenant: si le symbole est propice, on autorise, mais on pourra exiger plus de confiance (voir bloc ci-dessous).
      if(!IsMostPropiceSymbol())
      {
         Print("â ïļ FLÃCHE DERIV ARROW - Symbole propice rang >", g_currentSymbolPriority + 1,
               " | autorisÃĐ (prioritÃĐ) sur ", _Symbol);
      }
      else
      {
         Print("ðĨ SYMBOLE LE PLUS PROPICE - FlÃĻche Deriv Arrow autorisÃĐe: ", _Symbol);
         Print("   â PrioritÃĐ maximale - ExÃĐcution autorisÃĐe");
      }
   }
   Print("ðĄ Le robot trade UNIQUEMENT sur les symboles les plus performants selon l'heure actuelle");

   // Lock global pour ÃĐviter double ouverture via chemins diffÃĐrents
   if(!TryAcquireOpenLock())
   {
      Print("?? FLÃCHE DERIV ARROW BLOQUÃE - lock indisponible (anti-duplication tick)");
      return;
   }

   // Anti-duplication/exposition:
   // - pending existant => toujours bloquÃĐ
   // - position existante => ouverture possible seulement si CanOpenAdditionalPositionForSymbol autorise
   int pendingExp = CountPendingOrdersForSymbol(_Symbol);
   int existingExp = CountPositionsForSymbol(_Symbol);
   if(pendingExp > 0)
   {
      Print("?? FLÃCHE DERIV ARROW BLOQUÃE - pending dÃĐjÃ  existant sur ", _Symbol);
      ReleaseOpenLock();
      return;
   }
   if(existingExp > 0 && !CanOpenAdditionalPositionForSymbol(_Symbol, direction))
   {
      Print("?? FLÃCHE DERIV ARROW BLOQUÃE - duplication interdite sur ", _Symbol,
            " | existing=", existingExp, " | dir=", direction);
      ReleaseOpenLock();
      return;
   }
   Print("? Anti-duplication OK (lock + exposition)");
   
   Print("?? TOUTES LES VALIDATIONS RÃUSSIES - EXÃCUTION DU TRADE...");
   
   // NOUVEAU: MÃMOIRE DES FLÃCHES DÃJÃ TRAITÃES
   static string lastProcessedArrow = "";
   static datetime lastProcessedTime = 0;
   
   // CrÃĐer une clÃĐ unique pour cette flÃĻche (symbole + direction + heure OBJPROP_TIME de la flÃĻche).
   datetime arrowTime = 0;
   if(!GetLatestColoredSignalArrowTimeForBoomCrashDir(direction, arrowTime))
      arrowTime = TimeCurrent();
   string currentArrowKey = _Symbol + "_" + direction + "_" + TimeToString(arrowTime, TIME_MINUTES);
   
   // VÃĐrifier si cette flÃĻche a dÃĐjÃ  ÃĐtÃĐ traitÃĐe rÃĐcemment
   if(lastProcessedArrow == currentArrowKey && (TimeCurrent() - lastProcessedTime) < 300) // 5 minutes
   {
      Print("?? FLÃCHE DERIV ARROW DÃJÃ TRAITÃE - ", direction, " sur ", _Symbol, " (ignorer pour ÃĐviter duplication)");
      ReleaseOpenLock();
      return;
   }
   
   // Obtenir le prix actuel
   MqlRates r[];
   ArraySetAsSeries(r, true);
   if(CopyRates(_Symbol, PERIOD_CURRENT, 0, 1, r) < 1)
   {
      Print("? ERREUR - Impossible d'obtenir les prix pour ", _Symbol);
      ReleaseOpenLock();
      return;
   }
   
   double currentPrice = r[0].close;
   double stopLoss, takeProfit;

   // NOUVEAU: FOREX/MÃTAUX - entrÃĐe uniquement sur pullback proche des EMA (ÃĐvite entrÃĐe en extension)
   ENUM_SYMBOL_CATEGORY catNow = SMC_GetSymbolCategory(_Symbol);
   if(catNow == SYM_FOREX || catNow == SYM_METAL || catNow == SYM_COMMODITY)
   {
      double e21, e31, dist, maxDist;
      if(!IsPriceNearEMAPullbackZone(direction, currentPrice, e21, e31, dist, maxDist))
      {
         static datetime lastEmaBlockLog = 0;
         if(TimeCurrent() - lastEmaBlockLog >= 60)
         {
            Print("â ENTRY BLOQUÃE (EMA pullback) - ", _Symbol, " ", direction,
                  " | Prix=", DoubleToString(currentPrice, _Digits),
                  " | EMA21=", DoubleToString(e21, _Digits),
                  " | EMA31=", DoubleToString(e31, _Digits),
                  " | DistZone=", DoubleToString(dist, _Digits),
                  " > Max=", DoubleToString(maxDist, _Digits));
            lastEmaBlockLog = TimeCurrent();
         }
         ReleaseOpenLock();
         return;
      }
   }
   
   // NOUVEAU: CALCUL SL/TP CORRECT POUR ÃVITER "INVALID STOPS"
   // Approche robuste : stopsLevel broker + buffer spÃĐcifique Boom/Crash + arrondi tick size
   long stopsLevel = SymbolInfoInteger(_Symbol, SYMBOL_TRADE_STOPS_LEVEL);
   double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   double tickSize = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_SIZE);
   if(tickSize <= 0.0) tickSize = point;
   
   // Distance minimale obligatoire du courtier
   bool isWeltradeSynth = IsWeltradeGainSynthSymbol(_Symbol) || IsWeltradePainSynthSymbol(_Symbol);
   double minStopDistance = (double)stopsLevel * point;
   
   // Si stopsLevel = 0, utiliser une distance par dÃĐfaut sÃĐcuritaire
   if(minStopDistance <= 0)
   {
      if(isCrash || isBoom || isWeltradeSynth)
      {
         minStopDistance = MathMax(1.0, BoomCrashSlMinPointsFloor) * point;
      }
      else
      {
         minStopDistance = 20 * point; // 20 pips pour autres
      }
   }
   else if(isCrash || isBoom || isWeltradeSynth)
   {
      // MÃŠme avec stopsLevel non nul, certains synthÃĐtiques refusent des stops trop proches
      minStopDistance = MathMax(minStopDistance, MathMax(1.0, BoomCrashSlBrokerFloorPoints) * point);
   }
   
   // Buffer plus conservateur pour absorber variation spread/tick au moment de l'envoi
   double bcSlMult = BoomCrashSlSafeDistanceMult;
   if(bcSlMult < 1.01) bcSlMult = 1.01;
   double safeDistance = minStopDistance * ((isCrash || isBoom || isWeltradeSynth) ? bcSlMult : 2.0);
   
   // Calculer SL/TP selon la direction
   if(direction == "BUY")
   {
      stopLoss = currentPrice - safeDistance;
      takeProfit = currentPrice + (safeDistance * 2.0);
   }
   else // SELL
   {
      stopLoss = currentPrice + safeDistance;
      takeProfit = currentPrice - (safeDistance * 2.0);
   }
   
   Print("?? DEBUG SL/TP - ", _Symbol, " ", direction, 
         " | Prix: ", DoubleToString(currentPrice, _Digits),
         " | Courtier StopsLevel: ", stopsLevel,
         " | MinDistance: ", DoubleToString(minStopDistance, _Digits),
         " | SafeDistance: ", DoubleToString(safeDistance, _Digits),
         " | SL: ", DoubleToString(stopLoss, _Digits),
         " | TP: ", DoubleToString(takeProfit, _Digits));
   
   // VALIDATION FINALE DES DISTANCES
   double askPrice = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   double bidPrice = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   
   if(direction == "BUY")
   {
      // VÃĐrifier que SL est assez loin de l'ask
      if(askPrice - stopLoss < safeDistance)
      {
         stopLoss = askPrice - safeDistance;
         Print("?? SL ajustÃĐ pour BUY sur ", _Symbol, " | Nouveau SL: ", DoubleToString(stopLoss, _Digits));
      }
      // VÃĐrifier que TP est assez loin de l'ask
      if(takeProfit - askPrice < safeDistance)
      {
         takeProfit = askPrice + (safeDistance * 2.0);
         Print("?? TP ajustÃĐ pour BUY sur ", _Symbol, " | Nouveau TP: ", DoubleToString(takeProfit, _Digits));
      }
   }
   else // SELL
   {
      // VÃĐrifier que SL est assez loin du bid
      if(stopLoss - bidPrice < safeDistance)
      {
         stopLoss = bidPrice + safeDistance;
         Print("?? SL ajustÃĐ pour SELL sur ", _Symbol, " | Nouveau SL: ", DoubleToString(stopLoss, _Digits));
      }
      // VÃĐrifier que TP est assez loin du bid
      if(bidPrice - takeProfit < safeDistance)
      {
         takeProfit = bidPrice - (safeDistance * 2.0);
         Print("?? TP ajustÃĐ pour SELL sur ", _Symbol, " | Nouveau TP: ", DoubleToString(takeProfit, _Digits));
      }
   }
   
   // Aligner strictement SL/TP sur le tick size, avec arrondi orientÃĐ pour garder la validitÃĐ
   if(direction == "BUY")
   {
      stopLoss = MathFloor(stopLoss / tickSize) * tickSize;     // SL en dessous
      takeProfit = MathCeil(takeProfit / tickSize) * tickSize;  // TP au-dessus
   }
   else
   {
      stopLoss = MathCeil(stopLoss / tickSize) * tickSize;      // SL au-dessus
      takeProfit = MathFloor(takeProfit / tickSize) * tickSize; // TP en dessous
   }
   stopLoss = NormalizeDouble(stopLoss, _Digits);
   takeProfit = NormalizeDouble(takeProfit, _Digits);
   
   // ExÃĐcuter l'ordre au marchÃĐ
   MqlTradeRequest request = {};
   MqlTradeResult result = {};
   
   request.action = TRADE_ACTION_DEAL;
   request.symbol = _Symbol;
   double lotToTrade = CalculateLotSize();
   if(lotToTrade <= 0.0)
   {
      Print("ðŦ DERIV ARROW - Volume calculÃĐ nul (probablement zone correction / pause / blocage) sur ", _Symbol);
      ReleaseOpenLock();
      return;
   }
   request.volume = lotToTrade;
   request.type = (direction == "BUY") ? ORDER_TYPE_BUY : ORDER_TYPE_SELL;
   if(!IsOrderTypeAllowedForBoomCrash(_Symbol, request.type))
   {
      Print("ðŦ ORDRE DERIV ARROW BLOQUÃ - Type interdit pour ", _Symbol);
      return;
   }
   request.price = (direction == "BUY") ? askPrice : bidPrice;
   EnforceMinBoomCrashStopLossDollarRisk(_Symbol, direction, request.price, request.volume, stopLoss);
   request.sl = stopLoss;
   request.tp = takeProfit;
   request.deviation = 20;
   request.magic = InpMagicNumber;
   request.comment = "DERIV ARROW " + direction;
   
   if(!IsMinimumProfitPotentialMet(request.price, takeProfit, direction, lotToTrade))
   {
      ReleaseOpenLock();
      return;
   }
   
   if(OrderSend(request, result) && (result.retcode == TRADE_RETCODE_DONE || result.retcode == 10009))
   {
      g_lastEntryTimeForSymbol = TimeCurrent();
      double execPrice = result.price;
      if(execPrice <= 0.0)
         execPrice = ((direction == "BUY") ? askPrice : bidPrice);
      Print("? ORDRE DERIV ARROW EXÃCUTÃ - ", direction, " sur ", _Symbol,
            " | Prix: ", DoubleToString(execPrice, _Digits),
            " | SL: ", DoubleToString(stopLoss, _Digits),
            " | TP: ", DoubleToString(takeProfit, _Digits),
            " | Ticket: ", result.order);
      // Notification d'information APRÃS exÃĐcution confirmÃĐe.
      SendDerivArrowNotification(direction, execPrice, stopLoss, takeProfit);
      NotifyTradeEvent("â POSITION OUVERTE - DERIV ARROW " + direction + " " + _Symbol +
                       " | Ticket: " + IntegerToString((int)result.order), EntryTradeSoundFile);
      
      // MÃMORISER CETTE FLÃCHE COMME TRAITÃE
      lastProcessedArrow = currentArrowKey;
      lastProcessedTime = TimeCurrent();
   }
   else
   {
      Print("? ÃCHEC ORDRE DERIV ARROW - retcode=", result.retcode,
            " | comment=", result.comment,
            " | lastError=", GetLastError());
   }

   ReleaseOpenLock();
}

// Alignement avec GetCurrentTrendDirection(): reprise directionnelle avant validation OTE+Imbalance diffÃĐrÃĐe
bool IsOTEImbalanceDirectionAlignedWithResumedTrend(const string dirUpper)
{
   string t = GetCurrentTrendDirection();
   if(dirUpper == "BUY")  return (t == "UPTREND");
   if(dirUpper == "SELL") return (t == "DOWNTREND");
   return false;
}

// Corps commun: notification setup, filtres IA/ML, envoi d'ordre (appelÃĐ aprÃĻs filtre correction / pending)
void ExecuteOTEImbalanceTradeCore(const string d, const double entry, const double slIn, const double tpIn, const bool useFlexible, const int currentPositions, const int maxPositions)
{
   if(!IsDirectionAllowedForBoomCrash(_Symbol, d)) return;
   if(IsMaxPositionsReached()) return;

   ENUM_SYMBOL_CATEGORY cat = SMC_GetSymbolCategory(_Symbol);
   double sl = slIn;
   double tp = tpIn;

   NotifyRobotEventOncePerBar("OTE_IMB_SETUP_" + _Symbol + "_" + d,
                              "ð OTE+Imbalance setup validÃĐ (" + d + ") - " + _Symbol + " @ " + DoubleToString(entry, _Digits),
                              EntryTradeSoundFile,
                              PERIOD_M1);

   if(UsePropiceSymbolsFilter && !g_currentSymbolIsPropice)
   {
      Print("â OTE+Imbalance bloquÃĐ - symbole non propice: ", _Symbol);
      return;
   }

   if(UseAIServer)
   {
      string ia = g_lastAIAction;
      StringToUpper(ia);
      double confPct = g_lastAIConfidence * 100.0;

      if(ia == "" || ia == "HOLD")
      {
         Print("â OTE+Imbalance bloquÃĐ - IA HOLD/absente sur ", _Symbol);
         return;
      }

      if(ia != d)
      {
         if(useFlexible)
         {
            double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
            double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
            double currentPrice = (d == "BUY") ? ask : bid;

            bool strongConfluence = IsStrongOTEFVGConfluence(currentPrice, d);
            double minConfOverride = (cat == SYM_FOREX) ? OTE_MinConfidenceForex : OTE_MinConfidenceOther;

            if(!strongConfluence || confPct < minConfOverride)
            {
               Print("â OTE+Imbalance bloquÃĐ - IA=", ia, " != ", d, " sur ", _Symbol,
                     " (", DoubleToString(confPct, 1), "%) - Confluence insuffisante");
               return;
            }
            Print("â ïļ OTE+Imbalance AUTORISÃ malgrÃĐ IA â  direction - Confluence forte sur ", _Symbol);
         }
         else
         {
            Print("â OTE+Imbalance bloquÃĐ - IA=", ia, " != ", d, " sur ", _Symbol,
                  " (", DoubleToString(confPct, 1), "%)");
            return;
         }
      }

      // OTE setup marchÃĐ: confiance minimale dÃĐdiÃĐe (demande utilisateur: 60% min).
      double minConfidence = OTESetupMarketMinAIConfidencePercent;
      if(minConfidence <= 0.0) minConfidence = 60.0;

      if(confPct < minConfidence)
      {
         Print("â OTE+Imbalance bloquÃĐ - Confiance IA trop faible: ",
               DoubleToString(confPct, 1), "% < ", DoubleToString(minConfidence, 1),
               "% sur ", _Symbol);
         return;
      }
   }

   if(!IsMLModelTrustedForCurrentSymbol(d))
   {
      if(useFlexible)
      {
         double minAccuracy = 0.65;
         if(g_mlLastAccuracy < minAccuracy && !IsStrongOTEFVGConfluence(SymbolInfoDouble(_Symbol, d == "BUY" ? SYMBOL_ASK : SYMBOL_BID), d))
         {
            Print("â OTE+Imbalance bloquÃĐ - ModÃĻle ML non fiable sur ", _Symbol,
                  " (acc=", DoubleToString(g_mlLastAccuracy * 100.0, 1), "%)");
            return;
         }
         if(g_mlLastAccuracy >= minAccuracy)
            Print("â ïļ OTE+Imbalance AUTORISÃ malgrÃĐ ML moyen - Confluence forte sur ", _Symbol);
      }
      else
      {
         Print("â OTE+Imbalance bloquÃĐ - ModÃĻle ML non fiable sur ", _Symbol,
               " (acc=", DoubleToString(g_mlLastAccuracy * 100.0, 1), "%)");
         return;
      }
   }

   if(!TryAcquireOpenLock()) return;

   double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   int stopsLevel = (int)SymbolInfoInteger(_Symbol, SYMBOL_TRADE_STOPS_LEVEL);
   double minDist = MathMax((double)stopsLevel * point, point * 10.0);

   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   double price = (d == "BUY") ? ask : bid;

   if(d == "BUY")
   {
      if(price - sl < minDist) sl = price - minDist;
      if(tp - price < minDist) tp = price + minDist * 2.0;
   }
   else
   {
      if(sl - price < minDist) sl = price + minDist;
      if(price - tp < minDist) tp = price - minDist * 2.0;
   }

   sl = NormalizeDouble(sl, _Digits);
   tp = NormalizeDouble(tp, _Digits);

   double lot = CalculateLotSize();
   lot = NormalizeVolumeForSymbol(lot);

   bool ok = false;
   string comment = useFlexible ? "OTE_IMBALANCE_FLEX" : "OTE_IMBALANCE";
   if(d == "BUY")
      ok = trade.Buy(lot, _Symbol, 0.0, sl, tp, comment);
   else
      ok = trade.Sell(lot, _Symbol, 0.0, sl, tp, comment);

   if(ok)
   {
      string modeStr = useFlexible ? "FLEXIBLE" : "STRICT";
      Print("â OTE+Imbalance ", modeStr, " EXECUTÃ ", d, " ", _Symbol,
            " | lot=", DoubleToString(lot, 2),
            " | SL=", DoubleToString(sl, _Digits),
            " | TP=", DoubleToString(tp, _Digits),
            " | Positions: ", currentPositions + 1, "/", maxPositions);
   }
   else
   {
      string modeStr = useFlexible ? "FLEXIBLE" : "STRICT";
      Print("â OTE+Imbalance ", modeStr, " ÃĐchouÃĐ ", d, " ", _Symbol,
            " | Erreur: ", trade.ResultRetcode(), " - ", trade.ResultComment());
   }

   ReleaseOpenLock();
}

// ExÃĐcute la stratÃĐgie OTE + Imbalance (FVG) amÃĐliorÃĐe avec logique flexible SMC_OTE
void ExecuteOTEImbalanceTrade()
{
   ENUM_SYMBOL_CATEGORY symCat = SMC_GetSymbolCategory(_Symbol);
   if(!(symCat == SYM_FOREX || symCat == SYM_METAL || symCat == SYM_COMMODITY))
      return;

   bool useFlexible = OTE_UseFlexibleLogic;
   int maxPositions = OTE_MaxPositionsPerSymbol;

   if(CheckSymbolLossProtection())
   {
      Print("ðĻ OTE+Imbalance BLOQUÃE - Protection symbole activÃĐe sur ", _Symbol);
      Print("   ð° Perte actuelle: ", DoubleToString(g_symbolCurrentLoss, 2), "$ > Limite: ", DoubleToString(MaxLossPerSymbolDollars, 2), "$");
      return;
   }

   if(UsePropiceSymbolsFilter)
   {
      if(!g_currentSymbolIsPropice && !PreferBestSymbolWithoutBlocking)
      {
         Print("ðŦ OTE+Imbalance BLOQUÃE - Symbole non 'propice': ", _Symbol);
         Print("   Heure UTC: ", TimeToString(TimeCurrent(), TIME_SECONDS), " | Top propices: ", g_propiceTopSymbolsText);
         Print("   ðŦ BLOCAGE TOTAL - Aucun trade autorisÃĐ sur les symboles non propices");
         return;
      }
      else if(!g_currentSymbolIsPropice && PreferBestSymbolWithoutBlocking)
      {
         Print("â ïļ OTE+Imbalance - symbole non propice mais autorisÃĐ (mode opportunitÃĐs max): ", _Symbol);
      }

      if(!IsMostPropiceSymbol())
      {
         if(!PropiceAllowMarketOrdersOnAllPropiceSymbols)
         {
            string mostPropice = GetMostPropiceSymbol();
            Print("ðŦ OTE+Imbalance BLOQUÃE - Symbole pas le plus propice: ", _Symbol);
            Print("   ð Position actuelle: ", g_currentSymbolPriority + 1, "ÃĻme dans la liste");
            Print("   ðĨ Symbole le plus propice: ", mostPropice);
            Print("   ðŦ BLOCAGE TOTAL - Seul le symbole le plus propice peut ÃŠtre tradÃĐ");
            return;
         }
         Print("â ïļ OTE+Imbalance - Symbole propice rang >", g_currentSymbolPriority + 1,
               ") autorisÃĐ: ", _Symbol, " (prioritÃĐ seulement)");
      }
      else
      {
         Print("ðĨ SYMBOLE LE PLUS PROPICE - OTE+Imbalance autorisÃĐe: ", _Symbol);
         Print("   â PrioritÃĐ maximale - ExÃĐcution autorisÃĐe");
      }
   }

   if(IsMaxPositionsReached()) return;
   
   int currentPositions = CountPositionsForSymbol(_Symbol);
   if(g_oteImbPendingAfterCorrection)
   {
      if(g_oteImbPendingSymbol != _Symbol)
      {
         g_oteImbPendingAfterCorrection = false;
         g_oteImbPendingDir = "";
         g_oteImbPendingSymbol = "";
      }
      else if(OTE_BlockExecutionOnCorrectionZone && OTE_DeferImbalanceExecuteUntilTrendResumes)
      {
         int timeoutSec = OTE_DeferImbalanceTimeoutMinutes * 60;
         if(OTE_DeferImbalanceTimeoutMinutes > 0 && (TimeCurrent() - g_oteImbPendingSince) >= timeoutSec)
         {
            Print("âąïļ OTE+Imbalance pending annulÃĐ (timeout ", IntegerToString(OTE_DeferImbalanceTimeoutMinutes), " min) - ", _Symbol);
            g_oteImbPendingAfterCorrection = false;
            g_oteImbPendingDir = "";
            g_oteImbPendingSymbol = "";
         }
         else
         {
            string dirPend = "";
            double eP = 0.0, sP = 0.0, tP = 0.0;
            bool det = false;
            if(g_oteImbPendingUseFlexible)
               det = DetectOTEImbalanceSetupFlexible(dirPend, eP, sP, tP);
            else
               det = DetectOTEImbalanceSetup(dirPend, eP, sP, tP);
            if(!det)
            {
               Print("ð OTE+Imbalance pending abandonnÃĐ - setup plus valide - ", _Symbol);
               g_oteImbPendingAfterCorrection = false;
               g_oteImbPendingDir = "";
               g_oteImbPendingSymbol = "";
               return;
            }
            string dUp = dirPend;
            StringToUpper(dUp);
            string pdUp = g_oteImbPendingDir;
            StringToUpper(pdUp);
            if(dUp != pdUp)
            {
               Print("ð OTE+Imbalance pending abandonnÃĐ - direction changÃĐe (", pdUp, " â ", dUp, ") ", _Symbol);
               g_oteImbPendingAfterCorrection = false;
               g_oteImbPendingDir = "";
               g_oteImbPendingSymbol = "";
               return;
            }
            if(IsInEquilibriumCorrectionZone())
               return;
            if(!IsOTEImbalanceDirectionAlignedWithResumedTrend(dUp))
               return;

            currentPositions = CountPositionsForSymbol(_Symbol);
            if(currentPositions >= maxPositions)
               return;

            bool flexSave = g_oteImbPendingUseFlexible;
            g_oteImbPendingAfterCorrection = false;
            g_oteImbPendingDir = "";
            g_oteImbPendingSymbol = "";
            ExecuteOTEImbalanceTradeCore(dUp, eP, sP, tP, flexSave, currentPositions, maxPositions);
            return;
         }
      }
      else
      {
         g_oteImbPendingAfterCorrection = false;
         g_oteImbPendingDir = "";
         g_oteImbPendingSymbol = "";
      }
   }

   currentPositions = CountPositionsForSymbol(_Symbol);
   if(currentPositions >= maxPositions)
   {
      static datetime lastBlockLog = 0;
      if(TimeCurrent() - lastBlockLog >= 60)
      {
         Print("ðĄïļ OTE+Imbalance - ", maxPositions, " position(s) dÃĐjÃ  ouverte(s) sur ", _Symbol, " - Nouveaux trades bloquÃĐs");
         lastBlockLog = TimeCurrent();
      }
      return;
   }

   string dir;
   double entry, sl, tp;
   bool setupDetected = false;
   if(useFlexible)
      setupDetected = DetectOTEImbalanceSetupFlexible(dir, entry, sl, tp);
   else
      setupDetected = DetectOTEImbalanceSetup(dir, entry, sl, tp);

   if(!setupDetected)
      return;

   string d = dir;
   StringToUpper(d);

   if(OTE_DeferImbalanceExecuteUntilTrendResumes && OTE_BlockExecutionOnCorrectionZone && IsInEquilibriumCorrectionZone())
   {
      g_oteImbPendingAfterCorrection = true;
      g_oteImbPendingDir = d;
      g_oteImbPendingSymbol = _Symbol;
      g_oteImbPendingUseFlexible = useFlexible;
      g_oteImbPendingSince = TimeCurrent();
      Print("âģ OTE+Imbalance ARMÃ - Setup en zone correction; attente sortie zone + reprise tendance (",
            GetCurrentTrendDirection(), ") | ", _Symbol, " ", d);
      return;
   }

   ExecuteOTEImbalanceTradeCore(d, entry, sl, tp, useFlexible, currentPositions, maxPositions);
}

// NOUVEAU: DÃĐtection OTE+Imbalance flexible (logique SMC_OTE intÃĐgrÃĐe): ÃĐvite les entrÃĐes en extension / en pleine correction loin des EMA.
// Retourne true si le prix actuel est proche de la zone EMA21/EMA31 sur LTF, sinon false.
bool IsPriceNearEMAPullbackZone(const string direction, double currentPrice, double &ema21Out, double &ema31Out, double &distOut, double &maxDistOut)
{
   ema21Out = 0.0;
   ema31Out = 0.0;
   distOut = 0.0;
   maxDistOut = 0.0;

   if(ema21LTF == INVALID_HANDLE || ema31LTF == INVALID_HANDLE) return true; // fail-open

   double buf[];
   ArraySetAsSeries(buf, true);
   if(CopyBuffer(ema21LTF, 0, 0, 2, buf) < 1) return true;
   ema21Out = buf[0];
   if(CopyBuffer(ema31LTF, 0, 0, 2, buf) < 1) return true;
   ema31Out = buf[0];

   // ATR LTF pour distance max (tolÃĐrance)
   double atrVal = 0.0;
   if(atrHandle != INVALID_HANDLE)
   {
      double a[];
      ArraySetAsSeries(a, true);
      if(CopyBuffer(atrHandle, 0, 0, 2, a) >= 1)
         atrVal = a[0];
   }
   double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   if(atrVal <= 0.0) atrVal = point * 100.0;

   // Distance autorisÃĐe: 0.25 ATR (min 10 points)
   maxDistOut = MathMax(atrVal * 0.25, point * 10.0);

   double zoneLow = MathMin(ema21Out, ema31Out);
   double zoneHigh = MathMax(ema21Out, ema31Out);

   // Distance du prix Ã  la "zone EMA" (0 si dans la zone)
   if(currentPrice < zoneLow) distOut = zoneLow - currentPrice;
   else if(currentPrice > zoneHigh) distOut = currentPrice - zoneHigh;
   else distOut = 0.0;

   // Si dÃĐjÃ  dans la zone, OK
   if(distOut <= maxDistOut) return true;

   // Sinon, trop loin: on attend le pullback vers EMA
   return false;
}

// NOUVEAU: DÃĐtection OTE+Imbalance flexible (logique SMC_OTE intÃĐgrÃĐe)
bool DetectOTEImbalanceSetupFlexible(string &dirOut, double &entryOut, double &slOut, double &tpOut)
{
   dirOut = "";
   entryOut = 0.0;
   slOut = 0.0;
   tpOut = 0.0;

   ENUM_SYMBOL_CATEGORY cat = SMC_GetSymbolCategory(_Symbol);
   if(!(cat == SYM_FOREX || cat == SYM_METAL || cat == SYM_COMMODITY))
      return false;

   if(!UseFVG || !UseOTE)
      return false;

   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);

   // 1) DÃĐtection tendance via EMA HTF (plus flexible que SMC_OTE)
   bool bullHTF = IsBullishHTF();
   bool bearHTF = IsBearishHTF();
   if(!bullHTF && !bearHTF)
      return false;

   string dir = bullHTF ? "BUY" : "SELL";

   // 2) Swing High / Low rÃĐcents (logique SMC_OTE)
   if(!DetectNonRepaintingSwingPoints())
      return false;

   double lastSH, lastSL;
   datetime tSH, tSL;
   GetLatestConfirmedSwings(lastSH, tSH, lastSL, tSL);

   if(lastSH <= 0 || lastSL <= 0 || tSH == 0 || tSL == 0)
      return false;

   // 3) Zone OTE (0.62-0.786 du mouvement) - logique SMC_OTE
   double high = lastSH;
   double low  = lastSL;
   if(high <= low) return false;

   double range = high - low;
   double oteLow, oteHigh;

   if(dir == "BUY")
   {
      // OTE BUY: retracement 62-78.6% depuis le bas vers le haut
      oteHigh = low + range * 0.62;
      oteLow  = low + range * 0.786;
   }
   else
   {
      // OTE SELL: retracement 62-78.6% depuis le haut vers le bas
      oteLow  = high - range * 0.62;
      oteHigh = high - range * 0.786;
      if(oteLow > oteHigh)
      {
         double tmp = oteLow; oteLow = oteHigh; oteHigh = tmp;
      }
   }

   // 4) Imbalance (FVG) rÃĐcente sur LTF - logique SMC_OTE
   FVGData fvg;
   if(!SMC_DetectFVG(_Symbol, LTF, 40, fvg))
      return false;

   // Direction cohÃĐrente avec la tendance
   if((dir == "BUY" && fvg.direction != 1) ||
      (dir == "SELL" && fvg.direction != -1))
      return false;

   double fvgLow  = fvg.bottom;
   double fvgHigh = fvg.top;

   // 5) Confluence flexible (logique SMC_OTE) - chevauchement partiel autorisÃĐ
   double zoneLow  = MathMax(fvgLow, oteLow);
   double zoneHigh = MathMin(fvgHigh, oteHigh);

   // NOUVEAU: Confluence flexible - autoriser chevauchement partiel
   bool confluenceOk = (zoneHigh > zoneLow) || (MathAbs(zoneHigh - zoneLow) < (oteHigh - oteLow) * 0.3);
   
   if(!confluenceOk)
      return false;

   double price = (dir == "BUY") ? bid : ask;
   
   // 5) VÃRIFICATION CRUCIALE: Entrer uniquement sur niveaux techniques clÃĐs
   // Ãviter les entrÃĐes pendant les corrections
   if(OTE_UseTechnicalLevels)
   {
      bool isValidEntryLevel = false;
      double entryLevel = 0.0;
      string entrySource = "";
      
      // a) Support/RÃĐsistance 20 barres le plus proche
      double sr20Level = GetClosestSupportResistance20Bars(price, dir);
      if(sr20Level > 0)
      {
         double distToSR = MathAbs(price - sr20Level);
         double atr20 = GetATRValue(PERIOD_M15, 20);
         if(atr20 > 0 && distToSR <= atr20 * OTE_SR20_ATR_Tolerance)
         {
            isValidEntryLevel = true;
            entryLevel = sr20Level;
            entrySource = "SR20";
         }
      }
      
      // b) Niveaux Pivot Daily
      if(!isValidEntryLevel)
      {
         double pivotLevel = GetClosestPivotLevel(price, dir);
         if(pivotLevel > 0)
         {
            double distToPivot = MathAbs(price - pivotLevel);
            double atr20 = GetATRValue(PERIOD_M15, 20);
            if(atr20 > 0 && distToPivot <= atr20 * OTE_Pivot_ATR_Tolerance)
            {
               isValidEntryLevel = true;
               entryLevel = pivotLevel;
               entrySource = "PIVOT";
            }
         }
      }
      
      // c) Supertrend M5
      if(!isValidEntryLevel)
      {
         double stLevel = GetSupertrendLevelM5(dir);
         if(stLevel > 0)
         {
            double distToST = MathAbs(price - stLevel);
            double atr5 = GetATRValue(PERIOD_M5, 14);
            if(atr5 > 0 && distToST <= atr5 * OTE_ST_ATR_Tolerance)
            {
               isValidEntryLevel = true;
               entryLevel = stLevel;
               entrySource = "ST_M5";
            }
         }
      }
      
      // d) Trendline significative
      if(!isValidEntryLevel)
      {
         double tlLevel = GetClosestTrendlineLevel(price, dir);
         if(tlLevel > 0)
         {
            double distToTL = MathAbs(price - tlLevel);
            double atr20 = GetATRValue(PERIOD_M15, 20);
            if(atr20 > 0 && distToTL <= atr20 * OTE_TL_ATR_Tolerance)
            {
               isValidEntryLevel = true;
               entryLevel = tlLevel;
               entrySource = "TRENDLINE";
            }
         }
      }
      
      // BLOQUER si aucun niveau technique valide trouvÃĐ
      if(!isValidEntryLevel)
      {
         Print("â OTE+Imbalance BLOQUÃ - Aucun niveau technique valide pour ", dir,
               " | Prix: ", DoubleToString(price, _Digits),
               " | Direction: ", dir,
               " | Symbole: ", _Symbol);
         return false;
      }
      
      // VÃĐrification supplÃĐmentaire: ne pas entrer si le prix est en correction forte
      if(IsInStrongCorrection(price, dir))
      {
         Print("â OTE+Imbalance BLOQUÃ - Prix en correction forte sur ", _Symbol,
               " | Prix: ", DoubleToString(price, _Digits),
               " | Direction: ", dir,
               " | Niveau: ", entrySource, " @ ", DoubleToString(entryLevel, _Digits),
               " | Distance: ", DoubleToString(MathAbs(price - entryLevel), _Digits));
         return false;
      }
      
      Print("â OTE+Imbalance NIVEAU TECHNIQUE VALIDÃ - ", entrySource,
            " | Prix: ", DoubleToString(price, _Digits),
            " | Niveau: ", DoubleToString(entryLevel, _Digits),
            " | Direction: ", dir,
            " | Distance: ", DoubleToString(MathAbs(price - entryLevel), _Digits));
   }
   else
   {
      // Mode sans restriction technique (ancienne logique)
      Print("â ïļ OTE+Imbalance MODE SANS RESTRICTION TECHNIQUE - EntrÃĐe directe",
            " | Prix: ", DoubleToString(price, _Digits),
            " | Direction: ", dir);
   }

   // 6) SL/TP avec risque minimum (ÃĐviter SL trop proche)
   double buffer = MathMax(point * 10.0, range * 0.04); // Buffer plus "large"
   double sl, tp;
   if(dir == "BUY")
   {
      sl = zoneLow - buffer;
      double risk = price - sl;
      if(risk <= point * 5.0) return false;
      tp = price + (MathMax(3.0, InpRiskReward) * risk);
   }
   else
   {
      sl = zoneHigh + buffer;
      double risk = sl - price;
      if(risk <= point * 5.0) return false;
      tp = price - (MathMax(3.0, InpRiskReward) * risk);
   }

   dirOut = dir;
   entryOut = price;
   slOut = sl;
   tpOut = tp;

   return true;
}

// NOUVEAU: Fonctions techniques pour les niveaux d'entrÃĐe

// DÃĐtecter le support/rÃĐsistance 20 barres le plus proche
double GetClosestSupportResistance20Bars(double price, string direction)
{
   MqlRates rates[];
   ArraySetAsSeries(rates, true);
   if(CopyRates(_Symbol, PERIOD_M15, 0, 25, rates) < 20) return 0.0;
   
   double closestLevel = 0.0;
   double minDistance = DBL_MAX;
   
   for(int i = 1; i < 20; i++)
   {
      double level = (direction == "BUY") ? rates[i].low : rates[i].high;
      double distance = MathAbs(price - level);
      
      if(distance < minDistance)
      {
         minDistance = distance;
         closestLevel = level;
      }
   }
   
   return closestLevel;
}

// DÃĐtecter le niveau Pivot Daily le plus proche
double GetClosestPivotLevel(double price, string direction)
{
   double pivotPoints[4]; // [0]=S1, [1]=S2, [2]=R1, [3]=R2
   if(!CalculateDailyPivots(pivotPoints[0], pivotPoints[1], pivotPoints[2], pivotPoints[3]))
      return 0.0;
   
   double closestLevel = 0.0;
   double minDistance = DBL_MAX;
   
   // Pour BUY: chercher supports (S1, S2)
   // Pour SELL: chercher rÃĐsistances (R1, R2)
   int startIdx = (direction == "BUY") ? 0 : 2;
   int endIdx = (direction == "BUY") ? 2 : 4;
   
   for(int i = startIdx; i < endIdx; i++)
   {
      double distance = MathAbs(price - pivotPoints[i]);
      if(distance < minDistance)
      {
         minDistance = distance;
         closestLevel = pivotPoints[i];
      }
   }
   
   return closestLevel;
}

// Calculer les pivots daily
bool CalculateDailyPivots(double &s1, double &s2, double &r1, double &r2)
{
   MqlRates dailyRates[];
   ArraySetAsSeries(dailyRates, true);
   if(CopyRates(_Symbol, PERIOD_D1, 0, 2, dailyRates) < 2) return false;
   
   double high = dailyRates[1].high;
   double low = dailyRates[1].low;
   double close = dailyRates[1].close;
   
   double pivot = (high + low + close) / 3.0;
   double range = high - low;
   
   s1 = pivot - (range * 0.382);
   s2 = pivot - (range * 0.618);
   r1 = pivot + (range * 0.382);
   r2 = pivot + (range * 0.618);
   
   return true;
}

// DÃĐtecter le niveau Supertrend M5
double GetSupertrendLevelM5(string direction)
{
   int stHandle = iCustom(_Symbol, PERIOD_M5, "Supertrend", 10, 3.0);
   if(stHandle == INVALID_HANDLE) return 0.0;
   
   double stBuffer[];
   ArraySetAsSeries(stBuffer, true);
   if(CopyBuffer(stHandle, 0, 0, 2, stBuffer) < 1)
   {
      IndicatorRelease(stHandle);
      return 0.0;
   }
   
   double level = stBuffer[0];
   IndicatorRelease(stHandle);
   
   // VÃĐrifier que le niveau est cohÃĐrent avec la direction
   if(direction == "BUY" && level > 0) return level;
   if(direction == "SELL" && level > 0) return level;
   
   return 0.0;
}

// DÃĐtecter la trendline la plus proche
double GetClosestTrendlineLevel(double price, string direction)
{
   int total = ObjectsTotal(0, -1, OBJ_TREND);
   double closestLevel = 0.0;
   double minDistance = DBL_MAX;
   
   for(int i = 0; i < total; i++)
   {
      string name = ObjectName(0, i, -1, OBJ_TREND);
      if(StringFind(name, "Trendline") < 0 && StringFind(name, "TL") < 0) continue;
      
      datetime time1 = (datetime)ObjectGetInteger(0, name, OBJPROP_TIME, 0);
      datetime time2 = (datetime)ObjectGetInteger(0, name, OBJPROP_TIME, 1);
      double price1 = ObjectGetDouble(0, name, OBJPROP_PRICE, 0);
      double price2 = ObjectGetDouble(0, name, OBJPROP_PRICE, 1);
      
      if(time1 == 0 || time2 == 0) continue;
      
      // Calculer le niveau actuel de la trendline
      double slope = (price2 - price1) / (time2 - time1);
      double currentLevel = price1 + slope * (TimeCurrent() - time1);
      
      double distance = MathAbs(price - currentLevel);
      if(distance < minDistance)
      {
         minDistance = distance;
         closestLevel = currentLevel;
      }
   }
   
   return closestLevel;
}

// VÃĐrifier si le prix est en correction forte
bool IsInStrongCorrection(double price, string direction)
{
   MqlRates rates[];
   ArraySetAsSeries(rates, true);
   if(CopyRates(_Symbol, PERIOD_M15, 0, 10, rates) < 5) return false;
   
   double atr = GetATRValue(PERIOD_M15, 14);
   if(atr <= 0) return false;
   
   // Utiliser le paramÃĻtre configurÃĐ pour le seuil de correction
   double correctionThreshold = atr * OTE_Correction_ATR_Threshold;
   
   // Pour BUY: vÃĐrifier si le prix baisse fortement
   if(direction == "BUY")
   {
      double decline = rates[0].close - rates[4].close;
      if(decline < -correctionThreshold) // Baisse forte sur 5 bougies
      {
         Print("ð CORRECTION FORTE DÃTECTÃE - Baisse de ", DoubleToString(MathAbs(decline), _Digits),
               " points (seuil: ", DoubleToString(correctionThreshold, _Digits), ")");
         return true;
      }
   }
   else // SELL
   {
      double rise = rates[0].close - rates[4].close;
      if(rise > correctionThreshold) // Hausse forte sur 5 bougies
      {
         Print("ð CORRECTION FORTE DÃTECTÃE - Hausse de ", DoubleToString(rise, _Digits),
               " points (seuil: ", DoubleToString(correctionThreshold, _Digits), ")");
         return true;
      }
   }
   
   return false;
}

// Obtenir la valeur ATR
double GetATRValue(ENUM_TIMEFRAMES timeframe, int period)
{
   int handle = iATR(_Symbol, timeframe, period);
   if(handle == INVALID_HANDLE) return 0.0;
   
   double buffer[];
   ArraySetAsSeries(buffer, true);
   if(CopyBuffer(handle, 0, 0, 1, buffer) < 1)
   {
      IndicatorRelease(handle);
      return 0.0;
   }
   
   double value = buffer[0];
   IndicatorRelease(handle);
   return value;
}

// Obtenir la valeur ATR actuelle (M1) pour le scalping
double GetCurrentATRValue()
{
   if(atrHandle != INVALID_HANDLE)
   {
      double atr[];
      ArraySetAsSeries(atr, true);
      if(CopyBuffer(atrHandle, 0, 0, 1, atr) >= 1)
         return atr[0];
   }
   
   // Fallback: utiliser GetATRValue ou estimation
   double atr = GetATRValue(PERIOD_M1, 14);
   if(atr > 0) return atr;
   
   // Dernier fallback: estimation basÃĐe sur le prix
   double price = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   return price * 0.002; // 0.2% du prix comme approximation ATR
}

// NOUVEAU: Fonction pour vÃĐrifier la confluence forte OTE+FVG
bool IsStrongOTEFVGConfluence(double price, string direction)
{
   if(!UseFVG || !UseOTE) return false;

   // DÃĐtecter FVG rÃĐcent
   FVGData fvg;
   if(!SMC_DetectFVG(_Symbol, LTF, 40, fvg))
      return false;

   // DÃĐtecter swing points
   if(!DetectNonRepaintingSwingPoints())
      return false;

   double lastSH, lastSL;
   datetime tSH, tSL;
   GetLatestConfirmedSwings(lastSH, tSH, lastSL, tSL);

   if(lastSH <= 0 || lastSL <= 0) return false;

   // Calculer zone OTE
   double high = lastSH, low = lastSL;
   double range = high - low;
   double oteLow, oteHigh;

   if(direction == "BUY")
   {
      oteHigh = low + range * 0.62;
      oteLow  = low + range * 0.786;
   }
   else
   {
      oteLow  = high - range * 0.62;
      oteHigh = high - range * 0.786;
      if(oteLow > oteHigh)
      {
         double tmp = oteLow; oteLow = oteHigh; oteHigh = tmp;
      }
   }

   // VÃĐrifier confluence
   double zoneLow  = MathMax(fvg.bottom, oteLow);
   double zoneHigh = MathMin(fvg.top, oteHigh);

   // Confluence forte si:
   // 1. Intersection significative (>20% de la zone OTE)
   // 2. Prix proche de la zone de confluence
   double intersectionSize = zoneHigh - zoneLow;
   double oteSize = oteHigh - oteLow;
   
   bool strongIntersection = (intersectionSize > 0 && intersectionSize > oteSize * 0.2);
   bool priceNearZone = (price >= zoneLow - (oteSize * 0.1) && price <= zoneHigh + (oteSize * 0.1));

   return strongIntersection && priceNearZone;
}

// DÃĐtection de setup ICT-like: tendance claire + Imbalance (FVG) + zone OTE (0.62-0.786) alignÃĐes.
bool DetectOTEImbalanceSetup(string &dirOut, double &entryOut, double &slOut, double &tpOut)
{
   dirOut = "";
   entryOut = 0.0;
   slOut = 0.0;
   tpOut = 0.0;

   ENUM_SYMBOL_CATEGORY cat = SMC_GetSymbolCategory(_Symbol);
   if(!(cat == SYM_FOREX || cat == SYM_METAL || cat == SYM_COMMODITY))
      return false;

   if(!UseFVG || !UseOTE)
      return false;

   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);

   // 1) DÃĐtection tendance via EMA HTF
   bool bullHTF = IsBullishHTF();
   bool bearHTF = IsBearishHTF();
   if(!bullHTF && !bearHTF)
      return false;

   string dir = bullHTF ? "BUY" : "SELL";

   // 2) Swing High / Low rÃĐcents (structure)
   if(!DetectNonRepaintingSwingPoints())
      return false;

   double lastSH, lastSL;
   datetime tSH, tSL;
   GetLatestConfirmedSwings(lastSH, tSH, lastSL, tSL);

   if(lastSH <= 0 || lastSL <= 0 || tSH == 0 || tSL == 0)
      return false;

   // 3) Zone OTE (0.62-0.786 du mouvement)
   double high = lastSH;
   double low  = lastSL;
   if(high <= low) return false;

   double range = high - low;
   double oteLow, oteHigh;

   if(dir == "BUY")
   {
      // OTE BUY: retracement 62-78.6% depuis le bas vers le haut
      oteHigh = low + range * 0.62;
      oteLow  = low + range * 0.786;
   }
   else
   {
      // OTE SELL: retracement 62-78.6% depuis le haut vers le bas
      oteLow  = high - range * 0.62;
      oteHigh = high - range * 0.786;
      if(oteLow > oteHigh)
      {
         double tmp = oteLow; oteLow = oteHigh; oteHigh = tmp;
      }
   }

   // 4) Imbalance (FVG) rÃĐcente sur LTF
   FVGData fvg;
   if(!SMC_DetectFVG(_Symbol, LTF, 40, fvg))
      return false;

   // Direction cohÃĐrente avec la tendance
   if((dir == "BUY" && fvg.direction != 1) ||
      (dir == "SELL" && fvg.direction != -1))
      return false;

   double fvgLow  = fvg.bottom;
   double fvgHigh = fvg.top;

   // 5) Confluence: intersection FVG âĐ OTE
   double zoneLow  = MathMax(fvgLow, oteLow);
   double zoneHigh = MathMin(fvgHigh, oteHigh);

   if(zoneHigh <= zoneLow)
      return false;

   double price = (dir == "BUY") ? bid : ask;
   if(price < zoneLow || price > zoneHigh)
      return false; // attendre que le prix entre dans la zone confluente

   // 6) SL sous / au-dessus de la zone, TP >= 3R
   double buffer = MathMax(point * 15.0, range * 0.07);
   double sl, tp;
   if(dir == "BUY")
   {
      sl = zoneLow - buffer;
      double risk = price - sl;
      if(risk <= point * 8.0) return false;
      tp = price + (MathMax(3.0, InpRiskReward) * risk);
   }
   else
   {
      sl = zoneHigh + buffer;
      double risk = sl - price;
      if(risk <= point * 8.0) return false;
      tp = price - (MathMax(3.0, InpRiskReward) * risk);
   }

   dirOut = dir;
   entryOut = price;
   slOut = NormalizeDouble(sl, _Digits);
   tpOut = NormalizeDouble(tp, _Digits);

   return true;
}

//| ExÃĐcuter les ordres au marchÃĐ basÃĐs sur les dÃĐcisions IA SMC EMA   |
void ExecuteAIDecisionMarketOrder()
{
   // CatÃĐgorie du symbole pour adapter le seuil de confiance IA
   ENUM_SYMBOL_CATEGORY cat = SMC_GetSymbolCategory(_Symbol);
   double requiredConf = MinAIConfidence;
   // Pour tous les marchÃĐs HORS Boom/Crash: 85% minimum
   if(cat != SYM_BOOM_CRASH)
      requiredConf = 0.85;

   if(UseHighConfidenceFilterWhenSomeSymbolsProfitLocked)
   {
      int lockedCount = CountProfitTargetLockedSymbols();
      if(lockedCount >= LockedSymbolsMinCountForFilter)
      {
         double extraConf = ExtraMinAIConfidenceWhenLockedPercent / 100.0;
         requiredConf = MathMin(0.99, requiredConf + extraConf);
      }
   }

   // PrioritÃĐ "propice": si rang > 0, on rend l'entrÃĐe plus exigeante (sans bloquer totalement).
   if(UsePropiceSymbolsFilter && PropiceAllowMarketOrdersOnAllPropiceSymbols &&
      g_currentSymbolIsPropice && g_currentSymbolPriority > 0)
   {
      double rankExtraConf = (double)g_currentSymbolPriority * (PropiceNonTopExtraMinAIConfidencePercentPerRank / 100.0);
      requiredConf = MathMin(0.99, requiredConf + rankExtraConf);
   }
   
   // DÃĐcision IA normalisÃĐe
   string actMarketU = g_lastAIAction;
   StringToUpper(actMarketU);
   double confUnit = NormalizeAIConfidenceUnit();

   // Cas IA=HOLD: au lieu de "ne rien faire", on peut placer un LIMIT prÃĻs du SR le plus proche,
   // mais AVANT la ligne Entry M5 (entre prix actuel et g_m5*EntryLevel).
   if((actMarketU == "HOLD") && IA_HoldPlaceLimitBeforeM5Entry && EnableTrading && !BlockAllTrades)
   {
      if(confUnit + 1e-9 >= IA_HoldMinConfidence)
      {
         // Direction Ã  utiliser pendant HOLD:
         // - Boom/GainX => BUY ; Crash/PainX => SELL
         // - Sinon: choisir selon la pile EMA (BUY si strong BUY, SELL si strong SELL)
         string holdDir = "";
         if(IsBoomSymbol(_Symbol) || IsWeltradeGainSynthSymbol(_Symbol)) holdDir = "BUY";
         else if(IsCrashSymbol(_Symbol) || IsWeltradePainSynthSymbol(_Symbol)) holdDir = "SELL";
         else if(IsStrongM1M5TrendByEMAs("BUY")) holdDir = "BUY";
         else if(IsStrongM1M5TrendByEMAs("SELL")) holdDir = "SELL";

         if(holdDir != "" && IsDirectionAllowedForBoomCrash(_Symbol, holdDir))
            PlaceHoldLimitBeforeM5Entry(holdDir, confUnit);
      }
      return; // HOLD ne dÃĐclenche jamais un deal marchÃĐ ici
   }

   bool hasActionForMarket = (actMarketU == "BUY" || actMarketU == "SELL");
   bool derivArrowAlignedForMarket = hasActionForMarket &&
      HasRecentSMCDerivArrowForDirection(actMarketU);

   // Mode "EMA alignÃĐes + flÃĻche + conf>=seuil": entrÃĐe marchÃĐ immÃĐdiate, en relaxant les filtres secondaires.
   // IMPORTANT: ÃĐvaluÃĐ AVANT le filtre de confiance global pour ÃĐviter une entrÃĐe tardive.
   bool emaAlignedImmediate =
      IA_EmaAlignedExecuteMarket &&
      derivArrowAlignedForMarket &&
      hasActionForMarket &&
      (confUnit + 1e-9 >= IA_EmaAlignedMinConfidence) &&
      IsStrongM1M5TrendByEMAs(actMarketU);

   // RÃĻgle demandÃĐe:
   // - prioritÃĐ au STAIR_SETUP affichÃĐ
   // - sinon, fallback autorisÃĐ seulement si flÃĻche DERIV "pure" prÃĐsente et alignÃĐe.
   if(emaAlignedImmediate && !IsStairSetupDisplayedOnChartForDirection(actMarketU))
   {
      string pureArrowDir = "";
      bool hasPureDerivArrow = GetDerivArrowDirection(pureArrowDir);
      StringToUpper(pureArrowDir);
      bool pureArrowAligned = hasPureDerivArrow && (pureArrowDir == actMarketU);
      if(!pureArrowAligned)
      {
         static datetime s_lastEmaStairWaitLog = 0;
         if(TimeCurrent() - s_lastEmaStairWaitLog >= 15)
         {
            Print("âģ EMA alignÃĐes dÃĐtectÃĐes mais STAIR_SETUP non affichÃĐ et pas de flÃĻche DERIV pure alignÃĐe (",
                  actMarketU, ") sur ", _Symbol, " -> ordre marchÃĐ non exÃĐcutÃĐ.");
            s_lastEmaStairWaitLog = TimeCurrent();
         }
         return;
      }
   }

   double effectiveRequiredConf = requiredConf;
   if(emaAlignedImmediate)
      effectiveRequiredConf = MathMin(requiredConf, IA_EmaAlignedMinConfidence);

   // VÃĐrifier si on a une dÃĐcision IA valide pour marchÃĐ (avec seuil effectif corrigÃĐ)
   if(!hasActionForMarket || confUnit + 1e-9 < effectiveRequiredConf)
      return;

   bool skipSecondaryMarketFilters =
      (BypassSecondaryMarketFiltersWhenAIDerivArrow && derivArrowAlignedForMarket) ||
      emaAlignedImmediate;
   
   // NOUVEAU: Obtenir les prÃĐdictions de Protected Points futurs
   double futureSupport = 0.0, futureResistance = 0.0;
   bool hasFutureLevels = GetFutureProtectedPointLevels(futureSupport, futureResistance);
   
   double currentPrice = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   
   // VALIDATION SUPPLÃMENTAIRE BASÃE SUR LES PRÃDICTIONS FUTURES
   if(hasFutureLevels && !skipSecondaryMarketFilters)
   {
      // Si IA dit BUY, vÃĐrifier qu'on n'est pas trop prÃĻs d'une rÃĐsistance future
      if(g_lastAIAction == "BUY" && futureResistance > 0)
      {
         double distanceToResistance = futureResistance - currentPrice;
         double atr = GetATRValue(PERIOD_M15, 14);
         
         if(distanceToResistance < atr * 0.5) // Trop proche de la rÃĐsistance future
         {
            static datetime lastWarningLog = 0;
            if(TimeCurrent() - lastWarningLog >= 60) // Log toutes les minutes
            {
               Print("ðŦ IA BUY BLOQUÃ - Trop proche rÃĐsistance future: ", DoubleToString(futureResistance, _Digits));
               Print("   ð Distance: ", DoubleToString(distanceToResistance, _Digits), " < ", DoubleToString(atr * 0.5, _Digits));
               Print("   ðĄ Attendre un meilleur point d'entrÃĐe");
               lastWarningLog = TimeCurrent();
            }
            return;
         }
      }
      
      // Si IA dit SELL, vÃĐrifier qu'on n'est pas trop prÃĻs d'un support futur
      if(g_lastAIAction == "SELL" && futureSupport > 0)
      {
         double distanceToSupport = currentPrice - futureSupport;
         double atr = GetATRValue(PERIOD_M15, 14);
         
         if(distanceToSupport < atr * 0.5) // Trop proche du support future
         {
            static datetime lastWarningLog = 0;
            if(TimeCurrent() - lastWarningLog >= 60) // Log toutes les minutes
            {
               Print("ðŦ IA SELL BLOQUÃ - Trop proche support future: ", DoubleToString(futureSupport, _Digits));
               Print("   ð Distance: ", DoubleToString(distanceToSupport, _Digits), " < ", DoubleToString(atr * 0.5, _Digits));
               Print("   ðĄ Attendre un meilleur point d'entrÃĐe");
               lastWarningLog = TimeCurrent();
            }
            return;
         }
      }
      
      // LOG DES PRÃDICTIONS UTILISÃES
      static datetime lastPredictionLog = 0;
      if(TimeCurrent() - lastPredictionLog >= 300) // Log toutes les 5 minutes
      {
         Print("ðŪ PRÃDICTIONS FUTURES UTILISÃES - ", _Symbol);
         Print("   ðŊ Support futur: ", (futureSupport > 0 ? DoubleToString(futureSupport, _Digits) : "N/A"));
         Print("   ðŊ RÃĐsistance future: ", (futureResistance > 0 ? DoubleToString(futureResistance, _Digits) : "N/A"));
         Print("   ð Prix actuel: ", DoubleToString(currentPrice, _Digits));
         Print("   ðĪ Action IA: ", g_lastAIAction, " (confiance: ", DoubleToString(g_lastAIConfidence * 100, 1), "%)");
         lastPredictionLog = TimeCurrent();
      }
   }
   
   // HOLD dÃĐjÃ  gÃĐrÃĐ plus haut (LIMIT ÃĐventuel). Ici, on ne devrait plus ÃŠtre en HOLD.
   
   // Calculer une note de setup globale et bloquer si trop basse
   double setupScore = ComputeSetupScore(g_lastAIAction);

   if(UseHighConfidenceFilterWhenSomeSymbolsProfitLocked)
   {
      int lockedCount = CountProfitTargetLockedSymbols();
      if(lockedCount >= LockedSymbolsMinCountForFilter)
      {
         setupScore += ExtraMinSetupScoreWhenLocked;
      }
   }

   // PrioritÃĐ "propice": rang > 0 => seuil de setup plus strict (sans bloquer totalement).
   double minSetupScoreEntry = GetCategoryMinSetupScore(_Symbol);
   if(UsePropiceSymbolsFilter && PropiceAllowMarketOrdersOnAllPropiceSymbols &&
      g_currentSymbolIsPropice && g_currentSymbolPriority > 0)
   {
      minSetupScoreEntry += (double)g_currentSymbolPriority * PropiceNonTopExtraMinSetupScore;
   }

   if(!skipSecondaryMarketFilters && setupScore < minSetupScoreEntry)
   {
   // RÃĐduire la frÃĐquence des logs de setup score pour ÃĐviter la surcharge
   static datetime lastSetupScoreLog = 0;
   if(TimeCurrent() - lastSetupScoreLog >= 60) // Log toutes les 60 secondes maximum
   {
      Print("?? ORDRE IA BLOQUÃ - SetupScore trop bas: ",
            DoubleToString(setupScore, 1), " < ",
            DoubleToString(minSetupScoreEntry, 1),
            " pour ", _Symbol, " (", g_lastAIAction, ")");
      lastSetupScoreLog = TimeCurrent();
   }
      return;
   }
   
   Print("? ORDRES MARCHÃ AUTORISÃS - IA: ", g_lastAIAction,
         " | SetupScore=", DoubleToString(setupScore, 1));

   // RÃĐentrÃĐe aprÃĻs perte sur ce symbole: exiger conditions exceptionnelles
   if(!AllowReentryAfterRecentLoss(_Symbol, g_lastAIAction, false))
      return;

   // PROTECTION CONTRE LES PERTES PAR SYMBOLE - VÃĐrifier avant tout
   if(CheckSymbolLossProtection())
   {
      Print("ðĻ TRADE IA BLOQUÃ - Protection symbole activÃĐe sur ", _Symbol);
      Print("   ð° Perte actuelle: ", DoubleToString(g_symbolCurrentLoss, 2), "$ > Limite: ", DoubleToString(MaxLossPerSymbolDollars, 2), "$");
      Print("   ðŦ Trading sur ce symbole BLOQUÃ pour protection du capital");
      return;
   }
   
   // FILTRE PRIORITÃ SYMBOLES PROPICES - BLOCAGE TOTAL SI NON PRIORITAIRE
   if(UsePropiceSymbolsFilter)
   {
      if(!g_currentSymbolIsPropice && !PreferBestSymbolWithoutBlocking)
      {
         Print("ðŦ TRADE IA BLOQUÃ - Symbole non 'propice' actuellement: ", _Symbol);
         Print("   Heure UTC: ", TimeToString(TimeCurrent(), TIME_SECONDS), " | Top propices: ", g_propiceTopSymbolsText);
         Print("   ðĄ Le robot trade UNIQUEMENT sur les symboles les plus performants selon l'heure actuelle");
         Print("   ðŦ BLOCAGE TOTAL - Aucun trade autorisÃĐ sur les symboles non propices");
         return;
      }
      else if(!g_currentSymbolIsPropice && PreferBestSymbolWithoutBlocking)
      {
         Print("â ïļ TRADE IA - symbole non propice mais autorisÃĐ (mode opportunitÃĐs max): ", _Symbol);
      }
      
      // Avant: blocage total si pas rang 0.
      // Maintenant: on autorise si le symbole est propice (rang >0) et on appliquera des seuils plus stricts via requiredConf.
      if(!IsMostPropiceSymbol())
      {
         if(!PropiceAllowMarketOrdersOnAllPropiceSymbols)
         {
            string mostPropice = GetMostPropiceSymbol();
            Print("ðŦ TRADE IA BLOQUÃ - Symbole pas le plus propice: ", _Symbol);
            Print("   ð Position actuelle: ", g_currentSymbolPriority + 1, "ÃĻme dans la liste");
            Print("   ðĨ Symbole le plus propice: ", mostPropice);
            Print("   ðŦ BLOCAGE TOTAL - Seul le symbole le plus propice peut ÃŠtre tradÃĐ");
            return;
         }
         Print("â ïļ TRADE IA autorisÃĐ (propice rang >", g_currentSymbolPriority + 1,
               ") sur ", _Symbol, " - seuils plus stricts appliquÃĐs");
      }
      else
      {
         Print("ðĨ SYMBOLE LE PLUS PROPICE - Trading autorisÃĐ: ", _Symbol);
         Print("   â PrioritÃĐ maximale - Conditions de trading normales");
         Print("   ðŊ Confiance IA: ", DoubleToString(g_lastAIConfidence * 100, 1), "%");
      }
   }
   
   // VÃĐrification ANTI-DUPLICATION stricte - AUCUNE position sur CE symbole
   if(HasAnyExposureForSymbol(_Symbol))
   {
      Print("?? DUPLICATION BLOQUÃE - Exposition dÃĐjÃ  existante sur ", _Symbol, " (position ou ordre en attente)");
      return; // BLOQUER TOUTE duplication sur ce symbole
   }
   
   // BOOM/CRASH: exiger flÃĻche rÃĐcente OU (optionnel) tendance forte + confiance ML ÃĐlevÃĐe
   if(cat == SYM_BOOM_CRASH)
   {
      if(!HasRecentSMCDerivArrowForDirection(g_lastAIAction))
      {
         Print("?? ORDRES MARCHÃ BLOQUÃS SUR BOOM/CRASH - Pas de flÃĻche (ou conditions tendance forte non remplies) pour ", _Symbol);
         return;
      }
   }
   
   // BLOQUER LES ORDRES SI PRIX EST DANS UN RANGE
   if(!skipSecondaryMarketFilters && IsPriceInRange())
   {
      Print("?? ORDRES MARCHÃ BLOQUÃS - Prix dans un range sur ", _Symbol, " - Attente de breakout");
      return;
   }
   
   // VÃĐrifier le lock pour ÃĐviter les doublons
   if(!TryAcquireOpenLock()) return;
   
   // RÃĻgle Boom/Crash: pas de SELL sur Boom, pas de BUY sur Crash
   if(!IsDirectionAllowedForBoomCrash(_Symbol, g_lastAIAction))
   {
      Print("? Ordre IA ", g_lastAIAction, " bloquÃĐ sur ", _Symbol, " (rÃĻgle Boom/Crash)");
      ReleaseOpenLock();
      return;
   }
   
   // FILTRE TENDANCE STRICTE: EMA stack + OB confirmÃĐ + Fibo OTE
   if(!IsTrendAlignedEntry(g_lastAIAction))
   {
      Print("ðŦ IA SMC-EMA PRÃCIS BLOQUÃ - Filtre de tendance SMC sur ", _Symbol, " : ", g_lastAIAction);
      ReleaseOpenLock();
      return;
   }
   
   // VALIDATION MULTI-SIGNAUX POUR ENTRÃES PRÃCISES
   if(!ValidateEntryWithMultipleSignals(g_lastAIAction))
   {
      Print("? ENTRÃE BLOQUÃE - Validation multi-signaux ÃĐchouÃĐe pour ", g_lastAIAction, " sur ", _Symbol);
      ReleaseOpenLock();
      return;
   }
   
   // CALCULER L'ENTRÃE PRÃCISE AU LIEU DU PRIX ACTUEL
   double preciseEntry, preciseSL, preciseTP;
   if(!CalculatePreciseEntryPoint(g_lastAIAction, preciseEntry, preciseSL, preciseTP))
   {
      Print("? CALCUL D'ENTRÃE PRÃCISE ÃCHOUÃ pour ", g_lastAIAction, " sur ", _Symbol);
      ReleaseOpenLock();
      return;
   }

   // Valider/Ajuster SL/TP avant d'envoyer l'ordre prÃĐcis (stop-level broker + tick size)
   string dirForValidation = (g_lastAIAction == "BUY" || g_lastAIAction == "buy") ? "BUY" : "SELL";
   ValidateAndAdjustStopLossTakeProfit(dirForValidation, preciseEntry, preciseSL, preciseTP);

   double tickSize = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_SIZE);
   if(tickSize <= 0) tickSize = _Point;
   if(tickSize > 0)
   {
      preciseSL = MathRound(preciseSL / tickSize) * tickSize;
      preciseTP = MathRound(preciseTP / tickSize) * tickSize;
      preciseSL = NormalizeDouble(preciseSL, _Digits);
      preciseTP = NormalizeDouble(preciseTP, _Digits);
   }
   // Re-valider aprÃĻs arrondi tick
   ValidateAndAdjustStopLossTakeProfit(dirForValidation, preciseEntry, preciseSL, preciseTP);
   preciseSL = NormalizeDouble(preciseSL, _Digits);
   preciseTP = NormalizeDouble(preciseTP, _Digits);

   // CohÃĐrence direction SL/TP
   if(dirForValidation == "BUY")
   {
      if(preciseSL >= preciseEntry || preciseTP <= preciseEntry)
      {
         Print("â IA SMC-EMA PRÃCIS invalid SL/TP - sl=", DoubleToString(preciseSL, _Digits),
               " tp=", DoubleToString(preciseTP, _Digits), " entry=", DoubleToString(preciseEntry, _Digits));
         ReleaseOpenLock();
         return;
      }
   }
   else
   {
      if(preciseSL <= preciseEntry || preciseTP >= preciseEntry)
      {
         Print("â IA SMC-EMA PRÃCIS invalid SL/TP - sl=", DoubleToString(preciseSL, _Digits),
               " tp=", DoubleToString(preciseTP, _Digits), " entry=", DoubleToString(preciseEntry, _Digits));
         ReleaseOpenLock();
         return;
      }
   }
   
   double lot = CalculateLotSize();
   Print("ð DIAGNOSTIC VOLUME - ", _Symbol);
   Print("   ðĶ Lot calculÃĐ: ", DoubleToString(lot, 2));
   Print("   ð Min Lot: ", DoubleToString(SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN), 2));
   Print("   ð Max Lot: ", DoubleToString(SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MAX), 2));
   Print("   ð Lot Step: ", DoubleToString(SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_STEP), 2));
   
   if(lot <= 0)
   {
      Print("â VOLUME INVALIDE - Lot calculÃĐ: ", DoubleToString(lot, 2), " <= 0");
      ReleaseOpenLock();
      return;
   }
   
   bool orderExecuted = false;
   
   if(g_lastAIAction == "BUY" || g_lastAIAction == "buy")
   {
      if(!HasRecentSMCDerivArrowForDirection("BUY"))
      {
         Print("?? ORDRE MARCHÃ BLOQUÃ - Attendre flÃĻche SMC_DERIV_ARROW BUY sur ", _Symbol);
         ReleaseOpenLock();
         return;
      }
      // Utiliser l'entrÃĐe prÃĐcise calculÃĐe au lieu du prix actuel
      if(trade.Buy(lot, _Symbol, preciseEntry, preciseSL, preciseTP, "IA SMC-EMA BUY PRÃCIS"))
      {
         orderExecuted = true;
         
         // MatÃĐrialiser le setup OTE sur le graphique
         DrawOTESetup(preciseEntry, preciseSL, preciseTP, "BUY");
         
         Print("?? ORDRE BUY PRÃCIS EXÃCUTÃ - Entry: ", DoubleToString(preciseEntry, _Digits), 
               " | SL: ", DoubleToString(preciseSL, _Digits), 
               " | TP: ", DoubleToString(preciseTP, _Digits),
               " | Lot: ", DoubleToString(lot, 2),
               " | Conf: ", DoubleToString(g_lastAIConfidence*100, 1), "%");
         
         NotifyTradeEvent("â POSITION OUVERTE - BUY PRÃCIS " + _Symbol + " @" + DoubleToString(preciseEntry, _Digits) +
                          " Conf " + DoubleToString(g_lastAIConfidence * 100.0, 1) + "%", EntryTradeSoundFile);
      }
      else
      {
         Print("? Ãchec ordre BUY PRÃCIS - Erreur: ", trade.ResultRetcode(), " - ", trade.ResultRetcodeDescription());
      }
   }
   else if(g_lastAIAction == "SELL" || g_lastAIAction == "sell")
   {
      if(!HasRecentSMCDerivArrowForDirection("SELL"))
      {
         Print("?? ORDRE MARCHÃ BLOQUÃ - Attendre flÃĻche SMC_DERIV_ARROW SELL sur ", _Symbol);
         ReleaseOpenLock();
         return;
      }
      // Utiliser l'entrÃĐe prÃĐcise calculÃĐe au lieu du prix actuel
      if(trade.Sell(lot, _Symbol, preciseEntry, preciseSL, preciseTP, "IA SMC-EMA SELL PRÃCIS"))
      {
         orderExecuted = true;
         
         // MatÃĐrialiser le setup OTE sur le graphique
         DrawOTESetup(preciseEntry, preciseSL, preciseTP, "SELL");
         
         Print("?? ORDRE SELL PRÃCIS EXÃCUTÃ - Entry: ", DoubleToString(preciseEntry, _Digits), 
               " | SL: ", DoubleToString(preciseSL, _Digits), 
               " | TP: ", DoubleToString(preciseTP, _Digits),
               " | Lot: ", DoubleToString(lot, 2),
               " | Conf: ", DoubleToString(g_lastAIConfidence*100, 1), "%");
         
         NotifyTradeEvent("â POSITION OUVERTE - SELL PRÃCIS " + _Symbol + " @" + DoubleToString(preciseEntry, _Digits) +
                          " Conf " + DoubleToString(g_lastAIConfidence * 100.0, 1) + "%", EntryTradeSoundFile);
      }
      else
      {
         Print("? Ãchec ordre SELL PRÃCIS - Erreur: ", trade.ResultRetcode(), " - ", trade.ResultRetcodeDescription());
      }
   }
   
   ReleaseOpenLock();
   
   if(orderExecuted)
   {
      // RÃĐinitialiser le gain maximum pour la nouvelle position
      g_maxProfit = 0;
   }
}

//| FONCTIONS DE GESTION DES PAUSES ET BLACKLIST TEMPORAIRE        |
void InitializeSymbolPauseSystem()
{
   g_pauseCount = 0;
   for(int i = 0; i < 20; i++)
   {
      g_symbolPauses[i].symbol = "";
      g_symbolPauses[i].pauseUntil = 0;
      g_symbolPauses[i].consecutiveLosses = 0;
      g_symbolPauses[i].consecutiveWins = 0;
      g_symbolPauses[i].lastTradeTime = 0;
      g_symbolPauses[i].lastProfit = 0;
      g_symbolPauses[i].profitTargetReached = false;  // Initialisation du nouveau champ
   }
}

// RÃĐinitialiser les pauses de profit target au dÃĐbut de chaque journÃĐe
void ResetDailyProfitTargetPauses()
{
   static datetime lastResetDate = 0;
   datetime currentDate = GetTodayStart();
   
   if(lastResetDate < currentDate)
   {
      // Nouvelle journÃĐe dÃĐtectÃĐe - rÃĐinitialiser les pauses de profit target
      for(int i = 0; i < 20; i++)
      {
         if(g_symbolPauses[i].profitTargetReached)
         {
            Print("ð RÃINITIALISATION JOURNALIÃRE - Pause profit target rÃĐinitialisÃĐe pour: ", g_symbolPauses[i].symbol);
            g_symbolPauses[i].profitTargetReached = false;
            g_symbolPauses[i].pauseUntil = 0;
            g_symbolPauses[i].symbol = ""; // Effacer complÃĻtement l'entrÃĐe
         }
      }
      
      // RÃĐinitialiser aussi la pause globale de profit journalier
      if(g_dailyProfitTargetReached)
      {
         Print("ð RÃINITIALISATION JOURNALIÃRE - Pause profit global rÃĐinitialisÃĐe");
         g_dailyProfitTargetReached = false;
         g_dailyProfitPauseStartTime = 0;
         g_dailyProfitPeak = 0.0;
         g_dailyPauseUntil = 0;
      }
      
      lastResetDate = currentDate;
      Print("â RÃINITIALISATION JOURNALIÃRE TERMINEE - Toutes les pauses profit target ont ÃĐtÃĐ rÃĐinitialisÃĐes");
   }
}

bool IsSymbolPaused(string symbol)
{
   // 1. VÃĐrifier si le symbole doit ÃŠtre en pause pour profit target atteint
   if(ShouldPauseSymbolForProfit(symbol))
      return true;
   
   // 2. VÃĐrifier les pauses existantes (pertes/gains successifs)
   datetime currentTime = TimeCurrent();
   for(int i = 0; i < g_pauseCount; i++)
   {
      if(g_symbolPauses[i].symbol == symbol)
      {
         if(currentTime < g_symbolPauses[i].pauseUntil)
         {
            Print("?? SYMBOLE EN PAUSE: ", symbol, " - Jusqu'Ã : ", TimeToString(g_symbolPauses[i].pauseUntil, TIME_SECONDS));
            return true;
         }
         break;
      }
   }
   return false;
}

// Compte combien de symboles sont actuellement verrouillÃĐs par profit target (pour ÃĐviter les trades peu probables).
int CountProfitTargetLockedSymbols()
{
   int count = 0;
   datetime now = TimeCurrent();
   for(int i = 0; i < 20; i++)
   {
      if(g_symbolPauses[i].symbol == "") continue;
      if(!g_symbolPauses[i].profitTargetReached) continue;
      if(g_symbolPauses[i].pauseUntil <= now) continue;
      count++;
   }
   return count;
}

void UpdateSymbolPauseInfo(string symbol, double profit)
{
   datetime currentTime = TimeCurrent();
   int index = -1;
   
   // Trouver ou crÃĐer l'entrÃĐe pour ce symbole
   for(int i = 0; i < g_pauseCount; i++)
   {
      if(g_symbolPauses[i].symbol == symbol)
      {
         index = i;
         break;
      }
   }
   
   if(index == -1 && g_pauseCount < 20)
   {
      // CrÃĐer nouvelle entrÃĐe
      index = g_pauseCount;
      g_symbolPauses[index].symbol = symbol;
      g_symbolPauses[index].pauseUntil = 0;
      g_symbolPauses[index].consecutiveLosses = 0;
      g_symbolPauses[index].consecutiveWins = 0;
      g_pauseCount++;
   }
   
   if(index >= 0)
   {
      // Mettre Ã  jour les compteurs
      if(profit < 0)
      {
         g_symbolPauses[index].consecutiveLosses++;
         g_symbolPauses[index].consecutiveWins = 0;
         Print("?? PERTE DÃTECTÃE: ", symbol, " | Perte: ", DoubleToString(profit, 2), "$ | Pertes consÃĐcutives: ", g_symbolPauses[index].consecutiveLosses);
      }
      else if(profit > 0)
      {
         g_symbolPauses[index].consecutiveWins++;
         g_symbolPauses[index].consecutiveLosses = 0;
         Print("?? GAIN DÃTECTÃ: ", symbol, " | Gain: ", DoubleToString(profit, 2), "$ | Gains consÃĐcutifs: ", g_symbolPauses[index].consecutiveWins);
      }
      
      g_symbolPauses[index].lastTradeTime = currentTime;
      g_symbolPauses[index].lastProfit = profit;
   }
}

// Fonction pour calculer le profit cumulÃĐ par symbole (toutes positions fermÃĐes + ouvertes)
double GetSymbolCumulativeProfit(string symbol)
{
   double symbolProfit = 0.0;
   
   // 1. Ajouter le profit des positions ouvertes pour ce symbole
   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      ulong ticket = PositionGetTicket(i);
      if(ticket == 0) continue;
      string posSymbol = PositionGetString(POSITION_SYMBOL);
      if(posSymbol != symbol) continue;
      
      ulong posMagic = PositionGetInteger(POSITION_MAGIC);
      if(posMagic != InpMagicNumber) continue;
      
      symbolProfit += PositionGetDouble(POSITION_PROFIT) + PositionGetDouble(POSITION_SWAP);
   }
   
   // 2. Ajouter le profit des positions fermÃĐes aujourd'hui pour ce symbole (via l'historique)
   datetime todayStart = GetTodayStart();
   for(int i = HistoryDealsTotal() - 1; i >= 0; i--)
   {
      ulong dealTicket = HistoryDealGetTicket(i);
      if(dealTicket == 0) continue;
      
      datetime dealTime = (datetime)HistoryDealGetInteger(dealTicket, DEAL_TIME);
      if(dealTime < todayStart) continue; // Seulement les trades d'aujourd'hui
      
      string dealSymbol = HistoryDealGetString(dealTicket, DEAL_SYMBOL);
      if(dealSymbol != symbol) continue;
      
      ulong dealMagic = HistoryDealGetInteger(dealTicket, DEAL_MAGIC);
      if(dealMagic != InpMagicNumber) continue;
      
      // Seulement les deals de type fermeture (SELL pour BUY, BUY pour SELL)
      ENUM_DEAL_TYPE dealType = (ENUM_DEAL_TYPE)HistoryDealGetInteger(dealTicket, DEAL_TYPE);
      if(dealType == DEAL_TYPE_BUY || dealType == DEAL_TYPE_SELL)
      {
         symbolProfit += HistoryDealGetDouble(dealTicket, DEAL_PROFIT) + HistoryDealGetDouble(dealTicket, DEAL_SWAP) + HistoryDealGetDouble(dealTicket, DEAL_COMMISSION);
      }
   }
   
   return symbolProfit;
}

// Fonction pour obtenir l'heure de dÃĐbut de journÃĐe
datetime GetTodayStart()
{
   MqlDateTime dt;
   TimeCurrent(dt);
   dt.hour = 0;
   dt.min = 0;
   dt.sec = 0;
   return StructToTime(dt);
}

// Fonction pour vÃĐrifier si un symbole doit ÃŠtre en pause (profit target atteint)
bool ShouldPauseSymbolForProfit(string symbol)
{
   if(SymbolProfitTargetUSD <= 0.0) return false; // DÃĐsactivÃĐ
   
   double symbolProfit = GetSymbolCumulativeProfit(symbol);
   
   // Exception pour Boom/Crash + Welltrade synth: utiliser 2$ comme target
   double target = SymbolProfitTargetUSD;
   ENUM_SYMBOL_CATEGORY cat = SMC_GetSymbolCategory(symbol);
   if(cat == SYM_BOOM_CRASH || cat == SYM_WELTRADE_SYNTH)
      target = 2.0;
   
   if(symbolProfit >= target)
   {
      // Marquer le symbole comme ÃĐtant en pause jusqu'Ã  fin de journÃĐe
      for(int i = 0; i < 20; i++)
      {
         if(g_symbolPauses[i].symbol == "" || g_symbolPauses[i].symbol == symbol)
         {
            g_symbolPauses[i].symbol = symbol;
            g_symbolPauses[i].profitTargetReached = true;
            
            // Pause jusqu'Ã  fin de journÃĐe (23:59:59)
            MqlDateTime dt;
            TimeCurrent(dt);
            dt.hour = 23; dt.min = 59; dt.sec = 59;
            g_symbolPauses[i].pauseUntil = StructToTime(dt);
            
            Print("ðŊ PROFIT TARGET SYMBOLE ATTEINT - ", symbol, ": ", DoubleToString(symbolProfit, 2), "$ âĨ ", DoubleToString(target, 1), "$");
            Print("âļïļ PAUSE SYMBOLE ACTIVÃE - ", symbol, " jusqu'Ã  fin de journÃĐe (", TimeToString(g_symbolPauses[i].pauseUntil, TIME_SECONDS), ")");
            break;
         }
      }
      return true;
   }
   
   return false;
}

bool ShouldPauseSymbol(string symbol, double profit)
{
   // Pause aprÃĻs 2 pertes successives (10 minutes)
   if(profit < 0)
   {
      for(int i = 0; i < g_pauseCount; i++)
      {
         if(g_symbolPauses[i].symbol == symbol)
         {
            if(g_symbolPauses[i].consecutiveLosses >= 1) // DÃĐjÃ  1 perte, celle-ci fait 2
            {
               Print("?? PAUSE 10 MINUTES: ", symbol, " - 2 pertes successives dÃĐtectÃĐes");
               return true;
            }
            break;
         }
      }
   }
   
   // Pause aprÃĻs 2 gains successifs (5 minutes)
   if(profit > 0)
   {
      for(int i = 0; i < g_pauseCount; i++)
      {
         if(g_symbolPauses[i].symbol == symbol)
         {
            if(g_symbolPauses[i].consecutiveWins >= 1) // DÃĐjÃ  1 gain, celui-ci fait 2
            {
               Print("?? PAUSE 5 MINUTES: ", symbol, " - 2 gains successifs dÃĐtectÃĐs");
               return true;
            }
            break;
         }
      }
   }
   
   return false;
}

void ApplySymbolPause(string symbol, int minutes)
{
   datetime currentTime = TimeCurrent();
   datetime pauseUntil = currentTime + (minutes * 60);
   
   for(int i = 0; i < g_pauseCount; i++)
   {
      if(g_symbolPauses[i].symbol == symbol)
      {
         g_symbolPauses[i].pauseUntil = pauseUntil;
         Print("?? SYMBOLE MIS EN PAUSE: ", symbol, " - DurÃĐe: ", minutes, " minutes | Jusqu'Ã : ", TimeToString(pauseUntil, TIME_SECONDS));
         break;
      }
   }
}

//| DÃTECTION DE RANGE - ÃVITER DE TRADER DANS LES RANGES         |
bool DetectPriceRange()
{
   // Utiliser les 20 derniÃĻres bougies pour dÃĐtecter un range
   MqlRates rates[];
   ArraySetAsSeries(rates, true);
   if(CopyRates(_Symbol, PERIOD_M1, 0, 20, rates) < 20) return false;
   
   double highs[], lows[];
   ArrayResize(highs, 20);
   ArrayResize(lows, 20);
   
   for(int i = 0; i < 20; i++)
   {
      highs[i] = rates[i].high;
      lows[i] = rates[i].low;
   }
   
   // Calculer le plus haut et plus bas sur la pÃĐriode
   double highestHigh = rates[0].high;
   double lowestLow = rates[0].low;
   
   for(int i = 1; i < 20; i++)
   {
      if(rates[i].high > highestHigh) highestHigh = rates[i].high;
      if(rates[i].low < lowestLow) lowestLow = rates[i].low;
   }
   
   double rangeSize = highestHigh - lowestLow;
   double currentPrice = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   
   // DÃĐterminer si le prix est dans le range (zone mÃĐdiane 40-60%)
   double rangeMiddle = lowestLow + (rangeSize * 0.5);
   double rangeWidth = rangeSize * 0.2; // 20% de chaque cÃītÃĐ du milieu
   
   bool inRange = (currentPrice >= (rangeMiddle - rangeWidth) && currentPrice <= (rangeMiddle + rangeWidth));
   
   // CritÃĻres supplÃĐmentaires pour confirmer le range
   bool isConsolidating = false;
   
   // VÃĐrifier si les bougies ont des corps petits (indique de consolidation)
   double avgBodySize = 0;
   for(int i = 0; i < 20; i++)
   {
      double bodySize = MathAbs(rates[i].close - rates[i].open);
      avgBodySize += bodySize;
   }
   avgBodySize /= 20;
   
   // Si les corps sont petits par rapport au range, c'est une consolidation
   isConsolidating = (avgBodySize < rangeSize * 0.1);
   
   // DÃĐtection finale de range
   bool isRange = inRange && isConsolidating && (rangeSize > 0);
   
   if(isRange)
   {
      Print("?? RANGE DÃTECTÃ sur ", _Symbol, 
             " | Range: ", DoubleToString(lowestLow, _Digits), " - ", DoubleToString(highestHigh, _Digits),
             " | Prix actuel: ", DoubleToString(currentPrice, _Digits),
             " | Largeur range: ", DoubleToString(rangeSize, _Digits),
             " | Corps moyen: ", DoubleToString(avgBodySize, _Digits));
   }
   
   return isRange;
}

bool IsPriceInRange()
{
   return DetectPriceRange();
}

bool PassFutureDirectionConfidenceGate(const string direction, const string contextTag, const bool quiet)
{
   if(!UseFutureDirectionConfidenceGate)
      return true;

   string dir = direction;
   StringToUpper(dir);
   if(dir != "BUY" && dir != "SELL")
      return false;

   const int lookback = MathMax(18, FutureDirectionLookbackBars);
   MqlRates rr[];
   ArraySetAsSeries(rr, true);
   int copied = CopyRates(_Symbol, PERIOD_M15, 0, lookback + 8, rr);
   if(copied < lookback + 5)
      return false;

   int confirmations = 0;
   double score = 0.0;

   // 1) Alignement structure HTF
   bool bullHTF = IsBullishHTF();
   bool bearHTF = IsBearishHTF();
   bool htfOk = (dir == "BUY" && bullHTF) || (dir == "SELL" && bearHTF);
   if(htfOk)
   {
      confirmations++;
      score += 22.0;
   }
   else
   {
      score -= 10.0;
   }

   // 2) Position premium/discount compatible
   bool pdOk = IsOTEEntryDirectionSafeForPremiumDiscount(_Symbol, dir);
   if(pdOk)
   {
      confirmations++;
      score += 18.0;
   }
   else
   {
      score -= 12.0;
   }

   // 3) Momentum M15: derniere bougie close impulsive dans le sens
   double sumBody = 0.0, sumRange = 0.0;
   int nStat = MathMin(lookback, copied - 3);
   for(int i = 2; i < 2 + nStat; i++)
   {
      sumBody += MathAbs(rr[i].close - rr[i].open);
      sumRange += (rr[i].high - rr[i].low);
   }
   double avgBody = (nStat > 0) ? (sumBody / (double)nStat) : 0.0;
   double avgRange = (nStat > 0) ? (sumRange / (double)nStat) : 0.0;
   double body1 = MathAbs(rr[1].close - rr[1].open);
   double range1 = rr[1].high - rr[1].low;
   bool dirCandleOk = (dir == "BUY") ? (rr[1].close > rr[1].open) : (rr[1].close < rr[1].open);
   bool momentumOk = dirCandleOk && body1 >= (avgBody * 1.10);
   if(momentumOk)
   {
      confirmations++;
      score += 20.0;
   }

   // 4) Expansion de range (impulsion rÃĐelle)
   bool expansionOk = (avgRange > 0.0 && range1 >= (avgRange * 1.08));
   if(expansionOk)
   {
      confirmations++;
      score += 15.0;
   }

   // 5) IA non contradictoire (ou neutralisÃĐ si IA inactive)
   bool aiOk = true;
   if(UseAIServer)
   {
      string ia = g_lastAIAction;
      StringToUpper(ia);
      aiOk = (ia == dir && ia != "HOLD" && ia != "");
   }
   if(aiOk)
   {
      confirmations++;
      score += 15.0;
   }
   else
   {
      score -= 10.0;
   }

   // Sweep + reclaim de liquiditÃĐ (fort filtre anti faux dÃĐpart)
   bool sweepReclaimOk = false;
   double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   if(point <= 0.0) point = _Point;
   if(point <= 0.0) point = 0.0001;

   if(copied > 8)
   {
      if(dir == "BUY")
      {
         double prevMin = rr[3].low;
         for(int i = 4; i < MathMin(copied, lookback + 3); i++)
            if(rr[i].low < prevMin) prevMin = rr[i].low;
         bool swept = (rr[2].low < (prevMin - 2.0 * point));
         bool reclaimed = (rr[1].close > prevMin);
         sweepReclaimOk = swept && reclaimed;
      }
      else
      {
         double prevMax = rr[3].high;
         for(int i = 4; i < MathMin(copied, lookback + 3); i++)
            if(rr[i].high > prevMax) prevMax = rr[i].high;
         bool swept = (rr[2].high > (prevMax + 2.0 * point));
         bool reclaimed = (rr[1].close < prevMax);
         sweepReclaimOk = swept && reclaimed;
      }
   }

   if(sweepReclaimOk)
      score += 12.0;
   else if(FutureDirectionRequireSweepReclaim)
      score -= 15.0;

   if(score < 0.0) score = 0.0;
   if(score > 100.0) score = 100.0;

   int minConf = MathMax(1, FutureDirectionMinConfirmations);
   bool confOk = confirmations >= minConf;
   bool scoreOk = score + 1e-9 >= FutureDirectionMinScore;
   bool sweepOk = (!FutureDirectionRequireSweepReclaim || sweepReclaimOk);
   bool pass = confOk && scoreOk && sweepOk;

   if(!pass && !quiet)
   {
      static datetime s_lastFutureGateLog = 0;
      datetime now = TimeCurrent();
      if(now - s_lastFutureGateLog >= 12)
      {
         Print("ðŦ FUTURE CONF GATE BLOQUE | ", _Symbol,
               " | ctx=", contextTag,
               " | dir=", dir,
               " | score=", DoubleToString(score, 1), "/", DoubleToString(FutureDirectionMinScore, 1),
               " | conf=", IntegerToString(confirmations), "/", IntegerToString(minConf),
               " | sweep=", sweepReclaimOk ? "OK" : "NO");
         s_lastFutureGateLog = now;
      }
   }

   return pass;
}

//| NOTE DE SETUP IA (0-100) â calcul sans log (recovery, filtres internes) |
double ComputeSetupScoreValue(const string direction)
{
   double score = 0.0;
   double confPct = g_lastAIConfidence * 100.0;
   if(confPct < 0.0) confPct = 0.0;
   if(confPct > 100.0) confPct = 100.0;
   score += confPct * 0.60;

   double alignPct = 0.0, cohPct = 0.0;
   if(StringLen(g_lastAIAlignment) > 0)
   {
      string s = g_lastAIAlignment;
      StringReplace(s, "%", "");
      alignPct = StringToDouble(s);
      if(alignPct < 0.0) alignPct = 0.0;
      if(alignPct > 100.0) alignPct = 100.0;
   }
   if(StringLen(g_lastAICoherence) > 0)
   {
      string s2 = g_lastAICoherence;
      StringReplace(s2, "%", "");
      cohPct = StringToDouble(s2);
      if(cohPct < 0.0) cohPct = 0.0;
      if(cohPct > 100.0) cohPct = 100.0;
   }
   score += alignPct * 0.20;
   score += cohPct * 0.20;

   bool bullHTF = IsBullishHTF();
   bool bearHTF = IsBearishHTF();
   string dir = direction;
   StringToUpper(dir);

   if(dir == "BUY" && bullHTF)       score += 5.0;
   if(dir == "SELL" && bearHTF)      score += 5.0;
   if(dir == "BUY" && bearHTF)       score -= 10.0;
   if(dir == "SELL" && bullHTF)      score -= 10.0;

   if(IsPriceInRange())
      score -= 15.0;

   if(ChartPatternAffectTradeDecision)
      score += GetChartPatternDirectionalBonus(dir);

   if(score < 0.0)   score = 0.0;
   if(score > 100.0) score = 100.0;
   return score;
}

//| NOTE DE SETUP IA (0-100)                                         |
double ComputeSetupScore(const string direction)
{
   double score = ComputeSetupScoreValue(direction);
   double confPct = g_lastAIConfidence * 100.0;
   if(confPct < 0.0) confPct = 0.0;
   if(confPct > 100.0) confPct = 100.0;
   double alignPct = 0.0, cohPct = 0.0;
   if(StringLen(g_lastAIAlignment) > 0)
   {
      string s = g_lastAIAlignment;
      StringReplace(s, "%", "");
      alignPct = StringToDouble(s);
      if(alignPct < 0.0) alignPct = 0.0;
      if(alignPct > 100.0) alignPct = 100.0;
   }
   if(StringLen(g_lastAICoherence) > 0)
   {
      string s2 = g_lastAICoherence;
      StringReplace(s2, "%", "");
      cohPct = StringToDouble(s2);
      if(cohPct < 0.0) cohPct = 0.0;
      if(cohPct > 100.0) cohPct = 100.0;
   }
   string dir = direction;
   StringToUpper(dir);
   Print("?? SETUP SCORE ", _Symbol, " ", dir, " = ", DoubleToString(score, 1),
         " (Conf=", DoubleToString(confPct,1), "% Align=", DoubleToString(alignPct,1),
         "% Coh=", DoubleToString(cohPct,1), "%)");
   return score;
}

//+------------------------------------------------------------------+
//| EntrÃĐe ÂŦ rÃĐflÃĐchie Âŧ : score (direction) + IA + vetos explicites   |
//+------------------------------------------------------------------+
bool PassReflectiveEntryGate(const string direction, const string commentCore, const bool quiet)
{
   if(!UseReflectiveEntryGate)
      return true;

   if(commentCore == "STAIR_ENTRY" && !ReflectiveApplyToStairEntry)
      return true;

   string dir = direction;
   StringToUpper(dir);
   if(dir != "BUY" && dir != "SELL")
      return false;

   if(ReflectiveVetoEquilibriumZone && IsInEquilibriumCorrectionZone())
   {
      const bool stairBypassEq = (commentCore == "STAIR_ENTRY" && StairEntryBypassEquilibriumCorrectionZone);
      if(!stairBypassEq)
      {
         if(!quiet)
         {
            static datetime s_lastReflEq = 0;
            if(TimeCurrent() - s_lastReflEq >= 25)
            {
               Print("ðŦ REFLECTIVE veto - zone ÃĐquilibre ICT | ", _Symbol,
                     " | ctx=", commentCore, " | dir=", dir);
               s_lastReflEq = TimeCurrent();
            }
         }
         return false;
      }
   }

   double minSc = GetCategoryMinSetupScore(_Symbol) + ReflectiveExtraMinSetupScore;
   if(UsePropiceSymbolsFilter && PropiceAllowMarketOrdersOnAllPropiceSymbols &&
      g_currentSymbolIsPropice && g_currentSymbolPriority > 0)
      minSc += (double)g_currentSymbolPriority * PropiceNonTopExtraMinSetupScore;

   if(UseHighConfidenceFilterWhenSomeSymbolsProfitLocked)
   {
      int lockedCount = CountProfitTargetLockedSymbols();
      if(lockedCount >= LockedSymbolsMinCountForFilter)
         minSc += ExtraMinSetupScoreWhenLocked;
   }

   const double sc = ComputeSetupScoreValue(dir);
   if(sc + 1e-9 < minSc)
   {
      if(!quiet)
      {
         static datetime s_lastReflSc = 0;
         if(TimeCurrent() - s_lastReflSc >= 25)
         {
            Print("ðŦ REFLECTIVE - score insuffisant | ", _Symbol, " | ctx=", commentCore,
                  " | sc=", DoubleToString(sc, 1), " < ", DoubleToString(minSc, 1),
                  " | dir=", dir);
            s_lastReflSc = TimeCurrent();
         }
      }
      return false;
   }

   if(!UseAIServer)
      return true;

   if(ReflectiveVetoWhenAIDisagrees)
   {
      string ia = g_lastAIAction;
      StringToUpper(ia);

      const bool stairHoldSkipDir =
         (commentCore == "STAIR_ENTRY" && ia == "HOLD" && ReflectiveAllowStairHoldWithoutIaDirection);

      if(!stairHoldSkipDir && (ia != dir || ia == "HOLD"))
      {
         if(!quiet)
         {
            static datetime s_lastReflIa = 0;
            if(TimeCurrent() - s_lastReflIa >= 25)
            {
               Print("ðŦ REFLECTIVE veto - IA non alignÃĐe | ", _Symbol, " | ctx=", commentCore,
                     " | IA=", g_lastAIAction, " | dir=", dir);
               s_lastReflIa = TimeCurrent();
            }
         }
         return false;
      }
   }

   double minAiPct = ReflectiveMinAIConfidencePercent;
   if(minAiPct <= 0.0)
      minAiPct = GetCategoryMinAIConfidencePercent(_Symbol);
   double minAiU = (minAiPct > 1.0) ? (minAiPct / 100.0) : minAiPct;
   if(!IsAIConfidenceAtLeast(minAiU, "REFLECTIVE", true, quiet))
      return false;

   return true;
}

//| MÃTRIQUES ML FALLBACK - SI SERVEUR IA INDISPONIBLE          |
void GenerateFallbackMLMetrics()
{
   // Si le serveur IA n'est pas connectÃĐ, gÃĐnÃĐrer des mÃĐtriques basiques
   if(!g_aiConnected)
   {
      // Calculer des mÃĐtriques basÃĐes sur l'analyse technique locale
      double currentPrice = SymbolInfoDouble(_Symbol, SYMBOL_BID);
      MqlRates rates[];
      ArraySetAsSeries(rates, true);
      
      if(CopyRates(_Symbol, PERIOD_M1, 0, 20, rates) >= 20)
      {
         // Calculer la tendance simple
         double priceChange = rates[0].close - rates[19].close;
         bool isUptrend = priceChange > 0;
         
         // Calculer la volatilitÃĐ
         double avgRange = 0;
         for(int i = 0; i < 20; i++)
         {
            avgRange += rates[i].high - rates[i].low;
         }
         avgRange /= 20;
         
         // GÃĐnÃĐrer des mÃĐtriques de fallback
         if(isUptrend)
         {
            g_lastAIAction = "BUY";
            g_lastAIConfidence = MathMin(0.65, 0.5 + (priceChange / currentPrice) * 10); // Max 65%
         }
         else
         {
            g_lastAIAction = "SELL";
            g_lastAIConfidence = MathMin(0.65, 0.5 + MathAbs(priceChange / currentPrice) * 10); // Max 65%
         }
         
         // Alignement et cohÃĐrence basÃĐs sur la volatilitÃĐ
         double volatilityScore = MathMin(1.0, avgRange / currentPrice * 100);
         g_lastAIAlignment = DoubleToString(volatilityScore * 80, 1) + "%"; // Max 80%
         g_lastAICoherence = DoubleToString(volatilityScore * 70, 1) + "%"; // Max 70%
         
         Print("?? MÃTRIQUES FALLBACK - Action: ", g_lastAIAction, 
               " | Confiance: ", DoubleToString(g_lastAIConfidence * 100, 1), "%",
               " | Alignement: ", g_lastAIAlignment,
               " | CohÃĐrence: ", g_lastAICoherence);
      }
      else
      {
         // Valeurs par dÃĐfaut si pas assez de donnÃĐes
         g_lastAIAction = "HOLD";
         g_lastAIConfidence = 0.0;
         g_lastAIAlignment = "0.0%";
         g_lastAICoherence = "0.0%";
         
         Print("?? MÃTRIQUES DÃFAUT - Pas assez de donnÃĐes pour fallback");
      }
   }
}

//| FONCTIONS IA - COMMUNICATION AVEC LE SERVEUR                       |

bool UpdateAIDecision(int timeoutMs = -1)
{
   // DÃĐporter toute la logique rÃĐseau sur GetAISignalData()
   bool ok = GetAISignalData();
   if(!ok)
   {
      // En cas d'ÃĐchec complet, gÃĐnÃĐrer immÃĐdiatement un fallback local
      GenerateFallbackAIDecision();
      return false;
   }
   // GetAISignalData met dÃĐjÃ  Ã  jour g_lastAIAction / g_lastAIConfidence / alignement / cohÃĐrence
   Print("? DÃĐcision IA mise Ã  jour via /decision - Action: ", g_lastAIAction,
         " | Confiance: ", DoubleToString(g_lastAIConfidence*100, 1), "%");
   return true;
}

string GetAISignalData(string symbol, string timeframe)
{
   string symEnc = symbol;
   StringReplace(symEnc, " ", "%20");
   
   string baseUrl = UseRenderAsPrimary ? AI_ServerRender : AI_ServerURL;
   string path = "/ml/signal?symbol=" + symEnc + "&timeframe=" + timeframe;
   string headers = "";
   char post[], result[];
   string resultHeaders;
   
   int res = WebRequest("GET", baseUrl + path, headers, AI_Timeout_ms, post, result, resultHeaders);
   
   if(res == 200)
   {
      return CharArrayToString(result);
