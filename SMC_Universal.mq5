input double HMS_TargetBandPctOfRange = 14.0; // Zone de prise / vente haute (% du range depuis le sommet)
input double HMS_StopLineAtrMult = 0.40; // Ligne guide SL sous le support (× ATR HMS)
input bool   HMS_DrawOtePocket = true; // Ombrer la poche OTE 61.8–78.6 % depuis le creux du range (BUY)
input bool   HMS_DrawOtePocketFromTop = true; // Idem depuis le sommet (poche SELL symétrique)
