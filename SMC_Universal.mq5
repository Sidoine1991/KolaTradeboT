      ObjectSetInteger(0, m5TrendLine, OBJPROP_STYLE, STYLE_SOLID);
      ObjectSetInteger(0, m5TrendLine, OBJPROP_WIDTH, 2);
      ObjectSetInteger(0, m5TrendLine, OBJPROP_BACK, false);
      
      string m5TrendLabel = "SMC_PRED_M5_TREND_LABEL";
      ObjectCreate(0, m5TrendLabel, OBJ_TEXT, 0, timeStart + PeriodSeconds(PERIOD_M1) * 100, 
                   bosHigh + m5TrendSlope_Down * 40);
      ObjectSetString(0, m5TrendLabel, OBJPROP_TEXT, "M5 TREND ENTRY");
      ObjectSetInteger(0, m5TrendLabel, OBJPROP_COLOR, clrYellow);
      ObjectSetInteger(0, m5TrendLabel, OBJPROP_FONTSIZE, 9);
      ObjectSetInteger(0, m5TrendLabel, OBJPROP_BACK, false);
      
      // 5b. ENTRY au 50%
      string entryZone = "SMC_PRED_ENTRY_ZONE";
      ObjectCreate(0, entryZone, OBJ_RECTANGLE, 0, 
                   timeStart + PeriodSeconds(PERIOD_M1) * 80, entry - (swingHigh - swingLow) * 0.01,
                   timeStart + PeriodSeconds(PERIOD_M1) * 100, entry + (swingHigh - swingLow) * 0.01);
      ObjectSetInteger(0, entryZone, OBJPROP_COLOR, entryColor);
      ObjectSetInteger(0, entryZone, OBJPROP_BGCOLOR, C'255,165,0');
      ObjectSetInteger(0, entryZone, OBJPROP_FILL, true);
      ObjectSetInteger(0, entryZone, OBJPROP_BACK, true);
      
      string entryLine = "SMC_PRED_ENTRY_LINE";
      ObjectCreate(0, entryLine, OBJ_HLINE, 0, timeStart, entry);
      ObjectSetInteger(0, entryLine, OBJPROP_COLOR, entryColor);
      ObjectSetInteger(0, entryLine, OBJPROP_STYLE, STYLE_SOLID);
      ObjectSetInteger(0, entryLine, OBJPROP_WIDTH, 3);
      ObjectSetInteger(0, entryLine, OBJPROP_BACK, false);
      
      // Label d'entrÃĐe - VISIBLE (texte blanc)
      string entryLabel = "SMC_PRED_ENTRY_LABEL";
      CreateVisibleLabel(entryLabel, timeStart + PeriodSeconds(PERIOD_M1) * 85, 
                        entry - (swingHigh - swingLow) * 0.03, "ðī ENTRY 50%", entryColor);
      
      // 6. STOP LOSS
      string slLine = "SMC_PRED_SL_LINE";
      ObjectCreate(0, slLine, OBJ_HLINE, 0, timeStart, stopLoss);
      ObjectSetInteger(0, slLine, OBJPROP_COLOR, clrRed);
      ObjectSetInteger(0, slLine, OBJPROP_STYLE, STYLE_DASH);
      ObjectSetInteger(0, slLine, OBJPROP_WIDTH, 2);
      ObjectSetInteger(0, slLine, OBJPROP_BACK, false);
      
      // Label SL - VISIBLE
      string slLabel = "SMC_PRED_SL_LABEL";
      CreateVisibleLabel(slLabel, timeStart + PeriodSeconds(PERIOD_M1) * 5, 
                        stopLoss + (swingHigh - swingLow) * 0.02, "ðī SL", clrRed);
      
      // 7. TAKE PROFIT (RR 1:5)
      string tpLine = "SMC_PRED_TP_LINE";
      ObjectCreate(0, tpLine, OBJ_HLINE, 0, timeStart, takeProfit);
      ObjectSetInteger(0, tpLine, OBJPROP_COLOR, clrGreen);
      ObjectSetInteger(0, tpLine, OBJPROP_STYLE, STYLE_DASH);
      ObjectSetInteger(0, tpLine, OBJPROP_WIDTH, 2);
      ObjectSetInteger(0, tpLine, OBJPROP_BACK, false);
      
      // Label TP - VISIBLE
      string tpLabel = "SMC_PRED_TP_LABEL";
      CreateVisibleLabel(tpLabel, timeStart + PeriodSeconds(PERIOD_M1) * 5, 
                        takeProfit - (swingHigh - swingLow) * 0.02, "ðĒ TP (RR 1:5)", clrGreen);
      
      // 8. TITRE SETUP
      string title = "SMC_PRED_TITLE";
      ObjectCreate(0, title, OBJ_TEXT, 0, timeStart + PeriodSeconds(PERIOD_M1) * 100, takeProfit - (swingHigh - swingLow) * 0.1);
      ObjectSetString(0, title, OBJPROP_TEXT, "âŽïļ SMC PREDICTION SETUP BAISSIER (200M1) âŽïļ");
      ObjectSetInteger(0, title, OBJPROP_COLOR, clrOrange);
      ObjectSetInteger(0, title, OBJPROP_FONTSIZE, 12);
      
      // Placer les ordres limit sur M5 Trend Entry Point
      PlaceSMCPredictionLimitOrders("SELL", bosHigh + m5TrendSlope_Down * 50, entry, stopLoss, takeProfit);
      
      Print("\nâ === SMC PREDICTION SETUP BAISSIER TRACÃ ===");
      Print("ð BOS LEVEL: ", DoubleToString(bosHigh, _Digits));
      Print("ð CHoCH LEVEL: ", DoubleToString(chochLevel, _Digits));
      Print("ðĶ ORDER BLOCK: ", DoubleToString(orderBlockLow, _Digits), " - ", DoubleToString(orderBlockHigh, _Digits));
      Print("âŽïļ M5 TREND ENTRY: ", DoubleToString(bosHigh + m5TrendSlope_Down * 50, _Digits));
      Print("ðŊ ENTRY (50%): ", DoubleToString(entry, _Digits));
      Print("ð STOP LOSS: ", DoubleToString(stopLoss, _Digits));
      Print("â TAKE PROFIT (RR 1:5): ", DoubleToString(takeProfit, _Digits));
      Print("âąïļ Projection: 200 bougies M1 (~3h20 min)\n");
   }
}

// Fonction utilitaire pour tracer les niveaux Fibonacci
void DrawFibonacciLevelsForPrediction(datetime timeStart, datetime timeEnd, double basePrice, double fiboPrice, string label, color col)
{
   string objName = "SMC_PRED_FIBO_" + label;
   ObjectCreate(0, objName, OBJ_HLINE, 0, timeStart, fiboPrice);
   ObjectSetInteger(0, objName, OBJPROP_COLOR, col);
   ObjectSetInteger(0, objName, OBJPROP_STYLE, STYLE_DOT);
   ObjectSetInteger(0, objName, OBJPROP_WIDTH, 1);
   ObjectSetInteger(0, objName, OBJPROP_BACK, true);
   
   string labelName = "SMC_PRED_FIBO_LABEL_" + label;
   ObjectCreate(0, labelName, OBJ_TEXT, 0, timeStart + PeriodSeconds(PERIOD_M1) * 20, fiboPrice);
   ObjectSetString(0, labelName, OBJPROP_TEXT, label + "%");
   ObjectSetInteger(0, labelName, OBJPROP_COLOR, col);
   ObjectSetInteger(0, labelName, OBJPROP_FONTSIZE, 7);
}

// CrÃĐer un label visible (texte blanc, sans fond)
void CreateVisibleLabel(string name, datetime time, double price, string text, color col)
{
   ObjectCreate(0, name, OBJ_TEXT, 0, time, price);
   ObjectSetString(0, name, OBJPROP_TEXT, text);
   ObjectSetInteger(0, name, OBJPROP_COLOR, clrWhite); // Texte blanc pour contraste
   ObjectSetInteger(0, name, OBJPROP_FONTSIZE, 10);
   ObjectSetInteger(0, name, OBJPROP_BACK, false); // Pas de fond
}

// RÃĐcupÃĐrer les niveaux du SMC Prediction Setup
struct SMCPredictionLevels
{
   string   direction;
   double   bosLevel;
   double   chochLevel;
   double   m5TrendEntryPoint;
   double   entry50Percent;
   double   stopLoss;
   double   takeProfit;
};

bool GetSMCPredictionSetupLevels(SMCPredictionLevels &levelsOut)
{
   MqlRates rates[];
   ArraySetAsSeries(rates, true);
   int copied = CopyRates(_Symbol, PERIOD_M1, 0, 50, rates);
   if(copied < 20) return false;
   
   double currentPrice = rates[0].close;
   double swingHigh = rates[0].high;
   double swingLow = rates[0].low;
   
   // Trouver le swing high/low sur les derniÃĻres 30 bougies
   for(int i = 0; i < 30 && i < copied; i++)
   {
      swingHigh = MathMax(swingHigh, rates[i].high);
      swingLow = MathMin(swingLow, rates[i].low);
   }
   
   // DÃĐterminer la direction
   levelsOut.direction = (currentPrice > (swingHigh + swingLow) / 2) ? "BUY" : "SELL";
   
   if(levelsOut.direction == "BUY")
   {
      levelsOut.bosLevel = swingLow;
      double m5TrendSlope = (swingHigh - swingLow) / 100.0;
      levelsOut.m5TrendEntryPoint = swingLow + m5TrendSlope * 50;
      
      double fiboRange = swingHigh - swingLow;
      levelsOut.entry50Percent = swingLow + fiboRange * 0.50;
      levelsOut.stopLoss = swingLow - (swingHigh - swingLow) * 0.1;
      
      double riskInPips = (levelsOut.entry50Percent - levelsOut.stopLoss) / SymbolInfoDouble(_Symbol, SYMBOL_POINT);
      levelsOut.takeProfit = levelsOut.entry50Percent + (riskInPips * 5 * SymbolInfoDouble(_Symbol, SYMBOL_POINT));
      levelsOut.chochLevel = levelsOut.bosLevel + (swingHigh - swingLow) * 0.2;
   }
   else // SELL
   {
      levelsOut.bosLevel = swingHigh;
      double m5TrendSlope = (swingLow - swingHigh) / 100.0;
      levelsOut.m5TrendEntryPoint = swingHigh + m5TrendSlope * 50;
      
      double fiboRange = swingHigh - swingLow;
      levelsOut.entry50Percent = swingHigh - fiboRange * 0.50;
      levelsOut.stopLoss = swingHigh + (swingHigh - swingLow) * 0.1;
      
      double riskInPips = (levelsOut.stopLoss - levelsOut.entry50Percent) / SymbolInfoDouble(_Symbol, SYMBOL_POINT);
      levelsOut.takeProfit = levelsOut.entry50Percent - (riskInPips * 5 * SymbolInfoDouble(_Symbol, SYMBOL_POINT));
      levelsOut.chochLevel = levelsOut.bosLevel - (swingHigh - swingLow) * 0.2;
   }
   
   return true;
}

// ExÃĐcuter le trade SMC Prediction Ã  partir de la dÃĐtection de flÃĻche
void ExecuteSMCPredictionArrowTrade()
{
   // DÃĐterminer si une flÃĻche pure existe
   bool hasBuyArrow = ChartHasPureColorArrowForBoomCrashDir("BUY");
   bool hasSellArrow = ChartHasPureColorArrowForBoomCrashDir("SELL");
   
   if(!hasBuyArrow && !hasSellArrow)
      return; // Pas de flÃĻche dÃĐtectÃĐe
   
   // RÃĐcupÃĐrer les niveaux du setup
   SMCPredictionLevels levels;
   if(!GetSMCPredictionSetupLevels(levels))
      return; // Impossible de calculer les niveaux
   
   // DÃĐterminer si la flÃĻche correspond Ã  la direction du setup
   string detectedDir = "";
   if(hasBuyArrow && levels.direction == "BUY")
      detectedDir = "BUY";
   else if(hasSellArrow && levels.direction == "SELL")
      detectedDir = "SELL";
   else
      return; // Pas de correspondance flÃĻche/setup
   
   // VÃĐrifications de sÃĐcuritÃĐ standard
   if(!IsDirectionAllowedForBoomCrash(_Symbol, detectedDir))
   {
      Print("ðŦ SMC ARROW TRADE BLOQUÃ - Direction interdite: ", detectedDir);
      return;
   }
   
   if(UseAIServer && IsBoomCrashOrWeltradeDirectionalSynth(_Symbol) &&
      !IsBoomCrashDirectionAllowedByIA(_Symbol, detectedDir))
   {
      Print("ðŦ SMC ARROW TRADE BLOQUÃ - Direction vs IA: ", detectedDir);
      return;
   }
   
   if(IsMaxPositionsReached())
   {
      return;
   }
   
   double minLot = GetMinLotForSymbol(_Symbol);
   double lot = NormalizeVolumeForSymbol(MathMax(minLot, CalculateLotSize() * 0.5)); // Lot rÃĐduit pour limit, au moins minLot
   if(lot <= 0.0)
   {
      Print("â SMC ARROW TRADE BLOQUÃ - lot minimum indisponible");
      return;
   }
   
   // ===== ORDRE LIMIT UNIQUEMENT (Demande utilisateur) =====
   Print("\nð FLÃCHE DÃTECTÃE - Placement ordre LIMIT sur ", _Symbol);
   Print("Direction: ", detectedDir);
   Print("M5 TREND ENTRY: ", DoubleToString(levels.m5TrendEntryPoint, _Digits));
   
   PlaceSMCPredictionLimitOrders(detectedDir, levels.m5TrendEntryPoint, levels.entry50Percent, 
                                 levels.stopLoss, levels.takeProfit);
}

// Placer les ordres limit sur M5 Trend Entry Point
void PlaceSMCPredictionLimitOrders(string direction, double m5TrendEntry, double entry50,
                                   double stopLoss, double takeProfit)
{
   if(!IsDirectionAllowedForBoomCrash(_Symbol, direction)) return;
   if(IsMaxPositionsReached()) return;

   double minLot = GetMinLotForSymbol(_Symbol);
   double lot = NormalizeVolumeForSymbol(MathMax(minLot, CalculateLotSize() * 0.5)); // 50% du lot calculÃĐ, au moins minLot
   if(lot <= 0.0) return;
   
   if(direction == "BUY")
   {
      // Ordre Buy Limit sur M5 Trend Entry Point
      bool limitSuccess = trade.BuyLimit(lot, m5TrendEntry, _Symbol, stopLoss, takeProfit,
                                        ORDER_TIME_GTC, 0, "SMC_PRED_LIMIT_BUY");
      if(limitSuccess)
      {
         Print("ð ORDER LIMIT BUY placÃĐ");
         Print("   Price: ", DoubleToString(m5TrendEntry, _Digits));
         Print("   SL: ", DoubleToString(stopLoss, _Digits));
         Print("   TP: ", DoubleToString(takeProfit, _Digits));
         Print("   Lot: ", DoubleToString(lot, 2));
      }
      else
      {
         Print("â ïļ Erreur placement LIMIT BUY: ", GetLastError());
      }
   }
   else // SELL
   {
      // Ordre Sell Limit sur M5 Trend Entry Point
      bool limitSuccess = trade.SellLimit(lot, m5TrendEntry, _Symbol, stopLoss, takeProfit,
                                         ORDER_TIME_GTC, 0, "SMC_PRED_LIMIT_SELL");
      if(limitSuccess)
      {
         Print("ð ORDER LIMIT SELL placÃĐ");
         Print("   Price: ", DoubleToString(m5TrendEntry, _Digits));
         Print("   SL: ", DoubleToString(stopLoss, _Digits));
         Print("   TP: ", DoubleToString(takeProfit, _Digits));
         Print("   Lot: ", DoubleToString(lot, 2));
      }
      else
      {
         Print("â ïļ Erreur placement LIMIT SELL: ", GetLastError());
      }
   }
}

//+------------------------------------------------------------------+
//| WRAPPER POUR CAPTURER TOUTES LES FERMETURES                    |
//+------------------------------------------------------------------+
bool PositionCloseWithLog(ulong ticket, string reason = "")
{
   if(CloseOnlyOnAIHoldOrBrokerSLTP)
   {
      string r = reason;
      StringToUpper(r);
      bool isAIHoldClose = (StringFind(r, "IA HOLD") >= 0);
      // Mode "CloseOnlyOnAIHoldOrBrokerSLTP" : historiquement, on bloquait toute fermeture
      // sauf quand la raison contient "IA HOLD". Or on a besoin que certains close auto
      // critiques (spike / timeout / cassure EMA) passent aussi.
      bool allowByAutoCloseTags =
         isAIHoldClose ||
         (StringFind(r, "IA80_ARROW") >= 0) ||
         (StringFind(r, "OTE SETUP") >= 0 && StringFind(r, "ABSENT") >= 0) ||
         (StringFind(r, "SPIKE") >= 0) ||
         // Ex: "Temps de dÃĐtention maximum atteint"
         ((StringFind(r, "TEMPS") >= 0) && (StringFind(r, "DE") >= 0) &&
          (StringFind(r, "DÃTENTION") >= 0 || StringFind(r, "DETENTION") >= 0)) ||
         // Ex: "SELL cassÃĐ au-dessus EMA rapide (rallye)"
         (StringFind(r, "EMA") >= 0);

      if(!allowByAutoCloseTags)
      {
         Print("â Fermeture active bloquÃĐe (mode SL/TP/IA HOLD, hors tags auto autorisÃĐs) | ticket=", ticket, " | reason=", reason);
         return false;
      }
   }

   // Anti-doublon de fermeture : si on tente plusieurs fois de fermer la mÃŠme position dans un court dÃĐlai,
   // MT5 renvoie souvent "Order to close this position already exists".
   static ulong   lastCloseTickets[16] = {0};
   static datetime lastCloseTimes[16]  = {0};
   static int     lastCloseIdx = 0;

   datetime now = TimeCurrent();
   for(int i = 0; i < 16; i++)
   {
      if(lastCloseTickets[i] == ticket && lastCloseTimes[i] > 0 && (now - lastCloseTimes[i]) <= 3)
      {
         Print("?? SKIP duplicate close (cooldown) | ticket=", ticket, " | reason=", reason);
         return true;
      }
   }

   // Obtenir les informations avant fermeture
   if(!PositionSelectByTicket(ticket))
   {
      Print("?? Position dÃĐjÃ  fermÃĐe (skip) | ticket=", ticket, " | reason=", reason);
      return true;
   }
   else
   {
      string symbol = PositionGetString(POSITION_SYMBOL);
      double profit = PositionGetDouble(POSITION_PROFIT);
      double slPrice = PositionGetDouble(POSITION_SL);
      ENUM_POSITION_TYPE posType = (ENUM_POSITION_TYPE)PositionGetInteger(POSITION_TYPE);
      datetime openTime = (datetime)PositionGetInteger(POSITION_TIME);
      int secondsSinceOpen = (int)(now - openTime);

      if(BlockManualLossCloseBeforeSL && profit < 0.0 && slPrice > 0.0)
      {
         double pt = SymbolInfoDouble(symbol, SYMBOL_POINT);
         if(pt <= 0.0) pt = _Point;
         long stopsLevelPts = SymbolInfoInteger(symbol, SYMBOL_TRADE_STOPS_LEVEL);
         double tol = MathMax(pt * 2.0, (double)stopsLevelPts * pt);
         if(tol <= 0.0) tol = pt * 2.0;

         double bidNow = SymbolInfoDouble(symbol, SYMBOL_BID);
         double askNow = SymbolInfoDouble(symbol, SYMBOL_ASK);
         bool slHit = false;
         if(posType == POSITION_TYPE_BUY)
            slHit = (bidNow <= slPrice + tol);
         else if(posType == POSITION_TYPE_SELL)
            slHit = (askNow >= slPrice - tol);

         if(!slHit)
         {
            Print("â Fermeture manuelle bloquÃĐe avant SL | ", symbol,
                  " | ticket=", ticket,
                  " | reason=", reason,
                  " | pnl=", DoubleToString(profit, 2),
                  " | SL=", DoubleToString(slPrice, _Digits));
            return false;
         }
      }
      
      // PROTECTION PERTE / SPIKE:
      // - EquitÃĐ faible (< seuil): fermeture active autorisÃĐe seulement si perte <= seuil USD.
      // - EquitÃĐ >= seuil: si "spike non arrivÃĐ", on laisse le trade aller au SL broker.
      string rsnProt = reason;
      StringToUpper(rsnProt);
      bool adverseSpikeExit = (StringFind(rsnProt, "SPIKE ADVERSE") >= 0);
      bool boomCrashSpikeAutoClose = (StringFind(rsnProt, "SPIKE CLOSE") >= 0);
      bool oteSetupGoneFromChart = (StringFind(rsnProt, "OTE SETUP") >= 0 && StringFind(rsnProt, "ABSENT") >= 0);
      bool ia80ArrowExit = (StringFind(rsnProt, "IA80_ARROW") >= 0);
      bool spikeNoArrivalExit =
         (!adverseSpikeExit) &&
         (
            boomCrashSpikeAutoClose ||
            (StringFind(rsnProt, "SANS SPIKE") >= 0) ||
            ((StringFind(rsnProt, "DERIV") >= 0) && (StringFind(rsnProt, "DISPARU") >= 0 || StringFind(rsnProt, "DISPARUE") >= 0))
         );
      double eqNow = AccountInfoDouble(ACCOUNT_EQUITY);
      bool lowEquity = (eqNow < SpikeNoArrivalAllowSLAboveEquityUSD);
      double earlyCutAbs = MathMax(0.0, SpikeNoArrivalEarlyCutLossUSD);

      if(profit < 0 && spikeNoArrivalExit && !lowEquity)
      {
         Print("SPIKE NON ARRIVE - Equite elevee, fermeture active bloquee (laisser SL)");
         Print("   Equite: ", DoubleToString(eqNow, 2), "$ >= ", DoubleToString(SpikeNoArrivalAllowSLAboveEquityUSD, 2), "$");
         Print("   Position: ", symbol, " | Ticket: ", ticket, " | PnL: ", DoubleToString(profit, 2), "$");
         Print("   Raison: ", reason);
         return false;
      }

      if(profit < 0 && lowEquity && profit > -earlyCutAbs && !adverseSpikeExit && !oteSetupGoneFromChart && !ia80ArrowExit)
      {
         Print("PROTECTION PERTE (equite faible) - Fermeture bloquee");
         Print("   Position: ", symbol, " | Ticket: ", ticket);
         Print("   Perte: ", DoubleToString(profit, 2), "$ > -", DoubleToString(earlyCutAbs, 2), "$ (seuil)");
         Print("   Equite: ", DoubleToString(eqNow, 2), "$ < ", DoubleToString(SpikeNoArrivalAllowSLAboveEquityUSD, 2), "$");
         Print("   Raison: ", reason, " | ACTION: Position maintenue");
         return false; // Bloquer la fermeture
      }
      
      // Si la perte depasse le seuil configure en equite faible, autoriser la fermeture active.
      if(profit < 0 && lowEquity && profit <= -earlyCutAbs)
      {
         Print("PERTE IMPORTANTE (equite faible) - Fermeture autorisee");
         Print("   Position: ", symbol, " | Ticket: ", ticket);
         Print("   Perte: ", DoubleToString(profit, 2), "$ <= -", DoubleToString(earlyCutAbs, 2), "$ (seuil depasse)");
         Print("   Equite: ", DoubleToString(eqNow, 2), "$ < ", DoubleToString(SpikeNoArrivalAllowSLAboveEquityUSD, 2), "$");
         Print("   Raison: ", reason, " | ACTION: Fermeture autorisee");
      }
      
      // Si profit positif, autoriser normalement
      if(profit >= 0)
      {
         Print("?? POSITION EN GAIN - Fermeture autorisÃĐe");
         Print("   ?? Position: ", symbol, " | Ticket: ", ticket);
         Print("   ?? Profit: ", DoubleToString(profit, 2), "$ | ACTION: Fermeture autorisÃĐe");
      }
      
      Print("?? FERMETURE DÃTECTÃE - ", symbol, 
            " | Ticket: ", ticket,
            " | Profit: ", DoubleToString(profit, 2), "$",
            " | Ãge: ", secondsSinceOpen, "s",
            " | Raison: ", reason);
   }
   
   // ExÃĐcuter la fermeture rÃĐelle
   bool ok = trade.PositionClose(ticket);
   now = TimeCurrent();

   // Enregistrer l'historique pour empÃŠcher les doublons
   lastCloseTickets[lastCloseIdx] = ticket;
   lastCloseTimes[lastCloseIdx]   = now;
   lastCloseIdx = (lastCloseIdx + 1) % 16;

   if(ok)
   {
      g_lastCloseActionTime = now;
      g_lastCloseActionSymbol = PositionSelectByTicket(ticket) ? PositionGetString(POSITION_SYMBOL) : _Symbol;
      return true;
   }

   // Si la position n'existe plus, c'est que quelqu'un l'a dÃĐjÃ  fermÃĐe
   if(!PositionSelectByTicket(ticket))
   {
      g_lastCloseActionTime = now;
      return true;
   }

   // Si MT5/plateforme signale que la fermeture existe dÃĐjÃ , considÃĐrer comme OK (ÃĐvite les retries).
   string c = trade.ResultComment();
   StringToLower(c);
   if(StringFind(c, "already exists") >= 0 || StringFind(c, "order to close") >= 0)
   {
      g_lastCloseActionTime = now;
      return true;
   }

   return false;
}

