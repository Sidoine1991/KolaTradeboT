                   timeStart + PeriodSeconds(PERIOD_M1) * 30, chochLevel - (swingHigh - swingLow) * 0.02,
                   timeStart + PeriodSeconds(PERIOD_M1) * 50, chochLevel + (swingHigh - swingLow) * 0.02);
