      // Placer les ordres limit sur M5 Trend Entry Point
      PlaceSMCPredictionLimitOrders("BUY", bosLow + m5TrendSlope * 50, entry, stopLoss, takeProfit);
      
      Print("\nâ === SMC PREDICTION SETUP HAUSSIER TRACÃ ===");
      Print("ð BOS LEVEL: ", DoubleToString(bosLow, _Digits));
      Print("ð CHoCH LEVEL: ", DoubleToString(chochLevel, _Digits));
      Print("ðĶ ORDER BLOCK: ", DoubleToString(orderBlockLow, _Digits), " - ", DoubleToString(orderBlockHigh, _Digits));
      Print("âŽïļ M5 TREND ENTRY: ", DoubleToString(bosLow + m5TrendSlope * 50, _Digits));
      Print("ðŊ ENTRY (50%): ", DoubleToString(entry, _Digits));
      Print("ð STOP LOSS: ", DoubleToString(stopLoss, _Digits));
      Print("â TAKE PROFIT (RR 1:5): ", DoubleToString(takeProfit, _Digits));
      Print("âąïļ Projection: 200 bougies M1 (~3h20 min)\n");
   }
   else // BAISSIER
   {
      // Setup BAISSIER: cherche une zone Ã  casser vers le bas
      bosHigh = swingHigh;
      bosLow = swingHigh - (swingHigh - swingLow) * 0.618;
      chochLevel = bosLow - (swingHigh - swingLow) * 0.2;
      orderBlockHigh = bosLow + (swingHigh - swingLow) * 0.05;
      orderBlockLow = bosLow - (swingHigh - swingLow) * 0.05;
      
      // Zones Fibonacci pour calcul de l'entrÃĐe
