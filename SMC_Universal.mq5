input double PreSpike_CompressionRatio   = 0.65;  // PrÃĐ-spike: range10 < range50 * ratio (plus haut = plus permissif)
input double PreSpike_ConsolidationPct   = 0.002; // PrÃĐ-spike: distance au MA20 (0.2% par dÃĐfaut)
input double PreSpike_KeyLevelPct        = 0.002; // PrÃĐ-spike: proximitÃĐ swing high/low (0.2% par dÃĐfaut)

