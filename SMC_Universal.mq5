      Print("?? SPIKE TRADE ouvert — surveillance continue (fermeture dès gain net > 0 si activé) | dir=", direction, " | ", _Symbol);
   else
      Print("?? SPIKE TRADE ouvert — fermeture pilotée par ManageBoomCrashSpikeClose (seuils spike) | ", _Symbol);
   return;
   
   /* 
