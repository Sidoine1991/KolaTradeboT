// Retourne la derniÃĻre intersection prix/canal ML (et une projection simple)
// direction = "BUY" (canal infÃĐrieur) ou "SELL" (canal supÃĐrieur)
bool GetRecentAndProjectedMLChannelIntersection(string direction, double &recentPrice, datetime &recentTime, double &projectedPrice, datetime &projectedTime)
{
   if(!g_channelValid) return false;
   
   int periodSec = 60;
   double slopeUpper = (PredictionChannelBars > 0) ? (g_chUpperEnd - g_chUpperStart) / (double)PredictionChannelBars : 0;
   double slopeLower = (PredictionChannelBars > 0) ? (g_chLowerEnd - g_chLowerStart) / (double)PredictionChannelBars : 0;
   
   MqlRates rates[];
   ArraySetAsSeries(rates, true);
   int bars = CopyRates(_Symbol, PERIOD_M1, 0, 200, rates);
   if(bars < 10) return false;
   
   datetime last1 = 0, last2 = 0;
   double price1 = 0.0, price2 = 0.0;
   
   // Parcours des bougies (0 = plus rÃĐcente)
   for(int i = 1; i < bars; i++)
   {
      datetime tCurr = rates[i-1].time;
      datetime tPrev = rates[i].time;
      
      double minsFromStartCurr = (g_chTimeStart > 0) ? (double)(tCurr - g_chTimeStart) / (double)periodSec : 0.0;
      double minsFromStartPrev = (g_chTimeStart > 0) ? (double)(tPrev - g_chTimeStart) / (double)periodSec : 0.0;
      
      double chCurr = 0.0, chPrev = 0.0;
      if(direction == "BUY")
      {
         chCurr = g_chLowerStart + slopeLower * minsFromStartCurr;
         chPrev = g_chLowerStart + slopeLower * minsFromStartPrev;
      }
      else // SELL
      {
         chCurr = g_chUpperStart + slopeUpper * minsFromStartCurr;
         chPrev = g_chUpperStart + slopeUpper * minsFromStartPrev;
      }
      
      double diffCurr = rates[i-1].close - chCurr;
      double diffPrev = rates[i].close - chPrev;
      
      bool crossed = (diffCurr == 0.0 || diffPrev == 0.0 || (diffCurr > 0.0 && diffPrev < 0.0) || (diffCurr < 0.0 && diffPrev > 0.0));
      if(crossed)
      {
         datetime tInt = tCurr;
         double pInt = chCurr;
         
         if(last1 == 0)
         {
            last1 = tInt;
            price1 = pInt;
         }
         else
         {
            last2 = last1;
            price2 = price1;
            last1 = tInt;
            price1 = pInt;
         }
      }
   }
   
   if(last1 == 0)
      return false;
   
   recentPrice = price1;
   recentTime = last1;
   
   // Par dÃĐfaut la projection = derniÃĻre intersection
   projectedPrice = price1;
   projectedTime  = last1;
   
   if(last2 > 0 && g_chTimeEnd > 0)
   {
      int dtSec = (int)(last1 - last2);
      if(dtSec > 0)
      {
         datetime tProj = last1 + (datetime)dtSec;
         if(tProj > g_chTimeEnd)
            tProj = g_chTimeEnd;
         
         double minsFromStartProj = (g_chTimeStart > 0) ? (double)(tProj - g_chTimeStart) / (double)periodSec : 0.0;
         double chProj = 0.0;
         if(direction == "BUY")
            chProj = g_chLowerStart + slopeLower * minsFromStartProj;
         else
            chProj = g_chUpperStart + slopeUpper * minsFromStartProj;
         
         projectedPrice = chProj;
         projectedTime  = tProj;
      }
   }
   
   return true;
}

bool DetectSMCSignal(SMC_Signal &sig)
{
   sig.action = "HOLD";
   sig.confidence = 0;
   sig.reasoning = "";
   sig.entryPrice = 0;
   sig.stopLoss = 0;
   sig.takeProfit = 0;
   
   ENUM_SYMBOL_CATEGORY cat = SMC_GetSymbolCategory(_Symbol);
   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   
   if(atrHandle == INVALID_HANDLE) return false;
   double atr[];
   ArraySetAsSeries(atr, true);
   if(CopyBuffer(atrHandle, 0, 0, 3, atr) < 3) return false;
   double atrMult = SMC_GetATRMultiplier(cat);
   
   bool hasBuySignal = false;
   bool hasSellSignal = false;
   string reason = "";
   
   bool lsSSL = false, lsBSL = false;
   int lsBarsAgo = 99;
   if(UseLiquiditySweep)
   {
      string lsType;
      int barsAgo = 0;
      if(SMC_DetectLiquiditySweepEx(_Symbol, LTF, lsType, barsAgo))
      {
         lsBarsAgo = barsAgo;
         if(lsType == "SSL") lsSSL = true;
         else if(lsType == "BSL") lsBSL = true;
      }
      if(!RequireStructureAfterSweep)
      {
         if(lsSSL) { hasBuySignal = true; reason += "LS-SSL "; }
         else if(lsBSL) { hasSellSignal = true; reason += "LS-BSL "; }
      }
   }
   
   if(UseFVG)
   {
      FVGData fvg;
      if(SMC_DetectFVG(_Symbol, LTF, 30, fvg))
      {
         if(fvg.direction == 1 && bid >= fvg.bottom && bid <= fvg.top) { hasBuySignal = true; reason += "FVG-Bull "; }
         else if(fvg.direction == -1 && ask <= fvg.top && ask >= fvg.bottom) { hasSellSignal = true; reason += "FVG-Bear "; }
      }
   }
   
   if(UseOrderBlocks)
   {
      OrderBlockData ob;
      if(SMC_DetectOrderBlock(_Symbol, LTF, ob))
      {
         if(ob.direction == 1 && bid >= ob.low && bid <= ob.high) { hasBuySignal = true; reason += "OB-Bull "; }
         else if(ob.direction == -1 && ask <= ob.high && ask >= ob.low) { hasSellSignal = true; reason += "OB-Bear "; }
      }
   }
   
   if(UseBOS)
   {
      int bosDir;
      if(SMC_DetectBOS(_Symbol, LTF, bosDir))
      {
         if(bosDir == 1) { hasBuySignal = true; reason += "BOS-Up "; }
         else if(bosDir == -1) { hasSellSignal = true; reason += "BOS-Down "; }
      }
   }
   bool inDiscount = IsInDiscountZone();
   bool inPremium  = IsInPremiumZone();
   if(inDiscount) { hasBuySignal = true; reason += "Zone-Discount "; }
   if(inPremium)  { hasSellSignal = true; reason += "Zone-Premium "; }

   if(RequireStructureAfterSweep && UseLiquiditySweep)
   {
      bool waitOk = !NoEntryDuringSweep || (lsBarsAgo >= 1); // RÃĐduit de 2 Ã  1 barre
      // Moins restrictif: ne bloquer que les signaux contradictoires directs
      if(lsSSL && hasSellSignal) hasSellSignal = false; // Bloquer SELL si SSL dÃĐtectÃĐ
      if(lsBSL && hasBuySignal) hasBuySignal = false;  // Bloquer BUY si BSL dÃĐtectÃĐ
      // Garder les autres signaux mÃŠme sans confirmation LS
      if(hasBuySignal && lsSSL && waitOk) reason += "[LS+Conf] ";
      if(hasSellSignal && lsBSL && waitOk) reason += "[LS+Conf] ";
   }
   if((g_lastAIAction == "BUY" || g_lastAIAction == "buy") && g_lastAIConfidence >= MinAIConfidence) { hasBuySignal = true; reason += "IA-BUY "; }
   if((g_lastAIAction == "SELL" || g_lastAIAction == "sell") && g_lastAIConfidence >= MinAIConfidence) { hasSellSignal = true; reason += "IA-SELL "; }

   bool isBoom = (cat == SYM_BOOM_CRASH && StringFind(_Symbol, "Boom") >= 0);
   bool isCrash = (cat == SYM_BOOM_CRASH && StringFind(_Symbol, "Crash") >= 0);
   if(isBoom && BoomBuyOnly) hasSellSignal = false;
   if(isCrash && CrashSellOnly) hasBuySignal = false;
   
   double slDist = atr[0] * SL_ATRMult;
   double tpDist = atr[0] * TP_ATRMult;
   MqlRates r[];
   ArraySetAsSeries(r, true);
   bool haveRates = (CopyRates(_Symbol, LTF, 0, 10, r) >= 10);
   double newSwingLow = 0, newSwingHigh = 0;
   if(haveRates && StopBeyondNewStructure)
   {
      newSwingLow = r[1].low;
      newSwingHigh = r[1].high;
      for(int i = 2; i < 8; i++) { if(r[i].low < newSwingLow) newSwingLow = r[i].low; if(r[i].high > newSwingHigh) newSwingHigh = r[i].high; }
   }
   
   double buffer = atr[0] * 0.5;
   if(hasBuySignal && !hasSellSignal)
   {
      sig.action = "BUY";
      sig.confidence = 0.65;
      sig.concept = reason;
      sig.reasoning = "SMC: " + reason;
      sig.entryPrice = ask;
      // SL/TP toujours calculÃĐs Ã  lâouverture (y compris Boom/Crash)
      {
         double currentAsk = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
         double currentBid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
         
         if(StopBeyondNewStructure && lsSSL && newSwingLow > 0)
            sig.stopLoss = newSwingLow - buffer;
         else
         {
            double minSL = MathMax(20.0 * _Point, slDist * 0.3);
            sig.stopLoss = currentAsk - minSL;
         }
         
         double minTP = MathMax(40.0 * _Point, tpDist * 0.4);
         sig.takeProfit = currentAsk + minTP;
         
         Print("?? SL/TP ajustÃĐs: SL=", DoubleToString(sig.stopLoss, _Digits), 
                " TP=", DoubleToString(sig.takeProfit, _Digits), 
                " Ask=", DoubleToString(currentAsk, _Digits));
      }
      return true;
   }
   else if(hasSellSignal && !hasBuySignal)
   {
      sig.action = "SELL";
      sig.confidence = 0.65;
      sig.concept = reason;
      sig.reasoning = "SMC: " + reason;
      sig.entryPrice = bid;
      {
         double currentAsk = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
         double currentBid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
         
         if(StopBeyondNewStructure && lsBSL && newSwingHigh > 0)
            sig.stopLoss = newSwingHigh + buffer;
         else
         {
            double minSL = MathMax(20.0 * _Point, slDist * 0.3);
            sig.stopLoss = currentBid + minSL;
         }
         
         double minTP = MathMax(40.0 * _Point, tpDist * 0.4);
         sig.takeProfit = currentBid - minTP;
         
         Print("?? SL/TP ajustÃĐs SELL: SL=", DoubleToString(sig.stopLoss, _Digits), 
                " TP=", DoubleToString(sig.takeProfit, _Digits), 
                " Bid=", DoubleToString(currentBid, _Digits));
      }
      return true;
   }
   return false;
}

bool ConfirmWithAI(SMC_Signal &sig)
{
   if(!RequireAIConfirmation) return true;
   if(!UseAIServer) return true;
   
   // Plus permissif: utiliser la derniÃĻre dÃĐcision IA si disponible
   if(g_lastAIAction != "" && g_lastAIConfidence > 0)
   {
      // Confiance rÃĐduite pour plus d'opportunitÃĐs
      if(g_lastAIConfidence >= 0.40) // 40% au lieu de 55%
      {
         if(sig.action == "BUY" && (g_lastAIAction == "BUY" || g_lastAIAction == "buy")) 
         {
            Print("? Signal BUY confirmÃĐ par IA (conf: ", DoubleToString(g_lastAIConfidence*100, 1), "%)");
            return true;
         }
         if(sig.action == "SELL" && (g_lastAIAction == "SELL" || g_lastAIAction == "sell")) 
         {
            Print("? Signal SELL confirmÃĐ par IA (conf: ", DoubleToString(g_lastAIConfidence*100, 1), "%)");
            return true;
         }
      }
   }
   
   // Fallback plus permissif si IA disponible mais faible confiance
   if(g_lastAIConfidence >= 0.30 && g_lastAIConfidence > 0)
   {
      Print("?? Signal exÃĐcutÃĐ avec faible confiance IA (", DoubleToString(g_lastAIConfidence*100, 1), "%)");
      return true;
   }
   
   // Si IA indisponible, autoriser quand mÃŠme pour ne pas manquer d'opportunitÃĐs
   if(g_lastAIAction == "" || g_lastAIConfidence == 0)
   {
      Print("?? IA indisponible - Signal SMC exÃĐcutÃĐ sans confirmation");
      return true;
   }
   
   Print("? Signal rejetÃĐ - IA: ", g_lastAIAction, " (conf: ", DoubleToString(g_lastAIConfidence*100, 1), "%)");
   return false;
}

void ExecuteSignal(SMC_Signal &sig)
{
   if(IsMaxPositionsReached()) return;
   if(!TryAcquireOpenLock()) return;
   double lotSize = CalculateLotSize();
   lotSize = ApplyRecoveryLot(lotSize, sig.action);
   if(lotSize <= 0) { ReleaseOpenLock(); return; }
   
   // STRATÃGIE UNIQUE SPIKE POUR BOOM/CRASH:
   // ne pas exÃĐcuter la logique SMC classique sur Boom/Crash
   if(SMC_GetSymbolCategory(_Symbol) == SYM_BOOM_CRASH)
   {
      ReleaseOpenLock();
      return;
   }
   
   // Exiger une dÃĐcision IA forte + modÃĻle suffisamment prÃĐcis pour tous les marchÃĐs non Boom/Crash
   if(!IsAITradeAllowedForDirection(sig.action) || !IsMLModelTrustedForCurrentSymbol(sig.action))
   {
      ReleaseOpenLock();
      return;
   }

   // RÃĐentrÃĐe aprÃĻs perte sur ce symbole: exiger conditions exceptionnelles
   if(!AllowReentryAfterRecentLoss(_Symbol, sig.action, false))
   {
      ReleaseOpenLock();
      return;
   }
   
   // Interdire SELL sur Boom et BUY sur Crash
   if(!IsDirectionAllowedForBoomCrash(_Symbol, sig.action))
   {
      Print("? Signal ", sig.action, " bloquÃĐ sur ", _Symbol, " (rÃĻgle Boom/Crash: pas de SELL sur Boom, pas de BUY sur Crash)");
      ReleaseOpenLock();
      return;
   }
   
    // ContrÃīle de duplication: ne pas ouvrir de nouvelle position
    // si les conditions IA fortes + gain 2$ ne sont pas rÃĐunies
    if(!CanOpenAdditionalPositionForSymbol(_Symbol, sig.action))
    {
       Print("? Nouvelle position ", sig.action, " bloquÃĐe sur ", _Symbol, " (rÃĻgle duplication: besoin +2$ sur position initiale et IA >= 80%)");
       ReleaseOpenLock();
       return;
    }
   
   // RÃGLE SPÃCIALE BOOM/CRASH: Bloquer TOUJOURS les signaux contraires Ã  l'IA
   // Peu importe le niveau de confiance, pour respecter les rÃĻgles Boom/Crash
   ENUM_SYMBOL_CATEGORY cat = SMC_GetSymbolCategory(_Symbol);
   if(cat == SYM_BOOM_CRASH)
   {
      if(StringFind(_Symbol, "Boom") >= 0)
      {
         // Boom n'accepte que BUY
         if(sig.action == "SELL")
         {
            Print("? SELL SMC BLOQUÃ - Boom n'accepte que BUY (IA: ", g_lastAIAction, " ", DoubleToString(g_lastAIConfidence*100,1), "%)");
            ReleaseOpenLock();
            return;
         }
      }
      else if(StringFind(_Symbol, "Crash") >= 0)
      {
         // Crash n'accepte que SELL
         if(sig.action == "BUY")
         {
            Print("? BUY SMC BLOQUÃ - Crash n'accepte que SELL (IA: ", g_lastAIAction, " ", DoubleToString(g_lastAIConfidence*100,1), "%)");
            ReleaseOpenLock();
            return;
         }
      }
   }
   else
   {
      // Pour les autres symboles: bloquer seulement si confiance IA forte (>= max(MinAIConfidence, 60%))
      double strongAIThreshold = MathMax(MinAIConfidence, 0.65);
      if(g_lastAIConfidence >= strongAIThreshold)
      {
         if((g_lastAIAction == "BUY" || g_lastAIAction == "buy") && sig.action == "SELL")
         {
            Print("? SELL SMC bloquÃĐ car IA = BUY (conf: ", DoubleToString(g_lastAIConfidence*100,1), "%)");
            ReleaseOpenLock();
            return;
         }
         if((g_lastAIAction == "SELL" || g_lastAIAction == "sell") && sig.action == "BUY")
         {
            Print("? BUY SMC bloquÃĐ car IA = SELL (conf: ", DoubleToString(g_lastAIConfidence*100,1), "%)");
            ReleaseOpenLock();
            return;
         }
      }
   }
   
   // Protection capital: zone discount au bord infÃĐrieur ? SELL seulement si confiance IA >= 85%
   if(sig.action == "SELL" && IsAtDiscountLowerEdge() && g_lastAIConfidence < 0.85)
   {
      Print("? SELL SMC bloquÃĐ - Zone Discount au bord infÃĐrieur: confiance IA ? 85% requise (actuel: ",
            DoubleToString(g_lastAIConfidence*100, 1), "%)");
      ReleaseOpenLock();
      return;
   }

   // RÃĐduire les entrÃĐes hÃĒtives: exiger la flÃĻche SMC_DERIV_ARROW avant tout ordre au marchÃĐ
   if(!HasRecentSMCDerivArrowForDirection(sig.action))
   {
      Print("?? ORDRE SMC BLOQUÃ - Attendre flÃĻche SMC_DERIV_ARROW ", sig.action, " sur ", _Symbol);
      ReleaseOpenLock();
      return;
   }
   
   // RÃĐinitialiser le gain maximum pour la nouvelle position
   g_maxProfit = 0;
   
   if(sig.action == "BUY")
   {
      trade.Buy(lotSize, _Symbol, 0, sig.stopLoss, sig.takeProfit, "SMC " + sig.concept);
      if(trade.ResultRetcode() == TRADE_RETCODE_DONE)
      {
         Print("? SMC BUY @ ", sig.entryPrice, " - ", sig.concept);
         NotifyTradeEvent("â POSITION OUVERTE - SMC BUY " + _Symbol + " " + sig.concept, EntryTradeSoundFile);
      }
   }
   else if(sig.action == "SELL")
   {
      trade.Sell(lotSize, _Symbol, 0, sig.stopLoss, sig.takeProfit, "SMC " + sig.concept);
      if(trade.ResultRetcode() == TRADE_RETCODE_DONE)
      {
         Print("? SMC SELL @ ", sig.entryPrice, " - ", sig.concept);
         NotifyTradeEvent("â POSITION OUVERTE - SMC SELL " + _Symbol + " " + sig.concept, EntryTradeSoundFile);
      }
   }
   ReleaseOpenLock();
}

double CalculateLotSize()
{
   // Mettre Ã  jour les stats de drawdown journalier
   UpdateDailyEquityStats();

   // Activer le filtre de zone d'ÃĐquilibre UNIQUEMENT aprÃĻs avoir atteint la perte journaliÃĻre max
   bool dailyLossThresholdHit = IsDailyLossPauseActive();

   // Objectif "journalier par symbole" : si ce symbole est verrouillÃĐ, bloquer l'entrÃĐe
   if(UsePerSymbolDailyObjectiveOnly && IsSymbolPaused(_Symbol))
      return 0.0;

   // Si la perte journaliÃĻre max n'est PAS atteinte, on laisse le robot trader toutes les opportunitÃĐs,
   // y compris en zone de correction.
   // Une fois la perte journaliÃĻre atteinte, on active le filtre de zone pour bloquer uniquement ces entrÃĐes.
   if(dailyLossThresholdHit && IsInEquilibriumCorrectionZone())
   {
      static datetime lastCorrLog = 0;
      datetime now = TimeCurrent();
      if(now - lastCorrLog >= 30)
      {
         Print("ðŦ ENTRÃE BLOQUÃE - Zone de correction autour de l'ÃĐquilibre (",
               DoubleToString(EquilibriumCorrectionBandPercent, 1),
               "%) sur ", _Symbol,
               " aprÃĻs atteinte de la perte journaliÃĻre max.");
         lastCorrLog = now;
      }
      return 0.0;
   }

   // Si le gain journalier cible est atteint, bloquer toute nouvelle entrÃĐe jusqu'Ã  fin de journÃĐe
   if(!UsePerSymbolDailyObjectiveOnly && IsDailyProfitPauseActive())
   {
      Print("âļ Nouvelle entrÃĐe bloquÃĐe - gain journalier cible atteint (fin de journÃĐe).");
      return 0.0;
   }

   // Si la perte cumulative (trades consÃĐcutifs) a dÃĐclenchÃĐ une pause
   if(IsCumulativeLossPauseActive())
   {
      Print("âļ Nouvelle entrÃĐe bloquÃĐe - pause perte cumulative active.");
      return 0.0;
   }

   // Si le drawdown max est atteint, ne plus ouvrir de nouvelles positions
   if(IsDailyDrawdownExceeded())
   {
      Print("?? Nouvelle entrÃĐe bloquÃĐe par la gestion de risque journaliÃĻre.");
      return 0.0;
   }

   double minLot = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN);
   double lotStep = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_STEP);
   
   // Politique volume stricte: toujours lot minimum broker, quel que soit le symbole.
   return NormalizeVolumeForSymbol(minLot);
   double maxLot = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MAX);
   double balance = AccountInfoDouble(ACCOUNT_BALANCE);
   double riskPct = MaxRiskPerTradePercent;
   if(riskPct <= 0.0) riskPct = 1.0; // fallback trÃĻs conservateur
   double riskAmount = balance * (riskPct / 100.0);
   double tickVal = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_VALUE);
   double tickSize = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_SIZE);
   double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   if(tickVal <= 0 || tickSize <= 0) return minLot;
   if(atrHandle == INVALID_HANDLE) return minLot;
   double atr[];
   ArraySetAsSeries(atr, true);
   if(CopyBuffer(atrHandle, 0, 0, 1, atr) < 1) return minLot;
   double slPoints = (atr[0] / point) * SL_ATRMult;
   double pipVal = (tickVal / tickSize) * point;
   if(pipVal <= 0) return minLot;
   double lotSize = riskAmount / (slPoints * pipVal);
   lotSize = MathMax(minLot, MathMin(maxLot, lotSize));
   
   // CORRECTION ROBUSTE POUR ÃVITER "INVALID VOLUME"
   // Arrondir correctement selon le step du broker
   int steps = (int)MathRound(lotSize / lotStep);
   lotSize = steps * lotStep;
   
   // S'assurer que le lot est >= minLot
   if(lotSize < minLot)
      lotSize = minLot;
   
   // S'assurer que le lot est <= maxLot
   if(lotSize > maxLot)
      lotSize = maxLot;
   
   // Normalisation finale avec la prÃĐcision requise par le symbole
   int digits = 2; // Standard pour les volumes (gÃĐnÃĐralement 2 dÃĐcimales)
   double normalizedLot = NormalizeDouble(lotSize, digits);
   
   // VALIDATION FINALE - S'assurer que le lot reste dans la plage broker
   if(normalizedLot < minLot || normalizedLot > maxLot)
   {
      Print("ðĻ VOLUME AJUSTÃ - Lot calculÃĐ hors plage broker: ", DoubleToString(normalizedLot, digits));
      Print("   ð MinLot: ", DoubleToString(minLot, digits), " | MaxLot: ", DoubleToString(maxLot, digits));
      Print("   ð LotStep: ", DoubleToString(lotStep, digits));
      normalizedLot = minLot; // Repli strict: lot minimum broker
   }
   
   // S'assurer que le lot final est valide
   if(normalizedLot < minLot)
      normalizedLot = minLot;
   if(normalizedLot > maxLot)
      normalizedLot = maxLot;
   
   // Log de dÃĐbogage pour le volume calculÃĐ
   static datetime lastLotDebugLog = 0;
   if(TimeCurrent() - lastLotDebugLog >= 60) // Log toutes les minutes
   {
      Print("ð VOLUME CALCULÃ - ", _Symbol);
      Print("   ð° Balance: ", DoubleToString(balance, 2), "$");
      Print("   ðŊ Risk%: ", DoubleToString(riskPct, 1), "% | RiskAmount: ", DoubleToString(riskAmount, 2), "$");
      Print("   ð SL Points: ", DoubleToString(slPoints, 1), " | Pip Value: ", DoubleToString(pipVal, 5));
      Print("   ðĶ Lot calculÃĐ: ", DoubleToString(lotSize, digits), " | NormalisÃĐ: ", DoubleToString(normalizedLot, digits));
      Print("   â Lot final: ", DoubleToString(normalizedLot, digits), " (Valide: ", (normalizedLot >= minLot && normalizedLot <= maxLot ? "OUI" : "NON"), ")");
      lastLotDebugLog = TimeCurrent();
   }
   
   return NormalizeVolumeForSymbol(normalizedLot);
}

// Variante pour ordres en attente (BUY/SELL LIMIT) sur niveaux stratÃĐgiques (Pivot/SuperTrend/etc.).
// On garde le money management (pauses / drawdown) mais on ne bloque pas uniquement parce que le marchÃĐ est en "correction".
double CalculateLotSizeForPendingOrders()
{
   UpdateDailyEquityStats();

   // Pour les ordres en attente, on applique uniquement les pauses liÃĐes
   // au profit journalier, aux pertes cumulÃĐes et au drawdown, mais PAS
   // la perte journaliÃĻre max en tant que blocage global.
   if(IsDailyProfitPauseActive() || IsCumulativeLossPauseActive() || IsDailyDrawdownExceeded())
      return 0.0;

   double minLot = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN);
   double lotStep = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_STEP);
   
   // Politique volume stricte: toujours lot minimum broker.
   return NormalizeVolumeForSymbol(minLot);

   double maxLot = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MAX);
   double balance = AccountInfoDouble(ACCOUNT_BALANCE);
   double riskPct = MaxRiskPerTradePercent;
   if(riskPct <= 0.0) riskPct = 1.0;
   double riskAmount = balance * (riskPct / 100.0);

   double tickVal = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_VALUE);
   double tickSize = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_SIZE);
   double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   if(tickVal <= 0 || tickSize <= 0) return minLot;
   if(atrHandle == INVALID_HANDLE) return minLot;

   double atr[];
   ArraySetAsSeries(atr, true);
   if(CopyBuffer(atrHandle, 0, 0, 1, atr) < 1) return minLot;

   double slPoints = (atr[0] / point) * SL_ATRMult;
   double pipVal = (tickVal / tickSize) * point;
   if(pipVal <= 0) return minLot;

   double lotSize = riskAmount / (slPoints * pipVal);
   lotSize = MathMax(minLot, MathMin(maxLot, lotSize));
   if(lotStep <= 0) lotStep = 0.01;
   
   // CORRECTION ROBUSTE POUR ÃVITER "INVALID VOLUME" (ORDRES LIMIT)
   // Arrondir correctement selon le step du broker
   int steps = (int)MathFloor(lotSize / lotStep);
   lotSize = steps * lotStep;
   
   // S'assurer que le lot est >= minLot
   if(lotSize < minLot)
      lotSize = minLot;
   
   // S'assurer que le lot est <= maxLot
   if(lotSize > maxLot)
      lotSize = maxLot;
   
   // Normalisation finale avec la prÃĐcision requise par le symbole
   int digits = 2; // Standard pour les volumes (gÃĐnÃĐralement 2 dÃĐcimales)
   double normalizedLot = NormalizeDouble(lotSize, digits);
   
   // VALIDATION FINALE - S'assurer que le lot est valide
   if(normalizedLot < minLot || normalizedLot > maxLot)
   {
      Print("ðĻ ERREUR VOLUME ORDRE LIMIT - Lot calculÃĐ invalide: ", DoubleToString(normalizedLot, digits));
      Print("   ð MinLot: ", DoubleToString(minLot, digits), " | MaxLot: ", DoubleToString(maxLot, digits));
      Print("   ð LotStep: ", DoubleToString(lotStep, digits), " | Digits: ", digits);
      Print("   ðĄ Utilisation du lot minimum par sÃĐcuritÃĐ");
      return minLot; // Retourner le lot minimum en cas d'erreur
   }
   
   // Log de dÃĐbogage pour le volume calculÃĐ (ordres limit)
   static datetime lastPendingLotDebugLog = 0;
   if(TimeCurrent() - lastPendingLotDebugLog >= 120) // Log toutes les 2 minutes
   {
      Print("ð VOLUME ORDRE LIMIT CALCULÃ - ", _Symbol);
      Print("   ð° Balance: ", DoubleToString(balance, 2), "$");
      Print("   ðŊ Risk%: ", DoubleToString(riskPct, 1), "% | RiskAmount: ", DoubleToString(riskAmount, 2), "$");
      Print("   ð SL Points: ", DoubleToString(slPoints, 1), " | Pip Value: ", DoubleToString(pipVal, 5));
      Print("   ðĶ Lot calculÃĐ: ", DoubleToString(lotSize, digits), " | NormalisÃĐ: ", DoubleToString(normalizedLot, digits));
      Print("   â Lot final ordre limit: ", DoubleToString(normalizedLot, digits), " (Valide: ", (normalizedLot >= minLot && normalizedLot <= maxLot ? "OUI" : "NON"), ")");
      lastPendingLotDebugLog = TimeCurrent();
   }
   
   return NormalizeVolumeForSymbol(normalizedLot);
}

// Normaliser un volume arbitraire en respectant min/max/step du symbole
double NormalizeVolumeForSymbol(double desiredVolume)
{
   double minLot  = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN);
   double maxLot  = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MAX);
   double lotStep = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_STEP);
   if(minLot <= 0.0) minLot = 0.01;
   if(maxLot <= 0.0) maxLot = minLot;
   if(lotStep <= 0.0) lotStep = minLot;
   if(maxLot < minLot) maxLot = minLot;
   double vol = desiredVolume;
   if(vol < minLot) vol = minLot;
   if(vol > maxLot) vol = maxLot;

   // IMPORTANT: certains brokers exigent minLot + N*step (pas seulement N*step depuis 0)
   int steps = (int)MathFloor(((vol - minLot) / lotStep) + 1e-8);
   vol = minLot + steps * lotStep;
   if(vol < minLot) vol = minLot;
   if(vol > maxLot) vol = maxLot;

   int digits = 0;
   double stepRef = lotStep;
   while(stepRef < 1.0 && digits < 8)
   {
      stepRef *= 10.0;
      digits++;
   }
   double normalizedVol = NormalizeDouble(vol, digits);
   
   // VALIDATION FINALE - S'assurer que le lot est valide
   if(normalizedVol < minLot || normalizedVol > maxLot)
   {
      Print("ðĻ ERREUR VOLUME NORMALISATION - Volume invalide: ", DoubleToString(normalizedVol, digits));
      Print("   ð MinLot: ", DoubleToString(minLot, digits), " | MaxLot: ", DoubleToString(maxLot, digits));
      Print("   ð LotStep: ", DoubleToString(lotStep, digits), " | Digits: ", digits);
      Print("   ð Volume dÃĐsirÃĐ: ", DoubleToString(desiredVolume, digits));
      Print("   ðĄ Utilisation du lot minimum par sÃĐcuritÃĐ");
      return minLot; // Retourner le lot minimum en cas d'erreur
   }
   
   return normalizedVol;
}

// Met Ã  jour les statistiques d'ÃĐquitÃĐ journaliÃĻre (dÃĐbut, max, min)
void UpdateDailyEquityStats()
{
   double equity = AccountInfoDouble(ACCOUNT_EQUITY);
   MqlDateTime dt;
   TimeCurrent(dt);
   int today = dt.year * 10000 + dt.mon * 100 + dt.day;

   if(g_dailyEquityDate != today || g_dailyStartEquity <= 0.0)
   {
      g_dailyEquityDate = today;
      g_dailyStartEquity = equity;
      g_dailyMaxEquity = equity;
      g_dailyMinEquity = equity;
      g_dailyPauseUntil = 0;
      g_dailyLossPauseUntil = 0;
      g_lossPauseUntil = 0;
      g_cumulativeLossSuccessive = 0.0;
      Print("?? RÃĐinitialisation stats journaliÃĻres: ÃĐquitÃĐ dÃĐpart = ", DoubleToString(equity, 2));
   }
   else
   {
      if(equity > g_dailyMaxEquity) g_dailyMaxEquity = equity;
      if(equity < g_dailyMinEquity) g_dailyMinEquity = equity;
   }
}

// Indique si le drawdown journalier max autorisÃĐ est dÃĐpassÃĐ
bool IsDailyDrawdownExceeded()
{
   if(MaxDailyDrawdownPercent <= 0.0 || g_dailyStartEquity <= 0.0)
      return false;

   double equity = AccountInfoDouble(ACCOUNT_EQUITY);
   double ddPercent = 0.0;
   if(g_dailyStartEquity > 0.0)
      ddPercent = (g_dailyStartEquity - equity) / g_dailyStartEquity * 100.0;

   if(ddPercent >= MaxDailyDrawdownPercent)
   {
      Print("?? DRAWDOWN JOURNALIER MAX ATTEINT: ",
            DoubleToString(ddPercent, 1), "% / ",
            DoubleToString(MaxDailyDrawdownPercent, 1),
            "% - blocage des nouvelles entrÃĐes pour aujourd'hui.");
      return true;
   }
   return false;
}

// Zone de "correction" autour de l'ÃĐquilibre ICT: bande centrÃĐe sur eq
// Largeur = EquilibriumCorrectionBandPercent% de la hauteur PremiumâDiscount (premHigh - discLow)
bool IsInEquilibriumCorrectionZone()
{
   if(IsInServerPredictedCorrectionZone()) return true;
   if(!BlockEquilibriumCorrectionTrades) return false;
   if(EquilibriumCorrectionBandPercent <= 0.0) return false;

   double high[], low[], close[];
   ArraySetAsSeries(high, true); ArraySetAsSeries(low, true); ArraySetAsSeries(close, true);
   if(CopyHigh(_Symbol, PERIOD_H1, 0, 100, high) < 100 || CopyLow(_Symbol, PERIOD_H1, 0, 100, low) < 100 || CopyClose(_Symbol, PERIOD_H1, 0, 100, close) < 100)
      return false;

   int n = ArraySize(close);
   if(n < 25) return false;

   double sma20[];
   ArrayResize(sma20, n);
   ArraySetAsSeries(sma20, true);
   for(int i = 0; i < n - 20; i++)
   {
      double s = 0;
      for(int j = 0; j < 20; j++) s += close[i + j];
      sma20[i] = s / 20;
   }
   for(int i = n - 20; i < n; i++) sma20[i] = sma20[MathMax(0, n - 21)];

   double eq = sma20[0];
   double premHigh = high[ArrayMaximum(high, 0, 20)];
   double discLow  = low[ArrayMinimum(low, 0, 20)];
   if(premHigh <= eq || discLow >= eq) return false;

   double range = premHigh - discLow;
   if(range <= 0.0) return false;

   double band = range * (EquilibriumCorrectionBandPercent / 100.0);
   double half = band * 0.5;

   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   double mid = (bid > 0 && ask > 0) ? (bid + ask) * 0.5 : bid;
   if(mid <= 0) return false;

   bool inEqBand = (mid >= (eq - half) && mid <= (eq + half));
   if(!inEqBand) return false;

   // Mode strict: toute position dans la bande ÃĐquilibre ICT = zone de chop / impatience â pas d'entrÃĐe
   if(CorrectionZoneStrictBlocking)
      return true;

   // --- Sinon: confirmation M1 (range serrÃĐ OU ATR bas) avant de bloquer ---
   int lb = MathMax(20, CorrectionRangeLookbackBarsM1);
   double h1 = iHigh(_Symbol, PERIOD_M1, 0);
   if(Bars(_Symbol, PERIOD_M1) < (lb + 2)) return true; // si pas assez de data M1, rester conservateur

   double maxH = -DBL_MAX, minL = DBL_MAX;
   int aligned = 0;
   for(int i = 1; i <= lb; i++)
   {
      double o = iOpen(_Symbol, PERIOD_M1, i);
      double c = iClose(_Symbol, PERIOD_M1, i);
      double h = iHigh(_Symbol, PERIOD_M1, i);
      double l = iLow(_Symbol, PERIOD_M1, i);
      if(h <= 0 || l <= 0) continue;
      if(h > maxH) maxH = h;
      if(l < minL) minL = l;
      // simple alternance: si beaucoup de bougies inverses, c'est souvent une correction (pas une impulsion)
      if(c >= o) aligned++;
   }
   double rangeM1 = (maxH > -DBL_MAX && minL < DBL_MAX) ? (maxH - minL) : 0.0;
   double rangePct = (rangeM1 > 0.0) ? (rangeM1 / mid) * 100.0 : 0.0;

   // ATR(14) M1 en % (si dispo). Si l'ATR est trÃĻs faible â marchÃĐ "calme" â correction probable.
   double atrPct = 0.0;
   static int atrM1Handle = INVALID_HANDLE;
   if(atrM1Handle == INVALID_HANDLE)
      atrM1Handle = iATR(_Symbol, PERIOD_M1, 14);
   if(atrM1Handle != INVALID_HANDLE)
   {
      double buf[];
      ArraySetAsSeries(buf, true);
      if(CopyBuffer(atrM1Handle, 0, 0, 1, buf) >= 1 && buf[0] > 0.0)
         atrPct = (buf[0] / mid) * 100.0;
   }

   bool isTightRange = (rangePct > 0.0 && rangePct <= CorrectionMaxRangePctM1);
   bool isLowAtr     = (atrPct > 0.0 && atrPct <= CorrectionMaxAtrPctM1);

   if(DebugCorrectionZoneFilter)
   {
      static datetime lastDbg = 0;
      datetime now = TimeCurrent();
      if(now - lastDbg >= 15)
      {
         Print("CORR DEBUG ", _Symbol,
               " | inEqBand=YES",
               " | eq=", DoubleToString(eq, _Digits),
               " | mid=", DoubleToString(mid, _Digits),
               " | bandHalf=", DoubleToString(half, _Digits),
               " | rangePctM1=", DoubleToString(rangePct, 4),
               " (max ", DoubleToString(CorrectionMaxRangePctM1, 4), ")",
               " | atrPctM1=", DoubleToString(atrPct, 4),
               " (max ", DoubleToString(CorrectionMaxAtrPctM1, 4), ")",
               " | tightRange=", (isTightRange ? "YES" : "NO"),
               " | lowAtr=", (isLowAtr ? "YES" : "NO"));
         lastDbg = now;
      }
   }

   // On bloque seulement si (proche ÃĐquilibre) ET (range serrÃĐ OU ATR faible).
   return (isTightRange || isLowAtr);
}

// Gain journalier cible atteint â stop trading jusqu'Ã  fin de journÃĐe
bool IsDailyProfitPauseActive()
{
   if(DailyProfitTargetDollars <= 0.0 || g_dailyStartEquity <= 0.0) return false;

   datetime now = TimeCurrent();
   if(g_dailyPauseUntil > now) return true;

   double equity = AccountInfoDouble(ACCOUNT_EQUITY);
   double dailyProfit = equity - g_dailyStartEquity;
   if(dailyProfit < DailyProfitTargetDollars) return false;

   MqlDateTime dt;
   TimeCurrent(dt);
   dt.hour = 23; dt.min = 59; dt.sec = 59;
   g_dailyPauseUntil = StructToTime(dt);
   Print("âļ STOP JOURNALIER - Gain ", DoubleToString(dailyProfit, 2), "$ âĨ ",
         DoubleToString(DailyProfitTargetDollars, 2), "$ | pause jusqu'Ã  ",
         TimeToString(g_dailyPauseUntil, TIME_SECONDS));
   return true;
}

bool IsProfitLockTriggered()
{
   if(!EnableProfitLock) return false;
   if(ProfitLockStartDollars <= 0.0 || ProfitLockMaxGivebackDollars <= 0.0) return false;
   if(g_dailyStartEquity <= 0.0) return false;

   double equity = AccountInfoDouble(ACCOUNT_EQUITY);
   double peakProfit = g_dailyMaxEquity - g_dailyStartEquity;
   if(peakProfit < ProfitLockStartDollars) return false;

   double giveback = g_dailyMaxEquity - equity;
   return (giveback >= ProfitLockMaxGivebackDollars);
}

void CloseAllPositionsAndPendingOurEA(const string reason)
{
   // 1) Fermer positions
   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      if(!posInfo.SelectByIndex(i)) continue;
      if(posInfo.Magic() != InpMagicNumber) continue;
      ulong ticket = posInfo.Ticket();
      PositionCloseWithLog(ticket, reason);
   }

   // 2) Supprimer ordres en attente
   for(int i = OrdersTotal() - 1; i >= 0; i--)
   {
      ulong ticket = OrderGetTicket(i);
      if(ticket == 0) continue;
      if(!OrderSelect(ticket)) continue;
      if((int)OrderGetInteger(ORDER_MAGIC) != InpMagicNumber) continue;

      ENUM_ORDER_TYPE t = (ENUM_ORDER_TYPE)OrderGetInteger(ORDER_TYPE);
      if(t == ORDER_TYPE_BUY_LIMIT || t == ORDER_TYPE_SELL_LIMIT ||
         t == ORDER_TYPE_BUY_STOP  || t == ORDER_TYPE_SELL_STOP  ||
         t == ORDER_TYPE_BUY_STOP_LIMIT || t == ORDER_TYPE_SELL_STOP_LIMIT)
      {
         MqlTradeRequest req = {};
         MqlTradeResult  res = {};
         req.action = TRADE_ACTION_REMOVE;
         req.order  = ticket;
         req.symbol = OrderGetString(ORDER_SYMBOL);
         req.magic  = InpMagicNumber;
         if(!OrderSend(req, res))
         {
            Print("â ÃCHEC ANNULATION LIMIT - Ticket=", ticket, " | Code=", res.retcode);
         }
      }
      }
   }

void ActivateProfitLockIfNeeded()
{
   if(!IsProfitLockTriggered()) return;

   datetime now = TimeCurrent();
   if(g_dailyPauseUntil > now) return; // dÃĐjÃ  en pause

   // Pause jusqu'Ã  fin de journÃĐe
   MqlDateTime dt;
   TimeCurrent(dt);
   dt.hour = 23; dt.min = 59; dt.sec = 59;
   g_dailyPauseUntil = StructToTime(dt);

   double equity = AccountInfoDouble(ACCOUNT_EQUITY);
   double peakProfit = g_dailyMaxEquity - g_dailyStartEquity;
   double giveback = g_dailyMaxEquity - equity;

   Print("â PROFIT LOCK - Pic=", DoubleToString(peakProfit, 2), "$ | Giveback=", DoubleToString(giveback, 2),
         "$ âĨ ", DoubleToString(ProfitLockMaxGivebackDollars, 2), "$ | pause jusqu'Ã  ", TimeToString(g_dailyPauseUntil, TIME_SECONDS));

   if(ProfitLockClosePositions)
      CloseAllPositionsAndPendingOurEA("PROFIT LOCK - giveback");
}

// VÃĐrifie si le modÃĻle ML courant est suffisamment fiable pour autoriser un trade sur ce symbole/catÃĐgorie
bool IsMLModelTrustedForCurrentSymbol(const string direction)
{
   if(!UseAIServer) return true; // pas de filtrage si IA dÃĐsactivÃĐe
   if(g_mlLastAccuracy <= 0.0) return false; // pas de mÃĐtriques utilisables

   ENUM_SYMBOL_CATEGORY cat = SMC_GetSymbolCategory(_Symbol);
   double minAcc = 0.0;

   switch(cat)
   {
      case SYM_BOOM_CRASH:
         minAcc = 80.0; // Boom/Crash: demander une prÃĐcision ÃĐlevÃĐe
         break;
      case SYM_VOLATILITY:
      case SYM_WELTRADE_SYNTH:
         minAcc = 70.0;
         break;
      case SYM_FOREX:
      case SYM_METAL:
         minAcc = 65.0;
         break;
      case SYM_COMMODITY:
      case SYM_UNKNOWN:
      default:
         minAcc = 60.0;
         break;
   }

   if(g_mlLastAccuracy < minAcc)
   {
      Print("ðŦ ML BLOQUÃ - ModÃĻle insuffisamment prÃĐcis pour ", _Symbol,
            " (cat=", (int)cat, ") | Acc=", DoubleToString(g_mlLastAccuracy, 1),
            "% < seuil ", DoubleToString(minAcc, 1), "% | ModÃĻle=", g_mlLastModelName,
            " | Direction demandÃĐe=", direction);
      return false;
   }

   return true;
}

// Perte journaliÃĻre max atteinte â seuil de dÃĐclenchement du filtre de zone
bool IsDailyLossPauseActive()
{
   if(MaxDailyLossDollars <= 0.0 || g_dailyStartEquity <= 0.0) return false;

   double equity = AccountInfoDouble(ACCOUNT_EQUITY);
   double dailyProfit = equity - g_dailyStartEquity;
   return (dailyProfit <= -MaxDailyLossDollars);
}

// Pause aprÃĻs pertes consÃĐcutives cumulÃĐes (gÃĐrÃĐ par g_lossPauseUntil)
bool IsCumulativeLossPauseActive()
{
   datetime now = TimeCurrent();
   if(g_lossPauseUntil > now) return true;
   if(g_lossPauseUntil != 0 && g_lossPauseUntil <= now)
      g_lossPauseUntil = 0;
   return false;
}

// VÃĐrifie en continu les ordres LIMIT en attente et annule ceux qui ne sont plus alignÃĐs avec la dÃĐcision IA
void GuardPendingLimitOrdersWithAI()
{
   if(LimitOrdersDisableAutoCancel) return;
   if(!UseAIServer) return;

   // Mettre Ã  jour la dÃĐcision IA si elle est trop ancienne
   datetime now = TimeCurrent();
   if(now - g_lastAIUpdate >= AI_UpdateInterval_Seconds)
   {
      UpdateAIDecision(AI_Timeout_ms);
   }

   for(int i = OrdersTotal() - 1; i >= 0; i--)
   {
      ulong ticket = OrderGetTicket(i);
      if(ticket == 0) continue;
      if(!OrderSelect(ticket)) continue;
      if((int)OrderGetInteger(ORDER_MAGIC) != InpMagicNumber) continue;
      if(OrderGetString(ORDER_SYMBOL) != _Symbol) continue;

      ENUM_ORDER_TYPE t = (ENUM_ORDER_TYPE)OrderGetInteger(ORDER_TYPE);
      if(t != ORDER_TYPE_BUY_LIMIT && t != ORDER_TYPE_SELL_LIMIT) continue;

      // Ne contrÃīler que les ordres proches du prix courant (prÃŠts Ã  ÃŠtre dÃĐclenchÃĐs)
      double orderPrice = OrderGetDouble(ORDER_PRICE_OPEN);
      double refPrice   = (t == ORDER_TYPE_BUY_LIMIT)
                          ? SymbolInfoDouble(_Symbol, SYMBOL_ASK)
                          : SymbolInfoDouble(_Symbol, SYMBOL_BID);
      double point      = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
      if(point <= 0) point = 0.0001;
      double maxDistPts = 10.0; // ne vÃĐrifier l'IA que si on est Ã  <= 10 points
      if(MathAbs(orderPrice - refPrice) > maxDistPts * point)
         continue; // prix encore loin de l'ordre, ne pas annuler trop tÃīt

      string cmt = OrderGetString(ORDER_COMMENT);
      string dir = (t == ORDER_TYPE_BUY_LIMIT ? "BUY" : "SELL");

      string ia = g_lastAIAction;
      string iaUpper = ia;
      StringToUpper(iaUpper);
      double conf = AIConfidencePercent();
      double minConf = MinAIConfidencePercent + 10.0; // marge +10% par rapport au minimum global

      bool shouldCancel = false;

      // IA en HOLD -> annuler immÃĐdiatement l'ordre LIMIT
      if(iaUpper == "HOLD")
      {
         shouldCancel = true;
         Print("ðŦ LIMIT ANNULÃ - IA en HOLD sur ", _Symbol, " | Ticket=", ticket, " | Comment=", cmt);
      }
      else if(iaUpper == "BUY" && dir == "SELL")
      {
         shouldCancel = true;
         Print("ðŦ LIMIT ANNULÃ - IA=BUY mais ordre SELL LIMIT en attente sur ", _Symbol, " | Ticket=", ticket, " | Comment=", cmt);
      }
      else if(iaUpper == "SELL" && dir == "BUY")
      {
         shouldCancel = true;
         Print("ðŦ LIMIT ANNULÃ - IA=SELL mais ordre BUY LIMIT en attente sur ", _Symbol, " | Ticket=", ticket, " | Comment=", cmt);
      }
      else
      {
         // Direction alignÃĐe mais confiance insuffisante
         if(conf < minConf)
         {
            shouldCancel = true;
            Print("ðŦ LIMIT ANNULÃ - Confiance IA insuffisante pour ", dir, " sur ", _Symbol,
                  " | Conf=", DoubleToString(conf, 1), "% < seuil ", DoubleToString(minConf, 1),
                  "% | Ticket=", ticket, " | Comment=", cmt);
         }
      }

      if(shouldCancel)
      {
         MqlTradeRequest req = {};
         MqlTradeResult  res = {};
         req.action = TRADE_ACTION_REMOVE;
         req.order  = ticket;
         req.symbol = _Symbol;

         if(!OrderSend(req, res))
         {
            Print("? ÃCHEC ANNULATION LIMIT - Ticket=", ticket, " | Code=", res.retcode);
         }
      }
   }
}

// DÃĐtermine si un ordre limite doit ÃŠtre remplacÃĐ selon les conditions IA
bool ShouldReplaceLimitOrder(ENUM_ORDER_TYPE orderType, string orderComment, double orderPrice)
{
   if(!UseAIServer || !ReplaceMisalignedLimitOrders) return false;
   
   // Mettre Ã  jour la dÃĐcision IA si trop ancienne
   datetime now = TimeCurrent();
   if(now - g_lastAIUpdate >= AI_UpdateInterval_Seconds)
   {
      UpdateAIDecision(AI_Timeout_ms);
   }
   
   string ia = g_lastAIAction;
   string iaUpper = ia;
   StringToUpper(iaUpper);
   double conf = AIConfidencePercent();
   double minConf = MinConfidenceForReplacement * 100.0;
   
   string dir = (orderType == ORDER_TYPE_BUY_LIMIT) ? "BUY" : "SELL";
   
   // VÃĐrifier la distance du prix (configurable)
   double refPrice = (orderType == ORDER_TYPE_BUY_LIMIT)
                   ? SymbolInfoDouble(_Symbol, SYMBOL_ASK)
                   : SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   if(point <= 0) point = 0.0001;
   
   if(MathAbs(orderPrice - refPrice) > MaxDistanceForLimitCheck * point)
      return false; // Trop loin, pas besoin de remplacer maintenant
   
   // Condition 1: IA en HOLD -> ne pas remplacer
   if(iaUpper == "HOLD")
   {
      Print("ðŦ PAS DE REMPLACEMENT - IA en HOLD pour ", dir, " sur ", _Symbol);
      return false;
   }
   
   // Condition 2: Direction opposÃĐe -> remplacer
   if((iaUpper == "BUY" && dir == "SELL") || (iaUpper == "SELL" && dir == "BUY"))
   {
      Print("ð REMPLACEMENT REQUIS - IA=", ia, " opposÃĐe Ã  ordre ", dir, " sur ", _Symbol);
      return true;
   }
   
   // Condition 3: Confiance IA insuffisante -> ne pas remplacer
   if(conf < minConf)
   {
      Print("ðŦ PAS DE REMPLACEMENT - Confiance IA insuffisante: ", DoubleToString(conf, 1), "% < ", DoubleToString(minConf, 1), "%");
      return false;
   }
   
   // Condition 4: Direction alignÃĐe mais IA a changÃĐ depuis placement -> remplacer
   // (vÃĐrifier si l'ordre a ÃĐtÃĐ placÃĐ avant le dernier changement IA)
   if(StringFind(orderComment, "STRAT") >= 0)
   {
      // Ordre stratÃĐgique : remplacer si IA est plus forte maintenant
      Print("ð REMPLACEMENT REQUIS - Ordre stratÃĐgique ", dir, " avec IA ", ia, " (", DoubleToString(conf, 1), "%) sur ", _Symbol);
      return true;
   }
   
   return false;
}

// Remplace un ordre limite par un nouvel ordre alignÃĐ avec l'IA
bool ReplaceLimitOrder(ENUM_ORDER_TYPE oldOrderType, double oldOrderPrice, string oldOrderComment)
{
   if(!UseAIServer) return false;
   
   string ia = g_lastAIAction;
   string iaUpper = ia;
   StringToUpper(iaUpper);
   
   // DÃĐterminer le nouveau type d'ordre selon IA
   ENUM_ORDER_TYPE newOrderType;
   string newDirection;
   
   if(iaUpper == "BUY")
   {
      newOrderType = ORDER_TYPE_BUY_LIMIT;
      newDirection = "BUY";
   }
   else if(iaUpper == "SELL")
   {
      newOrderType = ORDER_TYPE_SELL_LIMIT;
      newDirection = "SELL";
   }
   else
   {
      Print("ðŦ IMPOSSIBLE REMPLACEMENT - IA=", ia, " non valide pour nouvel ordre");
      return false;
   }
   
   // Calculer le nouveau prix d'ordre
   double currentPrice = SymbolInfoDouble(_Symbol, (newOrderType == ORDER_TYPE_BUY_LIMIT) ? SYMBOL_ASK : SYMBOL_BID);
   double atrVal = GetCurrentATR();
   double newOrderPrice;
   double stopLoss = 0;
   double takeProfit = 0;
   double pointRep = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   double slPtsRep = IsBoomCrashOrWeltradeDirectionalSynth(_Symbol) ? (double)MathMax(1, BoomCrashFixedSlPoints) : 300.0;
   double tpPtsRep = IsBoomCrashOrWeltradeDirectionalSynth(_Symbol) ? (double)MathMax(1, BoomCrashFixedTpPoints) : 600.0;
   
   // Utiliser la logique existante de calcul de prix
   if(newOrderType == ORDER_TYPE_BUY_LIMIT)
   {
      // BUY LIMIT : sous le prix actuel
      string sourceOut;
      double supportLevel = GetClosestBuyLevel(currentPrice, atrVal, MaxDistanceLimitATR, sourceOut);
      if(supportLevel > 0)
         newOrderPrice = supportLevel;
      else
         newOrderPrice = currentPrice - 15 * pointRep;
      
      stopLoss = newOrderPrice - slPtsRep * pointRep;
      takeProfit = newOrderPrice + tpPtsRep * pointRep;
   }
   else
   {
      // SELL LIMIT : au-dessus du prix actuel
      string sourceOut;
      double resistanceLevel = GetClosestSellLevel(currentPrice, atrVal, MaxDistanceLimitATR, sourceOut);
      if(resistanceLevel > 0)
         newOrderPrice = resistanceLevel;
      else
         newOrderPrice = currentPrice + 15 * pointRep;
      
      stopLoss = newOrderPrice + slPtsRep * pointRep;
      takeProfit = newOrderPrice - tpPtsRep * pointRep;
   }
   
   // Calculer le lot size
   double lotSize = CalculateLotSizeForPendingOrders();
   if(lotSize <= 0)
   {
      Print("ðŦ IMPOSSIBLE REMPLACEMENT - Lot size invalide");
      return false;
   }
   
   // PrÃĐparer la requÃŠte d'ordre
   MqlTradeRequest req = {};
   MqlTradeResult res = {};
   
   req.action = TRADE_ACTION_PENDING;
   req.symbol = _Symbol;
   req.volume = lotSize;
   req.type = newOrderType;
   req.price = newOrderPrice;
   req.sl = stopLoss;
   req.tp = takeProfit;
   req.deviation = 20;
   req.magic = InpMagicNumber;
   req.comment = "STRAT " + newDirection + " LIMIT (REPLACEMENT)";
   req.type_filling = ORDER_FILLING_IOC;
   req.type_time = ORDER_TIME_GTC;
   
   // Valider et ajuster le prix si nÃĐcessaire
   if(!ValidateAndAdjustLimitPrice(req.price, req.sl, req.tp, newOrderType))
   {
      Print("ðŦ IMPOSSIBLE REMPLACEMENT - Prix/SL/TP invalides aprÃĻs ajustement");
      return false;
   }
   
   // Placer le nouvel ordre
   if(OrderSend(req, res))
   {
      Print("â REMPLACEMENT RÃUSSI - ", newDirection, " LIMIT placÃĐ | Prix=", DoubleToString(newOrderPrice, 5), 
            " | Lot=", DoubleToString(lotSize, 2), " | Ticket=", res.order);
      Print("   ð Ancien ordre: ", oldOrderComment, " | Prix=", DoubleToString(oldOrderPrice, 5));
      Print("   ð§  IA: ", ia, " | Confiance: ", DoubleToString(g_lastAIConfidence * 100, 1), "%");
      return true;
   }
   else
   {
      Print("â ÃCHEC REMPLACEMENT - ", newDirection, " LIMIT | Code=", res.retcode, " | Comment=", res.comment);
      return false;
   }
}

// RÃĐcupÃĻre l'ATR courant du timeframe M1
double GetCurrentATR()
{
   double atrBuffer[];
   ArraySetAsSeries(atrBuffer, true);
   
   int copied = CopyBuffer(atrM1, 0, 0, 1, atrBuffer);
   if(copied > 0 && atrBuffer[0] > 0)
      return atrBuffer[0];
   
   // Fallback : utiliser l'ATR LTF si M1 indisponible
   if(atrHandle != INVALID_HANDLE)
   {
      copied = CopyBuffer(atrHandle, 0, 0, 1, atrBuffer);
      if(copied > 0 && atrBuffer[0] > 0)
         return atrBuffer[0];
   }
   
   // Dernier fallback : ATR fixe selon symbole
   ENUM_SYMBOL_CATEGORY cat = SMC_GetSymbolCategory(_Symbol);
   switch(cat)
   {
      case SYM_BOOM_CRASH: return 0.025;  // 25 points pour Boom/Crash
      case SYM_FOREX:     return 0.00020; // 20 pips pour Forex
      case SYM_COMMODITY: return 0.5;    // 50 points pour matiÃĻres premiÃĻres
      default:            return 0.001;   // Valeur par dÃĐfaut
   }
}

// Version amÃĐliorÃĐe de GuardPendingLimitOrdersWithAI avec remplacement automatique
void GuardPendingLimitOrdersWithAI_Enhanced()
{
   if(!UseAIServer) return;

   // Sur Boom/Crash, on respecte uniquement la rÃĻgle de type (Boom=BUY only / Crash=SELL only).
   // Ne pas annuler un pending juste parce que l'IA affiche une action opposÃĐe (sinon on n'a jamais le pending visible).
   ENUM_SYMBOL_CATEGORY symCat = SMC_GetSymbolCategory(_Symbol);

   // Mettre Ã  jour la dÃĐcision IA si elle est trop ancienne
   datetime now = TimeCurrent();
   if(now - g_lastAIUpdate >= AI_UpdateInterval_Seconds)
   {
      UpdateAIDecision(AI_Timeout_ms);
   }

   for(int i = OrdersTotal() - 1; i >= 0; i--)
   {
      ulong ticket = OrderGetTicket(i);
      if(ticket == 0) continue;
      if(!OrderSelect(ticket)) continue;
      if((int)OrderGetInteger(ORDER_MAGIC) != InpMagicNumber) continue;
      if(OrderGetString(ORDER_SYMBOL) != _Symbol) continue;

      ENUM_ORDER_TYPE t = (ENUM_ORDER_TYPE)OrderGetInteger(ORDER_TYPE);
      if(t != ORDER_TYPE_BUY_LIMIT && t != ORDER_TYPE_SELL_LIMIT) continue;

      // VÃĐrifier tous les ordres limites (distance ÃĐtendue)
      double orderPrice = OrderGetDouble(ORDER_PRICE_OPEN);
      double refPrice   = (t == ORDER_TYPE_BUY_LIMIT)
                          ? SymbolInfoDouble(_Symbol, SYMBOL_ASK)
                          : SymbolInfoDouble(_Symbol, SYMBOL_BID);
      double point      = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
      if(point <= 0) point = 0.0001;
      
      // Distance ÃĐtendue selon paramÃĻtre
      if(MathAbs(orderPrice - refPrice) > MaxDistanceForLimitCheck * point)
         continue; // prix encore trop loin de l'ordre

      string cmt = OrderGetString(ORDER_COMMENT);
      string dir = (t == ORDER_TYPE_BUY_LIMIT ? "BUY" : "SELL");

      string ia = g_lastAIAction;
      string iaUpper = ia;
      StringToUpper(iaUpper);
      double conf = AIConfidencePercent();
      double minConf = MinAIConfidencePercent + 10.0; // marge +10% par rapport au minimum global

      bool shouldCancel = false;
      bool shouldReplace = false;

      // Logique d'annulation (existante)
      if(iaUpper == "HOLD")
      {
         shouldCancel = true;
         Print("ðŦ LIMIT ANNULÃ - IA en HOLD sur ", _Symbol, " | Ticket=", ticket, " | Comment=", cmt);
      }
      else if(symCat != SYM_BOOM_CRASH && iaUpper == "BUY" && dir == "SELL")
      {
         shouldCancel = true;
         shouldReplace = ReplaceMisalignedLimitOrders; // Remplacement si activÃĐ
         Print("ð LIMIT CONFLIT - IA=BUY mais ordre SELL LIMIT sur ", _Symbol, " | Ticket=", ticket, " | Comment=", cmt);
      }
      else if(symCat != SYM_BOOM_CRASH && iaUpper == "SELL" && dir == "BUY")
      {
         shouldCancel = true;
         shouldReplace = ReplaceMisalignedLimitOrders; // Remplacement si activÃĐ
         Print("ð LIMIT CONFLIT - IA=SELL mais ordre BUY LIMIT sur ", _Symbol, " | Ticket=", ticket, " | Comment=", cmt);
      }
      else if(symCat != SYM_BOOM_CRASH)
      {
         // Direction alignÃĐe mais confiance insuffisante
         if(conf < minConf)
         {
            shouldCancel = true;
            shouldReplace = ReplaceMisalignedLimitOrders && conf >= MinConfidenceForReplacement * 100.0;
            Print("ðŦ LIMIT CONFIANCE - Confiance IA insuffisante pour ", dir, " sur ", _Symbol,
                  " | Conf=", DoubleToString(conf, 1), "% < seuil ", DoubleToString(minConf, 1),
                  "% | Ticket=", ticket, " | Comment=", cmt);
         }
      }
      else
      {
         // Boom/Crash: garder l'ordre (sauf HOLD gÃĐrÃĐ au-dessus)
      }

      // ExÃĐcuter l'annulation si nÃĐcessaire
      if(shouldCancel)
      {
         MqlTradeRequest req = {};
         MqlTradeResult  res = {};
         req.action = TRADE_ACTION_REMOVE;
         req.order  = ticket;
         req.symbol = _Symbol;

         if(OrderSend(req, res))
         {
            Print("â LIMIT ANNULÃ - ", dir, " sur ", _Symbol, " | Ticket=", ticket, " | Raison: ", 
                  (iaUpper == "HOLD" ? "IA HOLD" : 
                   (iaUpper == "BUY" && dir == "SELL") ? "Direction opposÃĐe BUY vs SELL" :
                   (iaUpper == "SELL" && dir == "BUY") ? "Direction opposÃĐe SELL vs BUY" :
                   "Confiance insuffisante"));
            
            // Tenter le remplacement si activÃĐ et conditions rÃĐunies
            if(shouldReplace && ShouldReplaceLimitOrder(t, cmt, orderPrice))
            {
               ReplaceLimitOrder(t, orderPrice, cmt);
            }
         }
         else
         {
            Print("â ÃCHEC ANNULATION LIMIT - Ticket=", ticket, " | Code=", res.retcode);
         }
      }
   }
}

// VÃĐrifie que l'entraÃŪnement continu backend est actif; sinon, le dÃĐmarre (si forceStart ou statut indique non-actif)
bool EnsureMLContinuousTrainingRunning(bool forceStart = false)
{
   if(!ShowMLMetrics) return false;
   if(!AutoStartMLContinuousTraining && !forceStart) return false;

   static datetime lastCheck = 0;
   datetime now = TimeCurrent();
   int interval = MathMax(30, MLContinuousCheckIntervalSec);
   if(!forceStart && (now - lastCheck) < interval)
      return true;
   lastCheck = now;

   string baseUrl = UseRenderAsPrimary ? AI_ServerRender : AI_ServerURL;
   string fallbackUrl = UseRenderAsPrimary ? AI_ServerURL : AI_ServerRender;
   string headers = "Content-Type: application/json\r\n";
   char post[], result[];
   string resultHeaders;

   // 1) Lire status
   int resStatus = WebRequest("GET", baseUrl + "/ml/continuous/status", "", AI_Timeout_ms, post, result, resultHeaders);
   if(resStatus != 200)
      resStatus = WebRequest("GET", fallbackUrl + "/ml/continuous/status", "", AI_Timeout_ms2, post, result, resultHeaders);

   bool running = false;
   if(resStatus == 200)
   {
      string statusData = CharArrayToString(result);
      // On accepte plusieurs formats possibles: "running":true, "active":true, "enabled":true
      running = (StringFind(statusData, "\"running\": true") >= 0 ||
                 StringFind(statusData, "\"running\":true") >= 0 ||
                 StringFind(statusData, "\"active\": true") >= 0 ||
                 StringFind(statusData, "\"active\":true") >= 0 ||
                 StringFind(statusData, "\"enabled\": true") >= 0 ||
                 StringFind(statusData, "\"enabled\":true") >= 0);
   }

   // 2) DÃĐmarrer si nÃĐcessaire
   if(forceStart || !running)
   {
      string startUrl1 = baseUrl + "/ml/continuous/start";
      string startUrl2 = fallbackUrl + "/ml/continuous/start";
      int resStart = WebRequest("POST", startUrl1, headers, AI_Timeout_ms, post, result, resultHeaders);
      if(resStart != 200)
         resStart = WebRequest("POST", startUrl2, headers, AI_Timeout_ms2, post, result, resultHeaders);

      if(resStart == 200)
      {
         Print("â ML continuous training dÃĐmarrÃĐ/relancÃĐ.");
         return true;
      }
      Print("â ïļ Impossible de dÃĐmarrer ML continuous training (HTTP ", resStart, ").");
      return false;
   }

   return true;
}

// Affichage dÃĐdiÃĐ des mÃĐtriques ML sur le graphique (label)
void DrawMLMetricsOnChart()
{
   string name = "SMC_ML_METRICS_LABEL";
   if(!ShowMLMetrics)
   {
      ObjectDelete(0, name);
      return;
   }

   if(ObjectFind(0, name) < 0)
   {
      if(!ObjectCreate(0, name, OBJ_LABEL, 0, 0, 0))
         return;
      ObjectSetInteger(0, name, OBJPROP_CORNER, CORNER_LEFT_UPPER);
      ObjectSetInteger(0, name, OBJPROP_XDISTANCE, 10);
      ObjectSetInteger(0, name, OBJPROP_FONTSIZE, 7);  // RÃĐduit Ã  7 pour cohÃĐrence
      ObjectSetString(0, name, OBJPROP_FONT, "Consolas");
      ObjectSetInteger(0, name, OBJPROP_BACK, false);  // Premier plan pour visibilitÃĐ
   }

   // Calculer la position Y pour ÃĐviter la superposition avec le dashboard
   int y = MathMax(MLMetricsLabelYOffsetPixels, g_dashboardBottomY + 45);  // 45px d'espace sous le dashboard (augmentÃĐ)
   
   ObjectSetInteger(0, name, OBJPROP_YDISTANCE, y);

   // CatÃĐgorie de symbole pour rendre explicite le type de modÃĻle utilisÃĐ
   string catStr = "UNKNOWN";
   ENUM_SYMBOL_CATEGORY cat = SMC_GetSymbolCategory(_Symbol);
   switch(cat)
   {
      case SYM_BOOM_CRASH:  catStr = "Boom/Crash"; break;
      case SYM_VOLATILITY:  catStr = "Volatility"; break;
      case SYM_FOREX:       catStr = "Forex"; break;
      case SYM_COMMODITY:   catStr = "Commodity"; break;
      case SYM_METAL:       catStr = "Metal"; break;
      case SYM_WELTRADE_SYNTH: catStr = "Weltrade synth"; break;
   }

   string txt = "ML (" + catStr + ", " + _Symbol + "): " + (g_mlMetricsStr == "" ? "En attente..." : g_mlMetricsStr);
   txt += " | Canal: " + (g_channelValid ? "OK" : "â");
   ObjectSetString(0, name, OBJPROP_TEXT, txt);
   ObjectSetInteger(0, name, OBJPROP_COLOR, g_channelValid ? clrLime : clrYellow);
   
   // Log de dÃĐbogage pour vÃĐrifier le positionnement
   static datetime lastMLDebugLog = 0;
   if(TimeCurrent() - lastMLDebugLog >= 300) // Toutes les 5 minutes
   {
      Print("?? DEBUG ML Metrics - y=", y, " | dashboardBottom=", g_dashboardBottomY);
      lastMLDebugLog = TimeCurrent();
   }
}

// Fonction de nettoyage global des objets graphiques du dashboard
void CleanupDashboardObjects()
{
   // Nettoyer TOUS les objets dashboard existants - mÃĐthode plus agressive
   int totalDeleted = 0;
   
   // MÃĐthode 1: Nettoyer par prÃĐfixes connus
   string prefixes[] = {"SMC_DASHBOARD_LABEL", "SMC_DASH_LINE_", "SMC_ML_METRICS_LABEL", "SMC_PROPICE_LINE", "DASH_", "ML_"};
   
   for(int p = 0; p < ArraySize(prefixes); p++)
   {
      string prefix = prefixes[p];
      
      // Pour les prÃĐfixes de lignes, tester plusieurs numÃĐros
      if(prefix == "SMC_DASH_LINE_")
      {
         for(int i = 0; i < 200; i++)
         {
            string name = prefix + IntegerToString(i);
            if(ObjectFind(0, name) >= 0)
            {
               if(ObjectDelete(0, name))
                  totalDeleted++;
            }
         }
      }
      else
      {
         // Pour les objets uniques, essayer directement
         if(ObjectFind(0, prefix) >= 0)
         {
            if(ObjectDelete(0, prefix))
               totalDeleted++;
         }
      }
   }

   // Nettoyage ciblÃĐ des labels d'information susceptibles de rester obsolÃĻtes
   string staleLabels[] = {"SMC_FUT_STATUS", "SMC_Chan_Label", "SMC_Chan_Status", "SMC_ICT_SIG_CHECKLIST", "SMC_TOP_NET_RIGHT"};
   for(int s = 0; s < ArraySize(staleLabels); s++)
   {
      if(ObjectFind(0, staleLabels[s]) >= 0 && ObjectDelete(0, staleLabels[s]))
         totalDeleted++;
   }
   
   // MÃĐthode 2: Parcourir TOUS les objets sur le chart et supprimer ceux qui correspondent
   for(int i = ObjectsTotal(0) - 1; i >= 0; i--)
   {
      string objName = ObjectName(0, i);
      
      // Supprimer tous les objets avec ces prÃĐfixes
      if(StringFind(objName, "SMC_DASH_") == 0 ||
         StringFind(objName, "SMC_DASHBOARD_LABEL") == 0 ||
         StringFind(objName, "SMC_ML_") == 0 ||
         StringFind(objName, "SMC_PROPICE_") == 0 ||
         StringFind(objName, "DASH_") == 0 ||
         StringFind(objName, "ML_METRICS") == 0)
      {
         if(ObjectDelete(0, objName))
            totalDeleted++;
      }
   }
   
   if(totalDeleted > 0)
   {
      Print("ð§đ NETTOYAGE DASHBOARD - ", totalDeleted, " objets supprimÃĐs");
   }
}

// Fonction de nettoyage complet de tous les dessins SMC sur le chart
void CleanupAllChartObjects()
{
   // PrÃĐfixes de tous les objets SMC Ã  nettoyer
   string prefixes[] = {
      "SMC_",           // Tous les objets SMC
      "FVG_",           // Fair Value Gaps
      "OB_",            // Order Blocks
      "BOS_",           // Break of Structure
      "LS_",            // Liquidity Sweep
      "OTE_",           // Optimal Trade Entry
      "EQH_", "EQL_",   // Equal High/Low
      "PD_",            // Point of Interest
      "SWING_",         // Swing points
      "EMA_",           // EMA lines
      "TREND_",         // Trend lines
      "CHANNEL_",       // Channels
      "SPIKE_",         // Spike indicators
      "ARROW_",         // Arrow signals
      "PREDICT_",       // Predictions
      "LEVEL_",         // Support/Resistance levels
      "ZONE_",          // Zones (Premium/Discount)
      "PROPICE_",       // Propice symbols
      "ML_",            // ML metrics
      "DASH_",          // Dashboard
      "SIGNAL_",        // Signal arrows
      "WARNING_"        // Warnings
   };
   
   int totalDeleted = 0;
   
   for(int p = 0; p < ArraySize(prefixes); p++)
   {
      string prefix = prefixes[p];
      
      // Parcourir tous les objets sur le chart
      for(int i = ObjectsTotal(0) - 1; i >= 0; i--)
      {
         string objName = ObjectName(0, i);
         if(StringFind(objName, prefix) == 0)  // Commence par le prÃĐfixe
         {
            if(ObjectDelete(0, objName))
            {
               totalDeleted++;
            }
         }
      }
   }
   
   // Nettoyer aussi les objets plus anciens qui pourraient avoir d'autres noms
   string oldPrefixes[] = {"DERIV_", "BOOKMARK_", "KILLZONE_", "LIQUIDITY_"};
   
   for(int p = 0; p < ArraySize(oldPrefixes); p++)
   {
      string prefix = oldPrefixes[p];
      
      for(int i = ObjectsTotal(0) - 1; i >= 0; i--)
      {
         string objName = ObjectName(0, i);
         if(StringFind(objName, prefix) == 0)
         {
            if(ObjectDelete(0, objName))
            {
               totalDeleted++;
            }
         }
      }
   }
   
   if(totalDeleted > 0)
   {
      Print("ð§đ NETTOYAGE COMPLET - ", totalDeleted, " objets graphiques supprimÃĐs du chart");
   }
}

// Fonction pour vÃĐrifier et gÃĐrer la pause aprÃĻs avoir atteint l'objectif de profit journalier
bool CheckDailyProfitPause()
{
   // Calculer le profit journalier basÃĐ sur l'historique des trades du jour
   double dailyProfit = CalculateDailyProfitFromHistory();
   
   // Mettre Ã  jour les variables globales pour cohÃĐrence
   g_dayNetProfit = dailyProfit;
   
   // Mettre Ã  jour le pic de profit si nÃĐcessaire
   if(dailyProfit > g_dailyProfitPeak)
   {
      g_dailyProfitPeak = dailyProfit;
   }
   
   // VÃĐrifier si l'objectif de profit est atteint pour la premiÃĻre fois
   if(dailyProfit >= DailyProfitTarget && !g_dailyProfitTargetReached)
   {
      g_dailyProfitTargetReached = true;
      g_dailyProfitPauseStartTime = TimeCurrent();
      
      // Calculer la durÃĐe de pause : PauseAfterProfitHours heures aprÃĻs atteinte du target
      datetime pauseEndTime = g_dailyProfitPauseStartTime + (PauseAfterProfitHours * 3600);
      g_dailyPauseUntil = pauseEndTime;
      
      Print("ðŊ OBJECTIF PROFIT JOURNALIER ATTEINT !");
      Print("ð° Profit actuel: ", DoubleToString(dailyProfit, 2), "$ / Objectif: ", DoubleToString(DailyProfitTarget, 2), "$");
      Print("âļïļ PAUSE ACTIVÃE - DurÃĐe: ", PauseAfterProfitHours, " heures");
      Print("ðŦ TOUS LES TRADES BLOQUÃS jusqu'Ã  ", TimeToString(pauseEndTime, TIME_SECONDS));
      Print("ð BasÃĐ sur l'historique des trades du jour");
      
      return true;  // Bloquer les trades
   }
   
   // Si la pause est active, vÃĐrifier si elle est terminÃĐe
   if(g_dailyProfitTargetReached && g_dailyProfitPauseStartTime > 0)
   {
      datetime pauseEndTime = g_dailyPauseUntil;
      
      if(TimeCurrent() >= pauseEndTime)
      {
         // RÃĐinitialiser la pause
         g_dailyProfitTargetReached = false;
         g_dailyProfitPauseStartTime = 0;
         g_dailyProfitPeak = 0.0;
         g_dailyPauseUntil = 0;
         
         Print("â PAUSE TERMINÃE - Reprise du trading autorisÃĐe");
         Print("ð° Gains protÃĐgÃĐs: ", DoubleToString(dailyProfit, 2), "$");
         Print("ð Nouveaux trades autorisÃĐs Ã  partir de maintenant");
         
         return false;  // Autoriser les trades
      }
      else
      {
         // Pause encore active - afficher le temps restant
         int remainingSeconds = (int)(pauseEndTime - TimeCurrent());
         int remainingHours = remainingSeconds / 3600;
         int remainingMinutes = (remainingSeconds % 3600) / 60;
         
         // Log toutes les 10 minutes pendant la pause
         static datetime lastPauseLog = 0;
         if(TimeCurrent() - lastPauseLog >= 600) // 10 minutes
         {
            Print("âģ PAUSE PROFIT EN COURS");
            Print("âąïļ Temps restant: ", remainingHours, "h ", remainingMinutes, "min");
            Print("ð° Profit actuel: ", DoubleToString(dailyProfit, 2), "$ / Target: ", DoubleToString(DailyProfitTarget, 2), "$");
            Print("ð Statistiques basÃĐes sur l'historique des trades du jour");
            lastPauseLog = TimeCurrent();
         }
         
         return true;  // Bloquer les trades
      }
   }
   
   return false;  // Autoriser les trades
}

// Calculer le profit journalier basÃĐ sur l'historique des trades
double CalculateDailyProfitFromHistory()
{
   double dailyProfit = 0.0;
   datetime todayStart = GetTodayStart();
   
   // Parcourir l'historique des trades du jour
   for(int i = 0; i < HistoryDealsTotal(); i++)
   {
      ulong dealTicket = HistoryDealGetTicket(i);
      if(dealTicket == 0) continue;
      
      datetime dealTime = (datetime)HistoryDealGetInteger(dealTicket, DEAL_TIME);
      if(dealTime < todayStart) continue; // Skip trades from previous days
      
      long dealMagic = HistoryDealGetInteger(dealTicket, DEAL_MAGIC);
      if(dealMagic != InpMagicNumber) continue; // Only our EA's trades
      
      double dealProfit = HistoryDealGetDouble(dealTicket, DEAL_PROFIT);
      double dealSwap = HistoryDealGetDouble(dealTicket, DEAL_SWAP);
      double dealCommission = HistoryDealGetDouble(dealTicket, DEAL_COMMISSION);
      
      dailyProfit += dealProfit + dealSwap + dealCommission;
   }
   
   return dailyProfit;
}

// VÃĐrifier si le symbole actuel est le plus propice (prioritÃĐ 0)
bool IsMostPropiceSymbol()
{
   return g_currentSymbolPriority == 0;
}

// Obtenir le nom du symbole le plus propice (prioritÃĐ 0)
string GetMostPropiceSymbol()
{
   if(g_propiceTopSymbols == "")
      return "";
   
   // Extraire le premier symbole de la liste (le plus propice)
   string symbols[];
   StringSplit(g_propiceTopSymbols, ',', symbols);
   
   if(ArraySize(symbols) > 0)
   {
      StringTrimLeft(symbols[0]);
      StringTrimRight(symbols[0]);
      return symbols[0];
   }
   
   return "";
}

// VÃĐrifier la protection contre les pertes excessives par symbole
bool CheckSymbolLossProtection()
{
   // Calculer la perte actuelle pour ce symbole
   double currentLoss = 0.0;
   
   // Parcourir les positions ouvertes pour ce symbole
   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      if(posInfo.SelectByIndex(i))
      {
         if(posInfo.Symbol() == _Symbol && posInfo.Magic() == InpMagicNumber)
         {
            double positionProfit = posInfo.Profit();
            if(positionProfit < 0)
               currentLoss += MathAbs(positionProfit);
         }
      }
   }
   
   // Mettre Ã  jour la perte actuelle
   g_symbolCurrentLoss = currentLoss;
   
   // Si perte supÃĐrieure Ã  la limite maximale autorisÃĐe
   if(g_symbolCurrentLoss >= MaxLossPerSymbolDollars)
   {
      if(!g_symbolTradingBlocked)
      {
         g_symbolTradingBlocked = true;
         g_symbolLossStartTime = TimeCurrent();
         
         Print("ðĻ PROTECTION SYMBOLE ACTIVÃE - Perte maximale atteinte sur ", _Symbol);
         Print("   ð° Perte actuelle: ", DoubleToString(g_symbolCurrentLoss, 2), "$ > Limite: ", DoubleToString(MaxLossPerSymbolDollars, 2), "$");
         Print("   ðŦ Trading sur ce symbole BLOQUÃ jusqu'Ã  rÃĐinitialisation manuelle");
         Print("   â ïļ Toutes les nouvelles positions sur ", _Symbol, " seront refusÃĐes");
         
         // Envoyer une notification d'alerte
         string alertMsg = "ðĻ PROTECTION SYMBOLE - " + _Symbol + "\n" +
                         "Perte: " + DoubleToString(g_symbolCurrentLoss, 2) + "$\n" +
                         "Limite: " + DoubleToString(MaxLossPerSymbolDollars, 2) + "$\n" +
                         "Trading BLOQUÃ sur ce symbole";
         SendNotification(alertMsg);
      }
      return true; // Bloquer le trading
   }
   
   // Si le trading ÃĐtait bloquÃĐ mais qu'on a rÃĐcupÃĐrÃĐ (aucune perte)
   if(g_symbolTradingBlocked && g_symbolCurrentLoss == 0.0)
   {
      g_symbolTradingBlocked = false;
      Print("â PROTECTION SYMBOLE DÃSACTIVÃE - ", _Symbol, " - Trading rÃĐactivÃĐ");
   }
   
   return false; // Autoriser le trading
}

// RÃĐinitialiser manuellement la protection par symbole
void ResetSymbolProtection()
{
   g_symbolCurrentLoss = 0.0;
   g_symbolLossStartTime = 0;
   g_symbolTradingBlocked = false;
   
   Print("â PROTECTION SYMBOLE RÃINITIALISÃE - ", _Symbol);
   Print("   ð Trading rÃĐactivÃĐ sur ce symbole");
   Print("   ðĄ Protection remise Ã  zÃĐro - Surveillance des pertes reprise");
}

// PrÃĐdire les Protected High/Low Points dans les zones de prix futures
void PredictFutureProtectedPoints()
{
   // Nettoyer les anciennes prÃĐdictions
   ObjectsDeleteAll(0, "FUTURE_PROTECTED_");
   
   // Obtenir les donnÃĐes historiques pour l'analyse
   MqlRates rates[];
   ArraySetAsSeries(rates, true);
   if(CopyRates(_Symbol, PERIOD_M15, 0, 200, rates) < 100) return;
   
   // Calculer l'ATR pour la volatilitÃĐ
   double atrBuffer[];
   ArraySetAsSeries(atrBuffer, true);
   double atr = 0.0;
   if(atrHandle != INVALID_HANDLE && CopyBuffer(atrHandle, 0, 0, 1, atrBuffer) >= 1)
      atr = atrBuffer[0];
   
   // Obtenir le prix actuel
   double currentPrice = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   datetime currentTime = TimeCurrent();
   
   // --- PRÃDICTION DES FUTURES RÃSISTANCES (PROTECTED HIGH POINTS) ---
   
   // 1. BasÃĐ sur les highs protÃĐgÃĐs historiques rÃĐcents
   double recentHighs[];
   ArrayResize(recentHighs, 0);
   int highCount = 0;
   
   // Extraire les highs protÃĐgÃĐs des 50 derniÃĻres bougies
   for(int i = 10; i < 50; i++)
   {
      bool isProtectedHigh = true;
      double currentHigh = rates[i].high;
      
      // VÃĐrifier si c'est un high protÃĐgÃĐ
      for(int j = i - 5; j >= 0 && j >= i - 10; j--)
      {
         if(rates[j].high > currentHigh)
         {
            isProtectedHigh = false;
            break;
         }
      }
      
      if(isProtectedHigh && currentHigh > currentPrice)
      {
         ArrayResize(recentHighs, highCount + 1);
         recentHighs[highCount] = currentHigh;
         highCount++;
      }
   }
   
   // 2. Projeter les futures rÃĐsistances basÃĐes sur la structure du marchÃĐ
   double futureHighs[3];
   string highLabels[3] = {"R1+FUTUR", "R2+FUTUR", "R3+FUTUR"};
   color highColors[3] = {clrPurple, clrMagenta, clrMaroon};
   
   if(highCount >= 2)
   {
      // Calculer la distance moyenne et la tendance des highs protÃĐgÃĐs
      double avgHighDistance = 0.0;
      double highTrendSlope = 0.0;
      int validPoints = 0;
      
      for(int i = 1; i < highCount; i++)
      {
         double distance = recentHighs[i] - recentHighs[i-1];
         avgHighDistance += distance;
         
         // Calculer la pente de tendance (rÃĐgression linÃĐaire simple)
         if(i < highCount)
         {
            highTrendSlope += distance;
            validPoints++;
         }
      }
      
      if(validPoints > 0)
      {
         avgHighDistance /= (highCount - 1);
         highTrendSlope /= validPoints;
      }
      
      // Projeter 3 futures rÃĐsistances avec projection amÃĐliorÃĐe
      double lastHigh = recentHighs[0];
      double projectedBasePrice = lastHigh;
      
      for(int i = 0; i < 3; i++)
      {
         // Projection progressive basÃĐe sur la tendance historique
         double trendProjection = highTrendSlope * (i + 1) * 0.8; // 80% de la tendance pour conservatisme
         double volatilityAdjustment = 0.0;
         
         // Ajustement avec la volatilitÃĐ actuelle (ATR) - plus sophistiquÃĐ
         if(atr > 0)
         {
            // VolatilitÃĐ croissante pour les niveaux plus lointains
            volatilityAdjustment = atr * (0.3 + (i * 0.2)); // 0.3, 0.5, 0.7 ATR
            
            // Ajustement basÃĐ sur la direction de la tendance
            if(highTrendSlope > 0) // Tendance haussiÃĻre
               volatilityAdjustment *= 1.2; // Augmenter la projection
            else // Tendance baissiÃĻre ou neutre
               volatilityAdjustment *= 0.8; // RÃĐduire la projection
         }
         
         // Calcul du niveau futur avec tous les ajustements
         futureHighs[i] = projectedBasePrice + (avgHighDistance * (i + 1)) + trendProjection + volatilityAdjustment;
         
         // Projection temporelle amÃĐliorÃĐe - basÃĐe sur la vitesse historique
         int timeBars = 15 + (i * 10) + (int)(avgHighDistance / atr * 5); // 15, 25, 35+ bougies
         datetime futureTime = currentTime + (PeriodSeconds(PERIOD_M15) * timeBars);
         
         // CrÃĐer une ligne plus longue dans le futur pour meilleure visualisation
         datetime extendedFutureTime = futureTime + (PeriodSeconds(PERIOD_M15) * 20); // Extension de 20 bougies
         
         // Dessiner la ligne de prÃĐdiction amÃĐliorÃĐe
         string lineName = "FUTURE_PROTECTED_HIGH_" + IntegerToString(i);
         
         ObjectCreate(0, lineName, OBJ_TREND, 0, currentTime, futureHighs[i], extendedFutureTime, futureHighs[i]);
         ObjectSetInteger(0, lineName, OBJPROP_COLOR, highColors[i]);
         ObjectSetInteger(0, lineName, OBJPROP_STYLE, STYLE_DASH);
         ObjectSetInteger(0, lineName, OBJPROP_WIDTH, 2 + i); // Ãpaisseur croissante
         ObjectSetInteger(0, lineName, OBJPROP_BACK, true);
         
         // Ajouter un label avec plus d'informations
         string labelName = "FUTURE_PROTECTED_HIGH_LABEL_" + IntegerToString(i);
         string labelText = highLabels[i] + " " + DoubleToString(futureHighs[i], _Digits) + 
                          " (+" + IntegerToString(timeBars) + " bars)";
         
         ObjectCreate(0, labelName, OBJ_TEXT, 0, futureTime, futureHighs[i] + (atr * 0.4));
         ObjectSetString(0, labelName, OBJPROP_TEXT, labelText);
         ObjectSetInteger(0, labelName, OBJPROP_COLOR, highColors[i]);
         ObjectSetInteger(0, labelName, OBJPROP_FONTSIZE, 8);
         ObjectSetInteger(0, labelName, OBJPROP_BACK, false);
         
         // Ajouter une zone de probabilitÃĐ autour du niveau prÃĐdit
         string zoneName = "FUTURE_PROTECTED_HIGH_ZONE_" + IntegerToString(i);
         double zoneWidth = atr * 0.5; // Zone de Âą0.5 ATR
         
         ObjectCreate(0, zoneName, OBJ_RECTANGLE, 0, currentTime, futureHighs[i] - zoneWidth, 
                     extendedFutureTime, futureHighs[i] + zoneWidth);
         ObjectSetInteger(0, zoneName, OBJPROP_COLOR, highColors[i]);
         ObjectSetInteger(0, zoneName, OBJPROP_STYLE, STYLE_SOLID);
         ObjectSetInteger(0, zoneName, OBJPROP_WIDTH, 1);
         ObjectSetInteger(0, zoneName, OBJPROP_BACK, true);
         ObjectSetInteger(0, zoneName, OBJPROP_FILL, true);
         ObjectSetInteger(0, zoneName, OBJPROP_BGCOLOR, highColors[i]);
         ObjectSetInteger(0, zoneName, OBJPROP_COLOR, clrNONE); // Bordure transparente
      }
   }
   
   // --- PRÃDICTION DES FUTURS SUPPORTS (PROTECTED LOW POINTS) ---
   
   // 1. BasÃĐ sur les lows protÃĐgÃĐs historiques rÃĐcents
   double recentLows[];
   ArrayResize(recentLows, 0);
   int lowCount = 0;
   
   // Extraire les lows protÃĐgÃĐs des 50 derniÃĻres bougies
   for(int i = 10; i < 50; i++)
   {
      bool isProtectedLow = true;
      double currentLow = rates[i].low;
      
      // VÃĐrifier si c'est un low protÃĐgÃĐ
      for(int j = i - 5; j >= 0 && j >= i - 10; j--)
      {
         if(rates[j].low < currentLow)
         {
            isProtectedLow = false;
            break;
         }
      }
      
      if(isProtectedLow && currentLow < currentPrice)
      {
         ArrayResize(recentLows, lowCount + 1);
         recentLows[lowCount] = currentLow;
         lowCount++;
      }
   }
   
   // 2. Projeter les futurs supports basÃĐs sur la structure du marchÃĐ
   double futureLows[3];
   string lowLabels[3] = {"S1+FUTUR", "S2+FUTUR", "S3+FUTUR"};
   color lowColors[3] = {clrDarkGreen, clrDarkOrange, clrBrown};
   
   if(lowCount >= 2)
   {
      // Calculer la distance moyenne et la tendance des lows protÃĐgÃĐs
      double avgLowDistance = 0.0;
      double lowTrendSlope = 0.0;
      int validLowPoints = 0;
      
      for(int i = 1; i < lowCount; i++)
      {
         double distance = recentLows[i-1] - recentLows[i]; // InversÃĐ car les lows sont en ordre dÃĐcroissant
         avgLowDistance += distance;
         
         // Calculer la pente de tendance (rÃĐgression linÃĐaire simple)
         if(i < lowCount)
         {
            lowTrendSlope += distance;
            validLowPoints++;
         }
      }
      
      if(validLowPoints > 0)
      {
         avgLowDistance /= (lowCount - 1);
         lowTrendSlope /= validLowPoints;
      }
      
      // Projeter 3 futurs supports avec projection amÃĐliorÃĐe
      double lastLow = recentLows[0];
      double projectedBaseLow = lastLow;
      
      for(int i = 0; i < 3; i++)
      {
         // Projection progressive basÃĐe sur la tendance historique
         double trendProjection = lowTrendSlope * (i + 1) * 0.8; // 80% de la tendance pour conservatisme
         double volatilityAdjustment = 0.0;
         
         // Ajustement avec la volatilitÃĐ actuelle (ATR) - plus sophistiquÃĐ
         if(atr > 0)
         {
            // VolatilitÃĐ croissante pour les niveaux plus lointains
            volatilityAdjustment = atr * (0.3 + (i * 0.2)); // 0.3, 0.5, 0.7 ATR
            
            // Ajustement basÃĐ sur la direction de la tendance
            if(lowTrendSlope > 0) // Tendance baissiÃĻre des lows (les lows descendent)
               volatilityAdjustment *= 1.2; // Augmenter la projection vers le bas
            else // Tendance haussiÃĻre des lows ou neutre
               volatilityAdjustment *= 0.8; // RÃĐduire la projection
         }
         
         // Calcul du niveau futur avec tous les ajustements
         futureLows[i] = projectedBaseLow - (avgLowDistance * (i + 1)) - trendProjection - volatilityAdjustment;
         
         // Projection temporelle amÃĐliorÃĐe - basÃĐe sur la vitesse historique
         int timeBars = 15 + (i * 10) + (int)(avgLowDistance / atr * 5); // 15, 25, 35+ bougies
         datetime futureTime = currentTime + (PeriodSeconds(PERIOD_M15) * timeBars);
         
         // CrÃĐer une ligne plus longue dans le futur pour meilleure visualisation
         datetime extendedFutureTime = futureTime + (PeriodSeconds(PERIOD_M15) * 20); // Extension de 20 bougies
         
         // Dessiner la ligne de prÃĐdiction amÃĐliorÃĐe
         string lineName = "FUTURE_PROTECTED_LOW_" + IntegerToString(i);
         
         ObjectCreate(0, lineName, OBJ_TREND, 0, currentTime, futureLows[i], extendedFutureTime, futureLows[i]);
         ObjectSetInteger(0, lineName, OBJPROP_COLOR, lowColors[i]);
         ObjectSetInteger(0, lineName, OBJPROP_STYLE, STYLE_DASH);
         ObjectSetInteger(0, lineName, OBJPROP_WIDTH, 2 + i); // Ãpaisseur croissante
         ObjectSetInteger(0, lineName, OBJPROP_BACK, true);
         
         // Ajouter un label avec plus d'informations
         string labelName = "FUTURE_PROTECTED_LOW_LABEL_" + IntegerToString(i);
         string labelText = lowLabels[i] + " " + DoubleToString(futureLows[i], _Digits) + 
                          " (+" + IntegerToString(timeBars) + " bars)";
         
         ObjectCreate(0, labelName, OBJ_TEXT, 0, futureTime, futureLows[i] - (atr * 0.4));
         ObjectSetString(0, labelName, OBJPROP_TEXT, labelText);
         ObjectSetInteger(0, labelName, OBJPROP_COLOR, lowColors[i]);
         ObjectSetInteger(0, labelName, OBJPROP_FONTSIZE, 8);
         ObjectSetInteger(0, labelName, OBJPROP_BACK, false);
         
         // Ajouter une zone de probabilitÃĐ autour du niveau prÃĐdit
         string zoneName = "FUTURE_PROTECTED_LOW_ZONE_" + IntegerToString(i);
         double zoneWidth = atr * 0.5; // Zone de Âą0.5 ATR
         
         ObjectCreate(0, zoneName, OBJ_RECTANGLE, 0, currentTime, futureLows[i] - zoneWidth, 
                     extendedFutureTime, futureLows[i] + zoneWidth);
         ObjectSetInteger(0, zoneName, OBJPROP_COLOR, lowColors[i]);
         ObjectSetInteger(0, zoneName, OBJPROP_STYLE, STYLE_SOLID);
         ObjectSetInteger(0, zoneName, OBJPROP_WIDTH, 1);
         ObjectSetInteger(0, zoneName, OBJPROP_BACK, true);
         ObjectSetInteger(0, zoneName, OBJPROP_FILL, true);
         ObjectSetInteger(0, zoneName, OBJPROP_BGCOLOR, lowColors[i]);
         ObjectSetInteger(0, zoneName, OBJPROP_COLOR, clrNONE); // Bordure transparente
      }
   }
   
   // --- PRÃDICTION BASÃE SUR L'IA ET LES ZONES DE CONFLUENCE ---
   
   if(UseAIServer && g_lastAIAction != "")
   {
      // Si IA dit BUY, prÃĐdire un support futur probable
      if(g_lastAIAction == "BUY")
      {
         double predictedSupport = currentPrice - (atr * 1.5); // Support probable Ã  1.5 ATR en dessous
         datetime supportTime = currentTime + PeriodSeconds(PERIOD_M15) * 15; // 15 bougies dans le futur
         
         string aiSupportLine = "FUTURE_PROTECTED_AI_SUPPORT";
         ObjectCreate(0, aiSupportLine, OBJ_TREND, 0, currentTime, predictedSupport, supportTime, predictedSupport);
         ObjectSetInteger(0, aiSupportLine, OBJPROP_COLOR, clrLimeGreen);
         ObjectSetInteger(0, aiSupportLine, OBJPROP_STYLE, STYLE_DASHDOT);
         ObjectSetInteger(0, aiSupportLine, OBJPROP_WIDTH, 3);
         ObjectSetInteger(0, aiSupportLine, OBJPROP_BACK, true);
         
         string aiSupportLabel = "FUTURE_PROTECTED_AI_SUPPORT_LABEL";
         ObjectCreate(0, aiSupportLabel, OBJ_TEXT, 0, supportTime, predictedSupport - (atr * 0.2));
         ObjectSetString(0, aiSupportLabel, OBJPROP_TEXT, "AI-SUPPORT " + DoubleToString(predictedSupport, _Digits) + " (" + DoubleToString(g_lastAIConfidence * 100, 1) + "%)");
         ObjectSetInteger(0, aiSupportLabel, OBJPROP_COLOR, clrLimeGreen);
         ObjectSetInteger(0, aiSupportLabel, OBJPROP_FONTSIZE, 9);
         ObjectSetInteger(0, aiSupportLabel, OBJPROP_BACK, false);
      }
      
      // Si IA dit SELL, prÃĐdire une rÃĐsistance future probable
      if(g_lastAIAction == "SELL")
      {
         double predictedResistance = currentPrice + (atr * 1.5); // RÃĐsistance probable Ã  1.5 ATR au dessus
         datetime resistanceTime = currentTime + PeriodSeconds(PERIOD_M15) * 15; // 15 bougies dans le futur
         
         string aiResistanceLine = "FUTURE_PROTECTED_AI_RESISTANCE";
         ObjectCreate(0, aiResistanceLine, OBJ_TREND, 0, currentTime, predictedResistance, resistanceTime, predictedResistance);
         ObjectSetInteger(0, aiResistanceLine, OBJPROP_COLOR, clrRed);
         ObjectSetInteger(0, aiResistanceLine, OBJPROP_STYLE, STYLE_DASHDOT);
         ObjectSetInteger(0, aiResistanceLine, OBJPROP_WIDTH, 3);
         ObjectSetInteger(0, aiResistanceLine, OBJPROP_BACK, true);
         
         string aiResistanceLabel = "FUTURE_PROTECTED_AI_RESISTANCE_LABEL";
         ObjectCreate(0, aiResistanceLabel, OBJ_TEXT, 0, resistanceTime, predictedResistance + (atr * 0.2));
         ObjectSetString(0, aiResistanceLabel, OBJPROP_TEXT, "AI-RESISTANCE " + DoubleToString(predictedResistance, _Digits) + " (" + DoubleToString(g_lastAIConfidence * 100, 1) + "%)");
         ObjectSetInteger(0, aiResistanceLabel, OBJPROP_COLOR, clrRed);
         ObjectSetInteger(0, aiResistanceLabel, OBJPROP_FONTSIZE, 9);
         ObjectSetInteger(0, aiResistanceLabel, OBJPROP_BACK, false);
      }
   }
   
   // --- PROJECTION DES PROTECTED POINTS ACTUELS 500 BOUGIES DANS LE FUTUR ---
   
   // Trouver le Protected High Point le plus rÃĐcent
   double lastProtectedHigh = 0.0;
   datetime lastProtectedHighTime = 0;
   
   for(int i = 5; i < 50; i++)
   {
      bool isProtectedHigh = true;
      double currentHigh = rates[i].high;
      
      // VÃĐrifier si c'est un high protÃĐgÃĐ
      for(int j = i - 5; j >= 0 && j >= i - 10; j--)
      {
         if(rates[j].high > currentHigh)
         {
            isProtectedHigh = false;
            break;
         }
      }
      
      if(isProtectedHigh && currentHigh > currentPrice)
      {
         lastProtectedHigh = currentHigh;
         lastProtectedHighTime = rates[i].time;
         break; // Prendre le plus rÃĐcent
      }
   }
   
   // Trouver le Protected Low Point le plus rÃĐcent
   double lastProtectedLow = 0.0;
   datetime lastProtectedLowTime = 0;
   
   for(int i = 5; i < 50; i++)
   {
      bool isProtectedLow = true;
      double currentLow = rates[i].low;
      
      // VÃĐrifier si c'est un low protÃĐgÃĐ
      for(int j = i - 5; j >= 0 && j >= i - 10; j--)
      {
         if(rates[j].low < currentLow)
         {
            isProtectedLow = false;
            break;
         }
      }
      
      if(isProtectedLow && currentLow < currentPrice)
      {
         lastProtectedLow = currentLow;
         lastProtectedLowTime = rates[i].time;
         break; // Prendre le plus rÃĐcent
      }
   }
   
   // Projeter le Protected High actuel 500 bougies dans le futur
   if(lastProtectedHigh > 0)
   {
      datetime futureHighTime = currentTime + (PeriodSeconds(PERIOD_M15) * 500); // 500 bougies dans le futur
      datetime extendedHighTime = futureHighTime + (PeriodSeconds(PERIOD_M15) * 50); // Extension de 50 bougies
      
      string highLineName = "PROTECTED_HIGH_FUTURE_500";
      ObjectCreate(0, highLineName, OBJ_TREND, 0, currentTime, lastProtectedHigh, extendedHighTime, lastProtectedHigh);
      ObjectSetInteger(0, highLineName, OBJPROP_COLOR, clrOrange);
      ObjectSetInteger(0, highLineName, OBJPROP_STYLE, STYLE_SOLID);
      ObjectSetInteger(0, highLineName, OBJPROP_WIDTH, 3);
      ObjectSetInteger(0, highLineName, OBJPROP_BACK, true);
      
      string highLabelName = "PROTECTED_HIGH_FUTURE_500_LABEL";
      ObjectCreate(0, highLabelName, OBJ_TEXT, 0, futureHighTime, lastProtectedHigh + (atr * 0.5));
      ObjectSetString(0, highLabelName, OBJPROP_TEXT, "PROTECTED_HIGH " + DoubleToString(lastProtectedHigh, _Digits) + " (+500 bars)");
      ObjectSetInteger(0, highLabelName, OBJPROP_COLOR, clrOrange);
      ObjectSetInteger(0, highLabelName, OBJPROP_FONTSIZE, 10);
      ObjectSetInteger(0, highLabelName, OBJPROP_BACK, false);
   }
   
   // Projeter le Protected Low actuel 500 bougies dans le futur
   if(lastProtectedLow > 0)
   {
      datetime futureLowTime = currentTime + (PeriodSeconds(PERIOD_M15) * 500); // 500 bougies dans le futur
      datetime extendedLowTime = futureLowTime + (PeriodSeconds(PERIOD_M15) * 50); // Extension de 50 bougies
      
      string lowLineName = "PROTECTED_LOW_FUTURE_500";
      ObjectCreate(0, lowLineName, OBJ_TREND, 0, currentTime, lastProtectedLow, extendedLowTime, lastProtectedLow);
      ObjectSetInteger(0, lowLineName, OBJPROP_COLOR, clrGreen);
      ObjectSetInteger(0, lowLineName, OBJPROP_STYLE, STYLE_SOLID);
      ObjectSetInteger(0, lowLineName, OBJPROP_WIDTH, 3);
      ObjectSetInteger(0, lowLineName, OBJPROP_BACK, true);
      
      string lowLabelName = "PROTECTED_LOW_FUTURE_500_LABEL";
      ObjectCreate(0, lowLabelName, OBJ_TEXT, 0, futureLowTime, lastProtectedLow - (atr * 0.5));
      ObjectSetString(0, lowLabelName, OBJPROP_TEXT, "PROTECTED_LOW " + DoubleToString(lastProtectedLow, _Digits) + " (+500 bars)");
      ObjectSetInteger(0, lowLabelName, OBJPROP_COLOR, clrGreen);
      ObjectSetInteger(0, lowLabelName, OBJPROP_FONTSIZE, 10);
      ObjectSetInteger(0, lowLabelName, OBJPROP_BACK, false);
   }
   
   // --- LOG DES PRÃDICTIONS ---
   Print("ðŪ PRÃDICTIONS FUTURES DES POINTS PROTÃGÃS - ", _Symbol);
   Print("   ð BasÃĐ sur ", highCount, " highs et ", lowCount, " lows protÃĐgÃĐs historiques");
   Print("   ðŊ ATR actuel: ", DoubleToString(atr, _Digits));
   Print("   ðĄ PrÃĐdictions IA: ", g_lastAIAction, " (confiance: ", DoubleToString(g_lastAIConfidence * 100, 1), "%)");
   
   // Log des Protected Points projetÃĐs
   if(lastProtectedHigh > 0)
      Print("   ð  PROTECTED_HIGH projetÃĐ: ", DoubleToString(lastProtectedHigh, _Digits), " â +500 bougies");
   if(lastProtectedLow > 0)
      Print("   ðĒ PROTECTED_LOW projetÃĐ: ", DoubleToString(lastProtectedLow, _Digits), " â +500 bougies");
}

// Obtenir les niveaux futurs de Protected Points pour le trading
bool GetFutureProtectedPointLevels(double &futureSupportOut, double &futureResistanceOut)
{
   futureSupportOut = 0.0;
   futureResistanceOut = 0.0;
   
   // Obtenir les donnÃĐes historiques
   MqlRates rates[];
   ArraySetAsSeries(rates, true);
   if(CopyRates(_Symbol, PERIOD_M15, 0, 200, rates) < 100) return false;
   
   // Calculer l'ATR
   double atrBuffer[];
   ArraySetAsSeries(atrBuffer, true);
   double atr = 0.0;
   if(atrHandle != INVALID_HANDLE && CopyBuffer(atrHandle, 0, 0, 1, atrBuffer) >= 1)
      atr = atrBuffer[0];
   
   double currentPrice = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   
   // --- CALCULER LES FUTURES RÃSISTANCES ---
   double recentHighs[];
   ArrayResize(recentHighs, 0);
   int highCount = 0;
   
   // Extraire les highs protÃĐgÃĐs
   for(int i = 10; i < 50; i++)
   {
      bool isProtectedHigh = true;
      double currentHigh = rates[i].high;
      
      for(int j = i - 5; j >= 0 && j >= i - 10; j--)
      {
         if(rates[j].high > currentHigh)
         {
            isProtectedHigh = false;
            break;
         }
      }
      
      if(isProtectedHigh && currentHigh > currentPrice)
      {
         ArrayResize(recentHighs, highCount + 1);
         recentHighs[highCount] = currentHigh;
         highCount++;
      }
   }
   
   // Calculer la prochaine rÃĐsistance future
   if(highCount >= 2)
   {
      double avgHighDistance = 0.0;
      for(int i = 1; i < highCount; i++)
         avgHighDistance += recentHighs[i] - recentHighs[i-1];
      avgHighDistance /= (highCount - 1);
      
      futureResistanceOut = recentHighs[0] + avgHighDistance;
      if(atr > 0)
         futureResistanceOut += (atr * 0.5); // Ajustement volatilitÃĐ
   }
   
   // --- CALCULER LES FUTURS SUPPORTS ---
   double recentLows[];
   ArrayResize(recentLows, 0);
   int lowCount = 0;
   
   // Extraire les lows protÃĐgÃĐs
   for(int i = 10; i < 50; i++)
   {
      bool isProtectedLow = true;
      double currentLow = rates[i].low;
      
      for(int j = i - 5; j >= 0 && j >= i - 10; j--)
      {
         if(rates[j].low < currentLow)
         {
            isProtectedLow = false;
            break;
         }
      }
      
      if(isProtectedLow && currentLow < currentPrice)
      {
         ArrayResize(recentLows, lowCount + 1);
         recentLows[lowCount] = currentLow;
         lowCount++;
      }
   }
   
   // Calculer le prochain support futur
   if(lowCount >= 2)
   {
      double avgLowDistance = 0.0;
      for(int i = 1; i < lowCount; i++)
         avgLowDistance += recentLows[i-1] - recentLows[i];
      avgLowDistance /= (lowCount - 1);
      
      futureSupportOut = recentLows[0] - avgLowDistance;
      if(atr > 0)
         futureSupportOut -= (atr * 0.5); // Ajustement volatilitÃĐ
   }
   
   // --- PRIORITÃ AUX PRÃDICTIONS IA ---
   if(UseAIServer && g_lastAIAction != "")
   {
      if(g_lastAIAction == "BUY" && atr > 0)
      {
         futureSupportOut = currentPrice - (atr * 1.5);
      }
      else if(g_lastAIAction == "SELL" && atr > 0)
      {
         futureResistanceOut = currentPrice + (atr * 1.5);
      }
   }
   
   return (futureSupportOut > 0 || futureResistanceOut > 0);
}

void DrawDashboardOnChart(const string &lines[], const color &colors[], int count)
{
   // NETTOYAGE AGRESSIF - Supprimer TOUS les anciens labels dashboard
   for(int j = 0; j < 300; j++)  // jusqu'Ã  300 lignes potentielles
   {
      string name = "SMC_DASH_LINE_" + IntegerToString(j);
      if(ObjectFind(0, name) >= 0)
      {
         ObjectDelete(0, name);
      }
   }
   
   // VÃĐrification supplÃĐmentaire : parcourir tous les objets et supprimer ceux qui correspondent
   for(int i = ObjectsTotal(0) - 1; i >= 0; i--)
   {
      string objName = ObjectName(0, i);
      if(StringFind(objName, "SMC_DASH_LINE_") == 0)
      {
         ObjectDelete(0, objName);
      }
   }
   
   // CrÃĐer/mettre Ã  jour une liste de labels verticaux, sans superposition
   int x  = MathMax(0, DashboardLabelXOffsetPixels);
   int y0 = MathMax(0, DashboardLabelYStartPixels);
   int lh = MathMax(12, DashboardLabelLineHeightPixels);  // compact et lisible

   int maxLines = MathMin(count, 40);  // on autorise plus de lignes visibles

   static datetime lastDebugLog = 0;
   if(DebugMLMetricsHttp && TimeCurrent() - lastDebugLog >= 300)
   {
      Print("?? DEBUG Dashboard - x=", x, " | y0=", y0, " | lineHeight=", lh, " | lines=", maxLines);
      lastDebugLog = TimeCurrent();
   }

   for(int i = 0; i < maxLines; i++)
   {
      string name = "SMC_DASH_LINE_" + IntegerToString(i);
      
      // CrÃĐer le label s'il n'existe pas
      if(ObjectFind(0, name) < 0)
      {
         if(!ObjectCreate(0, name, OBJ_LABEL, 0, 0, 0))
            continue;
         ObjectSetInteger(0, name, OBJPROP_CORNER, CORNER_LEFT_UPPER);
         ObjectSetString(0, name, OBJPROP_FONT, "Consolas");
         ObjectSetInteger(0, name, OBJPROP_FONTSIZE, 8);  // harmonisÃĐ
         ObjectSetInteger(0, name, OBJPROP_BACK, false);  // Premier plan pour visibilitÃĐ
      }

      // Calcul de la position Y avec vÃĐrification
      int yPos = y0 + (i * lh);
      
      // Appliquer le positionnement
      ObjectSetInteger(0, name, OBJPROP_XDISTANCE, x);
      ObjectSetInteger(0, name, OBJPROP_YDISTANCE, yPos);
      ObjectSetInteger(0, name, OBJPROP_COLOR, colors[i]);
      ObjectSetString(0, name, OBJPROP_TEXT, lines[i]);

      // Log de dÃĐbogage pour les premiÃĻres lignes seulement
      if(i < 3 && TimeCurrent() - lastDebugLog >= 300)
      {
         Print("?? DEBUG Line ", i, " - yPos=", yPos, " | text=", StringSubstr(lines[i], 0, 30));
      }
   }

   g_dashboardBottomY = y0 + maxLines * lh;
}

// Applique la stratÃĐgie adaptÃĐe Ã  la catÃĐgorie de symbole (Boom/Crash, Volatility, Forex/Metals)
void RunCategoryStrategy()
{
   ENUM_SYMBOL_CATEGORY cat = SMC_GetSymbolCategory(_Symbol);
   
   switch(cat)
   {
      case SYM_BOOM_CRASH:
         // Boom/Crash: La gestion des spikes reste active, mais les entrÃĐes sont pilotÃĐes par l'IA 360
         break;

      case SYM_VOLATILITY:
      case SYM_WELTRADE_SYNTH:
         // Volatility: EntrÃĐes pilotÃĐes par l'IA 360
         break;

      case SYM_FOREX:
         // Forex: EntrÃĐes pilotÃĐes par l'IA 360
         break;

      case SYM_METAL:
      case SYM_COMMODITY:
      case SYM_UNKNOWN:
      default:
         break;
   }
}

// --- FOREX STRATEGY: BOS + Retest (market entry only) ---
// DÃĐtecte une cassure de structure (BOS) sur LTF puis attend un retest du niveau cassÃĐ.
// Quand le retest est validÃĐ, renvoie direction + niveaux SL/TP basÃĐs structure+ATR.
bool Forex_DetectBOSRetest(string &dirOut, double &entryOut, double &slOut, double &tpOut)
{
   dirOut = "";
   entryOut = 0.0;
   slOut = 0.0;
   tpOut = 0.0;

   // Cette stratÃĐgie ne s'applique qu'aux symboles Forex (mÃĐtaux exclus pour l'instant)
   if(SMC_GetSymbolCategory(_Symbol) != SYM_FOREX) return false;

   MqlRates rates[];
   ArraySetAsSeries(rates, true);
   int copied = CopyRates(_Symbol, LTF, 0, 120, rates);
   if(copied < 30) return false;

   // ATR sur LTF (tolÃĐrance retest)
   double atrVal = 0.0;
   if(atrHandle != INVALID_HANDLE)
   {
      double atrBuf[];
      ArraySetAsSeries(atrBuf, true);
      if(CopyBuffer(atrHandle, 0, 0, 2, atrBuf) >= 1)
         atrVal = atrBuf[0];
   }
   if(atrVal <= 0.0)
      atrVal = MathAbs(rates[1].high - rates[1].low); // fallback minimal

   double tol = MathMax(atrVal * 0.20, SymbolInfoDouble(_Symbol, SYMBOL_POINT) * 10.0);

   // Etat persistant "en attente de retest" (EA par symbole)
   static bool     s_waitingRetest = false;
   static string   s_dir = "";
   static double   s_level = 0.0;
   static datetime s_bosTime = 0;
   static datetime s_lastLog = 0;

   // Helper: chercher le swing high/low le plus rÃĐcent (fractal-like)
   double lastSwingHigh = 0.0;
   double lastSwingLow  = 0.0;
   int swingHighIdx = -1;
   int swingLowIdx  = -1;

   for(int i = 5; i < MathMin(copied - 5, 80); i++)
   {
      bool isHigh = (rates[i].high > rates[i-1].high && rates[i].high > rates[i+1].high &&
                     rates[i].high > rates[i-2].high && rates[i].high > rates[i+2].high);
      bool isLow  = (rates[i].low  < rates[i-1].low  && rates[i].low  < rates[i+1].low  &&
                     rates[i].low  < rates[i-2].low  && rates[i].low  < rates[i+2].low);

      if(swingHighIdx < 0 && isHigh) { swingHighIdx = i; lastSwingHigh = rates[i].high; }
      if(swingLowIdx  < 0 && isLow)  { swingLowIdx  = i; lastSwingLow  = rates[i].low;  }
      if(swingHighIdx >= 0 && swingLowIdx >= 0) break;
   }

   if(lastSwingHigh <= 0.0 || lastSwingLow <= 0.0) return false;

   double close1 = rates[1].close;
   double close2 = rates[2].close;

   // Timeout d'attente retest (ÃĐvite d'attendre ÃĐternellement)
   if(s_waitingRetest && s_bosTime > 0)
   {
      if((TimeCurrent() - s_bosTime) > (60 * 60 * 6)) // 6h
      {
         s_waitingRetest = false;
         s_dir = "";
         s_level = 0.0;
         s_bosTime = 0;
      }
   }

   // Si pas en attente, dÃĐtecter un BOS frais
   if(!s_waitingRetest)
   {
      // BOS UP: close[1] casse au-dessus du swing high
      if(close1 > lastSwingHigh && close2 <= lastSwingHigh)
      {
         s_waitingRetest = true;
         s_dir = "BUY";
         s_level = lastSwingHigh;
         s_bosTime = rates[1].time;
         if(TimeCurrent() - s_lastLog >= 60)
         {
            Print("ð FOREX BOS dÃĐtectÃĐ (BUY) sur ", _Symbol, " | Niveau=", DoubleToString(s_level, _Digits));
            s_lastLog = TimeCurrent();
         }
         return false;
      }
      // BOS DOWN: close[1] casse au-dessous du swing low
      if(close1 < lastSwingLow && close2 >= lastSwingLow)
      {
         s_waitingRetest = true;
         s_dir = "SELL";
         s_level = lastSwingLow;
         s_bosTime = rates[1].time;
         if(TimeCurrent() - s_lastLog >= 60)
         {
            Print("ð FOREX BOS dÃĐtectÃĐ (SELL) sur ", _Symbol, " | Niveau=", DoubleToString(s_level, _Digits));
            s_lastLog = TimeCurrent();
         }
         return false;
      }
      return false;
   }

   // En attente retest: vÃĐrifier retest du niveau cassÃĐ (tolÃĐrance ATR)
   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);

   bool retestOk = false;
   if(s_dir == "BUY")
   {
      // Prix revient toucher/approcher le niveau cassÃĐ et clÃīture sans rÃĐintÃĐgrer fortement sous le niveau
      bool touched = (rates[0].low <= (s_level + tol));
      bool held    = (rates[0].close >= (s_level - tol));
      retestOk = (touched && held);
      if(!retestOk && TimeCurrent() - s_lastLog >= 120)
      {
         Print("âģ FOREX Retest en attente (BUY) sur ", _Symbol,
               " | Niveau=", DoubleToString(s_level, _Digits),
               " | tol=", DoubleToString(tol, _Digits));
         s_lastLog = TimeCurrent();
      }
   }
   else if(s_dir == "SELL")
   {
      bool touched = (rates[0].high >= (s_level - tol));
      bool held    = (rates[0].close <= (s_level + tol));
      retestOk = (touched && held);
      if(!retestOk && TimeCurrent() - s_lastLog >= 120)
      {
         Print("âģ FOREX Retest en attente (SELL) sur ", _Symbol,
               " | Niveau=", DoubleToString(s_level, _Digits),
               " | tol=", DoubleToString(tol, _Digits));
         s_lastLog = TimeCurrent();
      }
   }
   else
   {
      s_waitingRetest = false;
      s_level = 0.0;
      s_bosTime = 0;
      return false;
   }

   if(!retestOk) return false;

   // Optionnel: si filtres SMC activÃĐs, exiger une validation multi-signaux existante
   if(UseLiquiditySweep || UseOrderBlocks || UseFVG)
   {
      if(!ValidateEntryWithMultipleSignals(s_dir))
      {
         if(TimeCurrent() - s_lastLog >= 60)
         {
            Print("â FOREX Retest OK mais filtres SMC KO sur ", _Symbol, " (", s_dir, ")");
            s_lastLog = TimeCurrent();
         }
         return false;
      }
   }

   dirOut = s_dir;
   entryOut = (s_dir == "BUY") ? ask : bid;

   // SL/TP structure + ATR
   double risk = 0.0;
   if(s_dir == "BUY")
   {
      // Ajustement: SL plus "large" et TP >= 3R
      slOut = s_level - atrVal * 1.00;
      risk = MathMax(entryOut - slOut, SymbolInfoDouble(_Symbol, SYMBOL_POINT) * 15.0);
      tpOut = entryOut + (MathMax(3.0, InpRiskReward) * risk);
   }
   else
   {
      // Ajustement: SL plus "large" et TP >= 3R
      slOut = s_level + atrVal * 1.00;
      risk = MathMax(slOut - entryOut, SymbolInfoDouble(_Symbol, SYMBOL_POINT) * 15.0);
      tpOut = entryOut - (MathMax(3.0, InpRiskReward) * risk);
   }

   // Consommer le signal (une seule entrÃĐe par BOS)
   s_waitingRetest = false;
   s_dir = "";
   s_level = 0.0;
   s_bosTime = 0;

   return true;
}

void ExecuteForexBOSRetest()
{
   if(SMC_GetSymbolCategory(_Symbol) != SYM_FOREX) return;

   // PROTECTION CONTRE LES PERTES PAR SYMBOLE - VÃĐrifier avant tout
   if(CheckSymbolLossProtection())
   {
      Print("ðĻ FOREX BOS+Retest BLOQUÃ - Protection symbole activÃĐe sur ", _Symbol);
      Print("   ð° Perte actuelle: ", DoubleToString(g_symbolCurrentLoss, 2), "$ > Limite: ", DoubleToString(MaxLossPerSymbolDollars, 2), "$");
      return;
   }
   
   // FILTRE PRIORITÃ SYMBOLES PROPICES - BLOCAGE TOTAL SI NON PRIORITAIRE
   if(UsePropiceSymbolsFilter)
   {
      if(!g_currentSymbolIsPropice && !PreferBestSymbolWithoutBlocking)
      {
         Print("ðŦ FOREX BOS+Retest BLOQUÃ - Symbole non 'propice': ", _Symbol);
         Print("   Heure UTC: ", TimeToString(TimeCurrent(), TIME_SECONDS), " | Top propices: ", g_propiceTopSymbolsText);
         Print("   ðŦ BLOCAGE TOTAL - Aucun trade autorisÃĐ sur les symboles non propices");
         return;
      }
      else if(!g_currentSymbolIsPropice && PreferBestSymbolWithoutBlocking)
      {
         Print("â ïļ FOREX BOS+Retest - symbole non propice mais autorisÃĐ (mode opportunitÃĐs max): ", _Symbol);
      }
      
      // Avant: blocage total si pas rang 0.
      // Maintenant: on autorise si le symbole est propice, avec seuils plus stricts cÃītÃĐ IA (voir gating ci-dessous).
      if(!IsMostPropiceSymbol())
      {
         if(!PropiceAllowMarketOrdersOnAllPropiceSymbols)
         {
            string mostPropice = GetMostPropiceSymbol();
            Print("ðŦ FOREX BOS+Retest BLOQUÃ - Symbole pas le plus propice: ", _Symbol);
            Print("   ð Position actuelle: ", g_currentSymbolPriority + 1, "ÃĻme dans la liste");
            Print("   ðĨ Symbole le plus propice: ", mostPropice);
            Print("   ðŦ BLOCAGE TOTAL - Seul le symbole le plus propice peut ÃŠtre tradÃĐ");
            return;
         }
         Print("â ïļ FOREX BOS+Retest - Symbole propice rang >", g_currentSymbolPriority + 1,
               ") autorisÃĐ: ", _Symbol, " (seuil IA plus strict)"); 
      }
      else
      {
         Print("ðĨ SYMBOLE LE PLUS PROPICE - FOREX BOS+Retest autorisÃĐ: ", _Symbol);
         Print("   â PrioritÃĐ maximale - ExÃĐcution autorisÃĐe");
      }
   }

   // Anti-duplication symbol exposure
   if(HasAnyExposureForSymbol(_Symbol)) return;

   string dir;
   double entry, sl, tp;
   if(!Forex_DetectBOSRetest(dir, entry, sl, tp)) return;

   string d = dir; StringToUpper(d);

   // IA gating (HOLD interdit + direction match + confiance >= MinAIConfidencePercent)
   if(UseAIServer)
   {
      string ia = g_lastAIAction;
      StringToUpper(ia);
      double confPct = g_lastAIConfidence * 100.0;
      double minConfPct = MinAIConfidencePercent;
      if(UsePropiceSymbolsFilter && PropiceAllowMarketOrdersOnAllPropiceSymbols &&
         g_currentSymbolIsPropice && g_currentSymbolPriority > 0)
      {
         minConfPct += (double)g_currentSymbolPriority *
                        PropiceNonTopExtraMinAIConfidencePercentPerRank;
      }

      if(ia == "" || ia == "HOLD")
      {
         Print("â FOREX BOS+Retest bloquÃĐ - IA HOLD/absente sur ", _Symbol);
         return;
      }
      if(ia != d)
      {
         Print("â FOREX BOS+Retest bloquÃĐ - IA=", ia, " != ", d, " sur ", _Symbol, " (", DoubleToString(confPct, 1), "%)");
         return;
      }
      if(confPct < minConfPct)
      {
         Print("â FOREX BOS+Retest bloquÃĐ - Confiance IA trop faible: ", DoubleToString(confPct,1),
               "% < ", DoubleToString(minConfPct,1), "% sur ", _Symbol);
         return;
      }
   }

   // ML gating (seuil Forex via IsMLModelTrustedForCurrentSymbol)
   if(!IsMLModelTrustedForCurrentSymbol(d))
   {
      Print("â FOREX BOS+Retest bloquÃĐ - ModÃĻle ML non fiable sur ", _Symbol,
            " (acc=", DoubleToString(g_mlLastAccuracy * 100.0, 1), "%)");
      return;
   }

   // Lock terminal-level (ÃĐviter doubles opens simultanÃĐs)
   if(!TryAcquireOpenLock()) return;

   // Respecter les contraintes stops level du broker
   double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   int stopsLevel = (int)SymbolInfoInteger(_Symbol, SYMBOL_TRADE_STOPS_LEVEL);
   double minDist = MathMax((double)stopsLevel * point, point * 10.0);

   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);

   if(d == "BUY")
   {
      entry = ask;
      if((entry - sl) < minDist) sl = entry - minDist;
      if((tp - entry) < minDist) tp = entry + minDist;
   }
   else
   {
      entry = bid;
      if((sl - entry) < minDist) sl = entry + minDist;
      if((entry - tp) < minDist) tp = entry - minDist;
   }

   sl = NormalizeDouble(sl, _Digits);
   tp = NormalizeDouble(tp, _Digits);

   double lot = CalculateLotSize(); // lots standard EA (risk mgmt dÃĐjÃ  existant)
   lot = NormalizeVolumeForSymbol(lot);

   bool ok = false;
   string comment = "FOREX_BOS_RETEST";
   if(d == "BUY")
      ok = trade.Buy(lot, _Symbol, 0.0, sl, tp, comment);
   else
      ok = trade.Sell(lot, _Symbol, 0.0, sl, tp, comment);

   if(ok)
   {
      Print("â FOREX BOS+Retest EXECUTÃ ", d, " ", _Symbol,
            " | lot=", DoubleToString(lot, 2),
            " | SL=", DoubleToString(sl, _Digits),
            " | TP=", DoubleToString(tp, _Digits));
   }
   else
   {
      Print("â FOREX BOS+Retest ÃCHEC ", d, " ", _Symbol,
            " | err=", IntegerToString(GetLastError()));
   }

   ReleaseOpenLock();
}

bool DetectPriceActionM15Signal(string &dirOut, double &slOut, double &tpOut)
{
   dirOut = "";
   slOut = 0.0;
   tpOut = 0.0;

   MqlRates rates[];
   ArraySetAsSeries(rates, true);

   int lookback = MathMax(20, PriceActionM15LookbackBars);
   int needBars = lookback + 10;
   int copied = CopyRates(_Symbol, PERIOD_M15, 0, needBars, rates);
   if(copied < (lookback + 5))
      return false;

   // Eviter la repetition de signal sur la meme bougie M15 close.
   static datetime s_lastSignalBarTime = 0;
   if(s_lastSignalBarTime == rates[1].time)
      return false;

   double atr = GetATRValue(PERIOD_M15, 14);
   double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   if(point <= 0.0) point = _Point;
   if(atr <= 0.0) atr = MathMax(MathAbs(rates[1].high - rates[1].low), point * 20.0);

   double buffer = MathMax(atr * MathMax(0.05, PriceActionM15BufferATRMult), point * 8.0);

   // Range structurel des barres M15 precedentes (hors bougies recentes).
   double rangeHigh = rates[3].high;
   double rangeLow = rates[3].low;
   for(int i = 4; i < MathMin(copied, lookback + 4); i++)
   {
      if(rates[i].high > rangeHigh) rangeHigh = rates[i].high;
      if(rates[i].low < rangeLow) rangeLow = rates[i].low;
   }

   // Pattern pure PA: breakout confirme sur [2], retest/rejet sur [1].
   bool buyBreak = (rates[2].close > (rangeHigh + buffer));
   bool buyRetestReject = (rates[1].low <= (rangeHigh + buffer) &&
                           rates[1].close > rangeHigh &&
                           rates[1].close > rates[1].open);

   bool sellBreak = (rates[2].close < (rangeLow - buffer));
   bool sellRetestReject = (rates[1].high >= (rangeLow - buffer) &&
                            rates[1].close < rangeLow &&
                            rates[1].close < rates[1].open);

   double rr = MathMax(1.5, PriceActionM15RiskReward);

   if(buyBreak && buyRetestReject)
   {
      double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
      double entry = (ask > 0.0 ? ask : rates[0].close);
      double sl = rates[1].low - buffer;
      double risk = MathMax(entry - sl, point * 20.0);
      dirOut = "BUY";
      slOut = NormalizeDouble(sl, _Digits);
      tpOut = NormalizeDouble(entry + rr * risk, _Digits);
      s_lastSignalBarTime = rates[1].time;
      return true;
   }

   if(sellBreak && sellRetestReject)
   {
      double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
      double entry = (bid > 0.0 ? bid : rates[0].close);
      double sl = rates[1].high + buffer;
      double risk = MathMax(sl - entry, point * 20.0);
      dirOut = "SELL";
      slOut = NormalizeDouble(sl, _Digits);
      tpOut = NormalizeDouble(entry - rr * risk, _Digits);
      s_lastSignalBarTime = rates[1].time;
      return true;
   }

   return false;
}

void DrawPriceActionM15Visuals(const string direction, const double entry, const double sl, const double tp, const string statusTag)
{
   if(!ShowPriceActionM15Visuals) return;

   string dir = direction;
   StringToUpper(dir);

   string base = "PA15_VIS_";
   string nArrow = base + "ARROW";
   string nEntry = base + "ENTRY";
   string nSL = base + "SL";
   string nTP = base + "TP";
   string nLabel = base + "LABEL";

   ObjectDelete(0, nArrow);
   ObjectDelete(0, nEntry);
   ObjectDelete(0, nSL);
   ObjectDelete(0, nTP);
   ObjectDelete(0, nLabel);

   datetime t = TimeCurrent();
   color dirColor = (dir == "BUY") ? clrLimeGreen : clrTomato;

   if(dir == "BUY")
      ObjectCreate(0, nArrow, OBJ_ARROW_UP, 0, t, entry);
   else
      ObjectCreate(0, nArrow, OBJ_ARROW_DOWN, 0, t, entry);
   ObjectSetInteger(0, nArrow, OBJPROP_COLOR, dirColor);
   ObjectSetInteger(0, nArrow, OBJPROP_WIDTH, 2);

   ObjectCreate(0, nEntry, OBJ_HLINE, 0, 0, entry);
   ObjectSetInteger(0, nEntry, OBJPROP_COLOR, clrDodgerBlue);
   ObjectSetInteger(0, nEntry, OBJPROP_STYLE, STYLE_DOT);
   ObjectSetInteger(0, nEntry, OBJPROP_WIDTH, 1);

   ObjectCreate(0, nSL, OBJ_HLINE, 0, 0, sl);
   ObjectSetInteger(0, nSL, OBJPROP_COLOR, clrRed);
   ObjectSetInteger(0, nSL, OBJPROP_STYLE, STYLE_DASH);
   ObjectSetInteger(0, nSL, OBJPROP_WIDTH, 1);

   ObjectCreate(0, nTP, OBJ_HLINE, 0, 0, tp);
   ObjectSetInteger(0, nTP, OBJPROP_COLOR, clrLimeGreen);
   ObjectSetInteger(0, nTP, OBJPROP_STYLE, STYLE_SOLID);
   ObjectSetInteger(0, nTP, OBJPROP_WIDTH, 1);

   ObjectCreate(0, nLabel, OBJ_TEXT, 0, t + PeriodSeconds(PERIOD_M15), entry);
   ObjectSetString(0, nLabel, OBJPROP_TEXT,
                   "PA M15 " + dir + " [" + statusTag + "] E:" + DoubleToString(entry, _Digits) +
                   " SL:" + DoubleToString(sl, _Digits) + " TP:" + DoubleToString(tp, _Digits));
   ObjectSetInteger(0, nLabel, OBJPROP_COLOR, dirColor);
   ObjectSetInteger(0, nLabel, OBJPROP_FONTSIZE, 9);
}

void ExecutePriceActionM15Strategy()
{
   if(!UsePriceActionM15Strategy) return;

   ENUM_SYMBOL_CATEGORY cat = SMC_GetSymbolCategory(_Symbol);
   if(cat == SYM_BOOM_CRASH || cat == SYM_VOLATILITY || cat == SYM_WELTRADE_SYNTH)
      return; // Reservee aux marches classiques.

   if(CheckSymbolLossProtection()) return;
   if(HasAnyExposureForSymbol(_Symbol)) return;

   string dir = "";
   double sl = 0.0, tp = 0.0;
   if(!DetectPriceActionM15Signal(dir, sl, tp))
      return;

   string d = dir;
   StringToUpper(d);
   double entryVis = (d == "BUY") ? SymbolInfoDouble(_Symbol, SYMBOL_ASK) : SymbolInfoDouble(_Symbol, SYMBOL_BID);
   if(entryVis <= 0.0) entryVis = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   DrawPriceActionM15Visuals(d, entryVis, sl, tp, "SIGNAL");

   // Gating IA + ML (coherent avec les autres strategies du robot).
   if(UseAIServer && !IsAITradeAllowedForDirection(d))
   {
      DrawPriceActionM15Visuals(d, entryVis, sl, tp, "BLOQUE_IA");
      return;
   }
   if(!IsMLModelTrustedForCurrentSymbol(d))
   {
      DrawPriceActionM15Visuals(d, entryVis, sl, tp, "BLOQUE_ML");
      return;
   }
   if(!PassFutureDirectionConfidenceGate(d, "PRICE_ACTION_M15", false))
   {
      DrawPriceActionM15Visuals(d, entryVis, sl, tp, "BLOQUE_FUTURE_CONF");
      return;
   }

   if(!TryAcquireOpenLock()) return;

   double lot = CalculateLotSize();
   lot = NormalizeVolumeForSymbol(lot);
   if(lot <= 0.0)
   {
      ReleaseOpenLock();
      return;
   }

   bool ok = false;
   string cmt = "PRICE_ACTION_M15";
   if(d == "BUY")
      ok = trade.Buy(lot, _Symbol, 0.0, sl, tp, cmt);
   else
      ok = trade.Sell(lot, _Symbol, 0.0, sl, tp, cmt);

   if(ok)
   {
      DrawPriceActionM15Visuals(d, entryVis, sl, tp, "EXECUTE");
      Print("â PRICE ACTION M15 EXECUTÃ ", d, " ", _Symbol,
            " | lot=", DoubleToString(lot, 2),
            " | SL=", DoubleToString(sl, _Digits),
            " | TP=", DoubleToString(tp, _Digits));
   }
   else
   {
      DrawPriceActionM15Visuals(d, entryVis, sl, tp, "ECHEC");
      Print("â PRICE ACTION M15 ÃCHEC ", d, " ", _Symbol,
            " | err=", IntegerToString(GetLastError()));
   }

   ReleaseOpenLock();
}

bool EnsureOrMoveRectangle(const string name, const datetime t1, const double p1, const datetime t2, const double p2)
{
   if(ObjectFind(0, name) < 0)
      return ObjectCreate(0, name, OBJ_RECTANGLE, 0, t1, p1, t2, p2);
   bool ok1 = ObjectMove(0, name, 0, t1, p1);
   bool ok2 = ObjectMove(0, name, 1, t2, p2);
   return (ok1 && ok2);
}

bool EnsureOrMoveTrend(const string name, const datetime t1, const double p1, const datetime t2, const double p2)
{
   if(ObjectFind(0, name) < 0)
      return ObjectCreate(0, name, OBJ_TREND, 0, t1, p1, t2, p2);
   bool ok1 = ObjectMove(0, name, 0, t1, p1);
   bool ok2 = ObjectMove(0, name, 1, t2, p2);
   return (ok1 && ok2);
}

bool EnsureOrMoveText(const string name, const datetime t, const double p, const string txt)
{
   if(ObjectFind(0, name) < 0 && !ObjectCreate(0, name, OBJ_TEXT, 0, t, p))
      return false;
   ObjectMove(0, name, 0, t, p);
   ObjectSetString(0, name, OBJPROP_TEXT, txt);
   return true;
}

bool EnsureOrSetHLine(const string name, const double price)
{
   if(ObjectFind(0, name) < 0)
   {
      if(!ObjectCreate(0, name, OBJ_HLINE, 0, 0, price))
         return false;
   }
   ObjectSetDouble(0, name, OBJPROP_PRICE, price);
   return true;
}

bool PredictM15PatternFromHistory(const MqlRates &rates[], const int copied, string &scenOut, double &projectedMoveOut, double &confidenceOut)
{
   scenOut = "NEUTRE";
   projectedMoveOut = 0.0;
   confidenceOut = 0.0;
   if(copied < 120) return false;

   int ctx = MathMax(8, PatternSimilarityContextBars);
   int hor = MathMax(3, PatternPredictionHorizonBars);
   if(copied <= (ctx + hor + 20)) return false;

   double currDelta = rates[1].close - rates[ctx].close;
   double currRange = 0.0;
   for(int i = 1; i <= ctx; i++)
      currRange += MathAbs(rates[i].high - rates[i].low);
   currRange /= (double)ctx;
   if(currRange <= 0.0) currRange = SymbolInfoDouble(_Symbol, SYMBOL_POINT) * 10.0;
   double currNorm = currDelta / currRange;

  const int maxTop = 30;
  double topScore[30];
  double topMove[30];
   int topCount = 0;
   ArrayInitialize(topScore, 1e9);
   ArrayInitialize(topMove, 0.0);

   int maxAnchor = MathMin(copied - 2, MathMax(100, HistoricalPatternLookbackBars));
   for(int a = hor + ctx + 2; a < maxAnchor; a++)
   {
      double d = rates[a - hor].close - rates[a - hor - ctx].close;
      double r = 0.0;
      for(int k = 0; k < ctx; k++)
         r += MathAbs(rates[a - hor - k].high - rates[a - hor - k].low);
      r /= (double)ctx;
      if(r <= 0.0) continue;

      double n = d / r;
      double dist = MathAbs(n - currNorm);
      dist += ((double)a / (double)maxAnchor) * 0.15; // legere penalite de recence

      double futMove = rates[a - hor].close - rates[a].close;

      int worst = 0;
      for(int j = 1; j < maxTop; j++)
         if(topScore[j] > topScore[worst]) worst = j;

      if(topCount < maxTop)
      {
         topScore[topCount] = dist;
         topMove[topCount] = futMove;
         topCount++;
      }
      else if(dist < topScore[worst])
      {
         topScore[worst] = dist;
         topMove[worst] = futMove;
      }
   }

   if(topCount < 8) return false;

   double wSum = 0.0, mSum = 0.0;
   int pos = 0, neg = 0;
   for(int i = 0; i < topCount; i++)
   {
      double w = 1.0 / MathMax(0.0001, topScore[i]);
      wSum += w;
      mSum += topMove[i] * w;
      if(topMove[i] >= 0.0) pos++; else neg++;
   }
   if(wSum <= 0.0) return false;

   projectedMoveOut = mSum / wSum;
   double agree = (double)MathMax(pos, neg) / (double)topCount;
   confidenceOut = MathMin(0.98, MathMax(0.30, agree));

   if(projectedMoveOut > 0.0) scenOut = "BULL";
   else if(projectedMoveOut < 0.0) scenOut = "BEAR";
   else scenOut = "RANGE";
   return true;
}

// Zone de setup au prix actuel + projection future M15 derivee de la structure / momentum reel des bougies.
void UpdatePriceActionM15ScenarioProjectionDraw()
{
   if(!ShowPriceActionScenarioProjection) return;

   ENUM_SYMBOL_CATEGORY cat = SMC_GetSymbolCategory(_Symbol);
   if(cat == SYM_BOOM_CRASH || cat == SYM_VOLATILITY || cat == SYM_WELTRADE_SYNTH)
      return;

   MqlRates rates[];
   ArraySetAsSeries(rates, true);
   int k = MathMax(8, PriceActionScenarioStructureBars);
   int projN = MathMax(4, PriceActionScenarioProjectionBars);
   int histN = MathMax(200, HistoricalPatternLookbackBars);
   int need = MathMax(k + projN + 5, histN + 30);
   if(CopyRates(_Symbol, PERIOD_M15, 0, need, rates) < k + 3)
      return;

   static datetime s_lastM15Bar = 0;
   static datetime s_lastRedraw = 0;
   datetime now = TimeCurrent();
   if(rates[1].time == s_lastM15Bar && (now - s_lastRedraw) < 8)
      return;
   s_lastM15Bar = rates[1].time;
   s_lastRedraw = now;

   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   double mid = (bid + ask) * 0.5;
   if(mid <= 0.0) mid = rates[0].close;
   // Ancrage scenario: derniere bougie M15 cloturee (prix reel), pas seulement le tick.
   const double anchorClose = rates[1].close;
   const datetime tAnchor = rates[1].time;

   double atr = GetATRValue(PERIOD_M15, 14);
   double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   if(point <= 0.0) point = _Point;
   if(atr <= 0.0) atr = MathMax(MathAbs(rates[1].high - rates[1].low), point * 20.0);

   double rangeH = rates[2].high;
   double rangeL = rates[2].low;
   for(int i = 3; i <= k && i < ArraySize(rates); i++)
   {
      if(rates[i].high > rangeH) rangeH = rates[i].high;
      if(rates[i].low < rangeL) rangeL = rates[i].low;
   }
   double rangeSize = rangeH - rangeL;

   double deltaClose = rates[1].close - rates[k].close;
   double biasTh = atr * MathMax(0.05, PriceActionScenarioBiasATRMult);
   double rangeTh = atr * MathMax(0.2, PriceActionScenarioRangeATRMult);
   double capMove = atr * MathMax(0.5, PriceActionScenarioMaxMoveATRMult);

   string scen = "NEUTRE";
   color scenColor = clrSilver;
   double projPrice = anchorClose;

   if(rangeSize <= rangeTh)
   {
      scen = "RANGE";
      scenColor = clrGold;
      projPrice = (rangeH + rangeL) * 0.5;
   }
   else if(deltaClose > biasTh)
   {
      scen = "BULL";
      scenColor = clrLimeGreen;
      double slope = deltaClose / (double)(k - 1);
      projPrice = anchorClose + slope * (double)projN;
   }
   else if(deltaClose < -biasTh)
   {
      scen = "BEAR";
      scenColor = clrTomato;
      double slope = deltaClose / (double)(k - 1);
      projPrice = anchorClose + slope * (double)projN;
   }
   else
   {
      scen = "NEUTRE";
      scenColor = clrDarkGray;
      double slope = deltaClose / (double)MathMax(1, k - 1);
      projPrice = anchorClose + slope * (double)projN;
   }

   // Renforcer la projection avec les patterns similaires observes dans l'historique M15.
   string histScen = "NEUTRE";
   double histMove = 0.0;
   double histConf = 0.0;
   if(PredictM15PatternFromHistory(rates, ArraySize(rates), histScen, histMove, histConf))
   {
      double blendedMove = ((projPrice - anchorClose) * (1.0 - histConf)) + (histMove * histConf);
      projPrice = anchorClose + blendedMove;
      if(histScen == "BULL") scen = "BULL";
      else if(histScen == "BEAR") scen = "BEAR";
      else if(scen == "NEUTRE") scen = "RANGE";
   }

   if(projPrice > anchorClose + capMove) projPrice = anchorClose + capMove;
   if(projPrice < anchorClose - capMove) projPrice = anchorClose - capMove;

   datetime t0 = now;
   datetime tSetupEnd = t0 + (datetime)(PeriodSeconds(PERIOD_M15) * MathMin(12, projN / 2 + 2));
   // Affichage: la cible tAnchor + projN*M15 peut tomber hors ecran; on dessine depuis TimeCurrent().
   int dispN = MathMin(projN, MathMax(4, PriceActionScenarioDisplayMaxBars));
   datetime tVisEnd = now + (datetime)(PeriodSeconds(PERIOD_M15) * dispN);
   double projVis = projPrice;
   if(scen != "RANGE" && projN > 0 && dispN < projN)
      projVis = anchorClose + (projPrice - anchorClose) * ((double)dispN / (double)projN);
   if(projVis > anchorClose + capMove) projVis = anchorClose + capMove;
   if(projVis < anchorClose - capMove) projVis = anchorClose - capMove;

   const string pfx = "PA15_SCEN_";
   if(!KeepScenarioObjectsPersistent)
   {
      ObjectDelete(0, pfx + "SETUP");
      ObjectDelete(0, pfx + "FUTURE");
      ObjectDelete(0, pfx + "PROJ");
      ObjectDelete(0, pfx + "RANGE_HI");
      ObjectDelete(0, pfx + "RANGE_LO");
      ObjectDelete(0, pfx + "LABEL");
   }

   double setupHalf = MathMax(point * 12.0, atr * 0.10);
   double pTop = mid + setupHalf;
   double pBot = mid - setupHalf;
   if(EnsureOrMoveRectangle(pfx + "SETUP", t0, pTop, tSetupEnd, pBot))
   {
      color fillBg = C'40,40,45';
      if(scen == "RANGE") fillBg = C'55,50,0';
      else if(scen == "BULL") fillBg = C'0,45,0';
      else if(scen == "BEAR") fillBg = C'50,0,0';
      ObjectSetInteger(0, pfx + "SETUP", OBJPROP_COLOR, scenColor);
      ObjectSetInteger(0, pfx + "SETUP", OBJPROP_STYLE, STYLE_SOLID);
      ObjectSetInteger(0, pfx + "SETUP", OBJPROP_WIDTH, 1);
      // Premier plan: sinon le rectangle est souvent invisible derriere les bougies.
      ObjectSetInteger(0, pfx + "SETUP", OBJPROP_BACK, false);
      ObjectSetInteger(0, pfx + "SETUP", OBJPROP_FILL, true);
      ObjectSetInteger(0, pfx + "SETUP", OBJPROP_BGCOLOR, fillBg);
      ObjectSetInteger(0, pfx + "SETUP", OBJPROP_SELECTABLE, false);
      ObjectSetInteger(0, pfx + "SETUP", OBJPROP_ZORDER, 1);
   }

   // Zone setup visible dans le FUTUR (a droite du graphique), autour du prix projete.
   const long secM15 = PeriodSeconds(PERIOD_M15);
   int zoneBars = MathMax(4, PriceActionScenarioFutureZoneBars);
   datetime tFutStart = tVisEnd - (datetime)(secM15 * zoneBars);
   // Garder la zone FUTUR strictement a droite de "maintenant" (marge vide), pas sous les bougies passees.
   datetime tMinFuture = now + (datetime)secM15;
   if(tFutStart < tMinFuture)
      tFutStart = tMinFuture;
   if(tFutStart >= tVisEnd)
      tFutStart = tVisEnd - (datetime)(secM15 * 2);
   double futHalf = MathMax(setupHalf * 2.0, atr * 0.22);
   double futTop = projVis + futHalf;
   double futBot = projVis - futHalf;
   if(futTop < futBot)
   {
      double tmp = futTop;
      futTop = futBot;
      futBot = tmp;
   }
   if(EnsureOrMoveRectangle(pfx + "FUTURE", tFutStart, futTop, tVisEnd, futBot))
   {
      ObjectSetInteger(0, pfx + "FUTURE", OBJPROP_COLOR, clrWhite);
      ObjectSetInteger(0, pfx + "FUTURE", OBJPROP_STYLE, STYLE_SOLID);
      ObjectSetInteger(0, pfx + "FUTURE", OBJPROP_WIDTH, 2);
      ObjectSetInteger(0, pfx + "FUTURE", OBJPROP_BACK, false);
      ObjectSetInteger(0, pfx + "FUTURE", OBJPROP_FILL, true);
      if(scen == "RANGE")
         ObjectSetInteger(0, pfx + "FUTURE", OBJPROP_BGCOLOR, C'90,80,0');
      else if(scen == "BULL")
         ObjectSetInteger(0, pfx + "FUTURE", OBJPROP_BGCOLOR, C'0,90,30');
      else if(scen == "BEAR")
         ObjectSetInteger(0, pfx + "FUTURE", OBJPROP_BGCOLOR, C'90,20,0');
      else
         ObjectSetInteger(0, pfx + "FUTURE", OBJPROP_BGCOLOR, C'55,55,70');
      ObjectSetInteger(0, pfx + "FUTURE", OBJPROP_SELECTABLE, false);
      ObjectSetInteger(0, pfx + "FUTURE", OBJPROP_ZORDER, 2);
   }

   if(scen == "RANGE")
   {
      if(EnsureOrMoveTrend(pfx + "RANGE_HI", t0, rangeH, tVisEnd, rangeH))
      {
         ObjectSetInteger(0, pfx + "RANGE_HI", OBJPROP_COLOR, clrTomato);
         ObjectSetInteger(0, pfx + "RANGE_HI", OBJPROP_STYLE, STYLE_DASH);
         ObjectSetInteger(0, pfx + "RANGE_HI", OBJPROP_RAY_RIGHT, false);
         ObjectSetInteger(0, pfx + "RANGE_HI", OBJPROP_SELECTABLE, false);
      }
      if(EnsureOrMoveTrend(pfx + "RANGE_LO", t0, rangeL, tVisEnd, rangeL))
      {
         ObjectSetInteger(0, pfx + "RANGE_LO", OBJPROP_COLOR, clrDodgerBlue);
         ObjectSetInteger(0, pfx + "RANGE_LO", OBJPROP_STYLE, STYLE_DASH);
         ObjectSetInteger(0, pfx + "RANGE_LO", OBJPROP_RAY_RIGHT, false);
         ObjectSetInteger(0, pfx + "RANGE_LO", OBJPROP_SELECTABLE, false);
      }
   }

   // Projection: cloture M15 reelle (anchor) -> cible visible (tVisEnd, projVis).
   if(EnsureOrMoveTrend(pfx + "PROJ", tAnchor, anchorClose, tVisEnd, projVis))
   {
      ObjectSetInteger(0, pfx + "PROJ", OBJPROP_COLOR, scenColor);
      ObjectSetInteger(0, pfx + "PROJ", OBJPROP_STYLE, STYLE_SOLID);
      ObjectSetInteger(0, pfx + "PROJ", OBJPROP_WIDTH, 2);
      ObjectSetInteger(0, pfx + "PROJ", OBJPROP_RAY_RIGHT, false);
      ObjectSetInteger(0, pfx + "PROJ", OBJPROP_SELECTABLE, false);
      ObjectSetInteger(0, pfx + "PROJ", OBJPROP_BACK, false);
      ObjectSetInteger(0, pfx + "PROJ", OBJPROP_ZORDER, 1);
   }

   string lastBar = (rates[1].close >= rates[1].open) ? "bull" : "bear";
   string txt = "PA M15 scen=" + scen + " | last M15 " + lastBar +
                " | mid=" + DoubleToString(mid, _Digits) +
                " | close[M15-1]=" + DoubleToString(anchorClose, _Digits) +
                " | affiche +" + IntegerToString(dispN) + "M15 -> " + DoubleToString(projVis, _Digits) +
                " (theor. " + IntegerToString(projN) + " -> " + DoubleToString(projPrice, _Digits) + ")";
   if(EnsureOrMoveText(pfx + "LABEL", tVisEnd, projVis, txt))
   {
      ObjectSetInteger(0, pfx + "LABEL", OBJPROP_COLOR, clrWhite);
      ObjectSetInteger(0, pfx + "LABEL", OBJPROP_FONTSIZE, 9);
      ObjectSetInteger(0, pfx + "LABEL", OBJPROP_SELECTABLE, false);
      ObjectSetInteger(0, pfx + "LABEL", OBJPROP_BACK, false);
      ObjectSetInteger(0, pfx + "LABEL", OBJPROP_ZORDER, 3);
   }

   ChartRedraw(0);
}

string FormatWLNet(int wins, int losses, double net)
{
   return IntegerToString(wins) + "W/" + IntegerToString(losses) + "L | Net=" + DoubleToString(net, 2) + "$";
}

// Stats strictement issues de l'historique MT5 (deals) filtrÃĐs par Magic + symbole + pÃĐriode.
// Compte les sorties (DEAL_ENTRY_OUT) et agrÃĻge profit+swap+commission.
bool GetSymbolStatsFromHistory(const string symbol, datetime fromTime, datetime toTime, int &winsOut, int &lossesOut, double &netOut)
{
   winsOut = 0;
   lossesOut = 0;
   netOut = 0.0;
   if(StringLen(symbol) <= 0) return false;
   if(fromTime <= 0 || toTime <= 0 || toTime <= fromTime) return false;

   if(!HistorySelect(fromTime, toTime))
      return false;

   int total = HistoryDealsTotal();
   if(total <= 0) return true; // pas d'historique -> stats Ã  0

   for(int i = 0; i < total; i++)
   {
      ulong ticket = HistoryDealGetTicket(i);
      if(ticket == 0) continue;

      long magic = (long)HistoryDealGetInteger(ticket, DEAL_MAGIC);
      if(magic != InpMagicNumber) continue;

      string sym = HistoryDealGetString(ticket, DEAL_SYMBOL);
      if(sym != symbol) continue;

      long entry = (long)HistoryDealGetInteger(ticket, DEAL_ENTRY);
      if(entry != DEAL_ENTRY_OUT) continue;

      double profit = HistoryDealGetDouble(ticket, DEAL_PROFIT) +
                      HistoryDealGetDouble(ticket, DEAL_SWAP) +
                      HistoryDealGetDouble(ticket, DEAL_COMMISSION);

      netOut += profit;
      if(profit > 0) winsOut++;
      else if(profit < 0) lossesOut++;
   }

   return true;
}

// Stats ÃĐtendues strictement issues de l'historique MT5 (deals) filtrÃĐs par Magic + symbole + pÃĐriode.
// tradeCount: nombre de deals de sortie (DEAL_ENTRY_OUT) dans la fenÃŠtre
// grossProfit: somme des profits positifs
// grossLossAbs: somme des pertes en valeur absolue (positive)
// lastTradeAtOut: timestamp du dernier deal de sortie (0 si aucun)
bool GetSymbolStatsExtendedFromHistory(const string symbol,
                                      datetime fromTime,
                                      datetime toTime,
                                      int &tradeCountOut,
                                      int &winsOut,
                                      int &lossesOut,
                                      double &netOut,
                                      double &grossProfitOut,
                                      double &grossLossAbsOut,
                                      datetime &lastTradeAtOut)
{
   tradeCountOut = 0;
   winsOut = 0;
   lossesOut = 0;
   netOut = 0.0;
   grossProfitOut = 0.0;
   grossLossAbsOut = 0.0;
   lastTradeAtOut = 0;

   if(StringLen(symbol) <= 0) return false;
   if(fromTime <= 0 || toTime <= 0 || toTime <= fromTime) return false;

   if(!HistorySelect(fromTime, toTime))
      return false;

   int total = HistoryDealsTotal();
   if(total <= 0) return true;

   for(int i = 0; i < total; i++)
   {
      ulong ticket = HistoryDealGetTicket(i);
      if(ticket == 0) continue;

      long magic = (long)HistoryDealGetInteger(ticket, DEAL_MAGIC);
      if(magic != InpMagicNumber) continue;

      string sym = HistoryDealGetString(ticket, DEAL_SYMBOL);
      if(sym != symbol) continue;

      long entry = (long)HistoryDealGetInteger(ticket, DEAL_ENTRY);
      if(entry != DEAL_ENTRY_OUT) continue;

      datetime t = (datetime)HistoryDealGetInteger(ticket, DEAL_TIME);
      if(t > lastTradeAtOut) lastTradeAtOut = t;

      double profit = HistoryDealGetDouble(ticket, DEAL_PROFIT) +
                      HistoryDealGetDouble(ticket, DEAL_SWAP) +
                      HistoryDealGetDouble(ticket, DEAL_COMMISSION);

      tradeCountOut++;
      netOut += profit;
      if(profit > 0)
      {
         winsOut++;
         grossProfitOut += profit;
      }
      else if(profit < 0)
      {
         lossesOut++;
         grossLossAbsOut += -profit;
      }
   }

   return true;
}

// Stats locales: met Ã  jour g_dayWins/g_dayLosses/g_dayNetProfit et g_monthWins/g_monthLosses/g_monthNetProfit
// directement depuis l'historique MT5 (source de vÃĐritÃĐ pour le panneau).
void EnsureLocalSymbolStatsUpToDate()
{
   // Throttle: ÃĐviter de marteler HistorySelect Ã  chaque tick
   static datetime lastLocalUpdate = 0;
   datetime now = TimeCurrent();
   if(now - lastLocalUpdate < 15) // maj max toutes les 15s (dashboard se met Ã  jour Ã  15s)
      return;
   lastLocalUpdate = now;

   datetime nowUtc = TimeGMT();
   MqlDateTime dt;
   TimeToStruct(nowUtc, dt);

   // DÃĐbut de journÃĐe UTC
   MqlDateTime d0 = dt;
   d0.hour = 0; d0.min = 0; d0.sec = 0;
   datetime dayStartUtc = StructToTime(d0);

   // DÃĐbut de mois UTC
   MqlDateTime m0 = dt;
   m0.day = 1;
   m0.hour = 0; m0.min = 0; m0.sec = 0;
   datetime monthStartUtc = StructToTime(m0);

   int tcDay=0, wDay=0, lDay=0;
   double netDay=0, gpDay=0, glDay=0;
   datetime lastDay=0;

   int tcMonth=0, wMonth=0, lMonth=0;
   double netMonth=0, gpMonth=0, glMonth=0;
   datetime lastMonth=0;

   if(GetSymbolStatsExtendedFromHistory(_Symbol, dayStartUtc, nowUtc, tcDay, wDay, lDay, netDay, gpDay, glDay, lastDay))
   {
      g_dayWins = wDay;
      g_dayLosses = lDay;
      g_dayNetProfit = netDay;
   }

   if(GetSymbolStatsExtendedFromHistory(_Symbol, monthStartUtc, nowUtc, tcMonth, wMonth, lMonth, netMonth, gpMonth, glMonth, lastMonth))
   {
      g_monthWins = wMonth;
      g_monthLosses = lMonth;
      g_monthNetProfit = netMonth;
   }
   g_symbolStatsLastLocalUpdate = nowUtc;
}

// Test de connectivitÃĐ Supabase
void TestSupabaseConnectivity()
{
   if(!UseAIServer) 
   {
      Print("â Test Supabase: IA dÃĐsactivÃĐe");
      return;
   }
   
   Print("ð TEST CONNECTIVITÃ SUPABASE...");
   
   string url1 = UseRenderAsPrimary ? (AI_ServerRender + "/health") : (AI_ServerURL + "/health");
   string url2 = UseRenderAsPrimary ? (AI_ServerURL + "/health") : (AI_ServerRender + "/health");
   
   string headers = "Content-Type: application/json\r\n";
   char post_data[], result_data[];
   string result_headers;
   
   int http_result = WebRequest("GET", url1, headers, 3000, post_data, result_data, result_headers);
   if(http_result != 200)
   {
      Print("â ïļ ÃCHEC SERVEUR 1 - HTTP ", http_result, " | URL: ", url1);
      http_result = WebRequest("GET", url2, headers, 3000, post_data, result_data, result_headers);
   }
   
   if(http_result == 200)
   {
      Print("â CONNECTIVITÃ SUPABASE OK - HTTP 200");
      string response = CharArrayToString(result_data);
      Print("   RÃĐponse: ", StringSubstr(response, 0, MathMin(100, StringLen(response))));
   }
   else
   {
      Print("â CONNECTIVITÃ SUPABASE ÃCHEC - HTTP ", http_result);
      if(http_result == -1)
         Print("   Erreur: Timeout ou connexion refusÃĐe");
      else if(http_result == 404)
         Print("   Erreur: Endpoint health non trouvÃĐ");
      else
         Print("   Erreur HTTP: ", http_result);
   }
}

// Envoie les stats jour/mois (UTC) au serveur pour UPSERT dans Supabase `symbol_trade_stats`
void SyncSymbolTradeStatsToServer()
{
   if(!UseAIServer) return;

   static datetime lastSync = 0;
   datetime now = TimeCurrent();
   if(now - lastSync < 300) return; // 5 minutes
   lastSync = now;

   if(AI_ServerURL == "" && AI_ServerRender == "") 
   {
      Print("â SYNC SUPABASE ÃCHEC - Aucune URL serveur configurÃĐe");
      g_symbolStatsSyncOk = false;
      return;
   }
   
   g_symbolStatsLastSyncAttempt = TimeGMT();
   Print("ð TENTATIVE SYNC SUPABASE - ", _Symbol, " | Serveur: ", UseRenderAsPrimary ? AI_ServerRender : AI_ServerURL);

   datetime nowUtc = TimeGMT();
   MqlDateTime dt;
   TimeToStruct(nowUtc, dt);

   MqlDateTime d0 = dt;
   d0.hour = 0; d0.min = 0; d0.sec = 0;
   datetime dayStartUtc = StructToTime(d0);

   MqlDateTime m0 = dt;
   m0.day = 1;
   m0.hour = 0; m0.min = 0; m0.sec = 0;
   datetime monthStartUtc = StructToTime(m0);

   int tcDay=0, wDay=0, lDay=0;
   double netDay=0, gpDay=0, glDay=0;
   datetime lastDay=0;

   int tcMonth=0, wMonth=0, lMonth=0;
   double netMonth=0, gpMonth=0, glMonth=0;
   datetime lastMonth=0;

   if(!GetSymbolStatsExtendedFromHistory(_Symbol, dayStartUtc, nowUtc, tcDay, wDay, lDay, netDay, gpDay, glDay, lastDay))
      return;
   if(!GetSymbolStatsExtendedFromHistory(_Symbol, monthStartUtc, nowUtc, tcMonth, wMonth, lMonth, netMonth, gpMonth, glMonth, lastMonth))
      return;

   string dayDate = TimeToString(dayStartUtc, TIME_DATE);
   string monthDate = TimeToString(monthStartUtc, TIME_DATE);
   long lastDayMs = (lastDay > 0 ? (long)lastDay * 1000 : 0);
   long lastMonthMs = (lastMonth > 0 ? (long)lastMonth * 1000 : 0);

   string json_payload = StringFormat(
      "{"
      "\"rows\":["
      "{"
      "\"symbol\":\"%s\","
      "\"period_type\":\"day\","
      "\"period_start\":\"%s\","
      "\"timeframe\":\"M1\","
      "\"trade_count\":%d,"
      "\"wins\":%d,"
      "\"losses\":%d,"
      "\"net_profit\":%.2f,"
      "\"gross_profit\":%.2f,"
      "\"gross_loss\":%.2f,"
      "\"last_trade_at\":%lld"
      "},"
      "{"
      "\"symbol\":\"%s\","
      "\"period_type\":\"month\","
      "\"period_start\":\"%s\","
      "\"timeframe\":\"M1\","
      "\"trade_count\":%d,"
      "\"wins\":%d,"
      "\"losses\":%d,"
      "\"net_profit\":%.2f,"
      "\"gross_profit\":%.2f,"
      "\"gross_loss\":%.2f,"
      "\"last_trade_at\":%lld"
      "}"
      "]"
      "}",
      _Symbol, dayDate, tcDay, wDay, lDay, netDay, gpDay, glDay, lastDayMs,
      _Symbol, monthDate, tcMonth, wMonth, lMonth, netMonth, gpMonth, glMonth, lastMonthMs
   );

   string url1 = UseRenderAsPrimary ? (AI_ServerRender + "/mt5/symbol-trade-stats-upload") : (AI_ServerURL + "/mt5/symbol-trade-stats-upload");
   string url2 = UseRenderAsPrimary ? (AI_ServerURL + "/mt5/symbol-trade-stats-upload") : (AI_ServerRender + "/mt5/symbol-trade-stats-upload");

   string headers = "Content-Type: application/json\r\n";
   char post_data[];
   char result_data[];
   string result_headers;
   StringToCharArray(json_payload, post_data, 0, StringLen(json_payload));

   int http_result = WebRequest("POST", url1, headers, AI_Timeout_ms, post_data, result_data, result_headers);
   if(http_result != 200)
   {
      Print("â ïļ ÃCHEC SERVEUR 1 - HTTP ", http_result, " | URL: ", url1);
      http_result = WebRequest("POST", url2, headers, AI_Timeout_ms2, post_data, result_data, result_headers);
   }

   if(http_result == 200)
   {
      g_dayWins = wDay; g_dayLosses = lDay; g_dayNetProfit = netDay;
      g_monthWins = wMonth; g_monthLosses = lMonth; g_monthNetProfit = netMonth;
      g_symbolStatsSyncOk = true;
      g_symbolStatsLastSyncOk = TimeGMT();
      g_symbolStatsLastChecksum = IntegerToString(tcDay) + "|" + IntegerToString(wDay) + "|" + IntegerToString(lDay) + "|" + DoubleToString(netDay, 2) +
                                  "|" + IntegerToString(tcMonth) + "|" + IntegerToString(wMonth) + "|" + IntegerToString(lMonth) + "|" + DoubleToString(netMonth, 2);
      Print("â SYNC SUPABASE RÃUSSIE - ", _Symbol, " | day ", IntegerToString(wDay), "W/", IntegerToString(lDay), "L net=", DoubleToString(netDay, 2),
            " | month ", IntegerToString(wMonth), "W/", IntegerToString(lMonth), "L net=", DoubleToString(netMonth, 2));
   }
   else
   {
      g_symbolStatsSyncOk = false;
      Print("â SYNC SUPABASE ÃCHEC - HTTP ", http_result, " | ", _Symbol);
      Print("   URL tentÃĐe: ", (http_result != 200 ? url2 : url1));
      Print("   Timeout: ", (http_result != 200 ? AI_Timeout_ms2 : AI_Timeout_ms), "ms");
      
      // Diagnostique supplÃĐmentaire
      if(http_result == -1)
         Print("   Erreur: Timeout ou connexion refusÃĐe");
      else if(http_result == 404)
         Print("   Erreur: Endpoint non trouvÃĐ (404)");
      else if(http_result == 500)
         Print("   Erreur: Erreur serveur interne (500)");
      else
         Print("   Erreur HTTP: ", http_result);
   }
}

//| VALIDATION ET AJUSTEMENT DES PRIX POUR ORDRES LIMITES            |
bool ValidateAndAdjustLimitPrice(double &entryPrice, double &stopLoss, double &takeProfit, ENUM_ORDER_TYPE orderType)
{
   // Avant d'exÃĐcuter un ordre LIMIT: exiger les conditions de tendance (EMA+OB+OTE selon config).
   if(LimitOrdersRequireTrendConfirmation && UseTrendAlignedEntryFilter)
   {
      string d = (orderType == ORDER_TYPE_BUY_LIMIT ? "BUY" : (orderType == ORDER_TYPE_SELL_LIMIT ? "SELL" : ""));
      if(d != "" && !IsTrendAlignedEntry(d))
      {
         Print("ðŦ LIMIT BLOQUÃ - Filtre tendance non validÃĐ | ", _Symbol, " | ", d);
         return false;
      }
   }

   // Garde-fou central Boom/Crash: aucune inversion directionnelle autorisÃĐe
   if(!IsOrderTypeAllowedForBoomCrash(_Symbol, orderType))
   {
      Print("ðŦ LIMIT BLOQUÃ - Type d'ordre interdit pour ", _Symbol,
            " | orderType=", (int)orderType,
            " | Rule: Boom=BUY only / Crash=SELL only");
      return false;
   }

   double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   double currentAsk = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   double currentBid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   
   // RÃĐcupÃĐrer les exigences du courtier
   long stopsLevel = SymbolInfoInteger(_Symbol, SYMBOL_TRADE_STOPS_LEVEL);
   double minDistance = stopsLevel * point;
   
   // DÃĐtection spÃĐcifique pour chaque type de symbole
   bool isVolatility = (StringFind(_Symbol, "Volatility") >= 0 || StringFind(_Symbol, "RANGE BREAK") >= 0);
   bool isGold = (StringFind(_Symbol, "XAU") >= 0 || StringFind(_Symbol, "GOLD") >= 0);
   bool isForex = (StringFind(_Symbol, "USD") >= 0 && !isGold && !isVolatility);
   
   if(isVolatility)
   {
      minDistance = MathMax(minDistance, 500 * point); // AugmentÃĐ Ã  500 pips pour Volatility
      Print("?? Volatility Index dÃĐtectÃĐ - Distance minimale: ", DoubleToString(minDistance, 0), " pips");
   }
   else if(isGold)
   {
      minDistance = MathMax(minDistance, 200 * point); // 200 pips minimum pour XAUUSD
      Print("?? Gold (XAUUSD) dÃĐtectÃĐ - Distance minimale: ", DoubleToString(minDistance, 0), " pips");
   }
   else if(isForex)
   {
      minDistance = MathMax(minDistance, 100 * point); // AugmentÃĐ Ã  100 pips pour Forex (AUDJPY, etc.)
      Print("?? Forex dÃĐtectÃĐ - Distance minimale: ", DoubleToString(minDistance, 0), " pips");
   }
   else
   {
      minDistance = MathMax(minDistance, 30 * point); // 30 pips minimum par dÃĐfaut
   }
   
   // Validation et ajustement du prix d'entrÃĐe
   bool priceAdjusted = false;
   
   if(orderType == ORDER_TYPE_BUY_LIMIT)
   {
      // BUY LIMIT doit ÃŠtre < Ask
      if(entryPrice >= currentAsk)
      {
         entryPrice = currentBid - (minDistance * 2); // Plus de marge
         priceAdjusted = true;
         Print("?? BUY LIMIT price ajustÃĐ: ", DoubleToString(entryPrice, _Digits), " (doit ÃŠtre < Ask)");
      }
      
      // VÃĐrifier distance minimale
      if(currentAsk - entryPrice < minDistance)
      {
         entryPrice = currentAsk - (minDistance * 1.5); // Plus de marge
         priceAdjusted = true;
         Print("?? BUY LIMIT distance ajustÃĐe: ", DoubleToString(entryPrice, _Digits), " (distance minimale)");
      }
   }
   else if(orderType == ORDER_TYPE_SELL_LIMIT)
   {
      // SELL LIMIT doit ÃŠtre > Bid
      if(entryPrice <= currentBid)
      {
         entryPrice = currentAsk + (minDistance * 2); // Plus de marge
         priceAdjusted = true;
         Print("?? SELL LIMIT price ajustÃĐ: ", DoubleToString(entryPrice, _Digits), " (doit ÃŠtre > Bid)");
      }
      
      // VÃĐrifier distance minimale
      if(entryPrice - currentBid < minDistance)
      {
         entryPrice = currentBid + (minDistance * 1.5); // Plus de marge
         priceAdjusted = true;
         Print("?? SELL LIMIT distance ajustÃĐe: ", DoubleToString(entryPrice, _Digits), " (distance minimale)");
      }
   }
   
   // Validation et ajustement du Stop Loss
   if(orderType == ORDER_TYPE_BUY_LIMIT)
   {
      if(stopLoss >= entryPrice || (entryPrice - stopLoss) < minDistance)
      {
         stopLoss = entryPrice - (minDistance * 1.2); // Plus de marge
         Print("?? BUY LIMIT SL ajustÃĐ: ", DoubleToString(stopLoss, _Digits));
      }
   }
   else if(orderType == ORDER_TYPE_SELL_LIMIT)
   {
      if(stopLoss <= entryPrice || (stopLoss - entryPrice) < minDistance)
      {
         stopLoss = entryPrice + (minDistance * 1.2); // Plus de marge
         Print("?? SELL LIMIT SL ajustÃĐ: ", DoubleToString(stopLoss, _Digits));
      }
   }

   // SL trop serrÃĐ sur LIMIT: ÃĐlargir d'environ +N bougies M1.
   ApplyExtraStopLossForLimitOrders(entryPrice, stopLoss, orderType);
   
   // Validation et ajustement du Take Profit
   if(orderType == ORDER_TYPE_BUY_LIMIT)
   {
      if(takeProfit <= entryPrice || (takeProfit - entryPrice) < minDistance)
      {
         takeProfit = entryPrice + (minDistance * 3); // Ratio 1:3 pour plus de sÃĐcuritÃĐ
         Print("?? BUY LIMIT TP ajustÃĐ: ", DoubleToString(takeProfit, _Digits));
      }
   }
   else if(orderType == ORDER_TYPE_SELL_LIMIT)
   {
      if(takeProfit >= entryPrice || (entryPrice - takeProfit) < minDistance)
      {
         takeProfit = entryPrice - (minDistance * 3); // Ratio 1:3 pour plus de sÃĐcuritÃĐ
         Print("?? SELL LIMIT TP ajustÃĐ: ", DoubleToString(takeProfit, _Digits));
      }
   }
   
   // Normaliser tous les prix
   entryPrice = NormalizeDouble(entryPrice, _Digits);
   stopLoss = NormalizeDouble(stopLoss, _Digits);
   takeProfit = NormalizeDouble(takeProfit, _Digits);
   
   // Validation finale trÃĻs stricte
   if(orderType == ORDER_TYPE_BUY_LIMIT)
   {
      if(entryPrice >= currentAsk || (currentAsk - entryPrice) < minDistance || 
         stopLoss >= entryPrice || (entryPrice - stopLoss) < minDistance ||
         takeProfit <= entryPrice || (takeProfit - entryPrice) < minDistance)
      {
         Print("? ERREUR CRITIQUE: Prix BUY LIMIT toujours invalides aprÃĻs ajustement!");
         Print("   Entry: ", DoubleToString(entryPrice, _Digits), " Ask: ", DoubleToString(currentAsk, _Digits));
         Print("   SL: ", DoubleToString(stopLoss, _Digits), " TP: ", DoubleToString(takeProfit, _Digits));
         Print("   MinDistance: ", DoubleToString(minDistance, 0), " pips");
         return false;
      }
   }
   else if(orderType == ORDER_TYPE_SELL_LIMIT)
   {
      if(entryPrice <= currentBid || (entryPrice - currentBid) < minDistance ||
         stopLoss <= entryPrice || (stopLoss - entryPrice) < minDistance ||
         takeProfit >= entryPrice || (entryPrice - takeProfit) < minDistance)
      {
         Print("? ERREUR CRITIQUE: Prix SELL LIMIT toujours invalides aprÃĻs ajustement!");
         Print("   Entry: ", DoubleToString(entryPrice, _Digits), " Bid: ", DoubleToString(currentBid, _Digits));
         Print("   SL: ", DoubleToString(stopLoss, _Digits), " TP: ", DoubleToString(takeProfit, _Digits));
         Print("   MinDistance: ", DoubleToString(minDistance, 0), " pips");
         return false;
      }
   }
   
   if(priceAdjusted)
   {
      Print("? Prix final ajustÃĐ - Entry: ", DoubleToString(entryPrice, _Digits), 
            " SL: ", DoubleToString(stopLoss, _Digits), 
            " TP: ", DoubleToString(takeProfit, _Digits));
   }
   
   return true;
}

// Validation "exact entry": ne modifie jamais le prix d'entrÃĐe,
// uniquement les SL/TP (et rejette l'ordre si le courtier exige un autre entry).
bool ValidateLimitPriceExactEntry(double entryPrice, double &stopLoss, double &takeProfit, ENUM_ORDER_TYPE orderType)
{
   static datetime lastExactEntryFailLog = 0;

   // Avant d'exÃĐcuter un ordre LIMIT: exiger les conditions de tendance (EMA+OB+OTE selon config).
   if(LimitOrdersRequireTrendConfirmation && UseTrendAlignedEntryFilter)
   {
      string d = (orderType == ORDER_TYPE_BUY_LIMIT ? "BUY" : (orderType == ORDER_TYPE_SELL_LIMIT ? "SELL" : ""));
      if(d != "" && !IsTrendAlignedEntry(d))
      {
         Print("ðŦ LIMIT BLOQUÃ (exact entry) - Filtre tendance non validÃĐ | ", _Symbol, " | ", d);
         return false;
      }
   }

   if(!IsOrderTypeAllowedForBoomCrash(_Symbol, orderType))
   {
      Print("ðŦ LIMIT BLOQUÃ (exact entry) - Type d'ordre interdit pour ", _Symbol,
            " | orderType=", (int)orderType,
            " | Rule: Boom=BUY only / Crash=SELL only");
      return false;
   }

   double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   double currentAsk = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   double currentBid = SymbolInfoDouble(_Symbol, SYMBOL_BID);

   long stopsLevel = SymbolInfoInteger(_Symbol, SYMBOL_TRADE_STOPS_LEVEL);
   double minDistance = stopsLevel * point;

   // Ajustements spÃĐcifiques (mÃŠme logique que ValidateAndAdjustLimitPrice)
   bool isVolatility = (StringFind(_Symbol, "Volatility") >= 0 || StringFind(_Symbol, "RANGE BREAK") >= 0);
   bool isGold = (StringFind(_Symbol, "XAU") >= 0 || StringFind(_Symbol, "GOLD") >= 0);
   bool isForex = (StringFind(_Symbol, "USD") >= 0 && !isGold && !isVolatility);

   if(isVolatility)
      minDistance = MathMax(minDistance, 500 * point);
   else if(isGold)
      minDistance = MathMax(minDistance, 200 * point);
   else if(isForex)
      minDistance = MathMax(minDistance, 100 * point);
   else
      minDistance = MathMax(minDistance, 30 * point);

   // Rejeter si le courtier n'accepte pas l'entrÃĐe Ã  ce niveau exact.
   if(orderType == ORDER_TYPE_BUY_LIMIT)
   {
      if(entryPrice >= currentAsk)
      {
         if(TimeCurrent() - lastExactEntryFailLog > 60)
         {
            Print("â exact entry BUY_LIMIT rejetÃĐ: entry >= Ask | Symbol=", _Symbol,
                  " entry=", DoubleToString(entryPrice, _Digits),
                  " Ask=", DoubleToString(currentAsk, _Digits));
            lastExactEntryFailLog = TimeCurrent();
         }
         return false;
      }
      if(currentAsk - entryPrice < minDistance)
      {
         if(TimeCurrent() - lastExactEntryFailLog > 60)
         {
            Print("â exact entry BUY_LIMIT rejetÃĐ: distance Ask-entry < minDistance | Symbol=", _Symbol,
                  " dist=", DoubleToString(currentAsk - entryPrice, _Digits),
                  " minDistance=", DoubleToString(minDistance, 0));
            lastExactEntryFailLog = TimeCurrent();
         }
         return false;
      }
   }
   else if(orderType == ORDER_TYPE_SELL_LIMIT)
   {
      if(entryPrice <= currentBid)
      {
         if(TimeCurrent() - lastExactEntryFailLog > 60)
         {
            Print("â exact entry SELL_LIMIT rejetÃĐ: entry <= Bid | Symbol=", _Symbol,
                  " entry=", DoubleToString(entryPrice, _Digits),
                  " Bid=", DoubleToString(currentBid, _Digits));
            lastExactEntryFailLog = TimeCurrent();
         }
         return false;
      }
      if(entryPrice - currentBid < minDistance)
      {
         if(TimeCurrent() - lastExactEntryFailLog > 60)
         {
            Print("â exact entry SELL_LIMIT rejetÃĐ: distance entry-Bid < minDistance | Symbol=", _Symbol,
                  " dist=", DoubleToString(entryPrice - currentBid, _Digits),
                  " minDistance=", DoubleToString(minDistance, 0));
            lastExactEntryFailLog = TimeCurrent();
         }
         return false;
      }
   }
   else
   {
      return false;
   }

   // Ajuster uniquement SL/TP (entry inchangÃĐe).
   if(orderType == ORDER_TYPE_BUY_LIMIT)
   {
      if(stopLoss >= entryPrice || (entryPrice - stopLoss) < minDistance)
         stopLoss = entryPrice - (minDistance * 1.2);
      if(takeProfit <= entryPrice || (takeProfit - entryPrice) < minDistance)
         takeProfit = entryPrice + (minDistance * 3.0);
   }
   else // SELL_LIMIT
   {
      if(stopLoss <= entryPrice || (stopLoss - entryPrice) < minDistance)
         stopLoss = entryPrice + (minDistance * 1.2);
      if(takeProfit >= entryPrice || (entryPrice - takeProfit) < minDistance)
         takeProfit = entryPrice - (minDistance * 3.0);
   }

   // SL trop serrÃĐ sur LIMIT: ÃĐlargir d'environ +N bougies M1.
   ApplyExtraStopLossForLimitOrders(entryPrice, stopLoss, orderType);

   // Alignement SL/TP sur tick size (rÃĐduit le risque de [Invalid stops]).
   double tickSize = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_SIZE);
   if(tickSize <= 0.0)
      tickSize = SymbolInfoDouble(_Symbol, SYMBOL_POINT);

   if(orderType == ORDER_TYPE_BUY_LIMIT)
   {
      stopLoss   = MathFloor(stopLoss / tickSize) * tickSize;  // en dessous
      takeProfit = MathCeil(takeProfit / tickSize) * tickSize;  // au dessus
   }
   else
   {
      stopLoss   = MathCeil(stopLoss / tickSize) * tickSize;  // au dessus
      takeProfit = MathFloor(takeProfit / tickSize) * tickSize; // en dessous
   }

   stopLoss   = NormalizeDouble(stopLoss, _Digits);
   takeProfit = NormalizeDouble(takeProfit, _Digits);

   // VÃĐrification finale trÃĻs stricte: entry reste exact.
   if(orderType == ORDER_TYPE_BUY_LIMIT)
   {
      if(entryPrice >= currentAsk) return false;
      if(currentAsk - entryPrice < minDistance) return false;
      if(stopLoss >= entryPrice || (entryPrice - stopLoss) < minDistance) 
      {
         if(TimeCurrent() - lastExactEntryFailLog > 60)
         {
            Print("â exact entry BUY_LIMIT rejetÃĐ: SL invalide/insuffisant | Symbol=", _Symbol,
                  " entry=", DoubleToString(entryPrice, _Digits),
                  " SL=", DoubleToString(stopLoss, _Digits),
                  " minDistance=", DoubleToString(minDistance, 0));
            lastExactEntryFailLog = TimeCurrent();
         }
         return false;
      }
      if(takeProfit <= entryPrice || (takeProfit - entryPrice) < minDistance)
      {
         if(TimeCurrent() - lastExactEntryFailLog > 60)
         {
            Print("â exact entry BUY_LIMIT rejetÃĐ: TP invalide/insuffisant | Symbol=", _Symbol,
                  " entry=", DoubleToString(entryPrice, _Digits),
                  " TP=", DoubleToString(takeProfit, _Digits),
                  " minDistance=", DoubleToString(minDistance, 0));
            lastExactEntryFailLog = TimeCurrent();
         }
         return false;
      }
   }
   else // SELL_LIMIT
   {
      if(entryPrice <= currentBid) return false;
      if(entryPrice - currentBid < minDistance) return false;
      if(stopLoss <= entryPrice || (stopLoss - entryPrice) < minDistance) 
      {
         if(TimeCurrent() - lastExactEntryFailLog > 60)
         {
            Print("â exact entry SELL_LIMIT rejetÃĐ: SL invalide/insuffisant | Symbol=", _Symbol,
                  " entry=", DoubleToString(entryPrice, _Digits),
                  " SL=", DoubleToString(stopLoss, _Digits),
                  " minDistance=", DoubleToString(minDistance, 0));
            lastExactEntryFailLog = TimeCurrent();
         }
         return false;
      }
      if(takeProfit >= entryPrice || (entryPrice - takeProfit) < minDistance)
      {
         if(TimeCurrent() - lastExactEntryFailLog > 60)
         {
            Print("â exact entry SELL_LIMIT rejetÃĐ: TP invalide/insuffisant | Symbol=", _Symbol,
                  " entry=", DoubleToString(entryPrice, _Digits),
                  " TP=", DoubleToString(takeProfit, _Digits),
                  " minDistance=", DoubleToString(minDistance, 0));
            lastExactEntryFailLog = TimeCurrent();
         }
         return false;
      }
   }

   return true;
}

void ManageTrailingStop()
{
   // DEBUG: Log pour vÃĐrifier si la fonction est appelÃĐe
   static datetime lastDebugLog = 0;
   datetime now = TimeCurrent();
   if(now - lastDebugLog >= 10) // Log toutes les 10 secondes maximum
   {
      Print("ð DEBUG ManageTrailingStop() appelÃĐe | Positions totales: ", PositionsTotal());
      lastDebugLog = now;
   }
   
   // OPTIMISATION: Sortir rapidement si aucune position
   if(PositionsTotal() == 0) return;
   
   // OPTIMISATION: Limiter le trailing stop aux positions de notre EA uniquement
   int ourPositionsCount = 0;
   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      if(posInfo.SelectByIndex(i) && posInfo.Magic() == InpMagicNumber)
      {
         ourPositionsCount++;
      }
   }
   
   if(ourPositionsCount == 0) return;
   
   Print("ð DEBUG: ", ourPositionsCount, " positions trouvÃĐes avec notre magic number");
   
   // NOTE: Modification SL dynamique OBLIGATOIRE partout
   // Plus de condition - le SL dynamique est maintenant obligatoire
   // if(!DynamicSL_Enable && !UseTrailingStop) return; // ANCIEN LOGIQUE - MAINTENANT OBLIGATOIRE

   // Throttle global: ÃĐviter spam de PositionModify
   static datetime lastRun = 0;
   datetime nowRun = TimeCurrent();
   if(nowRun - lastRun < 1) return; // max 1 fois / seconde
   lastRun = nowRun;
   
   // Parcourir uniquement nos positions
   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      if(!posInfo.SelectByIndex(i)) continue;
      if(posInfo.Magic() != InpMagicNumber) continue;
      
      // SL dynamique: tous les symboles y compris Boom/Crash si DynamicSL_OnBoomCrash (sortie spike sÃĐparÃĐe, plus haut dans OnTick)
      string symbol = posInfo.Symbol();
      ENUM_SYMBOL_CATEGORY cat = SMC_GetSymbolCategory(symbol);
      if(cat == SYM_BOOM_CRASH && !DynamicSL_OnBoomCrash)
         continue;

      ulong  ticket = posInfo.Ticket();
      double profit = posInfo.Profit() + posInfo.Swap() + posInfo.Commission();
      double openPrice = posInfo.PriceOpen();
      double currentSL = posInfo.StopLoss();
      double currentTP = posInfo.TakeProfit();
      
      Print("ð DEBUG Position: ", symbol, " | Ticket: ", ticket, " | Profit: ", DoubleToString(profit, 2), "$ | SL: ", DoubleToString(currentSL, _Digits));

      // Trailing distance: ATR du symbole de la position (M1)
      double atrValue = 0.0;
      int atrLocalHandle = iATR(symbol, PERIOD_M1, 14);
      if(atrLocalHandle != INVALID_HANDLE)
      {
         double atrBuf[];
         ArraySetAsSeries(atrBuf, true);
         if(CopyBuffer(atrLocalHandle, 0, 0, 1, atrBuf) >= 1)
            atrValue = atrBuf[0];
      }
      if(atrValue <= 0.0) continue;

      double trailDistance = atrValue * (TrailingStop_ATRMult > 0 ? TrailingStop_ATRMult : 3.0); // 3.0 ATR par dÃĐfaut
      // Break-even buffer: petit cushion pour sÃĐcuriser mÃŠme micro-gains
      double point = SymbolInfoDouble(symbol, SYMBOL_POINT);
      if(point <= 0) point = 0.0001;
      double beBuffer = (double)MathMax(0, DynamicSL_BE_BufferPoints > 0 ? DynamicSL_BE_BufferPoints : 5) * point; // 5 points par dÃĐfaut

      // Prix courant selon le symbole de la position
      double bid = SymbolInfoDouble(symbol, SYMBOL_BID);
      double ask = SymbolInfoDouble(symbol, SYMBOL_ASK);
      if(bid <= 0 || ask <= 0) continue;
      
      // VÃĐrifier existence position avant toute modif
      if(!PositionSelectByTicket(ticket))
         continue;
      if(PositionGetInteger(POSITION_MAGIC) != InpMagicNumber || PositionGetString(POSITION_SYMBOL) != symbol)
         continue;
      
      // Max profit par ticket (ÃĐvite g_maxProfit global qui mÃĐlange les positions)
      string gvName = "SMC_MAXPROFIT_" + IntegerToString((int)ticket);
      double maxP = 0.0;
      if(GlobalVariableCheck(gvName))
         maxP = GlobalVariableGet(gvName);
      if(profit > maxP)
      {
         maxP = profit;
         GlobalVariableSet(gvName, maxP);
      }

      // Modification SL dynamique OBLIGATOIRE - PROTECTION 80% CONTRE PERTE DE GAIN
      double startP = DynamicSL_Enable ? DynamicSL_StartProfitDollars : 
                      (UseTrailingStop ? TrailingStartProfitDollars : 0.50); // 0.50$ par dÃĐfaut
      
      // PROTECTION RENFORCÃE: ProtÃĐger 70% du gain maximum (perdre maximum 30%)
      double lockPct = DynamicSL_Enable ? DynamicSL_LockPctOfMax : 
                      (UseTrailingStop ? 0.70 : 0.70); // 70% par dÃĐfaut - PROTÃGER 70% DU GAIN MAX
      if(lockPct < 0.0) lockPct = 0.0;
      if(lockPct > 1.0) lockPct = 1.0;

      bool shouldTrail = (profit >= startP) || (maxP >= startP && profit <= (maxP * (1.0 - lockPct)));
      double lockProfit = maxP * lockPct;
      
      Print("ð DEBUG Trailing: Profit=", DoubleToString(profit, 2), "$ | MaxProfit=", DoubleToString(maxP, 2), "$ | Start=", DoubleToString(startP, 2), "$ | ShouldTrail=", shouldTrail ? "YES" : "NO");

      // Convertir lockProfit ($) -> distance prix, selon tick_value/tick_size et volume
      double tickSize = SymbolInfoDouble(symbol, SYMBOL_TRADE_TICK_SIZE);
      double tickVal  = SymbolInfoDouble(symbol, SYMBOL_TRADE_TICK_VALUE);
      if(tickSize <= 0) tickSize = point;
      if(tickVal <= 0) tickVal = 1.0;
      double dollarsPerPriceUnit = (tickVal / tickSize) * posInfo.Volume();
      if(dollarsPerPriceUnit <= 0) dollarsPerPriceUnit = 1.0;
      double lockPriceDist = (lockProfit > 0 ? (lockProfit / dollarsPerPriceUnit) : 0.0);
      
      if(shouldTrail)
      {
         if(posInfo.PositionType() == POSITION_TYPE_BUY)
         {
            // 1) Break-even dÃĻs micro gain: SL >= open + buffer
            double beSL = openPrice + beBuffer;
            // 2) Trailing ATR
            double newSL = bid - trailDistance;
            if(newSL < beSL) newSL = beSL;

            // 3) Lock X% du gain max en $: empÃŠcher de retomber trop bas
            if(DynamicSL_Enable && lockPriceDist > 0)
            {
               double lockSL = bid - lockPriceDist;
               if(lockSL < beSL) lockSL = beSL;
               if(newSL < lockSL) newSL = lockSL;
            }
            
            Print("ð DEBUG BUY SL: Open=", DoubleToString(openPrice, _Digits), " | Bid=", DoubleToString(bid, _Digits), " | CurrentSL=", DoubleToString(currentSL, _Digits), " | NewSL=", DoubleToString(newSL, _Digits), " | BeSL=", DoubleToString(beSL, _Digits));
            
            // Valider le SL avant modification
            if(ValidateStopLossForModification(symbol, "BUY", bid, newSL))
            {
               // Only move SL if it improves the current SL and is above open price
               bool shouldModify = (newSL > currentSL && newSL > openPrice);
               Print("ð DEBUG BUY Modify: ShouldModify=", shouldModify ? "YES" : "NO", " | NewSL>CurrentSL=", (newSL > currentSL) ? "YES" : "NO", " | NewSL>OpenPrice=", (newSL > openPrice) ? "YES" : "NO");
               
               if(shouldModify)
               {
                  if(trade.PositionModify(ticket, newSL, currentTP))
                  {
                     Print("?? Trailing Stop BUY mis Ã  jour: ", symbol, " | ", DoubleToString(currentSL, _Digits), " -> ", DoubleToString(newSL, _Digits));
                  }
                  else
                  {
                     Print("â ERREUR Trailing Stop BUY: ", trade.ResultRetcode(), " | ", trade.ResultRetcodeDescription());
                  }
               }
            }
            else
            {
               Print("ð DEBUG BUY SL Validation FAILED");
            }
         }
         else if(posInfo.PositionType() == POSITION_TYPE_SELL)
         {
            double beSL = openPrice - beBuffer;
            double newSL = ask + trailDistance;
            if(newSL > beSL) newSL = beSL;

            if(DynamicSL_Enable && lockPriceDist > 0)
            {
               double lockSL = ask + lockPriceDist;
               if(lockSL > beSL) lockSL = beSL;
               if(newSL > lockSL) newSL = lockSL;
            }
            
            Print("ð DEBUG SELL SL: Open=", DoubleToString(openPrice, _Digits), " | Ask=", DoubleToString(ask, _Digits), " | CurrentSL=", DoubleToString(currentSL, _Digits), " | NewSL=", DoubleToString(newSL, _Digits), " | BeSL=", DoubleToString(beSL, _Digits));
            
            // Valider le SL avant modification
            if(ValidateStopLossForModification(symbol, "SELL", ask, newSL))
            {
               // Only move SL if it improves the current SL and is below open price
               bool shouldModify = ((newSL < currentSL || currentSL == 0) && newSL < openPrice);
               Print("ð DEBUG SELL Modify: ShouldModify=", shouldModify ? "YES" : "NO", " | NewSL<CurrentSL=", (newSL < currentSL || currentSL == 0) ? "YES" : "NO", " | NewSL<OpenPrice=", (newSL < openPrice) ? "YES" : "NO");
               
               if(shouldModify)
               {
                  if(trade.PositionModify(ticket, newSL, currentTP))
                  {
                     Print("?? Trailing Stop SELL mis Ã  jour: ", symbol, " | ", DoubleToString(currentSL, _Digits), " -> ", DoubleToString(newSL, _Digits));
                  }
                  else
                  {
                     Print("â ERREUR Trailing Stop SELL: ", trade.ResultRetcode(), " | ", trade.ResultRetcodeDescription());
                  }
               }
            }
            else
            {
               Print("ð DEBUG SELL SL Validation FAILED");
            }
         }
      }
   }

   // Nettoyage opportuniste: supprimer les GV max profit des tickets qui n'existent plus
   static datetime lastCleanup = 0;
   datetime nowC = TimeCurrent();
   if(nowC - lastCleanup >= 30)
   {
      lastCleanup = nowC;
      for(int gi = (int)GlobalVariablesTotal() - 1; gi >= 0; gi--)
      {
         string gv = GlobalVariableName(gi);
         if(StringFind(gv, "SMC_MAXPROFIT_") != 0) continue;
         string tidStr = StringSubstr(gv, StringLen("SMC_MAXPROFIT_"));
         long tid = (long)StringToInteger(tidStr);
         if(tid <= 0) continue;
         if(!PositionSelectByTicket((ulong)tid))
            GlobalVariableDel(gv);
      }
   }
}

//| DONNÃES GRAPHIQUES POUR ANALYSE EN TEMPS RÃEL          |

// Buffer pour stocker les donnÃĐes graphiques en temps rÃĐel
MqlRates g_chartDataBuffer[];
static datetime g_lastChartCapture = 0;

//| FONCTION POUR CAPTURER LES DONNÃES GRAPHIQUES MT5          |
bool CaptureChartDataFromChart()
{
   // Protection anti-erreur critique
   static int captureErrors = 0;
   static datetime lastErrorReset = 0;
   datetime currentTime = TimeCurrent();
   
   // RÃĐinitialiser les erreurs toutes les 2 minutes
   if(currentTime - lastErrorReset >= 120)
   {
      captureErrors = 0;
      lastErrorReset = currentTime;
   }
   
   // Si trop d'erreurs de capture, dÃĐsactiver temporairement
   if(captureErrors > 3)
   {
      Print("?? Trop d'erreurs de capture graphique - Mode dÃĐgradÃĐ");
      return false;
   }
   
   // RÃĐcupÃĐrer les derniÃĻres bougies depuis le graphique
   MqlRates rates[];
   ArraySetAsSeries(rates, true);
   
   // Limiter la taille pour ÃĐviter les surcharges
   int barsToCopy = MathMin(50, 100); // Maximum 50 bougies
   
   if(CopyRates(_Symbol, PERIOD_M1, 0, barsToCopy, rates) >= barsToCopy)
   {
      // Stocker les donnÃĐes pour analyse ML
      int bufferSize = MathMin(barsToCopy, ArraySize(rates));
      int startIndex = MathMax(0, ArraySize(rates) - bufferSize);
      
      // VÃĐrifier que le buffer n'est pas trop grand
      if(bufferSize > 100)
      {
         Print("?? Buffer trop grand: ", bufferSize, " - Limitation Ã  100");
         bufferSize = 100;
      }
      
      // Redimensionner le buffer si nÃĐcessaire
      if(ArraySize(g_chartDataBuffer) != bufferSize)
         ArrayResize(g_chartDataBuffer, bufferSize);
      
      // Copier les donnÃĐes dans le buffer circulaire
      for(int i = 0; i < bufferSize && i < ArraySize(rates); i++)
      {
         g_chartDataBuffer[i] = rates[startIndex + i];
      }
      
      g_lastChartCapture = currentTime;
      Print("?? DonnÃĐes graphiques capturÃĐes: ", bufferSize, " bougies M1");
      return true;
   }
   else
   {
      captureErrors++;
      Print("? Erreur capture graphique (", captureErrors, "/3) - bars demandÃĐes: ", barsToCopy);
      return false;
   }
}

//| FONCTION POUR CALCULER LES FEATURES Ã PARTIR DES DONNÃES MT5          |
double compute_features_from_mt5_data(MqlRates &rates[])
{
   // Utiliser les prix OHLCV directement depuis les donnÃĐes MT5
   double features[];
   int ratesSize = ArraySize(rates);
   ArrayResize(features, ratesSize * 20); // Allocate enough space for all features
   
   for(int i = 0; i < ratesSize; i++)
   {
      // Features de base (using offset to avoid overlap)
      int baseIdx = i * 20;
      features[baseIdx] = rates[i].close;
      features[baseIdx + 1] = rates[i].open;
      features[baseIdx + 2] = rates[i].high;
      features[baseIdx + 3] = rates[i].low;
      
      // Features techniques (calculÃĐes sur les bougies)
      // RSI
      double rsi = ComputeRSI(rates, 14, i);
      features[baseIdx + 4] = (rsi < 30) ? -1 : (rsi > 70) ? 1 : 0;
      
      // MACD
      double macd = ComputeMACD(rates, 12, 26, 9, i);
      features[baseIdx + 5] = (macd > 0) ? 1 : 0;
      
      // ATR
      double atr = 0;
      for(int j = MathMax(0, i - 13); j < i; j++)
      {
         double range = rates[j].high - rates[j].low;
         atr += range;
      }
      if(i > 13) atr /= 14;
      features[baseIdx + 6] = atr;
      
      // Volume (convert long to double)
      features[baseIdx + 7] = (double)rates[i].tick_volume;
      
      // Moyennes mobiles
      if(i >= 20) features[baseIdx + 8] = rates[i].close;
      if(i >= 50) features[baseIdx + 9] = rates[i].close;
      if(i >= 100) features[baseIdx + 10] = rates[i].close;
      
      // Features de volatilitÃĐ
      if(i >= 20)
      {
         double returns[] = {0, 0, 0, 0, 0};
         for(int j = 1; j <= 20; j++)
         {
            double ret = rates[i - j].close - rates[i - j - 1].close;
            if(ret > 0) returns[j-1] = 1; else returns[j-1] = 0;
         }
         features[baseIdx + 11] = 1;
         for(int k = 0; k < ArraySize(returns); k++)
         {
            if(returns[k]) features[baseIdx + 11 + k] = 1;
         }
      }
      
      // Indicateurs de tendance
      if(i >= 2)
      {
         // EMA 5
         double ema5 = ComputeEMA(rates, 5, i);
         double ema20 = ComputeEMA(rates, 20, i);
         features[baseIdx + 12] = ema5;
         features[baseIdx + 13] = ema20;
         
         // RSI et autres indicateurs...
      }
      
      features[baseIdx] = rates[i].close; // Prix actuel
   }
   
   return 0.0;
}

//| FONCTION POUR DÃTECTER LES PATTERNS GRAPHIQUES          |
bool DetectChartPatterns(MqlRates &rates[])
{
   if(!EnableChartPatternDetection)
      return false;

   int n = ArraySize(rates);
   if(n < 30)
      return false;

   // Les tableaux de prix de l'EA sont en sÃĐrie (index 0 = bougie la plus rÃĐcente).
   int i0 = 1; // bougie clÃīturÃĐe la plus rÃĐcente
   int i1 = 2; // bougie prÃĐcÃĐdente
   if(i1 >= n) return false;

   double open0 = rates[i0].open, close0 = rates[i0].close, high0 = rates[i0].high, low0 = rates[i0].low;
   double open1 = rates[i1].open, close1 = rates[i1].close, high1 = rates[i1].high, low1 = rates[i1].low;
   double range0 = MathMax(1e-10, high0 - low0);
   double body0 = MathAbs(close0 - open0);

   string detected = "NONE";
   string dir = "NEUTRAL";
   double score = 0.0;

   // Chandeliers de retournement (prioritaires, rÃĐcents)
   bool bullEngulf = (close1 < open1 && close0 > open0 && open0 <= close1 && close0 >= open1);
   bool bearEngulf = (close1 > open1 && close0 < open0 && open0 >= close1 && close0 <= open1);
   bool hammer = ((MathMin(open0, close0) - low0) >= body0 * 1.8 && (high0 - MathMax(open0, close0)) <= body0 * 0.6);
   bool shootingStar = ((high0 - MathMax(open0, close0)) >= body0 * 1.8 && (MathMin(open0, close0) - low0) <= body0 * 0.6);
   bool doji = (body0 <= range0 * 0.12);

   if(bullEngulf)
   {
      detected = "Bullish Engulfing";
      dir = "BUY";
      score = 62.0;
   }
   else if(bearEngulf)
   {
      detected = "Bearish Engulfing";
      dir = "SELL";
      score = -62.0;
   }
   else if(hammer && close0 > open0)
   {
      detected = "Hammer";
      dir = "BUY";
      score = 54.0;
   }
   else if(shootingStar && close0 < open0)
   {
      detected = "Shooting Star";
      dir = "SELL";
      score = -54.0;
   }
   else if(doji)
   {
      detected = "Doji";
      dir = "NEUTRAL";
      score = 0.0;
   }

   // Figures chartistes simples (double top/bottom + triangle directionnel)
   int look = MathMin(45, n - 2);
   if(look >= 20)
   {
      int a = 3, b = 7, c = 12, d = 18;
      if(d < n)
      {
         double nearPips = SymbolInfoDouble(_Symbol, SYMBOL_POINT) * 60.0;
         double top1 = rates[b].high, top2 = rates[d].high;
         double bot1 = rates[b].low, bot2 = rates[d].low;
         bool dblTop = (MathAbs(top1 - top2) <= nearPips && close0 < rates[c].low);
         bool dblBottom = (MathAbs(bot1 - bot2) <= nearPips && close0 > rates[c].high);

         if(dblTop && MathAbs(score) < 72.0)
         {
            detected = "Double Top";
            dir = "SELL";
            score = -72.0;
         }
         else if(dblBottom && MathAbs(score) < 72.0)
         {
            detected = "Double Bottom";
            dir = "BUY";
            score = 72.0;
         }
      }

      // Pente structurelle -> canal/triangle directionnel approximatif
      int k1 = MathMin(12, n - 1);
      int k2 = MathMin(24, n - 1);
      if(k2 < n)
      {
         double upSlope = (rates[k1].high - rates[k2].high) / MathMax(1.0, (double)(k2 - k1));
         double dnSlope = (rates[k1].low - rates[k2].low) / MathMax(1.0, (double)(k2 - k1));
         if(upSlope > 0 && dnSlope > 0 && MathAbs(score) < 45.0)
         {
            detected = "Rising Channel";
            dir = "BUY";
            score = 45.0;
         }
         else if(upSlope < 0 && dnSlope < 0 && MathAbs(score) < 45.0)
         {
            detected = "Falling Channel";
            dir = "SELL";
            score = -45.0;
         }
      }
   }

   // Correctif directionnel pour Boom/Crash: ÃĐviter un setup opposÃĐ Ã  l'impulsion actuelle
   // sauf si le pattern de retournement est trÃĻs fort.
   double mNow = rates[1].close;
   double mPast = rates[MathMin(n - 1, 7)].close;
   double momentum = mNow - mPast;
   bool strongReversal = (MathAbs(score) >= 70.0);
   if(IsBoomSymbol(_Symbol) && momentum > 0.0 && dir == "SELL" && !strongReversal)
   {
      detected = "Trend Continuation (Boom)";
      dir = "BUY";
      score = 58.0;
   }
   else if(IsCrashSymbol(_Symbol) && momentum < 0.0 && dir == "BUY" && !strongReversal)
   {
      detected = "Trend Continuation (Crash)";
      dir = "SELL";
      score = -58.0;
   }

   // Zone de la figure (10 derniÃĻres bougies clÃīturÃĐes)
   double zLow = rates[1].low;
   double zHigh = rates[1].high;
   int zBars = MathMin(10, n - 1);
   for(int z = 1; z <= zBars; z++)
   {
      if(rates[z].low < zLow) zLow = rates[z].low;
      if(rates[z].high > zHigh) zHigh = rates[z].high;
   }

   g_lastChartPatternName = detected;
   g_lastChartPatternDirection = dir;
   g_lastChartPatternScore = score;
   g_lastChartPatternZoneLow = zLow;
   g_lastChartPatternZoneHigh = zHigh;
   g_lastChartPatternUpdateUtc = TimeCurrent();

   // Projection en segments successifs obliques (3 ÃĐtapes)
   double anchor = rates[1].close;
   double atrRef = MathMax(1e-10, GetATRValue(PERIOD_M15, 14));
   double signedStep = 0.0;
   if(dir == "BUY") signedStep = atrRef * 0.55;
   else if(dir == "SELL") signedStep = -atrRef * 0.55;
   g_lastChartPatternProj1 = anchor + signedStep;
   g_lastChartPatternProj2 = g_lastChartPatternProj1 + signedStep;
   g_lastChartPatternProj3 = g_lastChartPatternProj2 + signedStep;
   return true;
}

string GetChartPatternShortLabel()
{
   if(!EnableChartPatternDetection)
      return "Pattern OFF";
   return g_lastChartPatternName + " (" + g_lastChartPatternDirection + ")";
}

double GetChartPatternDirectionalBonus(const string direction)
{
   if(!EnableChartPatternDetection || !ChartPatternAffectTradeDecision)
      return 0.0;

   string d = direction;
   StringToUpper(d);
   if(d != "BUY" && d != "SELL")
      return 0.0;

   if(g_lastChartPatternDirection == "NEUTRAL")
      return 0.0;

   double strength = MathMin(1.0, MathAbs(g_lastChartPatternScore) / 100.0);
   double bonus = ChartPatternDirectionalWeight * strength;
   bool aligned = ((d == "BUY" && g_lastChartPatternDirection == "BUY") ||
                   (d == "SELL" && g_lastChartPatternDirection == "SELL"));
   return aligned ? bonus : -bonus;
}

bool IsChartPatternValidatedForDirection(const string direction, const double minAbsScore = 35.0)
{
   if(!EnableChartPatternDetection)
      return true;

   string d = direction;
   StringToUpper(d);
   if(d != "BUY" && d != "SELL")
      return false;

   if(g_lastChartPatternDirection == "NEUTRAL")
      return false;

   if(MathAbs(g_lastChartPatternScore) < minAbsScore)
      return false;

   return ((d == "BUY" && g_lastChartPatternDirection == "BUY") ||
           (d == "SELL" && g_lastChartPatternDirection == "SELL"));
}

void UpdateChartPatternContext(bool drawObjects = true)
{
   if(!EnableChartPatternDetection) return;

   static datetime s_lastRefresh = 0;
   datetime now = TimeCurrent();
   if(s_lastRefresh > 0 && (now - s_lastRefresh) < 8)
      return;
   s_lastRefresh = now;

   MqlRates r[];
   ArraySetAsSeries(r, true);
   int copied = CopyRates(_Symbol, PERIOD_M15, 0, 90, r);
   if(copied < 30) return;

   if(!DetectChartPatterns(r)) return;
   DrawChartPatternTradePlans();
   if(!drawObjects || !ChartPatternDrawProjection) return;

   datetime t0 = TimeCurrent();
   datetime t1 = t0 + PeriodSeconds(PERIOD_M15);
   datetime t2 = t0 + PeriodSeconds(PERIOD_M15) * 2;
   datetime t3 = t0 + PeriodSeconds(PERIOD_M15) * 3;
   color c = (g_lastChartPatternDirection == "BUY" ? clrLime : (g_lastChartPatternDirection == "SELL" ? clrTomato : clrSilver));
   string pfx = "CHART_PATTERN_" + _Symbol + "_";

   ObjectDelete(0, pfx + "SEG1");
   ObjectDelete(0, pfx + "SEG2");
   ObjectDelete(0, pfx + "SEG3");
   ObjectDelete(0, pfx + "ZONE");
   ObjectDelete(0, pfx + "LBL");

   ObjectCreate(0, pfx + "SEG1", OBJ_TREND, 0, t0, r[1].close, t1, g_lastChartPatternProj1);
   ObjectSetInteger(0, pfx + "SEG1", OBJPROP_COLOR, c);
   ObjectSetInteger(0, pfx + "SEG1", OBJPROP_WIDTH, 2);

   ObjectCreate(0, pfx + "SEG2", OBJ_TREND, 0, t1, g_lastChartPatternProj1, t2, g_lastChartPatternProj2);
   ObjectSetInteger(0, pfx + "SEG2", OBJPROP_COLOR, c);
   ObjectSetInteger(0, pfx + "SEG2", OBJPROP_WIDTH, 2);

   ObjectCreate(0, pfx + "SEG3", OBJ_TREND, 0, t2, g_lastChartPatternProj2, t3, g_lastChartPatternProj3);
   ObjectSetInteger(0, pfx + "SEG3", OBJPROP_COLOR, c);
   ObjectSetInteger(0, pfx + "SEG3", OBJPROP_WIDTH, 2);

   ObjectCreate(0, pfx + "ZONE", OBJ_RECTANGLE, 0, t0 - PeriodSeconds(PERIOD_M15) * 6, g_lastChartPatternZoneHigh, t0, g_lastChartPatternZoneLow);
   ObjectSetInteger(0, pfx + "ZONE", OBJPROP_COLOR, c);
   ObjectSetInteger(0, pfx + "ZONE", OBJPROP_STYLE, STYLE_DOT);
   ObjectSetInteger(0, pfx + "ZONE", OBJPROP_BACK, true);

   ObjectCreate(0, pfx + "LBL", OBJ_TEXT, 0, t0, g_lastChartPatternZoneHigh);
   ObjectSetString(0, pfx + "LBL", OBJPROP_TEXT, "Pattern: " + g_lastChartPatternName + " | dir " + g_lastChartPatternDirection);
   ObjectSetInteger(0, pfx + "LBL", OBJPROP_COLOR, c);
   ObjectSetInteger(0, pfx + "LBL", OBJPROP_FONTSIZE, 9);
}

void DrawChartPatternTradePlans()
{
   if(!EnableChartPatternDetection) return;
   if(g_lastChartPatternDirection != "BUY" && g_lastChartPatternDirection != "SELL") return;
   if(MathAbs(g_lastChartPatternScore) < 35.0) return;

   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   double px = (g_lastChartPatternDirection == "BUY") ? ask : bid;
   if(px <= 0.0) return;

   double atrM1_val = MathMax(_Point * 20.0, GetATRValue(PERIOD_M1, 14));
   double atrM15 = MathMax(_Point * 40.0, GetATRValue(PERIOD_M15, 14));
   double eScalp = px;
   double slScalp = (g_lastChartPatternDirection == "BUY") ? (eScalp - atrM1_val * 1.2) : (eScalp + atrM1_val * 1.2);
   double tpScalp = (g_lastChartPatternDirection == "BUY") ? (eScalp + atrM1_val * 1.8) : (eScalp - atrM1_val * 1.8);

   double eSwing = px;
   double slSwing = (g_lastChartPatternDirection == "BUY") ? (eSwing - atrM15 * 1.5) : (eSwing + atrM15 * 1.5);
   double tpSwing = (g_lastChartPatternDirection == "BUY") ? (eSwing + atrM15 * 2.6) : (eSwing - atrM15 * 2.6);

   string pfx = "CHART_PLAN_" + _Symbol + "_";
   ObjectDelete(0, pfx + "SCALP_E"); ObjectDelete(0, pfx + "SCALP_SL"); ObjectDelete(0, pfx + "SCALP_TP");
   ObjectDelete(0, pfx + "SWING_E"); ObjectDelete(0, pfx + "SWING_SL"); ObjectDelete(0, pfx + "SWING_TP");
   ObjectDelete(0, pfx + "TXT");

   EnsureOrSetHLine(pfx + "SCALP_E", eScalp);  ObjectSetInteger(0, pfx + "SCALP_E", OBJPROP_COLOR, clrAqua);    ObjectSetInteger(0, pfx + "SCALP_E", OBJPROP_WIDTH, 2);
   EnsureOrSetHLine(pfx + "SCALP_SL", slScalp);ObjectSetInteger(0, pfx + "SCALP_SL", OBJPROP_COLOR, clrTomato); ObjectSetInteger(0, pfx + "SCALP_SL", OBJPROP_STYLE, STYLE_DASH);
   EnsureOrSetHLine(pfx + "SCALP_TP", tpScalp);ObjectSetInteger(0, pfx + "SCALP_TP", OBJPROP_COLOR, clrLime);   ObjectSetInteger(0, pfx + "SCALP_TP", OBJPROP_STYLE, STYLE_DASH);

   EnsureOrSetHLine(pfx + "SWING_E", eSwing);  ObjectSetInteger(0, pfx + "SWING_E", OBJPROP_COLOR, clrDodgerBlue); ObjectSetInteger(0, pfx + "SWING_E", OBJPROP_WIDTH, 2);
   EnsureOrSetHLine(pfx + "SWING_SL", slSwing);ObjectSetInteger(0, pfx + "SWING_SL", OBJPROP_COLOR, clrOrangeRed); ObjectSetInteger(0, pfx + "SWING_SL", OBJPROP_STYLE, STYLE_DOT);
   EnsureOrSetHLine(pfx + "SWING_TP", tpSwing);ObjectSetInteger(0, pfx + "SWING_TP", OBJPROP_COLOR, clrGreen);     ObjectSetInteger(0, pfx + "SWING_TP", OBJPROP_STYLE, STYLE_DOT);

   datetime t = TimeCurrent() + PeriodSeconds(PERIOD_M1) * 60;
   string txt = "PLAN " + g_lastChartPatternDirection + " | " + g_lastChartPatternName +
                " | Scalping M1 E/SL/TP=" + DoubleToString(eScalp, _Digits) + "/" + DoubleToString(slScalp, _Digits) + "/" + DoubleToString(tpScalp, _Digits) +
                " | Swing M15 E/SL/TP=" + DoubleToString(eSwing, _Digits) + "/" + DoubleToString(slSwing, _Digits) + "/" + DoubleToString(tpSwing, _Digits);
   EnsureOrMoveText(pfx + "TXT", t, px, txt);
   ObjectSetInteger(0, pfx + "TXT", OBJPROP_COLOR, clrWhite);
   ObjectSetInteger(0, pfx + "TXT", OBJPROP_FONTSIZE, 9);
}

//| FONCTIONS TECHNIQUES POUR DONNÃES MT5                    |

double ComputeEMA(MqlRates &rates[], int period, int index)
{
   if(index < period - 1) return rates[index].close;
   
   double ema = rates[index].close;
   double multiplier = 2.0 / (period + 1);
   
   for(int i = 0; i <= index; i++)
   {
      ema = (rates[i].close - ema) * multiplier + ema;
   }
   
   return ema;
}

double ComputeRSI(MqlRates &rates[], int period, int index)
{
   if(index < period - 1) return 50.0;
   
   double gains = 0, losses = 0;
   for(int i = index - period + 1; i <= index; i++)
   {
      double change = rates[i].close - rates[i-1].close;
      if(change > 0)
         gains += change;
      else
         losses += -change;
   }
   
   double avgGain = gains / period;
   double avgLoss = losses / period;
   if(avgLoss == 0.0)
      return 100.0;
   double rs = avgGain / avgLoss;
   double rsi = 100.0 - (100.0 / (1.0 + rs));
   // Clamp pour rester dans [0,100]
   if(rsi < 0.0) rsi = 0.0;
   if(rsi > 100.0) rsi = 100.0;
   return rsi;
}

double ComputeMACD(MqlRates &rates[], int fast, int slow, int signal, int index)
{
   if(index < slow) return 0;
   
   double emaFast = rates[index].close;
   double emaSlow = rates[index].close;
   
   for(int i = 0; i <= index; i++)
   {
      emaFast = (rates[i].close * 2.0 / (fast + 1)) + emaFast * (fast - 1) / (fast + 1);
      emaSlow = (rates[i].close * 2.0 / (slow + 1)) + emaSlow * (slow - 1) / (slow + 1);
   }
   
   return emaFast - emaSlow;
}

// RÃĐsumÃĐ combinÃĐ des indicateurs classiques (MA/RSI/MACD/Bollinger/VWAP/Pivots/Ichimoku/OBV)
// Retourne true si suffisamment d'indicateurs sont alignÃĐs avec la direction demandÃĐe
bool IsClassicIndicatorsAligned(const string direction, string &summaryOut)
{
   summaryOut = "";

   if(!UseClassicIndicatorsFilter)
      return true;

   string dir = direction;
   if(dir != "BUY" && dir != "SELL")
      return true;

   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   if(bid <= 0)
      return true;

   // DonnÃĐes M1 rÃĐcentes
   MqlRates m1[];
   ArraySetAsSeries(m1, true);
   if(CopyRates(_Symbol, PERIOD_M1, 0, 60, m1) < 30)
      return true;

   double price = m1[0].close;

   int scoreFor = 0;
   int scoreAgainst = 0;

   // 1) Tendance EMA simple (dÃĐjÃ  existante via emaFastM1 / emaSlowM1)
   double emaFast = 0.0, emaSlow = 0.0;
   double bufFast[], bufSlow[];
   ArraySetAsSeries(bufFast, true);
   ArraySetAsSeries(bufSlow, true);

   if(emaFastM1 != INVALID_HANDLE && CopyBuffer(emaFastM1, 0, 0, 1, bufFast) > 0)
      emaFast = bufFast[0];
   if(emaSlowM1 != INVALID_HANDLE && CopyBuffer(emaSlowM1, 0, 0, 1, bufSlow) > 0)
      emaSlow = bufSlow[0];

   if(emaFast > 0.0 && emaSlow > 0.0)
   {
      bool emaBull = (emaFast > emaSlow);
      bool emaBear = (emaFast < emaSlow);
      if(emaBull || emaBear)
      {
         if((dir == "BUY"  && emaBull) ||
            (dir == "SELL" && emaBear))
         {
            scoreFor++;
            summaryOut += "[EMA OK] ";
         }
         else
         {
            scoreAgainst++;
            summaryOut += "[EMA CONTRA] ";
         }
      }
   }

   // 2) RSI (existing ComputeRSI)
   double rsi = ComputeRSI(m1, 14, 0);
   if(rsi > 70.0)
   {
      if(dir == "SELL") { scoreFor++; summaryOut += "[RSI SURACHAT?SELL] "; }
      else              { scoreAgainst++; summaryOut += "[RSI SURACHAT CONTRA] "; }
   }
   else if(rsi < 30.0)
   {
      if(dir == "BUY")  { scoreFor++; summaryOut += "[RSI SURVENTE?BUY] "; }
      else              { scoreAgainst++; summaryOut += "[RSI SURVENTE CONTRA] "; }
   }

   // 3) MACD (existing ComputeMACD)
   double macd = ComputeMACD(m1, 12, 26, 9, 0);
   if(macd > 0)
   {
      if(dir == "BUY")  { scoreFor++; summaryOut += "[MACD HAUSSIER] "; }
      else              { scoreAgainst++; summaryOut += "[MACD CONTRA] "; }
   }
   else if(macd < 0)
   {
      if(dir == "SELL") { scoreFor++; summaryOut += "[MACD BAISSIER] "; }
      else              { scoreAgainst++; summaryOut += "[MACD CONTRA] "; }
   }

   // 4) Bandes de Bollinger
   if(UseBollingerFilter)
   {
      int bbHandle = iBands(_Symbol, PERIOD_M1, 20, 2.0, 0, PRICE_CLOSE);
      if(bbHandle != INVALID_HANDLE)
      {
         double upper[], middle[], lower[];
         ArraySetAsSeries(upper,  true);
         ArraySetAsSeries(middle, true);
         ArraySetAsSeries(lower,  true);
         if(CopyBuffer(bbHandle, 0, 0, 1, upper)  == 1 &&
            CopyBuffer(bbHandle, 1, 0, 1, middle) == 1 &&
            CopyBuffer(bbHandle, 2, 0, 1, lower)  == 1)
         {
            bool nearUpper = (price >= middle[0]) && (price > upper[0] * 0.995);
            bool nearLower = (price <= middle[0]) && (price < lower[0] * 1.005);
            if(nearUpper)
            {
               if(dir == "SELL") { scoreFor++; summaryOut += "[BB HAUT?SELL] "; }
               else              { scoreAgainst++; summaryOut += "[BB HAUT CONTRA] "; }
            }
            else if(nearLower)
            {
               if(dir == "BUY")  { scoreFor++; summaryOut += "[BB BAS?BUY] "; }
               else              { scoreAgainst++; summaryOut += "[BB BAS CONTRA] "; }
            }
         }
         IndicatorRelease(bbHandle);
      }
   }

   // 5) VWAP intraday (M1, derniÃĻre session ~60 bougies)
   if(UseVWAPFilter)
   {
      double sumPV = 0.0, sumV = 0.0;
      int barsVWAP = MathMin(ArraySize(m1), 60);
      for(int i = 0; i < barsVWAP; i++)
      {
         double typical = (m1[i].high + m1[i].low + m1[i].close) / 3.0;
         double vol     = (double)m1[i].tick_volume;
         sumPV += typical * vol;
         sumV  += vol;
      }
      if(sumV > 0.0)
      {
         double vwap = sumPV / sumV;
         if(price > vwap * 1.001)
         {
            if(dir == "BUY")  { scoreFor++; summaryOut += "[VWAP AU-DESSUS?BUY] "; }
            else              { scoreAgainst++; summaryOut += "[VWAP CONTRA] "; }
         }
         else if(price < vwap * 0.999)
         {
            if(dir == "SELL") { scoreFor++; summaryOut += "[VWAP SOUS?SELL] "; }
            else              { scoreAgainst++; summaryOut += "[VWAP CONTRA] "; }
         }
      }
   }

   // 6) Points pivots journaliers
   if(UsePivotFilter)
   {
      MqlRates d1[];
      ArraySetAsSeries(d1, true);
      if(CopyRates(_Symbol, PERIOD_D1, 0, 3, d1) >= 2)
      {
         double highPrev = d1[1].high;
         double lowPrev  = d1[1].low;
         double closePrev= d1[1].close;
         double pivot = (highPrev + lowPrev + closePrev) / 3.0;
         double r1 = 2.0 * pivot - lowPrev;
         double s1 = 2.0 * pivot - highPrev;

         bool nearR1 = MathAbs(price - r1) / r1 < 0.002;
         bool nearS1 = MathAbs(price - s1) / s1 < 0.002;

         if(nearR1)
         {
            if(dir == "SELL") { scoreFor++; summaryOut += "[PIVOT R1?SELL] "; }
            else              { scoreAgainst++; summaryOut += "[PIVOT R1 CONTRA] "; }
         }
         else if(nearS1)
         {
            if(dir == "BUY")  { scoreFor++; summaryOut += "[PIVOT S1?BUY] "; }
            else              { scoreAgainst++; summaryOut += "[PIVOT S1 CONTRA] "; }
         }
      }
   }

   // 7) Ichimoku H1 (rÃĐsumÃĐ simple)
   if(UseIchimokuFilter)
   {
      int ichHandle = iIchimoku(_Symbol, PERIOD_H1, 9, 26, 52);
      if(ichHandle != INVALID_HANDLE)
      {
         double tenkanBuf[], kijunBuf[], spanABuf[], spanBBuf[];
         ArraySetAsSeries(tenkanBuf, true);
         ArraySetAsSeries(kijunBuf,  true);
         ArraySetAsSeries(spanABuf,  true);
         ArraySetAsSeries(spanBBuf,  true);

         bool okTenkan = (CopyBuffer(ichHandle, 0, 0, 1, tenkanBuf) == 1);
         bool okKijun  = (CopyBuffer(ichHandle, 1, 0, 1, kijunBuf)  == 1);
         bool okA      = (CopyBuffer(ichHandle, 2, 0, 1, spanABuf)  == 1);
         bool okB      = (CopyBuffer(ichHandle, 3, 0, 1, spanBBuf)  == 1);

         if(okTenkan && okKijun && okA && okB)
         {
            double cloudTop    = MathMax(spanABuf[0], spanBBuf[0]);
            double cloudBottom = MathMin(spanABuf[0], spanBBuf[0]);
            bool ichBull = (price > cloudTop && tenkanBuf[0] > kijunBuf[0]);
            bool ichBear = (price < cloudBottom && tenkanBuf[0] < kijunBuf[0]);

            if(ichBull)
            {
               if(dir == "BUY")  { scoreFor++; summaryOut += "[ICHIMOKU BULL] "; }
               else              { scoreAgainst++; summaryOut += "[ICHIMOKU CONTRA] "; }
            }
            else if(ichBear)
            {
               if(dir == "SELL") { scoreFor++; summaryOut += "[ICHIMOKU BEAR] "; }
               else              { scoreAgainst++; summaryOut += "[ICHIMOKU CONTRA] "; }
            }
         }
         IndicatorRelease(ichHandle);
      }
   }

   // 8) OBV (On-Balance Volume) sur M15
   if(UseOBVFilter)
   {
      MqlRates m15[];
      ArraySetAsSeries(m15, true);
      int copied = CopyRates(_Symbol, PERIOD_M15, 0, 30, m15);
      // Besoin d'au moins 2 barres pour comparer les clÃītures
      if(copied >= 2)
      {
         double obv = 0.0;
         // Parcourir les barres en comparant close[i] avec close[i-1]
         // pour ÃĐviter tout dÃĐpassement de tableau (array out of range).
         for(int i = 1; i < copied; i++)
         {
            double vol = (double)m15[i].tick_volume;
            if(m15[i].close > m15[i-1].close)
               obv += vol;
            else if(m15[i].close < m15[i-1].close)
               obv -= vol;
         }
         if(obv > 0)
         {
            if(dir == "BUY")  { scoreFor++; summaryOut += "[OBV INFLOW?BUY] "; }
            else              { scoreAgainst++; summaryOut += "[OBV CONTRA] "; }
         }
         else if(obv < 0)
         {
            if(dir == "SELL") { scoreFor++; summaryOut += "[OBV OUTFLOW?SELL] "; }
            else              { scoreAgainst++; summaryOut += "[OBV CONTRA] "; }
         }
      }
   }

   // DÃĐcision finale : au moins ClassicMinConfirmations en faveur
   bool ok = (scoreFor >= ClassicMinConfirmations);

   summaryOut = "For=" + IntegerToString(scoreFor) +
                " Against=" + IntegerToString(scoreAgainst) + " " + summaryOut;

   return ok;
}

