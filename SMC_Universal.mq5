   ObjectCreate(0, marker, OBJ_ARROW, 0, changeTime, changePrice);
   ObjectSetInteger(0, marker, OBJPROP_COLOR, clrPurple);
   ObjectSetInteger(0, marker, OBJPROP_ARROWCODE, 159);
   ObjectSetInteger(0, marker, OBJPROP_WIDTH, 4);
   ObjectSetInteger(0, marker, OBJPROP_BACK, false);
   
   // Label CHOCH
   string chochLabel = "CHOCH_SETUP_LABEL";
   ObjectCreate(0, chochLabel, OBJ_TEXT, 0, changeTime + PeriodSeconds(PERIOD_M1) * 3, 
                changePrice + SymbolInfoDouble(_Symbol, SYMBOL_POINT) * 8);
   ObjectSetString(0, chochLabel, OBJPROP_TEXT, "🔄 CHOCH " + direction + " 🔄");
   ObjectSetInteger(0, chochLabel, OBJPROP_COLOR, clrPurple);
   ObjectSetInteger(0, chochLabel, OBJPROP_FONTSIZE, 11);
   ObjectSetInteger(0, chochLabel, OBJPROP_BACK, false);
   
   Print("🔄 SETUP CHOCH MATÉRIALISÉ - ", direction, " @ ", DoubleToString(changePrice, _Digits), " ", _Symbol);
}

// Nettoyer tous les setups SMC
void ClearAllSMCSetups()
{
   ObjectsDeleteAll(0, "OTE_SETUP_");
   ObjectsDeleteAll(0, "STAIR_SETUP_");
   ObjectsDeleteAll(0, "BOS_SETUP_");
   ObjectsDeleteAll(0, "CHOCH_SETUP_");
   Print("🧹 TOUS LES SETUPS SMC NETTOYÉS - ", _Symbol);
}

//+------------------------------------------------------------------+
//| VRAI SETUP SMC DE PRÉDICTION - 200 BOUGIES M1                  |
//+------------------------------------------------------------------+
void DrawSMCPredictionSetup()
{
   // Supprimer les anciens setups de prédiction
   ObjectsDeleteAll(0, "SMC_PRED_");
   
   // Paramètres de base
   datetime timeStart = TimeCurrent();
   datetime timeEnd = timeStart + PeriodSeconds(PERIOD_M1) * 200; // 200 bougies M1
   
   // Récupérer les données pour identifier les niveaux clés
   MqlRates rates[];
   ArraySetAsSeries(rates, true);
   int copied = CopyRates(_Symbol, PERIOD_M1, 0, 50, rates);
   if(copied < 20) return;
   
   double currentPrice = rates[0].close;
   double swingHigh = rates[0].high;
   double swingLow = rates[0].low;
   
   // Trouver le swing high/low sur les dernières 30 bougies
   for(int i = 0; i < 30 && i < copied; i++)
   {
      swingHigh = MathMax(swingHigh, rates[i].high);
      swingLow = MathMin(swingLow, rates[i].low);
   }
   
   // Déterminer la direction dominante
   string direction = (currentPrice > (swingHigh + swingLow) / 2) ? "HAUSSIER" : "BAISSIER";
   
   // ===== CONFIGURATION DU SETUP =====
   double bosHigh, bosLow, chochLevel, orderBlockHigh, orderBlockLow;
   double entry, stopLoss, takeProfit;
   color dirColor, entryColor;
   
   if(direction == "HAUSSIER")
   {
      // Setup HAUSSIER: cherche une zone à casser vers le haut
      bosLow = swingLow;
      bosHigh = swingLow + (swingHigh - swingLow) * 0.618; // Fibonacci 61.8%
      chochLevel = bosHigh + (swingHigh - swingLow) * 0.2;
      orderBlockHigh = bosHigh + (swingHigh - swingLow) * 0.05;
      orderBlockLow = bosHigh - (swingHigh - swingLow) * 0.05;
      
      // Zones Fibonacci pour calcul de l'entrée
      double fiboRange = swingHigh - bosLow;
      double fibo_886 = bosLow + fiboRange * 0.886;
      double fibo_79  = bosLow + fiboRange * 0.79;
      double fibo_705 = bosLow + fiboRange * 0.705;
      double fibo_50  = bosLow + fiboRange * 0.50; // Entrée
      
      entry = fibo_50;
      stopLoss = bosLow - (swingHigh - swingLow) * 0.1;
      double riskInPips = (entry - stopLoss) / SymbolInfoDouble(_Symbol, SYMBOL_POINT);
      takeProfit = entry + (riskInPips * 5 * SymbolInfoDouble(_Symbol, SYMBOL_POINT));
      
      dirColor = clrGreen;
      entryColor = clrLime;
      
      // === TRACER SETUP HAUSSIER ===
      
      // 1. BOS - Ligne pointillée du break of structure
      string bosLine = "SMC_PRED_BOS_LINE";
      ObjectCreate(0, bosLine, OBJ_TREND, 0, timeStart, bosLow, timeEnd, bosLow);
      ObjectSetInteger(0, bosLine, OBJPROP_COLOR, clrOrange);
      ObjectSetInteger(0, bosLine, OBJPROP_STYLE, STYLE_DASH);
      ObjectSetInteger(0, bosLine, OBJPROP_WIDTH, 2);
      ObjectSetInteger(0, bosLine, OBJPROP_BACK, true);
      
      string bosLabel = "SMC_PRED_BOS_LABEL";
      ObjectCreate(0, bosLabel, OBJ_TEXT, 0, timeStart + PeriodSeconds(PERIOD_M1) * 10, bosLow - (swingHigh - swingLow) * 0.02);
      ObjectSetString(0, bosLabel, OBJPROP_TEXT, "BOS");
      ObjectSetInteger(0, bosLabel, OBJPROP_COLOR, clrOrange);
      ObjectSetInteger(0, bosLabel, OBJPROP_FONTSIZE, 9);
      
      // 2. CHoCH - Zone de changement de caractère
      string chochZone = "SMC_PRED_CHOCH_ZONE";
      ObjectCreate(0, chochZone, OBJ_RECTANGLE, 0, 
                   timeStart + PeriodSeconds(PERIOD_M1) * 30, chochLevel - (swingHigh - swingLow) * 0.02,
                   timeStart + PeriodSeconds(PERIOD_M1) * 50, chochLevel + (swingHigh - swingLow) * 0.02);
      ObjectSetInteger(0, chochZone, OBJPROP_COLOR, clrPurple);
      ObjectSetInteger(0, chochZone, OBJPROP_BGCOLOR, C'150,100,200');
      ObjectSetInteger(0, chochZone, OBJPROP_FILL, true);
      ObjectSetInteger(0, chochZone, OBJPROP_BACK, true);
      
      string chochLabel = "SMC_PRED_CHOCH_LABEL";
      ObjectCreate(0, chochLabel, OBJ_TEXT, 0, timeStart + PeriodSeconds(PERIOD_M1) * 35, chochLevel + (swingHigh - swingLow) * 0.05);
      ObjectSetString(0, chochLabel, OBJPROP_TEXT, "CHoCH");
      ObjectSetInteger(0, chochLabel, OBJPROP_COLOR, clrPurple);
      ObjectSetInteger(0, chochLabel, OBJPROP_FONTSIZE, 9);
      
      // 3. Order Block - Zone de liquidity
      string obZone = "SMC_PRED_OB_ZONE";
      ObjectCreate(0, obZone, OBJ_RECTANGLE, 0, 
                   timeStart + PeriodSeconds(PERIOD_M1) * 50, orderBlockLow,
                   timeStart + PeriodSeconds(PERIOD_M1) * 80, orderBlockHigh);
      ObjectSetInteger(0, obZone, OBJPROP_COLOR, clrSkyBlue);
      ObjectSetInteger(0, obZone, OBJPROP_BGCOLOR, C'173,216,230');
      ObjectSetInteger(0, obZone, OBJPROP_FILL, true);
      ObjectSetInteger(0, obZone, OBJPROP_BACK, true);
      
      string obLabel = "SMC_PRED_OB_LABEL";
      ObjectCreate(0, obLabel, OBJ_TEXT, 0, timeStart + PeriodSeconds(PERIOD_M1) * 65, (orderBlockLow + orderBlockHigh) / 2);
      ObjectSetString(0, obLabel, OBJPROP_TEXT, "Order Block");
      ObjectSetInteger(0, obLabel, OBJPROP_COLOR, clrSkyBlue);
      ObjectSetInteger(0, obLabel, OBJPROP_FONTSIZE, 8);
      
      // 4. Zones Fibonacci - Lignes de retracés
      DrawFibonacciLevelsForPrediction(timeStart, timeEnd, bosLow, fibo_886, "886", clrGray);
      DrawFibonacciLevelsForPrediction(timeStart, timeEnd, bosLow, fibo_79, "79", clrGray);
      DrawFibonacciLevelsForPrediction(timeStart, timeEnd, bosLow, fibo_705, "705", clrGray);
      
      // 5. M5 TREND ENTRY POINT - Ligne de tendance haussière
      double m5TrendSlope = (swingHigh - bosLow) / 100.0; // Pente modérée
      string m5TrendLine = "SMC_PRED_M5_TREND_LINE";
      ObjectCreate(0, m5TrendLine, OBJ_TREND, 0, 
                   timeStart + PeriodSeconds(PERIOD_M1) * 80, bosLow,
                   timeEnd, bosLow + m5TrendSlope * 120);
      ObjectSetInteger(0, m5TrendLine, OBJPROP_COLOR, clrYellow);
      ObjectSetInteger(0, m5TrendLine, OBJPROP_STYLE, STYLE_SOLID);
      ObjectSetInteger(0, m5TrendLine, OBJPROP_WIDTH, 2);
      ObjectSetInteger(0, m5TrendLine, OBJPROP_BACK, false);
      
      string m5TrendLabel = "SMC_PRED_M5_TREND_LABEL";
      ObjectCreate(0, m5TrendLabel, OBJ_TEXT, 0, timeStart + PeriodSeconds(PERIOD_M1) * 100, 
                   bosLow + m5TrendSlope * 40);
      ObjectSetString(0, m5TrendLabel, OBJPROP_TEXT, "M5↑");
      ObjectSetInteger(0, m5TrendLabel, OBJPROP_COLOR, clrYellow);
      ObjectSetInteger(0, m5TrendLabel, OBJPROP_FONTSIZE, 6);
      ObjectSetInteger(0, m5TrendLabel, OBJPROP_BACK, false);
      
      // 5b. ENTRY au 50% - ZONE SURLIGNÉE
      string entryZone = "SMC_PRED_ENTRY_ZONE";
      ObjectCreate(0, entryZone, OBJ_RECTANGLE, 0, 
                   timeStart + PeriodSeconds(PERIOD_M1) * 80, entry - (swingHigh - swingLow) * 0.015,
                   timeStart + PeriodSeconds(PERIOD_M1) * 100, entry + (swingHigh - swingLow) * 0.015);
      ObjectSetInteger(0, entryZone, OBJPROP_COLOR, clrWhite);
      ObjectSetInteger(0, entryZone, OBJPROP_BGCOLOR, entryColor);
      ObjectSetInteger(0, entryZone, OBJPROP_FILL, true);
      ObjectSetInteger(0, entryZone, OBJPROP_BACK, false);
      ObjectSetInteger(0, entryZone, OBJPROP_WIDTH, 2);
      
      string entryLine = "SMC_PRED_ENTRY_LINE";
      ObjectCreate(0, entryLine, OBJ_HLINE, 0, timeStart, entry);
      ObjectSetInteger(0, entryLine, OBJPROP_COLOR, entryColor);
      ObjectSetInteger(0, entryLine, OBJPROP_STYLE, STYLE_SOLID);
      ObjectSetInteger(0, entryLine, OBJPROP_WIDTH, 4);
      ObjectSetInteger(0, entryLine, OBJPROP_BACK, false);
      
      // 6. STOP LOSS
      string slLine = "SMC_PRED_SL_LINE";
      ObjectCreate(0, slLine, OBJ_HLINE, 0, timeStart, stopLoss);
      ObjectSetInteger(0, slLine, OBJPROP_COLOR, clrRed);
      ObjectSetInteger(0, slLine, OBJPROP_STYLE, STYLE_DASH);
      ObjectSetInteger(0, slLine, OBJPROP_WIDTH, 2);
      ObjectSetInteger(0, slLine, OBJPROP_BACK, false);
      
      // Label SL - MINIMAL
      string slLabel = "SMC_PRED_SL_LABEL";
      CreateSmallLabel(slLabel, timeStart + PeriodSeconds(PERIOD_M1) * 5, 
                        stopLoss - (swingHigh - swingLow) * 0.02, "S", clrRed);
      
      // 7. TAKE PROFIT (RR 1:5)
      string tpLine = "SMC_PRED_TP_LINE";
      ObjectCreate(0, tpLine, OBJ_HLINE, 0, timeStart, takeProfit);
      ObjectSetInteger(0, tpLine, OBJPROP_COLOR, clrGreen);
      ObjectSetInteger(0, tpLine, OBJPROP_STYLE, STYLE_DASH);
      ObjectSetInteger(0, tpLine, OBJPROP_WIDTH, 2);
      ObjectSetInteger(0, tpLine, OBJPROP_BACK, false);
      
      // Label TP - MINIMAL
      string tpLabel = "SMC_PRED_TP_LABEL";
      CreateSmallLabel(tpLabel, timeStart + PeriodSeconds(PERIOD_M1) * 5, 
                        takeProfit + (swingHigh - swingLow) * 0.02, "T", clrGreen);
      
      // 8. TITRE SETUP
      string title = "SMC_PRED_TITLE";
      ObjectCreate(0, title, OBJ_TEXT, 0, timeStart + PeriodSeconds(PERIOD_M1) * 100, takeProfit + (swingHigh - swingLow) * 0.1);
      ObjectSetString(0, title, OBJPROP_TEXT, "⬆️ SMC PREDICTION SETUP HAUSSIER (200M1) ⬆️");
      ObjectSetInteger(0, title, OBJPROP_COLOR, clrLime);
      ObjectSetInteger(0, title, OBJPROP_FONTSIZE, 12);
      
      // Placer les ordres limit sur M5 Trend Entry Point
      PlaceSMCPredictionLimitOrders("BUY", bosLow + m5TrendSlope * 50, entry, stopLoss, takeProfit);
      
      Print("\n✅ === SMC PREDICTION SETUP HAUSSIER TRACÉ ===");
      Print("📍 BOS LEVEL: ", DoubleToString(bosLow, _Digits));
      Print("🔄 CHoCH LEVEL: ", DoubleToString(chochLevel, _Digits));
      Print("📦 ORDER BLOCK: ", DoubleToString(orderBlockLow, _Digits), " - ", DoubleToString(orderBlockHigh, _Digits));
      Print("⬆️ M5 TREND ENTRY: ", DoubleToString(bosLow + m5TrendSlope * 50, _Digits));
      Print("🎯 ENTRY (50%): ", DoubleToString(entry, _Digits));
      Print("🛑 STOP LOSS: ", DoubleToString(stopLoss, _Digits));
      Print("✅ TAKE PROFIT (RR 1:5): ", DoubleToString(takeProfit, _Digits));
      Print("⏱️ Projection: 200 bougies M1 (~3h20 min)\n");
   }
   else // BAISSIER
   {
      // Setup BAISSIER: cherche une zone à casser vers le bas
      bosHigh = swingHigh;
      bosLow = swingHigh - (swingHigh - swingLow) * 0.618;
      chochLevel = bosLow - (swingHigh - swingLow) * 0.2;
      orderBlockHigh = bosLow + (swingHigh - swingLow) * 0.05;
      orderBlockLow = bosLow - (swingHigh - swingLow) * 0.05;
      
      // Zones Fibonacci pour calcul de l'entrée
      double fiboRange = bosHigh - swingLow;
      double fibo_886 = bosHigh - fiboRange * 0.886;
      double fibo_79  = bosHigh - fiboRange * 0.79;
      double fibo_705 = bosHigh - fiboRange * 0.705;
      double fibo_50  = bosHigh - fiboRange * 0.50; // Entrée
      
      entry = fibo_50;
      stopLoss = bosHigh + (swingHigh - swingLow) * 0.1;
      double riskInPips = (stopLoss - entry) / SymbolInfoDouble(_Symbol, SYMBOL_POINT);
      takeProfit = entry - (riskInPips * 5 * SymbolInfoDouble(_Symbol, SYMBOL_POINT));
      
      dirColor = clrRed;
      entryColor = clrOrange;
      
      // === TRACER SETUP BAISSIER ===
      
      // 1. BOS
      string bosLine = "SMC_PRED_BOS_LINE";
      ObjectCreate(0, bosLine, OBJ_TREND, 0, timeStart, bosHigh, timeEnd, bosHigh);
      ObjectSetInteger(0, bosLine, OBJPROP_COLOR, clrOrange);
      ObjectSetInteger(0, bosLine, OBJPROP_STYLE, STYLE_DASH);
      ObjectSetInteger(0, bosLine, OBJPROP_WIDTH, 2);
      ObjectSetInteger(0, bosLine, OBJPROP_BACK, true);
      
      string bosLabel = "SMC_PRED_BOS_LABEL";
      ObjectCreate(0, bosLabel, OBJ_TEXT, 0, timeStart + PeriodSeconds(PERIOD_M1) * 10, bosHigh + (swingHigh - swingLow) * 0.02);
      ObjectSetString(0, bosLabel, OBJPROP_TEXT, "BOS");
      ObjectSetInteger(0, bosLabel, OBJPROP_COLOR, clrOrange);
      ObjectSetInteger(0, bosLabel, OBJPROP_FONTSIZE, 9);
      
      // 2. CHoCH
      string chochZone = "SMC_PRED_CHOCH_ZONE";
      ObjectCreate(0, chochZone, OBJ_RECTANGLE, 0, 
                   timeStart + PeriodSeconds(PERIOD_M1) * 30, chochLevel - (swingHigh - swingLow) * 0.02,
                   timeStart + PeriodSeconds(PERIOD_M1) * 50, chochLevel + (swingHigh - swingLow) * 0.02);
      ObjectSetInteger(0, chochZone, OBJPROP_COLOR, clrPurple);
      ObjectSetInteger(0, chochZone, OBJPROP_BGCOLOR, C'150,100,200');
      ObjectSetInteger(0, chochZone, OBJPROP_FILL, true);
      ObjectSetInteger(0, chochZone, OBJPROP_BACK, true);
      
      string chochLabel = "SMC_PRED_CHOCH_LABEL";
      ObjectCreate(0, chochLabel, OBJ_TEXT, 0, timeStart + PeriodSeconds(PERIOD_M1) * 35, chochLevel - (swingHigh - swingLow) * 0.05);
      ObjectSetString(0, chochLabel, OBJPROP_TEXT, "CHoCH");
      ObjectSetInteger(0, chochLabel, OBJPROP_COLOR, clrPurple);
      ObjectSetInteger(0, chochLabel, OBJPROP_FONTSIZE, 9);
      
      // 3. Order Block
      string obZone = "SMC_PRED_OB_ZONE";
      ObjectCreate(0, obZone, OBJ_RECTANGLE, 0, 
                   timeStart + PeriodSeconds(PERIOD_M1) * 50, orderBlockLow,
                   timeStart + PeriodSeconds(PERIOD_M1) * 80, orderBlockHigh);
      ObjectSetInteger(0, obZone, OBJPROP_COLOR, clrSkyBlue);
      ObjectSetInteger(0, obZone, OBJPROP_BGCOLOR, C'173,216,230');
      ObjectSetInteger(0, obZone, OBJPROP_FILL, true);
      ObjectSetInteger(0, obZone, OBJPROP_BACK, true);
      
      string obLabel = "SMC_PRED_OB_LABEL";
      ObjectCreate(0, obLabel, OBJ_TEXT, 0, timeStart + PeriodSeconds(PERIOD_M1) * 65, (orderBlockLow + orderBlockHigh) / 2);
      ObjectSetString(0, obLabel, OBJPROP_TEXT, "Order Block");
      ObjectSetInteger(0, obLabel, OBJPROP_COLOR, clrSkyBlue);
      ObjectSetInteger(0, obLabel, OBJPROP_FONTSIZE, 8);
      
      // 4. Zones Fibonacci
      DrawFibonacciLevelsForPrediction(timeStart, timeEnd, bosHigh, fibo_886, "886", clrGray);
      DrawFibonacciLevelsForPrediction(timeStart, timeEnd, bosHigh, fibo_79, "79", clrGray);
      DrawFibonacciLevelsForPrediction(timeStart, timeEnd, bosHigh, fibo_705, "705", clrGray);
      
      // 5. M5 TREND ENTRY POINT - Ligne de tendance baissière
      double m5TrendSlope_Down = (swingLow - bosHigh) / 100.0; // Pente négative
      string m5TrendLine = "SMC_PRED_M5_TREND_LINE";
      ObjectCreate(0, m5TrendLine, OBJ_TREND, 0, 
                   timeStart + PeriodSeconds(PERIOD_M1) * 80, bosHigh,
                   timeEnd, bosHigh + m5TrendSlope_Down * 120);
      ObjectSetInteger(0, m5TrendLine, OBJPROP_COLOR, clrYellow);
      ObjectSetInteger(0, m5TrendLine, OBJPROP_STYLE, STYLE_SOLID);
      ObjectSetInteger(0, m5TrendLine, OBJPROP_WIDTH, 2);
      ObjectSetInteger(0, m5TrendLine, OBJPROP_BACK, false);
      
      string m5TrendLabel = "SMC_PRED_M5_TREND_LABEL";
      ObjectCreate(0, m5TrendLabel, OBJ_TEXT, 0, timeStart + PeriodSeconds(PERIOD_M1) * 100, 
                   bosHigh + m5TrendSlope_Down * 40);
      ObjectSetString(0, m5TrendLabel, OBJPROP_TEXT, "M5 TREND ENTRY");
      ObjectSetInteger(0, m5TrendLabel, OBJPROP_COLOR, clrYellow);
      ObjectSetInteger(0, m5TrendLabel, OBJPROP_FONTSIZE, 9);
      ObjectSetInteger(0, m5TrendLabel, OBJPROP_BACK, false);
      
      // 5b. ENTRY au 50%
      string entryZone = "SMC_PRED_ENTRY_ZONE";
      ObjectCreate(0, entryZone, OBJ_RECTANGLE, 0, 
                   timeStart + PeriodSeconds(PERIOD_M1) * 80, entry - (swingHigh - swingLow) * 0.01,
                   timeStart + PeriodSeconds(PERIOD_M1) * 100, entry + (swingHigh - swingLow) * 0.01);
      ObjectSetInteger(0, entryZone, OBJPROP_COLOR, entryColor);
      ObjectSetInteger(0, entryZone, OBJPROP_BGCOLOR, C'255,165,0');
      ObjectSetInteger(0, entryZone, OBJPROP_FILL, true);
      ObjectSetInteger(0, entryZone, OBJPROP_BACK, true);
      
      string entryLine = "SMC_PRED_ENTRY_LINE";
      ObjectCreate(0, entryLine, OBJ_HLINE, 0, timeStart, entry);
      ObjectSetInteger(0, entryLine, OBJPROP_COLOR, entryColor);
      ObjectSetInteger(0, entryLine, OBJPROP_STYLE, STYLE_SOLID);
      ObjectSetInteger(0, entryLine, OBJPROP_WIDTH, 3);
      ObjectSetInteger(0, entryLine, OBJPROP_BACK, false);
      
      // Label d'entrée - VISIBLE (texte blanc)
      string entryLabel = "SMC_PRED_ENTRY_LABEL";
      CreateVisibleLabel(entryLabel, timeStart + PeriodSeconds(PERIOD_M1) * 85, 
                        entry - (swingHigh - swingLow) * 0.03, "🔴 ENTRY 50%", entryColor);
      
      // 6. STOP LOSS
      string slLine = "SMC_PRED_SL_LINE";
      ObjectCreate(0, slLine, OBJ_HLINE, 0, timeStart, stopLoss);
      ObjectSetInteger(0, slLine, OBJPROP_COLOR, clrRed);
      ObjectSetInteger(0, slLine, OBJPROP_STYLE, STYLE_DASH);
      ObjectSetInteger(0, slLine, OBJPROP_WIDTH, 2);
      ObjectSetInteger(0, slLine, OBJPROP_BACK, false);
      
      // Label SL - MINIMAL
      string slLabel = "SMC_PRED_SL_LABEL";
      CreateSmallLabel(slLabel, timeStart + PeriodSeconds(PERIOD_M1) * 5, 
                        stopLoss + (swingHigh - swingLow) * 0.02, "S", clrRed);
      
      // 7. TAKE PROFIT (RR 1:5)
      string tpLine = "SMC_PRED_TP_LINE";
      ObjectCreate(0, tpLine, OBJ_HLINE, 0, timeStart, takeProfit);
      ObjectSetInteger(0, tpLine, OBJPROP_COLOR, clrGreen);
      ObjectSetInteger(0, tpLine, OBJPROP_STYLE, STYLE_DASH);
      ObjectSetInteger(0, tpLine, OBJPROP_WIDTH, 2);
      ObjectSetInteger(0, tpLine, OBJPROP_BACK, false);
      
      // Label TP - MINIMAL
      string tpLabel = "SMC_PRED_TP_LABEL";
      CreateSmallLabel(tpLabel, timeStart + PeriodSeconds(PERIOD_M1) * 5, 
                        takeProfit - (swingHigh - swingLow) * 0.02, "T", clrGreen);
      
      // 8. TITRE SETUP
      string title = "SMC_PRED_TITLE";
      ObjectCreate(0, title, OBJ_TEXT, 0, timeStart + PeriodSeconds(PERIOD_M1) * 100, takeProfit - (swingHigh - swingLow) * 0.1);
      ObjectSetString(0, title, OBJPROP_TEXT, "⬇️ SMC PREDICTION SETUP BAISSIER (200M1) ⬇️");
      ObjectSetInteger(0, title, OBJPROP_COLOR, clrOrange);
      ObjectSetInteger(0, title, OBJPROP_FONTSIZE, 12);
      
      // Placer les ordres limit sur M5 Trend Entry Point
      PlaceSMCPredictionLimitOrders("SELL", bosHigh + m5TrendSlope_Down * 50, entry, stopLoss, takeProfit);
      
      Print("\n✅ === SMC PREDICTION SETUP BAISSIER TRACÉ ===");
      Print("📍 BOS LEVEL: ", DoubleToString(bosHigh, _Digits));
      Print("🔄 CHoCH LEVEL: ", DoubleToString(chochLevel, _Digits));
      Print("📦 ORDER BLOCK: ", DoubleToString(orderBlockLow, _Digits), " - ", DoubleToString(orderBlockHigh, _Digits));
      Print("⬇️ M5 TREND ENTRY: ", DoubleToString(bosHigh + m5TrendSlope_Down * 50, _Digits));
      Print("🎯 ENTRY (50%): ", DoubleToString(entry, _Digits));
      Print("🛑 STOP LOSS: ", DoubleToString(stopLoss, _Digits));
      Print("✅ TAKE PROFIT (RR 1:5): ", DoubleToString(takeProfit, _Digits));
      Print("⏱️ Projection: 200 bougies M1 (~3h20 min)\n");
   }
}

// Fonction utilitaire pour tracer les niveaux Fibonacci
void DrawFibonacciLevelsForPrediction(datetime timeStart, datetime timeEnd, double basePrice, double fiboPrice, string label, color col)
{
   string objName = "SMC_PRED_FIBO_" + label;
   ObjectCreate(0, objName, OBJ_HLINE, 0, timeStart, fiboPrice);
   ObjectSetInteger(0, objName, OBJPROP_COLOR, col);
   ObjectSetInteger(0, objName, OBJPROP_STYLE, STYLE_DOT);
   ObjectSetInteger(0, objName, OBJPROP_WIDTH, 1);
   ObjectSetInteger(0, objName, OBJPROP_BACK, true);
   
   string labelName = "SMC_PRED_FIBO_LABEL_" + label;
   ObjectCreate(0, labelName, OBJ_TEXT, 0, timeStart + PeriodSeconds(PERIOD_M1) * 20, fiboPrice);
   ObjectSetString(0, labelName, OBJPROP_TEXT, label + "%");
   ObjectSetInteger(0, labelName, OBJPROP_COLOR, col);
   ObjectSetInteger(0, labelName, OBJPROP_FONTSIZE, 7);
}

// Créer un label visible (texte blanc, sans fond)
void CreateVisibleLabel(string name, datetime time, double price, string text, color col)
{
   ObjectCreate(0, name, OBJ_TEXT, 0, time, price);
   ObjectSetString(0, name, OBJPROP_TEXT, text);
   ObjectSetInteger(0, name, OBJPROP_COLOR, clrWhite); // Texte blanc pour contraste
   ObjectSetInteger(0, name, OBJPROP_FONTSIZE, 10);
   ObjectSetInteger(0, name, OBJPROP_BACK, false); // Pas de fond
}

// Créer un petit label minimal (pour S/T/E)
void CreateSmallLabel(string name, datetime time, double price, string text, color col)
{
   ObjectCreate(0, name, OBJ_TEXT, 0, time, price);
   ObjectSetString(0, name, OBJPROP_TEXT, text);
   ObjectSetInteger(0, name, OBJPROP_COLOR, col);
   ObjectSetInteger(0, name, OBJPROP_FONTSIZE, 6);
   ObjectSetInteger(0, name, OBJPROP_BACK, false);
}

// Récupérer les niveaux du SMC Prediction Setup
struct SMCPredictionLevels
{
   string   direction;
   double   bosLevel;
   double   chochLevel;
   double   m5TrendEntryPoint;
   double   entry50Percent;
   double   stopLoss;
   double   takeProfit;
};

bool GetSMCPredictionSetupLevels(SMCPredictionLevels &levelsOut)
{
   MqlRates rates[];
   ArraySetAsSeries(rates, true);
   int copied = CopyRates(_Symbol, PERIOD_M1, 0, 50, rates);
   if(copied < 20) return false;
   
   double currentPrice = rates[0].close;
   double swingHigh = rates[0].high;
   double swingLow = rates[0].low;
   
   // Trouver le swing high/low sur les dernières 30 bougies
   for(int i = 0; i < 30 && i < copied; i++)
   {
      swingHigh = MathMax(swingHigh, rates[i].high);
      swingLow = MathMin(swingLow, rates[i].low);
   }
   
   // Déterminer la direction
   levelsOut.direction = (currentPrice > (swingHigh + swingLow) / 2) ? "BUY" : "SELL";
   
   if(levelsOut.direction == "BUY")
   {
      levelsOut.bosLevel = swingLow;
      double m5TrendSlope = (swingHigh - swingLow) / 100.0;
      levelsOut.m5TrendEntryPoint = swingLow + m5TrendSlope * 50;
      
      double fiboRange = swingHigh - swingLow;
      levelsOut.entry50Percent = swingLow + fiboRange * 0.50;
      levelsOut.stopLoss = swingLow - (swingHigh - swingLow) * 0.1;
      
      double riskInPips = (levelsOut.entry50Percent - levelsOut.stopLoss) / SymbolInfoDouble(_Symbol, SYMBOL_POINT);
      levelsOut.takeProfit = levelsOut.entry50Percent + (riskInPips * 5 * SymbolInfoDouble(_Symbol, SYMBOL_POINT));
      levelsOut.chochLevel = levelsOut.bosLevel + (swingHigh - swingLow) * 0.2;
   }
   else // SELL
   {
      levelsOut.bosLevel = swingHigh;
      double m5TrendSlope = (swingLow - swingHigh) / 100.0;
      levelsOut.m5TrendEntryPoint = swingHigh + m5TrendSlope * 50;
      
      double fiboRange = swingHigh - swingLow;
      levelsOut.entry50Percent = swingHigh - fiboRange * 0.50;
      levelsOut.stopLoss = swingHigh + (swingHigh - swingLow) * 0.1;
      
      double riskInPips = (levelsOut.stopLoss - levelsOut.entry50Percent) / SymbolInfoDouble(_Symbol, SYMBOL_POINT);
      levelsOut.takeProfit = levelsOut.entry50Percent - (riskInPips * 5 * SymbolInfoDouble(_Symbol, SYMBOL_POINT));
      levelsOut.chochLevel = levelsOut.bosLevel - (swingHigh - swingLow) * 0.2;
   }
   
   return true;
}

// Exécuter le trade SMC Prediction à partir de la détection de flèche
void ExecuteSMCPredictionArrowTrade()
{
   // Déterminer si une flèche pure existe
   bool hasBuyArrow = ChartHasPureColorArrowForBoomCrashDir("BUY");
   bool hasSellArrow = ChartHasPureColorArrowForBoomCrashDir("SELL");
   
   if(!hasBuyArrow && !hasSellArrow)
      return; // Pas de flèche détectée
   
   // Récupérer les niveaux du setup
   SMCPredictionLevels levels;
   if(!GetSMCPredictionSetupLevels(levels))
      return; // Impossible de calculer les niveaux
   
   // Déterminer si la flèche correspond à la direction du setup
   string detectedDir = "";
   if(hasBuyArrow && levels.direction == "BUY")
      detectedDir = "BUY";
   else if(hasSellArrow && levels.direction == "SELL")
      detectedDir = "SELL";
   else
      return; // Pas de correspondance flèche/setup
   
   // Vérifications de sécurité standard
   if(!IsDirectionAllowedForBoomCrash(_Symbol, detectedDir))
   {
      Print("🚫 SMC ARROW TRADE BLOQUÉ - Direction interdite: ", detectedDir);
      return;
   }
   
   if(UseAIServer && IsBoomCrashOrWeltradeDirectionalSynth(_Symbol) &&
      !IsBoomCrashDirectionAllowedByIA(_Symbol, detectedDir))
   {
      Print("🚫 SMC ARROW TRADE BLOQUÉ - Direction vs IA: ", detectedDir);
      return;
   }
   
   if(!CanOpenAdditionalPositionForSymbol(_Symbol, detectedDir))
   {
      Print("⚠️ SMC ARROW - Position déjà ouverte sur ", _Symbol, " | ", detectedDir);
      return;
   }
   
   // NOUVEAU FILTRE: IA Haute confiance = attendre EMA/M5_Entry Touch + M5 Conf
   if(!IsHighConfidenceEntryTouchConfirmed(detectedDir))
   {
      return; // On annule l'entrée au marché, on attend que le prix touche et confirme
   }

   // ===== ENTRÉE MARCHÉ =====
   double entryPrice = (detectedDir == "BUY") ? SymbolInfoDouble(_Symbol, SYMBOL_ASK)
                                              : SymbolInfoDouble(_Symbol, SYMBOL_BID);
   
   // Appliquer les inputs manuels du panel si activé
   double usedSL = levels.stopLoss;
   double usedTP = levels.takeProfit;
   ApplyManualPanelInputs(entryPrice, detectedDir, usedSL, usedTP);
   
   double lot = CalculateLotSizeFromManualRisk(entryPrice, usedSL);
   if(lot <= 0.0)
   {
      Print("❌ SMC ARROW TRADE BLOQUÉ - lot minimum indisponible");
      return;
   }
   
   bool success = false;
   if(detectedDir == "BUY")
   {
      success = trade.Buy(lot, _Symbol, entryPrice, usedSL, usedTP, 
                         "SMC_PRED_BUY");
   }
   else
   {
      success = trade.Sell(lot, _Symbol, entryPrice, usedSL, usedTP,
                          "SMC_PRED_SELL");
   }
   
   if(success)
   {
      Print("\n✅ === POSITION OUVERTE VIA SMC_DERIV_ARROW ===");
      Print("Direction: ", detectedDir);
      Print("Entry: ", DoubleToString(entryPrice, _Digits));
      Print("SL: ", DoubleToString(usedSL, _Digits));
      Print("TP: ", DoubleToString(usedTP, _Digits));
      Print("M5 TREND ENTRY: ", DoubleToString(levels.m5TrendEntryPoint, _Digits));
      Print("Lot: ", DoubleToString(lot, 2));
      
      // ===== ORDRES LIMIT SUR M5 TREND ENTRY POINT =====
      PlaceSMCPredictionLimitOrders(detectedDir, levels.m5TrendEntryPoint, levels.entry50Percent, 
                                    levels.stopLoss, levels.takeProfit);
   }
   else
   {
      Print("❌ Erreur ouverture position SMC_PRED: ", GetLastError());
   }
}

// Placer les ordres limit sur M5 Trend Entry Point
void PlaceSMCPredictionLimitOrders(string direction, double m5TrendEntry, double entry50,
                                   double stopLoss, double takeProfit)
{
   if(!IsDirectionAllowedForBoomCrash(_Symbol, direction)) return;
   if(IsMaxPositionsReached()) return;

   // Appliquer les inputs manuels du panel si activé
   double usedSL = stopLoss;
   double usedTP = takeProfit;
   ApplyManualPanelInputs(m5TrendEntry, direction, usedSL, usedTP);
   
   double lot = CalculateLotSizeFromManualRisk(m5TrendEntry, usedSL);
   if(lot <= 0.0) return;
   
   if(direction == "BUY")
   {
      // Ordre Buy Limit sur M5 Trend Entry Point
      bool limitSuccess = trade.BuyLimit(lot, m5TrendEntry, _Symbol, usedSL, usedTP,
                                        ORDER_TIME_GTC, 0, "SMC_PRED_LIMIT_BUY");
      if(limitSuccess)
      {
         Print("📍 ORDER LIMIT BUY placé");
         Print("   Price: ", DoubleToString(m5TrendEntry, _Digits));
         Print("   SL: ", DoubleToString(usedSL, _Digits));
         Print("   TP: ", DoubleToString(usedTP, _Digits));
         Print("   Lot: ", DoubleToString(lot, 2));
      }
      else
      {
         Print("⚠️ Erreur placement LIMIT BUY: ", GetLastError());
      }
   }
   else // SELL
   {
      // Ordre Sell Limit sur M5 Trend Entry Point
      bool limitSuccess = trade.SellLimit(lot, m5TrendEntry, _Symbol, usedSL, usedTP,
                                         ORDER_TIME_GTC, 0, "SMC_PRED_LIMIT_SELL");
      if(limitSuccess)
      {
         Print("📍 ORDER LIMIT SELL placé");
         Print("   Price: ", DoubleToString(m5TrendEntry, _Digits));
         Print("   SL: ", DoubleToString(usedSL, _Digits));
         Print("   TP: ", DoubleToString(usedTP, _Digits));
         Print("   Lot: ", DoubleToString(lot, 2));
      }
      else
      {
         Print("⚠️ Erreur placement LIMIT SELL: ", GetLastError());
      }
   }
}

//+------------------------------------------------------------------+
//| WRAPPER POUR CAPTURER TOUTES LES FERMETURES                    |
//+------------------------------------------------------------------+
bool PositionCloseWithLog(ulong ticket, string reason = "")
{
   if(CloseOnlyOnAIHoldOrBrokerSLTP)
   {
      string r = reason;
      StringToUpper(r);
      bool isAIHoldClose = (StringFind(r, "IA HOLD") >= 0);
      // Mode "CloseOnlyOnAIHoldOrBrokerSLTP" : historiquement, on bloquait toute fermeture
      // sauf quand la raison contient "IA HOLD". Or on a besoin que certains close auto
      // critiques (spike / timeout / cassure EMA) passent aussi.
      bool allowByAutoCloseTags =
         isAIHoldClose ||
         (StringFind(r, "IA80_ARROW") >= 0) ||
         (StringFind(r, "OTE SETUP") >= 0 && StringFind(r, "ABSENT") >= 0) ||
         (StringFind(r, "SPIKE") >= 0) ||
         // Ex: "Temps de détention maximum atteint"
         ((StringFind(r, "TEMPS") >= 0) && (StringFind(r, "DE") >= 0) &&
          (StringFind(r, "DÉTENTION") >= 0 || StringFind(r, "DETENTION") >= 0)) ||
         // Ex: "SELL cassé au-dessus EMA rapide (rallye)"
         (StringFind(r, "EMA") >= 0);

      if(!allowByAutoCloseTags)
      {
         Print("⛔ Fermeture active bloquée (mode SL/TP/IA HOLD, hors tags auto autorisés) | ticket=", ticket, " | reason=", reason);
         return false;
      }
   }

   // Anti-doublon de fermeture : si on tente plusieurs fois de fermer la même position dans un court délai,
   // MT5 renvoie souvent "Order to close this position already exists".
   static ulong   lastCloseTickets[16] = {0};
   static datetime lastCloseTimes[16]  = {0};
   static int     lastCloseIdx = 0;

   datetime now = TimeCurrent();
   for(int i = 0; i < 16; i++)
   {
      if(lastCloseTickets[i] == ticket && lastCloseTimes[i] > 0 && (now - lastCloseTimes[i]) <= 3)
      {
         Print("?? SKIP duplicate close (cooldown) | ticket=", ticket, " | reason=", reason);
         return true;
      }
   }

   // Obtenir les informations avant fermeture
   if(!PositionSelectByTicket(ticket))
   {
      Print("?? Position déjà fermée (skip) | ticket=", ticket, " | reason=", reason);
      return true;
   }
   else
   {
      string symbol = PositionGetString(POSITION_SYMBOL);
      double profit = PositionGetDouble(POSITION_PROFIT);
      double slPrice = PositionGetDouble(POSITION_SL);
      ENUM_POSITION_TYPE posType = (ENUM_POSITION_TYPE)PositionGetInteger(POSITION_TYPE);
      datetime openTime = (datetime)PositionGetInteger(POSITION_TIME);
      int secondsSinceOpen = (int)(now - openTime);

      if(BlockManualLossCloseBeforeSL && profit < 0.0 && slPrice > 0.0)
      {
         double pt = SymbolInfoDouble(symbol, SYMBOL_POINT);
         if(pt <= 0.0) pt = _Point;
         long stopsLevelPts = SymbolInfoInteger(symbol, SYMBOL_TRADE_STOPS_LEVEL);
         double tol = MathMax(pt * 2.0, (double)stopsLevelPts * pt);
         if(tol <= 0.0) tol = pt * 2.0;

         double bidNow = SymbolInfoDouble(symbol, SYMBOL_BID);
         double askNow = SymbolInfoDouble(symbol, SYMBOL_ASK);
         bool slHit = false;
         if(posType == POSITION_TYPE_BUY)
            slHit = (bidNow <= slPrice + tol);
         else if(posType == POSITION_TYPE_SELL)
            slHit = (askNow >= slPrice - tol);

         if(!slHit)
         {
            Print("⛔ Fermeture manuelle bloquée avant SL | ", symbol,
                  " | ticket=", ticket,
                  " | reason=", reason,
                  " | pnl=", DoubleToString(profit, 2),
                  " | SL=", DoubleToString(slPrice, _Digits));
            return false;
         }
      }
      
      // PROTECTION PERTE / SPIKE:
      // - Equité faible (< seuil): fermeture active autorisée seulement si perte <= seuil USD.
      // - Equité >= seuil: si "spike non arrivé", on laisse le trade aller au SL broker.
      string rsnProt = reason;
      StringToUpper(rsnProt);
      bool adverseSpikeExit = (StringFind(rsnProt, "SPIKE ADVERSE") >= 0);
      bool boomCrashSpikeAutoClose = (StringFind(rsnProt, "SPIKE CLOSE") >= 0);
      bool oteSetupGoneFromChart = (StringFind(rsnProt, "OTE SETUP") >= 0 && StringFind(rsnProt, "ABSENT") >= 0);
      bool ia80ArrowExit = (StringFind(rsnProt, "IA80_ARROW") >= 0);
      bool spikeNoArrivalExit =
         (!adverseSpikeExit) &&
         (
            boomCrashSpikeAutoClose ||
            (StringFind(rsnProt, "SANS SPIKE") >= 0) ||
            ((StringFind(rsnProt, "DERIV") >= 0) && (StringFind(rsnProt, "DISPARU") >= 0 || StringFind(rsnProt, "DISPARUE") >= 0))
         );
      double eqNow = AccountInfoDouble(ACCOUNT_EQUITY);
      bool lowEquity = (eqNow < SpikeNoArrivalAllowSLAboveEquityUSD);
      double earlyCutAbs = MathMax(0.0, SpikeNoArrivalEarlyCutLossUSD);

      if(profit < 0 && spikeNoArrivalExit && !lowEquity)
      {
         Print("SPIKE NON ARRIVE - Equite elevee, fermeture active bloquee (laisser SL)");
         Print("   Equite: ", DoubleToString(eqNow, 2), "$ >= ", DoubleToString(SpikeNoArrivalAllowSLAboveEquityUSD, 2), "$");
         Print("   Position: ", symbol, " | Ticket: ", ticket, " | PnL: ", DoubleToString(profit, 2), "$");
         Print("   Raison: ", reason);
         return false;
      }

      if(profit < 0 && lowEquity && profit > -earlyCutAbs && !adverseSpikeExit && !oteSetupGoneFromChart && !ia80ArrowExit)
      {
         Print("PROTECTION PERTE (equite faible) - Fermeture bloquee");
         Print("   Position: ", symbol, " | Ticket: ", ticket);
         Print("   Perte: ", DoubleToString(profit, 2), "$ > -", DoubleToString(earlyCutAbs, 2), "$ (seuil)");
         Print("   Equite: ", DoubleToString(eqNow, 2), "$ < ", DoubleToString(SpikeNoArrivalAllowSLAboveEquityUSD, 2), "$");
         Print("   Raison: ", reason, " | ACTION: Position maintenue");
         return false; // Bloquer la fermeture
      }
      
      // Si la perte depasse le seuil configure en equite faible, autoriser la fermeture active.
      if(profit < 0 && lowEquity && profit <= -earlyCutAbs)
      {
         Print("PERTE IMPORTANTE (equite faible) - Fermeture autorisee");
         Print("   Position: ", symbol, " | Ticket: ", ticket);
         Print("   Perte: ", DoubleToString(profit, 2), "$ <= -", DoubleToString(earlyCutAbs, 2), "$ (seuil depasse)");
         Print("   Equite: ", DoubleToString(eqNow, 2), "$ < ", DoubleToString(SpikeNoArrivalAllowSLAboveEquityUSD, 2), "$");
         Print("   Raison: ", reason, " | ACTION: Fermeture autorisee");
      }
      
      // Si profit positif, autoriser normalement
      if(profit >= 0)
      {
         Print("?? POSITION EN GAIN - Fermeture autorisée");
         Print("   ?? Position: ", symbol, " | Ticket: ", ticket);
         Print("   ?? Profit: ", DoubleToString(profit, 2), "$ | ACTION: Fermeture autorisée");
      }
      
      Print("?? FERMETURE DÉTECTÉE - ", symbol, 
            " | Ticket: ", ticket,
            " | Profit: ", DoubleToString(profit, 2), "$",
            " | Âge: ", secondsSinceOpen, "s",
            " | Raison: ", reason);
   }
   
   // Exécuter la fermeture réelle
   bool ok = trade.PositionClose(ticket);
   now = TimeCurrent();

   // Enregistrer l'historique pour empêcher les doublons
   lastCloseTickets[lastCloseIdx] = ticket;
   lastCloseTimes[lastCloseIdx]   = now;
   lastCloseIdx = (lastCloseIdx + 1) % 16;

   if(ok)
   {
      g_lastCloseActionTime = now;
      g_lastCloseActionSymbol = PositionSelectByTicket(ticket) ? PositionGetString(POSITION_SYMBOL) : _Symbol;
      return true;
   }

   // Si la position n'existe plus, c'est que quelqu'un l'a déjà fermée
   if(!PositionSelectByTicket(ticket))
   {
      g_lastCloseActionTime = now;
      return true;
   }

   // Si MT5/plateforme signale que la fermeture existe déjà, considérer comme OK (évite les retries).
   string c = trade.ResultComment();
   StringToLower(c);
   if(StringFind(c, "already exists") >= 0 || StringFind(c, "order to close") >= 0)
   {
      g_lastCloseActionTime = now;
      return true;
   }

   return false;
}

