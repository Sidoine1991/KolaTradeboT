void ProcessAIDecision(string jsonData)
{
   // Parser la rÃĐponse JSON du serveur IA
   // Format attendu: {"action": "BUY/SELL/HOLD", "confidence": 0.85, "alignment": "75%", "coherence": "82%"}
   
   g_lastAIUpdate = TimeCurrent();
   
   // Extraire l'action
   if(StringFind(jsonData, "\"action\":") >= 0)
   {
      int start = StringFind(jsonData, "\"action\":") + 9;
      int end = StringFind(jsonData, ",", start);
      if(end < 0) end = StringFind(jsonData, "}", start);
      
      if(end > start)
      {
         string action = StringSubstr(jsonData, start, end - start);
         StringReplace(action, "\"", "");
         StringReplace(action, " ", "");
         g_lastAIAction = action;
      }
   }
   
   // Extraire la confiance
   if(StringFind(jsonData, "\"confidence\":") >= 0)
   {
      int start = StringFind(jsonData, "\"confidence\":") + 13;
      int end = StringFind(jsonData, ",", start);
      if(end < 0) end = StringFind(jsonData, "}", start);
      
      if(end > start)
      {
         string confStr = StringSubstr(jsonData, start, end - start);
         g_lastAIConfidence = StringToDouble(confStr);
         NormalizeStoredAIConfidenceInPlace();
      }
   }
   
   // Extraire l'alignement
   if(StringFind(jsonData, "\"alignment\":") >= 0)
   {
      int start = StringFind(jsonData, "\"alignment\":") + 12;
      int end = StringFind(jsonData, ",", start);
      if(end < 0) end = StringFind(jsonData, "}", start);
      
      if(end > start)
      {
         string alignStr = StringSubstr(jsonData, start, end - start);
         StringReplace(alignStr, "\"", "");
         g_lastAIAlignment = alignStr;
      }
   }
   
   // Extraire la cohÃĐrence
   if(StringFind(jsonData, "\"coherence\":") >= 0)
   {
      int start = StringFind(jsonData, "\"coherence\":") + 13;
      int end = StringFind(jsonData, ",", start);
      if(end < 0) end = StringFind(jsonData, "}", start);
      
      if(end > start)
      {
         string cohStr = StringSubstr(jsonData, start, end - start);
         StringReplace(cohStr, "\"", "");
         g_lastAICoherence = cohStr;
      }
   }
   
   // Si aucune donnÃĐe trouvÃĐe, valeurs par dÃĐfaut
   if(g_lastAIAction == "") g_lastAIAction = "HOLD";
   NormalizeStoredAIConfidenceInPlace();
   if(g_lastAIConfidence == 0) g_lastAIConfidence = 0.5;
   if(g_lastAIAlignment == "") g_lastAIAlignment = "50%";
   if(g_lastAICoherence == "") g_lastAICoherence = "50%";
}

//| NOTIFICATION MOBILE POUR APPARITION FLÃCHE DERIV ARROW          |
void SendDerivArrowNotification(string direction, double entryPrice, double stopLoss, double takeProfit)
{
   if(!UseNotifications) return;

   // Calculer le gain estimÃĐ
   double risk = MathAbs(entryPrice - stopLoss);
   double reward = MathAbs(takeProfit - entryPrice);
   double estimatedGain = 0;
   
   // Calculer le gain en points et en dollars (pour lot 0.01)
   double pointValue = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_VALUE);
   double tickSize = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_SIZE);
   double pointsToTP = MathAbs(takeProfit - entryPrice) / tickSize;
   estimatedGain = pointsToTP * pointValue * 0.01; // Pour lot 0.01
   
   // Calculer le ratio Risk/Reward
   double riskRewardRatio = reward / risk;
   
   // Formater les prix
   string entryStr = DoubleToString(entryPrice, _Digits);
   string slStr = DoubleToString(stopLoss, _Digits);
   string tpStr = DoubleToString(takeProfit, _Digits);
   string gainStr = DoubleToString(estimatedGain, 2);
   string ratioStr = DoubleToString(riskRewardRatio, 2);
   
   string alertMsg = "?? DERIV ARROW " + direction + " - " + _Symbol + 
                    " @ " + entryStr + 
                    " | SL: " + slStr + 
                    " | TP: " + tpStr + 
                    " | Gain: $" + gainStr + 
                    " | R/R: 1:" + ratioStr;
   
   // Push / alerte desktop dÃĐsactivÃĐs ici (flÃĻche DERIV â  ordre exÃĐcutÃĐ) â log terminal uniquement
   Print(alertMsg);
   
   // Log dÃĐtaillÃĐ
   Print("?? DERIV ARROW (info graphique) ", direction);
   Print("?? Symbole: ", _Symbol);
   Print("?? Entry: ", entryStr, " | SL: ", slStr, " | TP: ", tpStr);
   Print("?? Gain estimÃĐ: $", gainStr, " | Risk/Reward: 1:", ratioStr);
}

void NotifyTradeEvent(const string message, const string soundFile = "alert.wav")
{
   if(UseNotifications)
   {
      Alert(message);
      SendNotification(message);
   }
   if(UseSoundNotifications && soundFile != "")
      PlaySound(soundFile);
}

// Alerte optionnelle + son optionnel (sons indÃĐpendants de UseNotifications si UseSoundNotifications)
void NotifyTradeLifecycle(const string message, const string soundFile)
{
   if(UseNotifications)
   {
      Alert(message);
      SendNotification(message);
   }
   if(UseSoundNotifications && soundFile != "")
      PlaySound(soundFile);
}

//| Push MetaTrader: flÃĻche DERIV pertinente (Boom=vert/BUY, Crash=rouge/SELL) â apparition / disparition |
void PollDerivArrowAppearDisappearPush()
{
   if(!UseNotifications || !NotifyDerivArrowBoomCrashPush) return;
   if(SMC_GetSymbolCategory(_Symbol) != SYM_BOOM_CRASH) return;

   bool wantBoom = IsBoomSymbol(_Symbol);
   bool wantCrash = IsCrashSymbol(_Symbol);
   if(!wantBoom && !wantCrash) return;

   // MÃŠme critÃĻre visuel que fermeture DERIV / IA80 (largeurâĨ1, lookback M1) â ÃĐvite push ÂŦ disparue Âŧ sans close
   bool relevant = false;
   if(wantBoom && ChartHasColoredSignalArrowForBoomCrashDir("BUY"))
      relevant = true;
   else if(wantCrash && ChartHasColoredSignalArrowForBoomCrashDir("SELL"))
      relevant = true;

   static bool s_hadRelevant = false;
   static datetime s_absentSince = 0;

   int holdSec = MathMax(1, NotifyDerivArrowDisappearHoldSec);
   datetime now = TimeCurrent();

   if(relevant)
   {
      s_absentSince = 0;
      // FlÃĻche visuelle dÃĐdiÃĐe au signal push (visible mÃŠme si flÃĻche source est peu lisible).
      string vName = "SMC_DERIV_NOTIFY_ARROW_" + _Symbol;
      double refPx = SymbolInfoDouble(_Symbol, SYMBOL_BID);
      if(refPx <= 0.0) refPx = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
      if(refPx > 0.0)
      {
         if(ObjectFind(0, vName) < 0)
            ObjectCreate(0, vName, OBJ_ARROW, 0, now, refPx);
         else
         {
            ObjectSetInteger(0, vName, OBJPROP_TIME, 0, now);
            ObjectSetDouble(0, vName, OBJPROP_PRICE, 0, refPx);
         }
         bool isBuyArrow = wantBoom;
         ObjectSetInteger(0, vName, OBJPROP_COLOR, isBuyArrow ? clrLime : clrRed);
         ObjectSetInteger(0, vName, OBJPROP_WIDTH, 5);
         ObjectSetInteger(0, vName, OBJPROP_ARROWCODE, isBuyArrow ? 233 : 234);
         ObjectSetInteger(0, vName, OBJPROP_BACK, false);
         g_lastDerivSignalArrowUtc = now;
      }
      if(!s_hadRelevant)
      {
         string label = wantBoom ? "VERTE (BUY) Boom" : "ROUGE (SELL) Crash";
         SendNotification("DERIV " + label + " â apparue | " + _Symbol);
         s_hadRelevant = true;
      }
      return;
   }

   // Plus de flÃĻche pertinente sur ce tick
   if(!s_hadRelevant)
      return;

   if(s_absentSince == 0)
      s_absentSince = now;
   else if((int)(now - s_absentSince) >= holdSec)
   {
      ObjectDelete(0, "SMC_DERIV_NOTIFY_ARROW_" + _Symbol);
      string label = wantBoom ? "verte BUY" : "rouge SELL";
      SendNotification("DERIV flÃĻche " + label + " â disparue | " + _Symbol);
      s_hadRelevant = false;
      s_absentSince = 0;
   }
}

// Boom/Crash: entrÃĐe marchÃĐ si confiance IA >= seuil et flÃĻche alignÃĐe sur le graphique (complÃĐment DERIV/touch ; OTE/Stair inchangÃĐs)
void TryOpenIA80DerivArrowAutoEntry()
{
   if(!UseIA80ArrowAutoEntry || BlockAllTrades) return;
   if(SMC_GetSymbolCategory(_Symbol) != SYM_BOOM_CRASH) return;
   if(!UseAIServer) return;

   static datetime s_lastIa80Dbg = 0;

   double minConf = IA80ArrowAutoMinConfidence;
   if(minConf > 1.0) minConf /= 100.0;
   if(minConf < 0.0 || minConf > 1.0) minConf = 0.80;

   if(NormalizeAIConfidenceUnit() + 1e-9 < minConf)
   {
      if(IA80ArrowDebugLog && TimeCurrent() - s_lastIa80Dbg >= 20)
      {
         Print("?? IA80 skip | confiance ", DoubleToString(NormalizeAIConfidenceUnit() * 100.0, 1),
               "% < ", DoubleToString(minConf * 100.0, 1), "% | ", _Symbol);
         s_lastIa80Dbg = TimeCurrent();
      }
      return;
   }

   string dir = "";
   if(IsBoomSymbol(_Symbol)) dir = "BUY";
   else if(IsCrashSymbol(_Symbol)) dir = "SELL";
   else if(IsWeltradeGainSynthSymbol(_Symbol)) dir = "BUY";
   else if(IsWeltradePainSynthSymbol(_Symbol)) dir = "SELL";
   else return;

   string ia = g_lastAIAction;
   StringToUpper(ia);

   bool oppDir = (IsBoomSymbol(_Symbol) && ia == "SELL") || (IsCrashSymbol(_Symbol) && ia == "BUY") ||
                 (IsWeltradeGainSynthSymbol(_Symbol) && ia == "SELL") || (IsWeltradePainSynthSymbol(_Symbol) && ia == "BUY");
   if(oppDir)
   {
      if(IA80ArrowDebugLog && TimeCurrent() - s_lastIa80Dbg >= 20)
      {
         Print("?? IA80 skip | IA explicite contre sens ", ia, " | ", _Symbol);
         s_lastIa80Dbg = TimeCurrent();
      }
      return;
   }

   bool strictAction = (ia == dir);
   if(strictAction)
   {
      if(!IsBoomCrashDirectionAllowedByIA(_Symbol, dir)) return;
   }
   else
   {
      if(!IA80ArrowAllowHighConfWithoutStrictAction)
      {
         if(IA80ArrowDebugLog && TimeCurrent() - s_lastIa80Dbg >= 20)
         {
            Print("?? IA80 skip | action IA '", g_lastAIAction, "' (attendu ", dir,
                  ") â activer IA80ArrowAllowHighConfWithoutStrictAction ou corriger le serveur IA | ", _Symbol);
            s_lastIa80Dbg = TimeCurrent();
         }
         return;
      }
   }

   // Laisser STAIR_ENTRY ouvrir le trade quand lâescalier M1 est validÃĐ (mÃŠme tick, plus bas dans OnTick)
   if(IA80ArrowDisableWhenStairM1Pattern && UseStairEntry && EnableTrading && !BlockAllTrades && StairEntryUseM1StairDetector)
   {
      string stairDir = "";
      if(IsBoomSymbol(_Symbol)) stairDir = "BUY";
      else if(IsCrashSymbol(_Symbol)) stairDir = "SELL";

      if(stairDir != "" && stairDir == dir && IsDirectionAllowedForBoomCrash(_Symbol, stairDir) &&
         IsSyntheticStairPatternM1(stairDir))
      {
         double stairMinPct = StairEntryEffectiveMinAiPctForSymbol(_Symbol);
         if(g_lastAIConfidence * 100.0 >= stairMinPct)
         {
            if(!StairEntryRequireStrongM1M5EMA || IsStrongM1M5TrendByEMAs(stairDir))
            {
               if(IA80ArrowDebugLog && TimeCurrent() - s_lastIa80Dbg >= 20)
               {
                  Print("?? IA80 skip | prioritÃĐ STAIR_ENTRY (escalier M1 + filtres stair) | ", _Symbol);
                  s_lastIa80Dbg = TimeCurrent();
               }
               return;
            }
         }
      }
   }

   if(!ChartHasColoredSignalArrowForBoomCrashDir(dir))
   {
      if(IA80ArrowDebugLog && TimeCurrent() - s_lastIa80Dbg >= 20)
      {
         Print("?? IA80 skip | aucune flÃĻche ", dir, " dÃĐtectÃĐe (mode ÃĐtendu: lookback M1=",
               IntegerToString(IA80ArrowLookbackM1Bars), " barres, largeur>=",
               IntegerToString(IA80ArrowMinObjWidth), ") | ", _Symbol);
         s_lastIa80Dbg = TimeCurrent();
      }
      return;
   }

   if(!IsSpreadAcceptable()) return;
   if(IsEntryCooldownActive()) return;
   if(CheckSymbolLossProtection()) return;
   if(IsMaxPositionsReached()) return;
   if(CountPendingOrdersForSymbol(_Symbol) > 0) return;
   if(CountPositionsForSymbol(_Symbol) >= 1) return;
   if(!CanOpenAdditionalPositionForSymbol(_Symbol, dir)) return;

   if(!TryAcquireOpenLock()) return;

   datetime m1bar = iTime(_Symbol, PERIOD_M1, 0);
   static datetime s_lastIa80EntryBar = 0;
   if(m1bar > 0 && m1bar == s_lastIa80EntryBar)
   {
      ReleaseOpenLock();
      return;
   }

   MqlRates r[];
   ArraySetAsSeries(r, true);
   if(CopyRates(_Symbol, PERIOD_CURRENT, 0, 1, r) < 1)
   {
      ReleaseOpenLock();
      return;
   }

   bool isBoom = IsBoomSymbol(_Symbol);
   bool isCrash = IsCrashSymbol(_Symbol);
   bool isWeltradeSynth = IsWeltradeGainSynthSymbol(_Symbol) || IsWeltradePainSynthSymbol(_Symbol);
   double currentPrice = r[0].close;
   double stopLoss = 0.0, takeProfit = 0.0;

   long stopsLevel = SymbolInfoInteger(_Symbol, SYMBOL_TRADE_STOPS_LEVEL);
   double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   double tickSize = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_SIZE);
   if(tickSize <= 0.0) tickSize = point;

   double minStopDistance = (double)stopsLevel * point;
   if(minStopDistance <= 0)
      minStopDistance = (isBoom || isCrash || isWeltradeSynth) ? (MathMax(1.0, BoomCrashSlMinPointsFloor) * point) : (20.0 * point);
   else if(isBoom || isCrash || isWeltradeSynth)
      minStopDistance = MathMax(minStopDistance, MathMax(1.0, BoomCrashSlBrokerFloorPoints) * point);

   double bcSlMult2 = BoomCrashSlSafeDistanceMult;
   if(bcSlMult2 < 1.01) bcSlMult2 = 1.01;
   double safeDistance = minStopDistance * ((isBoom || isCrash || isWeltradeSynth) ? bcSlMult2 : 2.0);

   if(dir == "BUY")
   {
      stopLoss = currentPrice - safeDistance;
      takeProfit = currentPrice + (safeDistance * 2.0);
   }
   else
   {
      stopLoss = currentPrice + safeDistance;
      takeProfit = currentPrice - (safeDistance * 2.0);
   }

   double askPrice = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   double bidPrice = SymbolInfoDouble(_Symbol, SYMBOL_BID);

   if(dir == "BUY")
   {
      if(askPrice - stopLoss < safeDistance) stopLoss = askPrice - safeDistance;
      if(takeProfit - askPrice < safeDistance) takeProfit = askPrice + (safeDistance * 2.0);
   }
   else
   {
      if(stopLoss - bidPrice < safeDistance) stopLoss = bidPrice + safeDistance;
      if(bidPrice - takeProfit < safeDistance) takeProfit = bidPrice - (safeDistance * 2.0);
   }

   if(dir == "BUY")
   {
      stopLoss = MathFloor(stopLoss / tickSize) * tickSize;
      takeProfit = MathCeil(takeProfit / tickSize) * tickSize;
   }
   else
   {
      stopLoss = MathCeil(stopLoss / tickSize) * tickSize;
      takeProfit = MathFloor(takeProfit / tickSize) * tickSize;
   }
   stopLoss = NormalizeDouble(stopLoss, _Digits);
   takeProfit = NormalizeDouble(takeProfit, _Digits);

   ValidateAndAdjustStopLossTakeProfit(dir, (dir == "BUY") ? askPrice : bidPrice, stopLoss, takeProfit);

   MqlTradeRequest request = {};
   MqlTradeResult result = {};
   request.action = TRADE_ACTION_DEAL;
   request.symbol = _Symbol;
   double lotToTrade = CalculateLotSize();
   if(lotToTrade <= 0.0)
   {
      ReleaseOpenLock();
      return;
   }
   request.volume = lotToTrade;
   request.type = (dir == "BUY") ? ORDER_TYPE_BUY : ORDER_TYPE_SELL;
   if(!IsOrderTypeAllowedForBoomCrash(_Symbol, request.type))
   {
      ReleaseOpenLock();
      return;
   }
   request.price = (dir == "BUY") ? askPrice : bidPrice;
   EnforceMinBoomCrashStopLossDollarRisk(_Symbol, dir, request.price, request.volume, stopLoss);
   request.sl = stopLoss;
   request.tp = takeProfit;
   request.deviation = 20;
   request.magic = InpMagicNumber;
   request.comment = "IA80_ARROW_AUTO " + dir;

   if(OrderSend(request, result))
   {
      g_lastEntryTimeForSymbol = TimeCurrent();
      s_lastIa80EntryBar = (m1bar > 0) ? m1bar : TimeCurrent();
      Print("â IA80+FLÃCHE - Ordre marchÃĐ ", dir, " | ", _Symbol,
            " | conf=", DoubleToString(NormalizeAIConfidenceUnit() * 100.0, 1), "% | ticket=", result.order);
      NotifyTradeEvent("â IA80+FLÃCHE " + dir + " " + _Symbol + " | ticket=" + IntegerToString((int)result.order),
                       EntryTradeSoundFile);
   }
   else
   {
      static datetime s_lastIa80SendFailLog = 0;
      if(TimeCurrent() - s_lastIa80SendFailLog >= 15)
      {
         Print("?? IA80 OrderSend ÃĐchec | ", _Symbol, " | retcode=", result.retcode,
               " | comment=", result.comment, " | lastError=", GetLastError());
         s_lastIa80SendFailLog = TimeCurrent();
      }
   }

   ReleaseOpenLock();
}

// Fermetures secondaires pour IA80_ARROW_AUTO (aprÃĻs ManageBoomCrashSpikeClose = prioritÃĐ spike)
void ManageIA80ArrowScalpExits()
{
   if(!UseIA80ArrowAutoEntry) return;
   if(PositionsTotal() == 0) return;

   static datetime s_arrowAbsentSince = 0;
   static ulong s_trackedTicket = 0;
   static datetime s_ia80ArrowAnchorTime = 0;

   int minWaitBase = MathMax(1, IA80ArrowMinSecondsBeforeExit);
   int needSmall = MathMax(1, IA80ArrowExitSmallM1Count);
   int holdArrow = MathMax(1, MathMax(IA80ArrowArrowGoneHoldSec, NotifyDerivArrowDisappearHoldSec));
   datetime now = TimeCurrent();

   bool anyIa80 = false;

   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      if(!posInfo.SelectByIndex(i)) continue;
      if(posInfo.Magic() != InpMagicNumber) continue;
      string symbol = posInfo.Symbol();
      if(SMC_GetSymbolCategory(symbol) != SYM_BOOM_CRASH) continue;

      string cmt = posInfo.Comment();
      if(StringFind(cmt, "IA80_ARROW_AUTO") < 0) continue;

      anyIa80 = true;
      ulong ticket = posInfo.Ticket();
      datetime openTime = posInfo.Time();
      int secOpen = (int)(now - openTime);

      string dirStr = (posInfo.PositionType() == POSITION_TYPE_BUY) ? "BUY" : "SELL";

      int minWait = MathMax(minWaitBase, EffectiveBoomCrashSpikeCloseMinSeconds(cmt, symbol));

      if(ticket != s_trackedTicket)
      {
         s_trackedTicket = ticket;
         s_arrowAbsentSince = 0;
         s_ia80ArrowAnchorTime = 0;
      }

      if(secOpen < minWait)
      {
         s_arrowAbsentSince = 0;
         continue;
      }

      bool arrowOkForAnchor = ChartHasColoredSignalArrowForBoomCrashDir(dirStr);
      if(arrowOkForAnchor && s_ia80ArrowAnchorTime == 0)
      {
         datetime arrT = 0;
         if(GetLatestColoredSignalArrowTimeForBoomCrashDir(dirStr, arrT) && arrT > 0)
            s_ia80ArrowAnchorTime = arrT;
      }

      datetime anchorRef = (s_ia80ArrowAnchorTime > 0) ? s_ia80ArrowAnchorTime : openTime;
      int smallSinceArrow = CountSmallM1CandlesSinceForSymbol(symbol, anchorRef);
      bool noSpikeNow = (!IsPriceSpikeDetectedForSymbol(symbol) && !IsBoomCrashM1SpikeRangeBars01(symbol));

      if(smallSinceArrow >= needSmall && noSpikeNow)
      {
         if(PositionCloseWithLog(ticket, "IA80_ARROW - " + IntegerToString(needSmall) + " petites M1 aprÃĻs flÃĻche sans spike"))
         {
            Print("?? IA80_ARROW fermÃĐ | ", needSmall, " petites M1 aprÃĻs flÃĻche (ancre ", TimeToString(anchorRef, TIME_DATE|TIME_MINUTES),
                  ") | ", symbol, " | ticket=", ticket);
            s_arrowAbsentSince = 0;
            s_trackedTicket = 0;
            s_ia80ArrowAnchorTime = 0;
         }
         continue;
      }

      bool arrowOk = ChartHasColoredSignalArrowForBoomCrashDir(dirStr);

      if(arrowOk)
         s_arrowAbsentSince = 0;
      else
      {
         if(s_arrowAbsentSince == 0) s_arrowAbsentSince = now;
         else if((int)(now - s_arrowAbsentSince) >= holdArrow)
         {
            if(PositionCloseWithLog(ticket, "IA80_ARROW - flÃĻche alignÃĐe disparue du graphique"))
            {
               Print("?? IA80_ARROW fermÃĐ | flÃĻche disparue | ", symbol, " | ticket=", ticket);
               s_arrowAbsentSince = 0;
               s_trackedTicket = 0;
               s_ia80ArrowAnchorTime = 0;
            }
         }
      }
   }

   if(!anyIa80)
   {
      s_arrowAbsentSince = 0;
      s_trackedTicket = 0;
      s_ia80ArrowAnchorTime = 0;
   }
}

// Anti-spam simple: 1 notification par ÃĐvÃĐnement et par bougie
bool ShouldNotifyOncePerBar(const string key, const string symbol, const ENUM_TIMEFRAMES tf)
{
   if(!UseNotifications) return false;

   datetime barTime = iTime(symbol, tf, 0);
   if(barTime <= 0)
      barTime = TimeCurrent();

   static string   s_keys[80];
   static datetime s_times[80];
   static int      s_size = 0;

   for(int i = 0; i < s_size; i++)
   {
      if(s_keys[i] == key)
      {
         if(s_times[i] == barTime) return false;
         s_times[i] = barTime;
         return true;
      }
   }

   if(s_size < 80)
   {
      s_keys[s_size] = key;
      s_times[s_size] = barTime;
      s_size++;
   }
   else
   {
      // overwrite oldest (simple round-robin)
      int idx = (int)(barTime % 80);
      s_keys[idx] = key;
      s_times[idx] = barTime;
   }
   return true;
}

void NotifyRobotEventOncePerBar(const string key, const string message, const string soundFile = "alert.wav",
                               const ENUM_TIMEFRAMES tf = PERIOD_M1)
{
   // Push mobile rÃĐservÃĐ aux ordres marchÃĐ (NotifyTradeEvent) et fermetures spike â ici journal seulement
   if(ShouldNotifyOncePerBar(key, _Symbol, tf))
      Print(message);
}

//| CALCUL D'ENTRÃE PRÃCISE - SYSTÃME AMÃLIORÃ                    |
bool CalculatePreciseEntryPoint(string direction, double &entryPrice, double &stopLoss, double &takeProfit)
{
   // RÃĐcupÃĐrer les donnÃĐes de marchÃĐ rÃĐcentes
   MqlRates rates[];
   ArraySetAsSeries(rates, true);
   if(CopyRates(_Symbol, PERIOD_M1, 0, 50, rates) < 50) return false;
   
   if(atrHandle == INVALID_HANDLE) return false;
   double atr[];
   ArraySetAsSeries(atr, true);
   if(CopyBuffer(atrHandle, 0, 0, 1, atr) < 1) return false;
   double atrValue = atr[0];
   
   // Analyser la structure de marchÃĐ
   double currentPrice = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double support = rates[0].low;
   double resistance = rates[0].high;
   
   // Trouver le support/rÃĐsistance le plus proche (last 10 bougies)
   for(int i = 1; i < 10; i++)
   {
      if(rates[i].low < support) support = rates[i].low;
      if(rates[i].high > resistance) resistance = rates[i].high;
   }
   
   // Calculer les niveaux de Fibonacci sur les 20 derniÃĻres bougies
   double highest = rates[0].high;
   double lowest = rates[0].low;
   for(int i = 1; i < 20; i++)
   {
      if(rates[i].high > highest) highest = rates[i].high;
      if(rates[i].low < lowest) lowest = rates[i].low;
   }
   
   double fib38_2 = lowest + (highest - lowest) * 0.382;
   double fib61_8 = lowest + (highest - lowest) * 0.618;
   
   // Calculer l'entrÃĐe prÃĐcise selon la direction
   if(direction == "BUY")
   {
      // EntrÃĐe BUY: au-dessus du support ou fib38_2
      double buyLevel1 = support + (atrValue * 0.5);
      double buyLevel2 = fib38_2 + (atrValue * 0.3);
      
      entryPrice = MathMax(buyLevel1, buyLevel2);
      
      // CORRECTION: SL avec distance minimum garantie pour Boom/Crash
      double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
      double minSLDistance = MathMax(atrValue * 1.0, 10.0 * point); // AugmentÃĐ Ã  10 points minimum
      stopLoss = entryPrice - minSLDistance;
      
      // CORRECTION: TP avec distance minimum garantie (ratio 2:1 minimum)
      double risk = entryPrice - stopLoss;
      double minTPDistance = MathMax(risk * 2.0, 20.0 * point); // AugmentÃĐ Ã  20 points minimum
      takeProfit = entryPrice + minTPDistance;
      
      // Validation: l'entrÃĐe doit ÃŠtre < prix actuel + 1 ATR
      if(entryPrice > currentPrice + atrValue) return false;
   }
   else // SELL
   {
      // EntrÃĐe SELL: sous la rÃĐsistance ou fib61_8
      double sellLevel1 = resistance - (atrValue * 0.5);
      double sellLevel2 = fib61_8 - (atrValue * 0.3);
      
      entryPrice = MathMin(sellLevel1, sellLevel2);
      
      // CORRECTION: SL avec distance minimum garantie pour Boom/Crash
      double minSLDistance = MathMax(atrValue * 1.0, 10.0 * SymbolInfoDouble(_Symbol, SYMBOL_POINT)); // AugmentÃĐ Ã  10 points minimum
      stopLoss = entryPrice + minSLDistance;
      
      // CORRECTION: TP avec distance minimum garantie (ratio 2:1 minimum)
      double risk = stopLoss - entryPrice;
      double minTPDistance = MathMax(risk * 2.0, 20.0 * SymbolInfoDouble(_Symbol, SYMBOL_POINT)); // AugmentÃĐ Ã  20 points minimum
      takeProfit = entryPrice - minTPDistance;
      
      // Validation: l'entrÃĐe doit ÃŠtre > prix actuel - 1 ATR
      if(entryPrice < currentPrice - atrValue) return false;
   }
   
   // Validation finale des distances
   long stopsLevel = 0;
   double point = 0.0;
   SymbolInfoInteger(_Symbol, SYMBOL_TRADE_STOPS_LEVEL, stopsLevel);
   SymbolInfoDouble(_Symbol, SYMBOL_POINT, point);
   double minDistance = (double)stopsLevel * point;
   
   // CORRECTION: Distance minimum plus rÃĐaliste pour Boom/Crash
   if(minDistance == 0) 
   {
      // Pour Boom/Crash, utiliser une distance minimum rÃĐaliste
      if(StringFind(_Symbol, "Boom") >= 0 || StringFind(_Symbol, "Crash") >= 0)
         minDistance = 15.0 * point; // AugmentÃĐ Ã  15 points minimum pour Boom/Crash
      else
         minDistance = atrValue * 0.5; // Distance par dÃĐfaut pour autres symboles
   }
   
   // S'assurer que la distance minimum est au moins 15 points
   if(minDistance < 15.0 * point)
      minDistance = 15.0 * point;
   
   // LOGS DE DÃBOGAGE DÃTAILLÃS POUR DIAGNOSTIC STOPS
   Print("ð DIAGNOSTIC STOPS - ", _Symbol, " | Direction: ", direction);
   Print("   ð Entry: ", DoubleToString(entryPrice, _Digits));
   Print("   ðĄïļ SL: ", DoubleToString(stopLoss, _Digits));
   Print("   ðŊ TP: ", DoubleToString(takeProfit, _Digits));
   Print("   ð Current Price: ", DoubleToString(currentPrice, _Digits));
   Print("   ð Min Distance: ", DoubleToString(minDistance, _Digits));
   Print("   ð Entry-SL Distance: ", DoubleToString(MathAbs(entryPrice - stopLoss), _Digits));
   Print("   ð TP-Entry Distance: ", DoubleToString(MathAbs(takeProfit - entryPrice), _Digits));
   Print("   ð Stops Level: ", IntegerToString((int)stopsLevel), " points");
   Print("   ð Point: ", DoubleToString(point, _Digits));
   
   if(MathAbs(entryPrice - stopLoss) < minDistance) 
   {
      Print("â STOP LOSS INVALIDE - Distance insuffisante: ", DoubleToString(MathAbs(entryPrice - stopLoss), _Digits), " < ", DoubleToString(minDistance, _Digits));
      return false;
   }
   if(MathAbs(takeProfit - entryPrice) < minDistance * 2) 
   {
      Print("â TAKE PROFIT INVALIDE - Distance insuffisante: ", DoubleToString(MathAbs(takeProfit - entryPrice), _Digits), " < ", DoubleToString(minDistance * 2, _Digits));
      return false;
   }
   
   Print("?? ENTRÃE PRÃCISE CALCULÃE - ", direction,
         " | Entry: ", DoubleToString(entryPrice, _Digits),
         " | SL: ", DoubleToString(stopLoss, _Digits),
         " | TP: ", DoubleToString(takeProfit, _Digits),
         " | Risk/Reward: 1:", DoubleToString(MathAbs(takeProfit - entryPrice) / MathAbs(entryPrice - stopLoss), 2));
   
   return true;
}

//| VALIDATION MULTI-SIGNAUX POUR ENTRÃES PRÃCISES               |
bool ValidateEntryWithMultipleSignals(string direction)
{
   MqlRates rates[];
   ArraySetAsSeries(rates, true);
   if(CopyRates(_Symbol, PERIOD_M1, 0, 30, rates) < 30) return false;
   
   int confirmationCount = 0;
   
   // 1. Confirmation par momentum (last 5 bougies)
   double momentum = 0;
   for(int i = 0; i < 5; i++)
   {
      momentum += (rates[i].close - rates[i].open) / rates[i].open;
   }
   bool momentumConfirm = (direction == "BUY" && momentum > 0.001) || 
                          (direction == "SELL" && momentum < -0.001);
   if(momentumConfirm) confirmationCount++;
   
   // 2. Confirmation par volume (comparaison aux 10 bougies prÃĐcÃĐdentes)
   double recentVolume = 0;
   double avgVolume = 0;
   for(int i = 0; i < 5; i++) recentVolume += (double)rates[i].tick_volume;
   for(int i = 5; i < 15; i++) avgVolume += (double)rates[i].tick_volume;
   recentVolume /= 5;
   avgVolume /= 10;
   
   bool volumeConfirm = recentVolume > avgVolume * 1.2; // Volume > 20% moyenne
   if(volumeConfirm) confirmationCount++;
   
   // 3. Confirmation par structure (pas de range)
   double range = rates[0].high - rates[0].low;
   double avgRange = 0;
   for(int i = 1; i < 10; i++) avgRange += rates[i].high - rates[i].low;
   avgRange /= 9;
   
   bool structureConfirm = range > avgRange * 0.8; // Range actuel > 80% moyenne
   if(structureConfirm) confirmationCount++;
   
   // 4. Confirmation par EMA (trend alignÃĐ)
   double ema[];
   ArraySetAsSeries(ema, true);
   bool emaConfirm = false;
   if(ema50H != INVALID_HANDLE && CopyBuffer(ema50H, 0, 0, 1, ema) >= 1)
   {
      emaConfirm = (direction == "BUY" && rates[0].close > ema[0]) ||
                   (direction == "SELL" && rates[0].close < ema[0]);
      if(emaConfirm) confirmationCount++;
   }

   // 4b. Retouche EMA (9/21/50/100/200) avant de reprendre un trade (anti-correction)
   bool emaTouchConfirm = true;
   if(RequireEMATouchBeforeEntry)
   {
      emaTouchConfirm = false;
      int lb = MathMax(3, EMATouchLookbackBarsM1);

      // On rÃĐcupÃĻre les valeurs EMA sur M1 pour comparer aux bougies M1
      int handles[5] = { emaHandle, ema21LTF, ema50LTF, ema100LTF, ema200LTF };
      double emaBuf[5][64];
      int need = MathMin(lb + 1, 64);

      for(int h = 0; h < 5; h++)
      {
         if(handles[h] == INVALID_HANDLE) continue;
         double tmp[];
         ArraySetAsSeries(tmp, true);
         if(CopyBuffer(handles[h], 0, 0, need, tmp) < need) continue;
         for(int i = 0; i < need; i++) emaBuf[h][i] = tmp[i];
      }

      double mid = (rates[0].close > 0.0) ? rates[0].close : SymbolInfoDouble(_Symbol, SYMBOL_BID);
      double maxDist = mid * (EMATouchMaxDistancePct / 100.0);
      if(maxDist <= 0.0) maxDist = SymbolInfoDouble(_Symbol, SYMBOL_POINT) * 10.0;

      // Touch = une bougie dont high/low encadre l'EMA OU close suffisamment proche de l'EMA
      for(int i = 1; i <= lb && i < 30; i++)
      {
         for(int h = 0; h < 5; h++)
         {
            if(handles[h] == INVALID_HANDLE) continue;
            double ev = emaBuf[h][i];
            if(ev <= 0.0) continue;
            bool crossed = (rates[i].low <= ev && rates[i].high >= ev);
            bool near = (MathAbs(rates[i].close - ev) <= maxDist);
            if(crossed || near)
            {
               emaTouchConfirm = true;
               break;
            }
         }
         if(emaTouchConfirm) break;
      }

      if(DebugEMATouchFilter)
      {
         static datetime lastDbg = 0;
         datetime now = TimeCurrent();
         if(now - lastDbg >= 10)
         {
            Print("EMA TOUCH DEBUG ", _Symbol, " dir=", direction,
                  " | ok=", (emaTouchConfirm ? "YES" : "NO"),
                  " | lb=", lb, " | maxDist=", DoubleToString(maxDist, _Digits));
            lastDbg = now;
         }
      }

      // Si pas de retouche EMA â bloquer (anti-correction / attendre pullback)
      if(!emaTouchConfirm) return false;
   }
   
   // 5. Confirmation par volatilitÃĐ (ni trop basse, ni trop ÃĐlevÃĐe)
   double volatility = range / rates[0].close;
   bool volatilityConfirm = (volatility > 0.0005 && volatility < 0.02);
   if(volatilityConfirm) confirmationCount++;
   
   Print("?? VALIDATION MULTI-SIGNAUX - ", direction,
         " | Confirmations: ", confirmationCount, "/5",
         " | Momentum: ", momentumConfirm ? "?" : "?",
         " | Volume: ", volumeConfirm ? "?" : "?",
         " | Structure: ", structureConfirm ? "?" : "?",
         " | EMA: ", emaConfirm ? "?" : "?",
         " | VolatilitÃĐ: ", volatilityConfirm ? "?" : "?");
   
   // Exiger au moins 3 confirmations sur 5
   return confirmationCount >= 3;
}

//| DÃTECTION AVANCÃE DE SPIKE IMMINENT                          |

// Calcule la compression de volatilitÃĐ (prÃĐdicteur de spike)
double CalculateVolatilityCompression()
{
   // VÃĐrifier si l'handle ATR est valide
   if(atrHandle == INVALID_HANDLE) return 0.0;
   
   double buffer[];
   ArraySetAsSeries(buffer, true);
   
   // Utiliser ATR sur 20 pÃĐriodes pour la volatilitÃĐ rÃĐcente
   if(CopyBuffer(atrHandle, 0, 0, 20, buffer) < 20) return 0.0;
   
   double recentATR = buffer[0];
   double avgATR = 0.0;
   
   // Calculer la moyenne ATR sur 20 pÃĐriodes
   for(int i = 0; i < 20; i++)
   {
      avgATR += buffer[i];
   }
   avgATR /= 20.0;
   
   // Compression = ratio ATR rÃĐcent / moyenne ATR
   if(avgATR == 0) return 0.0;
   return recentATR / avgATR;
}

// Calcule l'accÃĐlÃĐration du prix (prÃĐdicteur de momentum)
double CalculatePriceAcceleration()
{
   MqlRates rates[];
   ArraySetAsSeries(rates, true);
   
   if(CopyRates(_Symbol, PERIOD_M1, 0, 10, rates) < 10) return 0.0;
   
   // Calculer les variations de prix sur 3 pÃĐriodes
   double change1 = (rates[0].close - rates[1].close) / rates[1].close;
   double change2 = (rates[1].close - rates[2].close) / rates[2].close;
   double change3 = (rates[2].close - rates[3].close) / rates[3].close;
   
   // AccÃĐlÃĐration = variation des variations
   double acceleration = (change1 - change3) / 3.0;
   
   return acceleration;
}

// DÃĐtecte les pics de volume anormaux
bool DetectVolumeSpike()
{
   long volume[];
   ArraySetAsSeries(volume, true);
   
   if(CopyTickVolume(_Symbol, PERIOD_M1, 0, 20, volume) < 20) return false;
   
   double recentVolume = (double)volume[0];
   double avgVolume = 0.0;
   
   // Calculer la moyenne de volume sur 20 pÃĐriodes
   for(int i = 1; i < 20; i++) // Exclure la pÃĐriode la plus rÃĐcente
   {
      avgVolume += (double)volume[i];
   }
   avgVolume /= 19.0;
   
   // Spike si volume > 2x la moyenne
   return (recentVolume > avgVolume * 2.0);
}

// DÃĐtecte les patterns prÃĐ-spike spÃĐcifiques Boom/Crash
bool IsPreSpikePattern()
{
   MqlRates rates[];
   ArraySetAsSeries(rates, true);
   
   if(CopyRates(_Symbol, PERIOD_M1, 0, 50, rates) < 50) return false;
   
   // 1. DÃĐtection de compression (range qui se resserre)
   double high50 = rates[0].high;
   double low50  = rates[0].low;
   for(int i = 1; i < 50; i++)
   {
      if(rates[i].high > high50) high50 = rates[i].high;
      if(rates[i].low  < low50)  low50  = rates[i].low;
   }
   double range50 = high50 - low50;
   
   double high10 = rates[0].high;
   double low10  = rates[0].low;
   for(int i = 1; i < 10; i++)
   {
      if(rates[i].high > high10) high10 = rates[i].high;
      if(rates[i].low  < low10)  low10  = rates[i].low;
   }
   double range10 = high10 - low10;
   
   // Compression rÃĐcente si range10 < (ratio) du range50
   bool compression = (range10 < range50 * PreSpike_CompressionRatio);
   
   // 2. DÃĐtection de formation en coin/wedge
   double ma5 = 0, ma20 = 0;
   for(int i = 0; i < 5; i++) ma5 += rates[i].close;
   ma5 /= 5.0;
   for(int i = 0; i < 20; i++) ma20 += rates[i].close;
   ma20 /= 20.0;
   
   // Prix proche de la moyenne mobile (consolidation)
   bool consolidation = (MathAbs(rates[0].close - ma20) / ma20 < PreSpike_ConsolidationPct);
   
   // 3. VÃĐrifier si le prix est Ã  un niveau clÃĐ
   bool keyLevel = IsNearKeyLevel(rates[0].close);
   
   return (compression && consolidation && keyLevel);
}

// VÃĐrifie si le prix est prÃĻs d'un niveau clÃĐ (support/rÃĐsistance)
bool IsNearKeyLevel(double price)
{
   MqlRates rates[];
   ArraySetAsSeries(rates, true);
   if(CopyRates(_Symbol, PERIOD_M1, 0, 100, rates) < 100) return false;
   
   // Chercher les niveaux de swing points rÃĐcents
   for(int i = 5; i < 50; i++)
   {
      double high = rates[i].high;
      double low = rates[i].low;
      
      // Si prix est Ã  moins de X% d'un swing high/low
      if(MathAbs(price - high) / high < PreSpike_KeyLevelPct || MathAbs(price - low) / low < PreSpike_KeyLevelPct)
      {
         return true;
      }
   }
   
   return false;
}

// Calcule la probabilitÃĐ de spike imminent
double CalculateSpikeProbability()
{
   // Objectif: fournir une proba 0..1 stable et exploitable mÃŠme quand le serveur IA ne renvoie rien.
   // Utilise des signaux rapides: compression ATR, accÃĐlÃĐration, volume, range, prÃĐ-spike, proximitÃĐ canal.
   ENUM_SYMBOL_CATEGORY cat = SMC_GetSymbolCategory(_Symbol);

   double volCompression = 1.0;
   if(atrHandle != INVALID_HANDLE)
   {
      double atrBuf[];
      ArraySetAsSeries(atrBuf, true);
      if(CopyBuffer(atrHandle, 0, 0, 10, atrBuf) >= 6)
      {
         double recentATR = atrBuf[0];
         double avgATR = 0.0;
         for(int i = 1; i <= 5; i++) avgATR += atrBuf[i];
         avgATR /= 5.0;
         if(avgATR > 0.0) volCompression = recentATR / avgATR;
      }
   }

   // Rates M1 rapides
   MqlRates r5[];
   ArraySetAsSeries(r5, true);
   double accel = 0.0;
   double rangeRatio = 1.0;
   if(CopyRates(_Symbol, PERIOD_M1, 0, 6, r5) >= 3)
   {
      double change1 = (r5[0].close - r5[1].close) / (r5[1].close == 0 ? 1.0 : r5[1].close);
      double change2 = (r5[1].close - r5[2].close) / (r5[2].close == 0 ? 1.0 : r5[2].close);
      accel = (change1 - change2) / 2.0;

      double range0 = MathAbs(r5[0].high - r5[0].low);
      double avgRange = 0.0;
      for(int i = 1; i < 6; i++) avgRange += MathAbs(r5[i].high - r5[i].low);
      avgRange /= 5.0;
      if(avgRange > 0.0) rangeRatio = range0 / avgRange;
   }

   // Volume ratio
   double volRatio = 1.0;
   bool volumeSpike = false;
   long volTicks[];
   ArraySetAsSeries(volTicks, true);
   if(CopyTickVolume(_Symbol, PERIOD_M1, 0, 10, volTicks) >= 6)
   {
      double recentV = (double)volTicks[0];
      double avgV = 0.0;
      for(int i = 1; i <= 5; i++) avgV += (double)volTicks[i];
      avgV /= 5.0;
      if(avgV > 0.0) volRatio = recentV / avgV;
      volumeSpike = (volRatio >= 1.6);
   }

   // PrÃĐ-spike "light" (sans scan swing complet)
   bool preSpikePattern = false;
   MqlRates r60[];
   ArraySetAsSeries(r60, true);
   if(cat == SYM_BOOM_CRASH && CopyRates(_Symbol, PERIOD_M1, 0, 60, r60) >= 50)
   {
      double hi10 = r60[0].high, lo10 = r60[0].low;
      for(int i = 0; i < 10; i++) { hi10 = MathMax(hi10, r60[i].high); lo10 = MathMin(lo10, r60[i].low); }
      double range10 = hi10 - lo10;
      double hi50 = r60[0].high, lo50 = r60[0].low;
      for(int i = 0; i < 50; i++) { hi50 = MathMax(hi50, r60[i].high); lo50 = MathMin(lo50, r60[i].low); }
      double range50 = hi50 - lo50;

      double ma20 = 0.0;
      for(int i = 0; i < 20; i++) ma20 += r60[i].close;
      ma20 /= 20.0;
      bool compression = (range50 > 0.0 && range10 < range50 * PreSpike_CompressionRatio);
      bool consolidation = (ma20 > 0.0 && (MathAbs(r60[0].close - ma20) / ma20) < PreSpike_ConsolidationPct);
      preSpikePattern = (compression && consolidation);
   }

   // ProximitÃĐ canal SMC H1
   bool touchChannel = false;
   if(cat == SYM_BOOM_CRASH)
   {
      if(StringFind(_Symbol, "Boom") >= 0)  touchChannel = PriceTouchesLowerChannel();
      if(StringFind(_Symbol, "Crash") >= 0) touchChannel = PriceTouchesUpperChannel();
   }

   // Normalisation 0..1
   double sCompression = 0.0;
   if(volCompression < 1.0) sCompression = MathMin((1.0 - volCompression) / 0.6, 1.0); // 0.4 => 1.0
   double sAccel = MathMin(MathAbs(accel) / 0.003, 1.0);
   double sVolume = 0.0;
   if(volRatio > 1.0) sVolume = MathMin((volRatio - 1.0) / 1.5, 1.0);
   double sRange = 0.0;
   if(rangeRatio > 1.0) sRange = MathMin((rangeRatio - 1.0) / 1.0, 1.0);
   double sPre = preSpikePattern ? 1.0 : 0.0;
   double sChan = touchChannel ? 1.0 : 0.0;

   double probability =
      0.25 * sCompression +
      0.20 * sAccel +
      0.20 * sVolume +
      0.15 * sRange +
      0.10 * sPre +
      0.10 * sChan;

   probability = MathMax(0.0, MathMin(probability, 1.0));

   // Publier pour les filtres/affichages
   g_lastSpikeProbability = probability;
   g_lastSpikeUpdate      = TimeCurrent();

   return probability;
}

// Envoie une alerte de spike imminent - VERSION OPTIMISÃE
void CheckImminentSpike()
{
   // Uniquement sur Boom/Crash
   ENUM_SYMBOL_CATEGORY cat = SMC_GetSymbolCategory(_Symbol);
   if(cat != SYM_BOOM_CRASH) return;
   
   // ProbabilitÃĐ unifiÃĐe (mÃŠme algo que l'affichage / filtre)
   double finalSpikeProb = CalculateSpikeProbability();
   double volCompression = CalculateVolatilityCompression();
   bool volumeSpike = DetectVolumeSpike();
   
   // VÃĐrification finale
   if(finalSpikeProb < 0.0 || finalSpikeProb > 1.0) return;
   
   // Alerte si probabilitÃĐ ÃĐlevÃĐe (ajustÃĐe Ã  75% pour correspondre aux trades)
   if(finalSpikeProb > 0.75)
   {
      string alertMsg = "?? SPIKE IMMINENT sur " + _Symbol + 
                      " | ProbabilitÃĐ: " + DoubleToString(finalSpikeProb*100, 1) + "%" +
                      " | Compression: " + DoubleToString(volCompression*100, 1) + "%" +
                      " | Volume: " + (volumeSpike ? "SPIKE" : "Normal");
      
      Print(alertMsg);
      
      // Pas de push ÂŦ spike imminent Âŧ â seuls exÃĐcution marchÃĐ + fermeture spike captÃĐe notifient
      
      // Dessiner un marqueur visuel rapide
      DrawSpikeWarning(finalSpikeProb);
   }

   // Mode prediction proche (<= 1 minute): compte a rebours + fleche clignotante + entree marche auto.
   UpdateSpikeCountdownAndAutoEntry(finalSpikeProb);
}

void UpdateSpikeCountdownAndAutoEntry(const double spikeProb)
{
   if(!EnableSpikeCountdownAutoEntry) return;
   if(StringFind(_Symbol, "Boom") < 0 && StringFind(_Symbol, "Crash") < 0) return;

   datetime now = TimeCurrent();
   string countdownName = "SPIKE_COUNTDOWN_" + _Symbol;
   string arrowName = "SMC_DERIV_ARROW_" + _Symbol;

   if(!g_spikeCountdownActive && spikeProb >= SpikeCountdownTriggerProbability)
   {
      int maxSec = MathMax(10, SpikeCountdownMaxSeconds);
      int eta = (int)MathRound((1.0 - MathMin(1.0, spikeProb)) * maxSec);
      eta = MathMax(5, MathMin(maxSec, eta));
      g_spikeCountdownEnd = now + eta;
      g_spikeCountdownActive = true;
      Print("âģ SPIKE COUNTDOWN ARMÃ - ", _Symbol, " | ETA=", eta, "s | p=", DoubleToString(spikeProb * 100.0, 1), "%");
   }

   if(!g_spikeCountdownActive)
      return;

   int remaining = (int)(g_spikeCountdownEnd - now);
   if(remaining < 0) remaining = 0;

   // Affichage compte a rebours sur le chart
   if(ObjectFind(0, countdownName) < 0)
      ObjectCreate(0, countdownName, OBJ_LABEL, 0, 0, 0);
   ObjectSetInteger(0, countdownName, OBJPROP_CORNER, CORNER_LEFT_UPPER);
   ObjectSetInteger(0, countdownName, OBJPROP_XDISTANCE, 15);
   ObjectSetInteger(0, countdownName, OBJPROP_YDISTANCE, 40);
   ObjectSetInteger(0, countdownName, OBJPROP_FONTSIZE, 13);
   ObjectSetInteger(0, countdownName, OBJPROP_COLOR, (remaining <= 10 ? clrTomato : clrYellow));
   ObjectSetString(0, countdownName, OBJPROP_TEXT,
                   "SPIKE ETA " + IntegerToString(remaining) + "s | p=" + DoubleToString(spikeProb * 100.0, 1) + "%");

   // Faire clignoter la fleche SMC_DERIV_ARROW si elle existe
   if(ObjectFind(0, arrowName) >= 0)
   {
      bool blinkOn = ((now % 2) == 0);
      ObjectSetInteger(0, arrowName, OBJPROP_COLOR, blinkOn ? clrLime : clrRed);
      ObjectSetInteger(0, arrowName, OBJPROP_WIDTH, blinkOn ? 5 : 2);
   }

   // Conditions d'auto entree marche
   string ia = g_lastAIAction;
   StringToUpper(ia);
   bool isBoom = (StringFind(_Symbol, "Boom") >= 0);
   bool isCrash = (StringFind(_Symbol, "Crash") >= 0);
   string dir = "";
   if(isBoom) dir = "BUY";
   else if(isCrash) dir = "SELL";

   bool iaAligned = (dir != "" && ia == dir);
   bool confOk = (NormalizeAIConfidenceUnit() >= SpikeAutoEntryMinAIConfidence);
   bool cooldownOk = (g_lastSpikeAutoEntryTime == 0 || (now - g_lastSpikeAutoEntryTime) >= MathMax(10, SpikeAutoEntryCooldownSeconds));

   if(remaining <= 0)
   {
      if(spikeProb >= SpikeCountdownTriggerProbability && iaAligned && confOk && cooldownOk)
      {
         Print("ð SPIKE AUTO-ENTRY - ", _Symbol, " | dir=", dir,
               " | p=", DoubleToString(spikeProb * 100.0, 1), "% | IA=", g_lastAIAction,
               " ", DoubleToString(NormalizeAIConfidenceUnit() * 100.0, 1), "%");
         ExecuteSpikeTrade(dir);
         g_lastSpikeAutoEntryTime = now;
      }
      else
      {
         Print("â SPIKE AUTO-ENTRY annulÃĐe - ", _Symbol,
               " | p=", DoubleToString(spikeProb * 100.0, 1), "%",
               " | iaAligned=", (iaAligned ? "YES" : "NO"),
               " | confOk=", (confOk ? "YES" : "NO"),
               " | cooldownOk=", (cooldownOk ? "YES" : "NO"));
      }

      g_spikeCountdownActive = false;
      g_spikeCountdownEnd = 0;
      ObjectDelete(0, countdownName);
   }
}

//| DÃTECTION DES MOUVEMENTS DE RETOUR VERS CANAUX SMC               |
void CheckSMCChannelReturnMovements()
{
   // Uniquement sur Boom/Crash
   ENUM_SYMBOL_CATEGORY cat = SMC_GetSymbolCategory(_Symbol);
   if(cat != SYM_BOOM_CRASH) return;
   
   // RÃĐcupÃĐrer les canaux SMC H1
   string upperName = "SMC_CH_H1_UPPER";
   string lowerName = "SMC_CH_H1_LOWER";
   if(ObjectFind(0, upperName) < 0 || ObjectFind(0, lowerName) < 0) return;
   
   double upperPrice = ObjectGetDouble(0, upperName, OBJPROP_PRICE);
   double lowerPrice = ObjectGetDouble(0, lowerName, OBJPROP_PRICE);
   if(upperPrice <= 0 || lowerPrice <= 0) return;
   
   // Obtenir les prix actuels
   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   if(bid <= 0 || ask <= 0) return;
   
   // Obtenir l'ATR pour les calculs de distance
   double atrVal = 0.0;
   if(atrHandle != INVALID_HANDLE)
   {
      double atrBuf[];
      ArraySetAsSeries(atrBuf, true);
      if(CopyBuffer(atrHandle, 0, 0, 1, atrBuf) > 0)
         atrVal = atrBuf[0];
   }
   if(atrVal <= 0) atrVal = SymbolInfoDouble(_Symbol, SYMBOL_POINT) * 100;
   
   bool isBoom = (StringFind(_Symbol, "Boom") >= 0);
   bool isCrash = (StringFind(_Symbol, "Crash") >= 0);
   
   // RÃGLE STRICTE: BLOQUER TOUS LES MOUVEMENTS DE RETOUR BUY SUR BOOM SI IA = SELL
   string aiAction = g_lastAIAction;
   if(aiAction == "buy") aiAction = "BUY";
   if(aiAction == "sell") aiAction = "SELL";
   
   if(isBoom && aiAction == "SELL")
   {
      // Ne mÃŠme pas analyser les mouvements de retour si IA = SELL sur Boom
      return;
   }
   
   if(isCrash && aiAction == "BUY")
   {
      // Ne mÃŠme pas analyser les mouvements de retour si IA = BUY sur Crash
      return;
   }
   
   // Analyser les 5 derniÃĻres bougies pour dÃĐtecter un mouvement de retour
   MqlRates rates[];
   ArraySetAsSeries(rates, true);
   if(CopyRates(_Symbol, PERIOD_M1, 0, 5, rates) < 3) return;
   
   // DÃĐtecter si le prix fait un mouvement de retour vers un canal
   bool returnMovementDetected = false;
   string returnDirection = "";
   double returnStrength = 0.0;
   
   if(isBoom)
   {
      // Pour Boom: vÃĐrifier si le prix monte vers le canal infÃĐrieur aprÃĻs ÃŠtre descendu
      double currentDistance = bid - lowerPrice;
      double previousDistance = rates[1].close - lowerPrice;
      
      // Mouvement de retour: la distance au canal diminue significativement
      if(previousDistance > currentDistance && previousDistance - currentDistance > atrVal * 0.3)
      {
         returnMovementDetected = true;
         returnDirection = "BUY";
         returnStrength = (previousDistance - currentDistance) / atrVal;
         
         // VÃĐrifier si le mouvement est assez fort pour justifier une entrÃĐe immÃĐdiate
         if(returnStrength >= 0.5 && currentDistance <= atrVal * 3.0)
         {
            Print("?? MOUVEMENT RETOUR BOOM - Vers canal infÃĐrieur | Force: ", DoubleToString(returnStrength, 1), " ATR | Distance: ", DoubleToString(currentDistance/atrVal, 1), " ATR");
            
            // Placer un ordre limite plus proche pour capturer ce mouvement
            PlaceReturnMovementLimitOrder("BUY", bid, lowerPrice, atrVal, returnStrength);
         }
      }
   }
   else if(isCrash)
   {
      // Pour Crash: vÃĐrifier si le prix descend vers le canal supÃĐrieur aprÃĻs ÃŠtre montÃĐ
      double currentDistance = upperPrice - ask;
      double previousDistance = upperPrice - rates[1].close;
      
      // Mouvement de retour: la distance au canal diminue significativement
      if(previousDistance > currentDistance && previousDistance - currentDistance > atrVal * 0.3)
      {
         returnMovementDetected = true;
         returnDirection = "SELL";
         returnStrength = (previousDistance - currentDistance) / atrVal;
         
         // VÃĐrifier si le mouvement est assez fort pour justifier une entrÃĐe immÃĐdiate
         if(returnStrength >= 0.5 && currentDistance <= atrVal * 3.0)
         {
            Print("?? MOUVEMENT RETOUR CRASH - Vers canal supÃĐrieur | Force: ", DoubleToString(returnStrength, 1), " ATR | Distance: ", DoubleToString(currentDistance/atrVal, 1), " ATR");
            
            // Placer un ordre limite plus proche pour capturer ce mouvement
            PlaceReturnMovementLimitOrder("SELL", ask, upperPrice, atrVal, returnStrength);
         }
      }
   }
}

//| PLACEMENT D'ORDRE LIMITE POUR MOUVEMENT DE RETOUR               |
void PlaceReturnMovementLimitOrder(string direction, double currentPrice, double channelPrice, double atrVal, double strength)
{
   if(!IsDirectionAllowedForBoomCrash(_Symbol, direction))
   {
      Print("ðŦ RETURN LIMIT BLOQUÃ - Direction interdite sur ", _Symbol, " : ", direction);
      return;
   }

   // BLOCAGE SÃCURITÃ: NE PAS PLACER D'ORDRES SI IA EST EN HOLD
   string aiAction = g_lastAIAction;
   StringToUpper(aiAction);
   if(aiAction == "HOLD")
   {
      Print("?? ORDRE RETOUR BLOQUÃ - IA en HOLD sur ", _Symbol, " - SÃĐcuritÃĐ activÃĐe");
      return;
   }
   
   // VÃĐrifier si on a dÃĐjÃ  un ordre de retour en cours
   int countReturnOrders = 0;
   for(int i = OrdersTotal() - 1; i >= 0; i--)
   {
      ulong ticket = OrderGetTicket(i);
      if(ticket == 0) continue;
      if(OrderGetInteger(ORDER_MAGIC) != InpMagicNumber) continue;
      if(OrderGetString(ORDER_SYMBOL) != _Symbol) continue;
      if(StringFind(OrderGetString(ORDER_COMMENT), "RETURN_MOVE") >= 0) countReturnOrders++;
   }
   if(countReturnOrders >= 1) return; // Un seul ordre de retour Ã  la fois
   
   // Limite globale: maximum 2 ordres LIMIT par symbole, dont 1 seul hors canal
   {
      int totalLimits = CountOpenLimitOrdersForSymbol(_Symbol);
      int chanLimits  = CountChannelLimitOrdersForSymbol(_Symbol);
      int otherLimits = totalLimits - chanLimits;
      // Pour Boom/Crash: un seul LIMIT proche Ã  la fois
      if(totalLimits >= 1 || otherLimits >= 1) return;
   }
   
   // RÃĐentrÃĐe aprÃĻs perte sur ce symbole: exiger conditions exceptionnelles (IA ?90% + spike/setup fort)
   if(!AllowReentryAfterRecentLoss(_Symbol, direction, strength >= 0.8))
      return;
   
   if(CountPositionsForSymbol(_Symbol) > 0) return; // Pas d'ordre si dÃĐjÃ  en position
   if(!TryAcquireOpenLock()) return;
   
   double lot = CalculateLotSize();
   if(lot <= 0) { ReleaseOpenLock(); return; }
   
   // Calculer le prix d'entrÃĐe optimisÃĐ pour le mouvement de retour
   double entryPrice;
   double distanceToChannel = MathAbs(currentPrice - channelPrice);
   
   if(direction == "BUY")
   {
      // PrioritÃĐ SuperTrend support: entrÃĐe juste au-dessus du support, mais < prix actuel
      double stSupp = 0.0, stRes = 0.0;
      double tmpS = 0.0, tmpR = 0.0;
      if(GetSuperTrendLevel(PERIOD_M5, tmpS, tmpR) && tmpS > 0) stSupp = tmpS;
      else if(GetSuperTrendLevel(PERIOD_H1, tmpS, tmpR) && tmpS > 0) stSupp = tmpS;
      if(stSupp > 0 && stSupp < currentPrice)
      {
         double candidate = stSupp + atrVal * 0.15;
         if(candidate < currentPrice)
            entryPrice = candidate;
         else
            entryPrice = currentPrice - atrVal * 0.5;
      }
      else
      {
      // BUY: placer l'ordre entre le prix actuel et le canal, plus proche du prix
      if(distanceToChannel <= atrVal * 2.0)
         entryPrice = channelPrice + (atrVal * 0.2); // TrÃĻs proche du canal
      else if(distanceToChannel <= atrVal * 4.0)
         entryPrice = currentPrice - (atrVal * 0.8); // Plus proche du prix
      else
         entryPrice = currentPrice - (atrVal * 1.2); // Distance modÃĐrÃĐe
      }
      
      if(entryPrice >= currentPrice) { ReleaseOpenLock(); return; }
      
      // Placer l'ordre BUY LIMIT
      MqlTradeRequest req;
      MqlTradeResult  res;
      ZeroMemory(req);
      ZeroMemory(res);
      req.action = TRADE_ACTION_PENDING;
      req.symbol = _Symbol;
      req.magic = InpMagicNumber;
      req.volume = lot;
      req.type = ORDER_TYPE_BUY_LIMIT;
      req.price = entryPrice;
      req.sl = entryPrice - atrVal * 2.0;
      req.tp = entryPrice + atrVal * 4.0;
      req.comment = "RETURN_MOVE BUY LIMIT";
      
      if(OrderSend(req, res))
      {
         Print("? ORDRE RETOUR BUY PLACÃ - Entry: ", DoubleToString(entryPrice, _Digits), 
               " | Force: ", DoubleToString(strength, 1), " ATR");
      }
      else
      {
         Print("? ÃCHEC ORDRE RETOUR BUY - Erreur: ", res.retcode);
      }
   }
   else // SELL
   {
      // PrioritÃĐ SuperTrend rÃĐsistance: entrÃĐe juste en-dessous de la rÃĐsistance, mais > prix actuel
      double stSupp = 0.0, stRes = 0.0;
      double tmpS = 0.0, tmpR = 0.0;
      if(GetSuperTrendLevel(PERIOD_M5, tmpS, tmpR) && tmpR > 0) stRes = tmpR;
      else if(GetSuperTrendLevel(PERIOD_H1, tmpS, tmpR) && tmpR > 0) stRes = tmpR;
      if(stRes > 0 && stRes > currentPrice)
      {
         double candidate = stRes - atrVal * 0.15;
         if(candidate > currentPrice)
            entryPrice = candidate;
         else
            entryPrice = currentPrice + atrVal * 0.5;
      }
      else
      {
      // SELL: placer l'ordre entre le prix actuel et le canal, plus proche du prix
      if(distanceToChannel <= atrVal * 2.0)
         entryPrice = channelPrice - (atrVal * 0.2); // TrÃĻs proche du canal
      else if(distanceToChannel <= atrVal * 4.0)
         entryPrice = currentPrice + (atrVal * 0.8); // Plus proche du prix
      else
         entryPrice = currentPrice + (atrVal * 1.2); // Distance modÃĐrÃĐe
      }
      
      if(entryPrice <= currentPrice) { ReleaseOpenLock(); return; }
      
      // Placer l'ordre SELL LIMIT
      MqlTradeRequest req;
      MqlTradeResult  res;
      ZeroMemory(req);
      ZeroMemory(res);
      req.action = TRADE_ACTION_PENDING;
      req.symbol = _Symbol;
      req.magic = InpMagicNumber;
      req.volume = lot;
      req.type = ORDER_TYPE_SELL_LIMIT;
      req.price = entryPrice;
      req.sl = entryPrice + atrVal * 2.0;
      req.tp = entryPrice - atrVal * 4.0;
      req.comment = "RETURN_MOVE SELL LIMIT";
      
      if(OrderSend(req, res))
      {
         Print("? ORDRE RETOUR SELL PLACÃ - Entry: ", DoubleToString(entryPrice, _Digits), 
               " | Force: ", DoubleToString(strength, 1), " ATR");
      }
      else
      {
         Print("? ÃCHEC ORDRE RETOUR SELL - Erreur: ", res.retcode);
      }
   }
   
   ReleaseOpenLock();
}

// ===================================================================
// STRATÃGIE SMC_OTE COMPLÃTE - DESSINS ET DÃTECTION
// 3 Ãtapes: 1) Tendance  2) Imbalance  3) OTE Zone
// ===================================================================

// Dessiner tous les ÃĐlÃĐments de la stratÃĐgie SMC_OTE
void DrawSMC_OTEStrategy()
{
   if(!ShowOTEImbalanceOnChart) return;
   
   // 1) Dessiner la tendance et structure de marchÃĐ
   DrawSMC_TrendAndStructure();
   
   // 2) Dessiner les zones d'Imbalance (FVG)
   DrawSMC_ImbalanceZones();
   
   // 3) Dessiner les zones OTE (Fibonacci 0.62-0.786)
   DrawSMC_OTEZones();
   
   // 4) Dessiner les setups 5 ÃĐtoiles (confluence complÃĻte)
   DrawSMC_FiveStarSetups();
}

bool IsSMCOTEAllowedForSymbolCategory(const ENUM_SYMBOL_CATEGORY cat)
{
   switch(cat)
   {
      case SYM_FOREX:          return SMC_OTE_AllowForex;
      case SYM_METAL:          return SMC_OTE_AllowMetals;
      case SYM_COMMODITY:      return SMC_OTE_AllowCommodities;
      case SYM_BOOM_CRASH:     return SMC_OTE_AllowBoomCrash;
      case SYM_WELTRADE_SYNTH: return SMC_OTE_AllowWeltradeSynth;
      case SYM_VOLATILITY:     return SMC_OTE_AllowVolatility;
      default:                 return false;
   }
}

// 1) DESSINER LA TENDANCE ET STRUCTURE DE MARCHÃ - VERSION STYLÃE
void DrawSMC_TrendAndStructure()
{
   // DÃĐtecter et dessiner les points High/Low protÃĐgÃĐs
   DrawProtectedHighsLows();
   
   // DÃĐtecter et dessiner les BOS (Break Of Structure)
   DrawBOSPoints();
   
   // DÃĐtecter et dessiner les CHoCH (Change of Character)
   DrawCHoCHPoints();
   
   // Dessiner la ligne de tendance principale
   DrawMainTrendLine();
}

// Dessiner les Highs et Lows protÃĐgÃĐs - VERSION STYLÃE
void DrawProtectedHighsLows()
{
   MqlRates rates[];
   ArraySetAsSeries(rates, true);
   if(CopyRates(_Symbol, LTF, 0, 100, rates) < 50) return;
   
   // Nettoyer les anciens dessins
   ObjectsDeleteAll(0, "PROTECTED_HIGH_");
   ObjectsDeleteAll(0, "PROTECTED_LOW_");
   
   // Limiter le nombre de points affichÃĐs
   int maxPoints = 3;
   int highCount = 0, lowCount = 0;
   
   // DÃĐtecter les highs protÃĐgÃĐs (limitÃĐ Ã  3)
   for(int i = 5; i < 45 && highCount < maxPoints; i++)
   {
      bool isProtectedHigh = true;
      double currentHigh = rates[i].high;
      
      // VÃĐrifier si ce high est protÃĐgÃĐ
      for(int j = MathMax(0, i-10); j < i; j++)
      {
         if(rates[j].high > currentHigh)
         {
            isProtectedHigh = false;
            break;
         }
      }
      
      if(isProtectedHigh && currentHigh > 0)
      {
         string highName = "PROTECTED_HIGH_" + IntegerToString(highCount);
         
         // Ligne horizontale fine au lieu de texte
         ObjectCreate(0, highName, OBJ_HLINE, 0, 0, currentHigh);
         ObjectSetInteger(0, highName, OBJPROP_COLOR, clrBlue);
         ObjectSetInteger(0, highName, OBJPROP_STYLE, STYLE_DOT);
         ObjectSetInteger(0, highName, OBJPROP_WIDTH, 1);
         ObjectSetInteger(0, highName, OBJPROP_BACK, true);
         
         // Petit point indicateur
         string pointName = "PROTECTED_HIGH_POINT_" + IntegerToString(highCount);
         ObjectCreate(0, pointName, OBJ_ARROW, 0, rates[i].time, currentHigh);
         ObjectSetInteger(0, pointName, OBJPROP_COLOR, clrBlue);
         ObjectSetInteger(0, pointName, OBJPROP_ARROWCODE, 159); // Cercle
         ObjectSetInteger(0, pointName, OBJPROP_WIDTH, 2);
         
         highCount++;
      }
   }
   
   // DÃĐtecter les lows protÃĐgÃĐs (limitÃĐ Ã  3)
   for(int i = 5; i < 45 && lowCount < maxPoints; i++)
   {
      bool isProtectedLow = true;
      double currentLow = rates[i].low;
      
      // VÃĐrifier si ce low est protÃĐgÃĐ
      for(int j = MathMax(0, i-10); j < i; j++)
      {
         if(rates[j].low < currentLow)
         {
            isProtectedLow = false;
            break;
         }
      }
      
      if(isProtectedLow && currentLow > 0)
      {
         string lowName = "PROTECTED_LOW_" + IntegerToString(lowCount);
         
         // Ligne horizontale fine au lieu de texte
         ObjectCreate(0, lowName, OBJ_HLINE, 0, 0, currentLow);
         ObjectSetInteger(0, lowName, OBJPROP_COLOR, clrRed);
         ObjectSetInteger(0, lowName, OBJPROP_STYLE, STYLE_DOT);
         ObjectSetInteger(0, lowName, OBJPROP_WIDTH, 1);
         ObjectSetInteger(0, lowName, OBJPROP_BACK, true);
         
         // Petit point indicateur
         string pointName = "PROTECTED_LOW_POINT_" + IntegerToString(lowCount);
         ObjectCreate(0, pointName, OBJ_ARROW, 0, rates[i].time, currentLow);
         ObjectSetInteger(0, pointName, OBJPROP_COLOR, clrRed);
         ObjectSetInteger(0, pointName, OBJPROP_ARROWCODE, 159); // Cercle
         ObjectSetInteger(0, pointName, OBJPROP_WIDTH, 2);
         
         lowCount++;
      }
   }
}

// Dessiner les points BOS - VERSION STYLÃE
void DrawBOSPoints()
{
   MqlRates rates[];
   ArraySetAsSeries(rates, true);
   if(CopyRates(_Symbol, LTF, 0, 100, rates) < 50) return;
   
   // Nettoyer les anciens dessins
   ObjectsDeleteAll(0, "BOS_");
   
   // Limiter le nombre de points BOS
   int maxBOS = 2;
   int bosCount = 0;
   
   for(int i = 10; i < 40 && bosCount < maxBOS; i++)
   {
      // BOS Haussier
      if(rates[i].high > rates[i+5].high && rates[i+3].low < rates[i+8].low)
      {
         string bosName = "BOS_BUY_" + IntegerToString(bosCount);
         ObjectCreate(0, bosName, OBJ_ARROW, 0, rates[i].time, rates[i].high);
         ObjectSetInteger(0, bosName, OBJPROP_COLOR, clrLime);
         ObjectSetInteger(0, bosName, OBJPROP_ARROWCODE, 233);
         ObjectSetInteger(0, bosName, OBJPROP_WIDTH, 3);
         
         bosCount++;
      }
      
      // BOS Baissier
      if(rates[i].low < rates[i+5].low && rates[i+3].high > rates[i+8].high)
      {
         string bosName = "BOS_SELL_" + IntegerToString(bosCount);
         ObjectCreate(0, bosName, OBJ_ARROW, 0, rates[i].time, rates[i].low);
         ObjectSetInteger(0, bosName, OBJPROP_COLOR, clrRed);
         ObjectSetInteger(0, bosName, OBJPROP_ARROWCODE, 234);
         ObjectSetInteger(0, bosName, OBJPROP_WIDTH, 3);
         
         bosCount++;
      }
   }
}

// Dessiner les points CHoCH - VERSION STYLÃE
void DrawCHoCHPoints()
{
   MqlRates rates[];
   ArraySetAsSeries(rates, true);
   if(CopyRates(_Symbol, LTF, 0, 100, rates) < 50) return;
   
   // Nettoyer les anciens dessins
   ObjectsDeleteAll(0, "CHOCH_");
   
   // Limiter le nombre de points CHoCH
   int maxCHoCH = 2;
   int chochCount = 0;
   
   for(int i = 15; i < 35 && chochCount < maxCHoCH; i++)
   {
      // CHoCH Haussier
      bool wasDowntrend = true;
      for(int j = i+5; j < i+15 && j < 50; j++)
      {
         if(rates[j].high > rates[j+1].high)
         {
            wasDowntrend = false;
            break;
         }
      }
      
      if(wasDowntrend && rates[i].high > rates[i+2].high && rates[i+1].high > rates[i+3].high)
      {
         string chochName = "CHOCH_BUY_" + IntegerToString(chochCount);
         ObjectCreate(0, chochName, OBJ_ARROW, 0, rates[i].time, rates[i].high);
         ObjectSetInteger(0, chochName, OBJPROP_COLOR, clrAqua);
         ObjectSetInteger(0, chochName, OBJPROP_ARROWCODE, 233);
         ObjectSetInteger(0, chochName, OBJPROP_WIDTH, 4);
         
         chochCount++;
      }
      
      // CHoCH Baissier
      bool wasUptrend = true;
      for(int j = i+5; j < i+15 && j < 50; j++)
      {
         if(rates[j].low < rates[j+1].low)
         {
            wasUptrend = false;
            break;
         }
      }
      
      if(wasUptrend && rates[i].low < rates[i+2].low && rates[i+1].low < rates[i+3].low)
      {
         string chochName = "CHOCH_SELL_" + IntegerToString(chochCount);
         ObjectCreate(0, chochName, OBJ_ARROW, 0, rates[i].time, rates[i].low);
         ObjectSetInteger(0, chochName, OBJPROP_COLOR, clrOrange);
         ObjectSetInteger(0, chochName, OBJPROP_ARROWCODE, 234);
         ObjectSetInteger(0, chochName, OBJPROP_WIDTH, 4);
         
         chochCount++;
      }
   }
}

// Dessiner la ligne de tendance principale
void DrawMainTrendLine()
{
   MqlRates rates[];
   ArraySetAsSeries(rates, true);
   if(CopyRates(_Symbol, LTF, 0, 100, rates) < 50) return;
   
   // Nettoyer les anciennes lignes
   ObjectsDeleteAll(0, "TREND_LINE_");
   
   // DÃĐtecter les points de tendance significatifs
   double trendHighs[], trendLows[];
   datetime trendHighTimes[], trendLowTimes[];
   
   int highCount = 0, lowCount = 0;
   
   // Identifier les highs et lows de tendance
   for(int i = 10; i < 40; i++)
   {
      // High de tendance
      if(rates[i].high > rates[i-1].high && rates[i].high > rates[i+1].high &&
         rates[i].high > rates[i-2].high && rates[i].high > rates[i+2].high)
      {
         ArrayResize(trendHighs, highCount + 1);
         ArrayResize(trendHighTimes, highCount + 1);
         trendHighs[highCount] = rates[i].high;
         trendHighTimes[highCount] = rates[i].time;
         highCount++;
      }
      
      // Low de tendance
      if(rates[i].low < rates[i-1].low && rates[i].low < rates[i+1].low &&
         rates[i].low < rates[i-2].low && rates[i].low < rates[i+2].low)
      {
         ArrayResize(trendLows, lowCount + 1);
         ArrayResize(trendLowTimes, lowCount + 1);
         trendLows[lowCount] = rates[i].low;
         trendLowTimes[lowCount] = rates[i].time;
         lowCount++;
      }
   }
   
   // Dessiner la ligne de tendance haussiÃĻre
   if(highCount >= 2)
   {
      string trendLineName = "TREND_LINE_UPTREND_" + _Symbol;
      if(ObjectFind(0, trendLineName) < 0)
      {
         ObjectCreate(0, trendLineName, OBJ_TREND, 0, 
                     trendHighTimes[highCount-1], trendHighs[highCount-1],
                     trendHighTimes[0], trendHighs[0]);
         ObjectSetInteger(0, trendLineName, OBJPROP_COLOR, clrLime);
         ObjectSetInteger(0, trendLineName, OBJPROP_STYLE, STYLE_SOLID);
         ObjectSetInteger(0, trendLineName, OBJPROP_WIDTH, 2);
         ObjectSetInteger(0, trendLineName, OBJPROP_RAY_RIGHT, true);
         ObjectSetString(0, trendLineName, OBJPROP_TEXT, "Uptrend");
      }
   }
   
   // Dessiner la ligne de tendance baissiÃĻre
   if(lowCount >= 2)
   {
      string trendLineName = "TREND_LINE_DOWNTREND_" + _Symbol;
      if(ObjectFind(0, trendLineName) < 0)
      {
         ObjectCreate(0, trendLineName, OBJ_TREND, 0, 
                     trendLowTimes[lowCount-1], trendLows[lowCount-1],
                     trendLowTimes[0], trendLows[0]);
         ObjectSetInteger(0, trendLineName, OBJPROP_COLOR, clrRed);
         ObjectSetInteger(0, trendLineName, OBJPROP_STYLE, STYLE_SOLID);
         ObjectSetInteger(0, trendLineName, OBJPROP_WIDTH, 2);
         ObjectSetInteger(0, trendLineName, OBJPROP_RAY_RIGHT, true);
         ObjectSetString(0, trendLineName, OBJPROP_TEXT, "Downtrend");
      }
   }
}

// 2) DESSINER LES ZONES D'IMBALANCE (FVG) - VERSION STYLÃE
void DrawSMC_ImbalanceZones()
{
   MqlRates rates[];
   ArraySetAsSeries(rates, true);
   int n = MathMax(120, MathMin(2000, SMCOTE_LookbackBarsLTF));
   if(CopyRates(_Symbol, LTF, 0, n, rates) < 50) return;
   
   // Nettoyer les anciennes zones
   if(!KeepSMCOTEObjectsPersistent)
      ObjectsDeleteAll(0, "SMC_IMBALANCE_");
   
   int maxI = MathMin(ArraySize(rates) - 3, 220);
   for(int i = 2; i < maxI; i++)
   {
      // Imbalance Haussier (Bullish FVG) - Style ÃĐpurÃĐ
      if(rates[i].high < rates[i+2].low && rates[i+1].high < rates[i+2].low)
      {
         double top = rates[i+2].low;
         double bottom = rates[i].high;
         double gap = top - bottom;
         
         // Ne dessiner que les gaps significatifs
         double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
         if(gap < point * 5.0) continue;
         
         string fvgName = "SMC_IMBALANCE_BUY_" + IntegerToString(i);
         
         // Rectangle semi-transparent avec bordure fine
         EnsureOrMoveRectangle(fvgName, rates[i].time, top, rates[i+2].time, bottom);
         ObjectSetInteger(0, fvgName, OBJPROP_COLOR, clrLime);
         ObjectSetInteger(0, fvgName, OBJPROP_BACK, true);
         ObjectSetInteger(0, fvgName, OBJPROP_STYLE, STYLE_SOLID);
         ObjectSetInteger(0, fvgName, OBJPROP_WIDTH, 1);
         ObjectSetInteger(0, fvgName, OBJPROP_FILL, true);
         ObjectSetInteger(0, fvgName, OBJPROP_BGCOLOR, clrLime);
         ObjectSetInteger(0, fvgName, OBJPROP_FILL, true);
         
         // Petit indicateur de gap au lieu de label text
         string indicatorName = "SMC_IMBALANCE_BUY_IND_" + IntegerToString(i);
         if(ObjectFind(0, indicatorName) < 0)
            ObjectCreate(0, indicatorName, OBJ_ARROW, 0, rates[i+1].time, (top + bottom) / 2);
         else
            ObjectMove(0, indicatorName, 0, rates[i+1].time, (top + bottom) / 2);
         ObjectSetInteger(0, indicatorName, OBJPROP_COLOR, clrWhite);
         ObjectSetInteger(0, indicatorName, OBJPROP_ARROWCODE, 159); // Cercle
         ObjectSetInteger(0, indicatorName, OBJPROP_WIDTH, 2);
      }
      
      // Imbalance Baissier (Bearish FVG) - Style ÃĐpurÃĐ
      if(rates[i].low > rates[i+2].high && rates[i+1].low > rates[i+2].high)
      {
         double bottom = rates[i+2].high;
         double top = rates[i].low;
         double gap = top - bottom;
         
         // Ne dessiner que les gaps significatifs
         double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
         if(gap < point * 5.0) continue;
         
         string fvgName = "SMC_IMBALANCE_SELL_" + IntegerToString(i);
         
         // Rectangle semi-transparent avec bordure fine
         EnsureOrMoveRectangle(fvgName, rates[i].time, top, rates[i+2].time, bottom);
         ObjectSetInteger(0, fvgName, OBJPROP_COLOR, clrRed);
         ObjectSetInteger(0, fvgName, OBJPROP_BACK, true);
         ObjectSetInteger(0, fvgName, OBJPROP_STYLE, STYLE_SOLID);
         ObjectSetInteger(0, fvgName, OBJPROP_WIDTH, 1);
         ObjectSetInteger(0, fvgName, OBJPROP_FILL, true);
         ObjectSetInteger(0, fvgName, OBJPROP_BGCOLOR, clrRed);
         
         // Petit indicateur de gap au lieu de label text
         string indicatorName = "SMC_IMBALANCE_SELL_IND_" + IntegerToString(i);
         if(ObjectFind(0, indicatorName) < 0)
            ObjectCreate(0, indicatorName, OBJ_ARROW, 0, rates[i+1].time, (top + bottom) / 2);
         else
            ObjectMove(0, indicatorName, 0, rates[i+1].time, (top + bottom) / 2);
         ObjectSetInteger(0, indicatorName, OBJPROP_COLOR, clrWhite);
         ObjectSetInteger(0, indicatorName, OBJPROP_ARROWCODE, 159); // Cercle
         ObjectSetInteger(0, indicatorName, OBJPROP_WIDTH, 2);
      }
   }
}

// 3) DESSINER LES ZONES OTE (FIBONACCI 0.62-0.786) - VERSION STYLÃE
void DrawSMC_OTEZones()
{
   MqlRates rates[];
   ArraySetAsSeries(rates, true);
   int n = MathMax(200, MathMin(3000, SMCOTE_LookbackBarsLTF));
   if(CopyRates(_Symbol, LTF, 0, n, rates) < 120) return;

   if(!KeepSMCOTEObjectsPersistent)
      ObjectsDeleteAll(0, "SMC_OTE_");

   double atr = GetATRValue(LTF, 14);
   double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   if(point <= 0.0) point = _Point;
   if(atr <= 0.0) atr = MathMax(MathAbs(rates[1].high - rates[1].low), point * 20.0);

   // On dessine 1 seule zone OTE "courante" BUY et/ou SELL (plus lisible, et surtout persistant).
   const string pfx = "SMC_OTE_CURR_";
   datetime tEnd = TimeCurrent() + (datetime)(PeriodSeconds(LTF) * MathMax(10, OTEImbalanceProjectionBars));

   // BUY: swingLow (plus ancien) puis swingHigh (plus recent) => retracement OTE vers le bas.
   bool buyFound = false;
   double buyLow = 0.0, buyHigh = 0.0;
   datetime tLow = 0, tHigh = 0;
   int maxScan = MathMin(ArraySize(rates) - 5, 1200);
   for(int i = 6; i < maxScan; i++)
   {
      bool isSwingLow = (rates[i].low < rates[i-1].low && rates[i].low < rates[i+1].low &&
                         rates[i].low < rates[i-2].low && rates[i].low < rates[i+2].low);
      if(!isSwingLow) continue;

      double hi = 0.0;
      datetime thi = 0;
      for(int j = i - 1; j >= 1; j--)
      {
         if(rates[j].high > hi)
         {
            hi = rates[j].high;
            thi = rates[j].time;
         }
      }
      if(hi <= 0.0) continue;
      double rg = hi - rates[i].low;
      if(rg < atr * 0.75) continue; // swing trop petit -> bruit

      buyLow = rates[i].low;
      buyHigh = hi;
      tLow = rates[i].time;
      tHigh = thi;
      buyFound = true;
      break;
   }

   if(buyFound && buyHigh > buyLow)
   {
      double rg = buyHigh - buyLow;
      double ote62 = buyLow + rg * 0.618;
      double ote786 = buyLow + rg * 0.786;
      double zLow = MathMin(ote62, ote786);
      double zHigh = MathMax(ote62, ote786);

      string rect = pfx + "BUY_ZONE";
      EnsureOrMoveRectangle(rect, tLow, zHigh, tEnd, zLow);
      ObjectSetInteger(0, rect, OBJPROP_COLOR, clrGold);
      ObjectSetInteger(0, rect, OBJPROP_BACK, true);
      ObjectSetInteger(0, rect, OBJPROP_FILL, true);
      ObjectSetInteger(0, rect, OBJPROP_BGCOLOR, C'140,110,0');
      ObjectSetInteger(0, rect, OBJPROP_WIDTH, 1);

      string l62 = pfx + "BUY_62";
      string l78 = pfx + "BUY_786";
      EnsureOrSetHLine(l62, ote62);
      EnsureOrSetHLine(l78, ote786);
      ObjectSetInteger(0, l62, OBJPROP_COLOR, clrYellow);
      ObjectSetInteger(0, l62, OBJPROP_STYLE, STYLE_SOLID);
      ObjectSetInteger(0, l62, OBJPROP_WIDTH, 2);
      ObjectSetInteger(0, l62, OBJPROP_BACK, true);
      ObjectSetInteger(0, l78, OBJPROP_COLOR, clrOrange);
      ObjectSetInteger(0, l78, OBJPROP_STYLE, STYLE_SOLID);
      ObjectSetInteger(0, l78, OBJPROP_WIDTH, 2);
      ObjectSetInteger(0, l78, OBJPROP_BACK, true);

      EnsureOrMoveText(pfx + "BUY_LBL", tEnd, (zLow + zHigh) * 0.5,
                       "SMC_CURR BUY | OTE 0.618-0.786 | swing=" + DoubleToString(buyLow, _Digits) + "â" + DoubleToString(buyHigh, _Digits));
      ObjectSetInteger(0, pfx + "BUY_LBL", OBJPROP_COLOR, clrWhite);
      ObjectSetInteger(0, pfx + "BUY_LBL", OBJPROP_FONTSIZE, 11);
      ObjectSetInteger(0, pfx + "BUY_LBL", OBJPROP_BACK, false);
   }

   // SELL: swingHigh (plus ancien) puis swingLow (plus recent) => retracement OTE vers le haut.
   bool sellFound = false;
   double sellHigh = 0.0, sellLow = 0.0;
   datetime tHi = 0, tLo = 0;
   for(int i = 6; i < maxScan; i++)
   {
      bool isSwingHigh = (rates[i].high > rates[i-1].high && rates[i].high > rates[i+1].high &&
                          rates[i].high > rates[i-2].high && rates[i].high > rates[i+2].high);
      if(!isSwingHigh) continue;

      double lo = 0.0;
      datetime tlo = 0;
      for(int j = i - 1; j >= 1; j--)
      {
         if(lo == 0.0 || rates[j].low < lo)
         {
            lo = rates[j].low;
            tlo = rates[j].time;
         }
      }
      if(lo <= 0.0) continue;
      double rg = rates[i].high - lo;
      if(rg < atr * 0.75) continue;

      sellHigh = rates[i].high;
      sellLow = lo;
      tHi = rates[i].time;
      tLo = tlo;
      sellFound = true;
      break;
   }

   if(sellFound && sellHigh > sellLow)
   {
      double rg = sellHigh - sellLow;
      double ote62 = sellHigh - rg * 0.618;
      double ote786 = sellHigh - rg * 0.786;
      double zLow = MathMin(ote62, ote786);
      double zHigh = MathMax(ote62, ote786);

      string rect = pfx + "SELL_ZONE";
      EnsureOrMoveRectangle(rect, tHi, zHigh, tEnd, zLow);
      ObjectSetInteger(0, rect, OBJPROP_COLOR, clrPurple);
      ObjectSetInteger(0, rect, OBJPROP_BACK, true);
      ObjectSetInteger(0, rect, OBJPROP_FILL, true);
      ObjectSetInteger(0, rect, OBJPROP_BGCOLOR, C'90,0,90');
      ObjectSetInteger(0, rect, OBJPROP_WIDTH, 1);

      string l62 = pfx + "SELL_62";
      string l78 = pfx + "SELL_786";
      EnsureOrSetHLine(l62, ote62);
      EnsureOrSetHLine(l78, ote786);
      ObjectSetInteger(0, l62, OBJPROP_COLOR, clrYellow);
      ObjectSetInteger(0, l62, OBJPROP_STYLE, STYLE_SOLID);
      ObjectSetInteger(0, l62, OBJPROP_WIDTH, 2);
      ObjectSetInteger(0, l62, OBJPROP_BACK, true);
      ObjectSetInteger(0, l78, OBJPROP_COLOR, clrOrange);
      ObjectSetInteger(0, l78, OBJPROP_STYLE, STYLE_SOLID);
      ObjectSetInteger(0, l78, OBJPROP_WIDTH, 2);
      ObjectSetInteger(0, l78, OBJPROP_BACK, true);

      EnsureOrMoveText(pfx + "SELL_LBL", tEnd, (zLow + zHigh) * 0.5,
                       "SMC_CURR SELL | OTE 0.618-0.786 | swing=" + DoubleToString(sellHigh, _Digits) + "â" + DoubleToString(sellLow, _Digits));
      ObjectSetInteger(0, pfx + "SELL_LBL", OBJPROP_COLOR, clrWhite);
      ObjectSetInteger(0, pfx + "SELL_LBL", OBJPROP_FONTSIZE, 11);
      ObjectSetInteger(0, pfx + "SELL_LBL", OBJPROP_BACK, false);
   }
}

// 4) DESSINER LES SETUPS 5 ÃTOILES (CONFLUENCE COMPLÃTE) - VERSION STYLÃE
void DrawSMC_FiveStarSetups()
{
   MqlRates rates[];
   ArraySetAsSeries(rates, true);
   int n = MathMax(120, MathMin(2000, SMCOTE_LookbackBarsLTF));
   if(CopyRates(_Symbol, LTF, 0, n, rates) < 80) return;
   
   // Nettoyer les anciens setups
   if(!KeepSMCOTEObjectsPersistent)
      ObjectsDeleteAll(0, "SMC_5STAR_");
   
   // DÃĐtecter les setups 5 ÃĐtoiles
   int maxI = MathMin(ArraySize(rates) - 3, 140);
   for(int i = 20; i < maxI; i++)
   {
      // VÃĐrifier setup BUY 5 ÃĐtoiles
      if(IsFiveStarBuySetup(rates, i))
      {
         string setupName = "SMC_5STAR_BUY_" + IntegerToString(i);
         
         // Ãtoile stylÃĐe au lieu de flÃĻche avec texte
         if(ObjectFind(0, setupName) < 0)
            ObjectCreate(0, setupName, OBJ_ARROW, 0, rates[i].time, rates[i].low);
         else
            ObjectMove(0, setupName, 0, rates[i].time, rates[i].low);
         ObjectSetInteger(0, setupName, OBJPROP_COLOR, clrLime);
         ObjectSetInteger(0, setupName, OBJPROP_ARROWCODE, 181); // Ãtoile
         ObjectSetInteger(0, setupName, OBJPROP_WIDTH, 4);
         
         // Zone d'entrÃĐe ÃĐpurÃĐe avec bordure lumineuse
         string zoneName = "SMC_5STAR_BUY_ZONE_" + IntegerToString(i);
         double entryZone = rates[i].low;
         EnsureOrMoveRectangle(zoneName,
                               rates[i].time, entryZone - 0.0008,
                               rates[i].time + PeriodSeconds(LTF) * 3, entryZone + 0.0008);
         ObjectSetInteger(0, zoneName, OBJPROP_COLOR, clrLime);
         ObjectSetInteger(0, zoneName, OBJPROP_BACK, true);
         ObjectSetInteger(0, zoneName, OBJPROP_STYLE, STYLE_SOLID);
         ObjectSetInteger(0, zoneName, OBJPROP_WIDTH, 2);
         ObjectSetInteger(0, zoneName, OBJPROP_FILL, true);
         ObjectSetInteger(0, zoneName, OBJPROP_BGCOLOR, clrLime);
         
         // Ligne verticale pour marquer l'entrÃĐe
         string lineName = "SMC_5STAR_BUY_LINE_" + IntegerToString(i);
         if(ObjectFind(0, lineName) < 0)
            ObjectCreate(0, lineName, OBJ_VLINE, 0, rates[i].time, 0);
         else
            ObjectMove(0, lineName, 0, rates[i].time, 0);
         ObjectSetInteger(0, lineName, OBJPROP_COLOR, clrLime);
         ObjectSetInteger(0, lineName, OBJPROP_STYLE, STYLE_DOT);
         ObjectSetInteger(0, lineName, OBJPROP_WIDTH, 1);
         ObjectSetInteger(0, lineName, OBJPROP_BACK, true);
      }
      
      // VÃĐrifier setup SELL 5 ÃĐtoiles
      if(IsFiveStarSellSetup(rates, i))
      {
         string setupName = "SMC_5STAR_SELL_" + IntegerToString(i);
         
         // Ãtoile stylÃĐe au lieu de flÃĻche avec texte
         if(ObjectFind(0, setupName) < 0)
            ObjectCreate(0, setupName, OBJ_ARROW, 0, rates[i].time, rates[i].high);
         else
            ObjectMove(0, setupName, 0, rates[i].time, rates[i].high);
         ObjectSetInteger(0, setupName, OBJPROP_COLOR, clrRed);
         ObjectSetInteger(0, setupName, OBJPROP_ARROWCODE, 181); // Ãtoile
         ObjectSetInteger(0, setupName, OBJPROP_WIDTH, 4);
         
         // Zone d'entrÃĐe ÃĐpurÃĐe avec bordure lumineuse
         string zoneName = "SMC_5STAR_SELL_ZONE_" + IntegerToString(i);
         double entryZone = rates[i].high;
         EnsureOrMoveRectangle(zoneName,
                               rates[i].time, entryZone + 0.0008,
                               rates[i].time + PeriodSeconds(LTF) * 3, entryZone - 0.0008);
         ObjectSetInteger(0, zoneName, OBJPROP_COLOR, clrRed);
         ObjectSetInteger(0, zoneName, OBJPROP_BACK, true);
         ObjectSetInteger(0, zoneName, OBJPROP_STYLE, STYLE_SOLID);
         ObjectSetInteger(0, zoneName, OBJPROP_WIDTH, 2);
         ObjectSetInteger(0, zoneName, OBJPROP_FILL, true);
         ObjectSetInteger(0, zoneName, OBJPROP_BGCOLOR, clrRed);
         
         // Ligne verticale pour marquer l'entrÃĐe
         string lineName = "SMC_5STAR_SELL_LINE_" + IntegerToString(i);
         if(ObjectFind(0, lineName) < 0)
            ObjectCreate(0, lineName, OBJ_VLINE, 0, rates[i].time, 0);
         else
            ObjectMove(0, lineName, 0, rates[i].time, 0);
         ObjectSetInteger(0, lineName, OBJPROP_COLOR, clrRed);
         ObjectSetInteger(0, lineName, OBJPROP_STYLE, STYLE_DOT);
         ObjectSetInteger(0, lineName, OBJPROP_WIDTH, 1);
         ObjectSetInteger(0, lineName, OBJPROP_BACK, true);
      }
   }
}

// VÃĐrifier si c'est un setup BUY 5 ÃĐtoiles
bool IsFiveStarBuySetup(MqlRates &rates[], int index)
{
   // 1) Tendance haussiÃĻre confirmÃĐe
   if(!IsUptrendConfirmed(rates, index)) return false;
   
   // 2) Imbalance dans la zone
   if(!HasImbalanceInZone(rates, index, "BUY")) return false;
   
   // 3) Zone OTE alignÃĐe
   if(!IsInOTEZone(rates, index, "BUY")) return false;
   
   return true;
}

// VÃĐrifier si c'est un setup SELL 5 ÃĐtoiles
bool IsFiveStarSellSetup(MqlRates &rates[], int index)
{
   // 1) Tendance baissiÃĻre confirmÃĐe
   if(!IsDowntrendConfirmed(rates, index)) return false;
   
   // 2) Imbalance dans la zone
   if(!HasImbalanceInZone(rates, index, "SELL")) return false;
   
   // 3) Zone OTE alignÃĐe
   if(!IsInOTEZone(rates, index, "SELL")) return false;
   
   return true;
}

// VÃĐrifier si la tendance haussiÃĻre est confirmÃĐe
bool IsUptrendConfirmed(MqlRates &rates[], int index)
{
   // VÃĐrifier les highs et lows plus ÃĐlevÃĐs
   for(int i = index; i < index + 10 && i < ArraySize(rates) - 1; i++)
   {
      if(rates[i].high < rates[i+1].high || rates[i].low < rates[i+1].low)
         return false;
   }
   return true;
}

// VÃĐrifier si la tendance baissiÃĻre est confirmÃĐe
bool IsDowntrendConfirmed(MqlRates &rates[], int index)
{
   // VÃĐrifier les highs et lows plus bas
   for(int i = index; i < index + 10 && i < ArraySize(rates) - 1; i++)
   {
      if(rates[i].high > rates[i+1].high || rates[i].low > rates[i+1].low)
         return false;
   }
   return true;
}

// VÃĐrifier s'il y a un imbalance dans la zone
bool HasImbalanceInZone(MqlRates &rates[], int index, string direction)
{
   // VÃĐrifier les 3 bougies pour l'imbalance
   if(index < 2) return false;
   
   if(direction == "BUY")
   {
      // Imbalance haussier: top bougie 1 ne touche pas bottom bougie 3
      return (rates[index].high < rates[index-2].low && 
              rates[index-1].high < rates[index-2].low);
   }
   else // SELL
   {
      // Imbalance baissier: bottom bougie 1 ne touche pas top bougie 3
      return (rates[index].low > rates[index-2].high && 
              rates[index-1].low > rates[index-2].high);
   }
}

// VÃĐrifier si le prix est dans la zone OTE
bool IsInOTEZone(MqlRates &rates[], int index, string direction)
{
   if(index < 20) return false;
   
   // Trouver les points swing pour Fibonacci
   double swingLow = 0, swingHigh = 0;
   
   if(direction == "BUY")
   {
      // Chercher le low et high pour la structure haussiÃĻre
      swingLow = rates[index].low;
      for(int i = index - 5; i >= MathMax(0, index - 25); i--)
      {
         if(rates[i].high > swingHigh)
            swingHigh = rates[i].high;
      }
      
      if(swingHigh > swingLow)
      {
         double range = swingHigh - swingLow;
         double ote62 = swingLow + range * 0.62;
         double ote786 = swingLow + range * 0.786;
         
         double currentPrice = rates[index].close;
         return (currentPrice >= ote62 && currentPrice <= ote786);
      }
   }
   else // SELL
   {
      // Chercher le high et low pour la structure baissiÃĻre
      swingHigh = rates[index].high;
      for(int i = index - 5; i >= MathMax(0, index - 25); i--)
      {
         if(rates[i].low < swingLow || swingLow == 0)
            swingLow = rates[i].low;
      }
      
      if(swingLow > 0 && swingLow < swingHigh)
      {
         double range = swingHigh - swingLow;
         double ote62 = swingHigh - range * 0.62;
         double ote786 = swingHigh - range * 0.786;
         
         double currentPrice = rates[index].close;
         return (currentPrice >= ote786 && currentPrice <= ote62);
      }
   }
   
   return false;
}

// ===================================================================
// STRATÃGIE SMC_OTE COMPLÃTE - EXÃCUTION
// 3 Ãtapes: 1) Tendance  2) Imbalance  3) OTE Zone
// ===================================================================

// ExÃĐcuter la stratÃĐgie SMC_OTE complÃĻte
void ExecuteSMC_OTEStrategy()
{
   // VÃĐrifier si la stratÃĐgie est activÃĐe
   if(!UseSMC_OTEStrategy) return;

   ENUM_SYMBOL_CATEGORY cat = SMC_GetSymbolCategory(_Symbol);
   if(!IsSMCOTEAllowedForSymbolCategory(cat))
      return;

   // VÃĐrifier le nombre de positions
   int currentPositions = CountPositionsForSymbol(_Symbol);
   if(currentPositions >= 2)
   {
      static datetime lastBlockLog = 0;
      if(TimeCurrent() - lastBlockLog >= 60)
      {
         Print("ðĄïļ SMC_OTE - 2 positions dÃĐjÃ  ouvertes sur ", _Symbol, " - Nouveaux trades bloquÃĐs");
         lastBlockLog = TimeCurrent();
      }
      return;
   }

   // ÃTAPE 1: Identifier la tendance du marchÃĐ
   string trendDirection = "";
   if(!IdentifyMarketTrend(trendDirection))
   {
      Print("ð SMC_OTE - Tendance non identifiÃĐe sur ", _Symbol);
      return;
   }
   
   // FILTRE TENDANCE STRICTE: EMA stack + OB confirmÃĐ + Fibo OTE
   if(!IsTrendAlignedEntry(trendDirection))
   {
      Print("ðŦ SMC_OTE - TREND FILTER bloquÃĐ (EMA/OB/Fibo) sur ", _Symbol);
      return;
   }

   // ÃTAPE 2: DÃĐtecter les zones d'Imbalance (FVG)
   double imbalanceTop = 0, imbalanceBottom = 0;
   datetime imbalanceTime = 0;
   if(!DetectImbalanceZone(trendDirection, imbalanceTop, imbalanceBottom, imbalanceTime))
   {
      Print("â ïļ SMC_OTE - Aucun Imbalance valide dÃĐtectÃĐ sur ", _Symbol);
      return;
   }

   // ÃTAPE 3: Calculer et vÃĐrifier la zone OTE (Fibonacci 0.62-0.786)
   double oteLow = 0, oteHigh = 0;
   if(!CalculateOTEZone(trendDirection, oteLow, oteHigh))
   {
      Print("ð SMC_OTE - Impossible de calculer la zone OTE sur ", _Symbol);
      return;
   }

   // VÃRIFICATION DE LA CONFLUENCE 5 ÃTOILES
   if(!IsFiveStarConfluence(trendDirection, imbalanceTop, imbalanceBottom, oteLow, oteHigh))
   {
      Print("â­ SMC_OTE - Confluence 5 ÃĐtoiles non validÃĐe sur ", _Symbol);
      return;
   }

   // VÃĐrifier si le prix est dans la zone d'entrÃĐe
   double currentPrice = (trendDirection == "BUY") ? SymbolInfoDouble(_Symbol, SYMBOL_ASK) : SymbolInfoDouble(_Symbol, SYMBOL_BID);
   if(!IsPriceInEntryZone(currentPrice, imbalanceTop, imbalanceBottom, oteLow, oteHigh))
   {
      Print("ð SMC_OTE - Prix pas dans la zone d'entrÃĐe sur ", _Symbol,
            " | Prix: ", DoubleToString(currentPrice, _Digits));
      return;
   }

   // Calculer SL/TP selon la stratÃĐgie (TP >= 3R risk/reward)
   double entryPrice = currentPrice;
   double stopLoss, takeProfit;
   
   if(trendDirection == "BUY")
   {
      stopLoss = MathMin(imbalanceBottom, oteLow) - 15 * SymbolInfoDouble(_Symbol, SYMBOL_POINT);
      double risk = entryPrice - stopLoss;
      takeProfit = entryPrice + (MathMax(3.0, InpRiskReward) * risk); // TP >= 3R
   }
   else // SELL
   {
      stopLoss = MathMax(imbalanceTop, oteHigh) + 15 * SymbolInfoDouble(_Symbol, SYMBOL_POINT);
      double risk = stopLoss - entryPrice;
      takeProfit = entryPrice - (MathMax(3.0, InpRiskReward) * risk); // TP >= 3R
   }

   // ExÃĐcuter le trade
   ExecuteSMC_OTETrade(trendDirection, entryPrice, stopLoss, takeProfit);
}

// ÃTAPE 1: Identifier la tendance du marchÃĐ
bool IdentifyMarketTrend(string &directionOut)
{
   directionOut = "";
   
   MqlRates rates[];
   ArraySetAsSeries(rates, true);
   int n = MathMax(80, MathMin(2000, SMCOTE_LookbackBarsHTF));
   if(CopyRates(_Symbol, HTF, 0, n, rates) < 60) return false;

   // Analyser la structure de marchÃĐ sur les 30 derniÃĻres bougies
   int higherHighs = 0, higherLows = 0;
   int lowerHighs = 0, lowerLows = 0;

   int maxI = MathMin(60, ArraySize(rates) - 10);
   for(int i = 5; i < maxI; i++)
   {
      // Comparer avec les bougies prÃĐcÃĐdentes
      if(rates[i].high > rates[i+5].high) higherHighs++;
      if(rates[i].low > rates[i+5].low) higherLows++;
      if(rates[i].high < rates[i+5].high) lowerHighs++;
      if(rates[i].low < rates[i+5].low) lowerLows++;
   }

   // DÃĐterminer la tendance dominante
   if(higherHighs > lowerHighs && higherLows > lowerLows)
   {
      directionOut = "BUY"; // MarchÃĐ haussier
      Print("ð SMC_OTE - Tendance haussiÃĻre identifiÃĐe sur ", _Symbol);
      return true;
   }
   else if(lowerHighs > higherHighs && lowerLows > higherLows)
   {
      directionOut = "SELL"; // MarchÃĐ baissier
      Print("ð SMC_OTE - Tendance baissiÃĻre identifiÃĐe sur ", _Symbol);
      return true;
   }
   else
   {
      return false; // Pas de tendance claire
   }
}

// ÃTAPE 2: DÃĐtecter les zones d'Imbalance (FVG)
bool DetectImbalanceZone(string direction, double &topOut, double &bottomOut, datetime &timeOut)
{
   MqlRates rates[];
   ArraySetAsSeries(rates, true);
   int n = MathMax(120, MathMin(2000, SMCOTE_LookbackBarsLTF));
   if(CopyRates(_Symbol, LTF, 0, n, rates) < 80) return false;

   // Chercher les imbalances rÃĐcents et significatifs
   int maxI = MathMin(ArraySize(rates) - 3, 220);
   for(int i = 2; i < maxI; i++)
   {
      if(direction == "BUY")
      {
         // Imbalance haussier: top bougie 1 ne touche pas bottom bougie 3
         if(rates[i].high < rates[i+2].low && rates[i+1].high < rates[i+2].low)
         {
            double gap = rates[i+2].low - rates[i].high;
            double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
            
            // VÃĐrifier que l'imbalance est significatif (au moins 5 points)
            if(gap >= point * 5.0)
            {
               topOut = rates[i+2].low;
               bottomOut = rates[i].high;
               timeOut = rates[i+1].time;
               
               Print("ðŊ SMC_OTE - Imbalance BUY dÃĐtectÃĐ | Gap: ", DoubleToString(gap, _Digits),
                     " | Top: ", DoubleToString(topOut, _Digits),
                     " | Bottom: ", DoubleToString(bottomOut, _Digits));
               return true;
            }
         }
      }
      else // SELL
      {
         // Imbalance baissier: bottom bougie 1 ne touche pas top bougie 3
         if(rates[i].low > rates[i+2].high && rates[i+1].low > rates[i+2].high)
         {
            double gap = rates[i].low - rates[i+2].high;
            double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
            
            // VÃĐrifier que l'imbalance est significatif (au moins 5 points)
            if(gap >= point * 5.0)
            {
               topOut = rates[i].low;
               bottomOut = rates[i+2].high;
               timeOut = rates[i+1].time;
               
               Print("ðŊ SMC_OTE - Imbalance SELL dÃĐtectÃĐ | Gap: ", DoubleToString(gap, _Digits),
                     " | Top: ", DoubleToString(topOut, _Digits),
                     " | Bottom: ", DoubleToString(bottomOut, _Digits));
               return true;
            }
         }
      }
   }

   return false;
}

// ÃTAPE 3: Calculer la zone OTE (Fibonacci 0.62-0.786)
bool CalculateOTEZone(string direction, double &lowOut, double &highOut)
{
   MqlRates rates[];
   ArraySetAsSeries(rates, true);
   int n = MathMax(120, MathMin(3000, SMCOTE_LookbackBarsHTF));
   if(CopyRates(_Symbol, HTF, 0, n, rates) < 80) return false;

   // Trouver les points swing significatifs
   double swingLow = 0, swingHigh = 0;
   datetime swingLowTime = 0, swingHighTime = 0;

   double atr = GetATRValue(HTF, 14);
   double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   if(point <= 0.0) point = _Point;
   if(atr <= 0.0) atr = MathMax(MathAbs(rates[1].high - rates[1].low), point * 20.0);

   if(direction == "BUY")
   {
      // Chercher un low significatif suivi d'un high significatif
      int maxI = MathMin(220, ArraySize(rates) - 5);
      for(int i = 10; i < maxI; i++)
      {
         // Low significatif
         if(rates[i].low < rates[i-1].low && rates[i].low < rates[i+1].low &&
            rates[i].low < rates[i-2].low && rates[i].low < rates[i+2].low)
         {
            if(swingLow == 0 || rates[i].low < swingLow)
            {
               swingLow = rates[i].low;
               swingLowTime = rates[i].time;
            }
         }
      }

      // Chercher le high suivant plus ÃĐlevÃĐ
      int maxJ = MathMin(180, ArraySize(rates) - 2);
      for(int j = 5; j < maxJ; j++)
      {
         if(rates[j].high > swingHigh && rates[j].time > swingLowTime)
         {
            swingHigh = rates[j].high;
            swingHighTime = rates[j].time;
         }
      }
   }
   else // SELL
   {
      // Chercher un high significatif suivi d'un low significatif
      int maxI = MathMin(220, ArraySize(rates) - 5);
      for(int i = 10; i < maxI; i++)
      {
         // High significatif
         if(rates[i].high > rates[i-1].high && rates[i].high > rates[i+1].high &&
            rates[i].high > rates[i-2].high && rates[i].high > rates[i+2].high)
         {
            if(swingHigh == 0 || rates[i].high > swingHigh)
            {
               swingHigh = rates[i].high;
               swingHighTime = rates[i].time;
            }
         }
      }

      // Chercher le low suivant plus bas
      int maxJ = MathMin(180, ArraySize(rates) - 2);
      for(int j = 5; j < maxJ; j++)
      {
         if(rates[j].low < swingLow && rates[j].time > swingHighTime)
         {
            swingLow = rates[j].low;
            swingLowTime = rates[j].time;
         }
      }
   }

   if(swingHigh > 0 && swingLow > 0 && swingHigh != swingLow)
   {
      double range = MathAbs(swingHigh - swingLow);
      if(range < atr * 0.75) return false; // swing trop petit: bruit HTF
      
      if(direction == "BUY")
      {
         lowOut = swingLow + range * 0.62;   // OTE 0.62
         highOut = swingLow + range * 0.786; // OTE 0.786
      }
      else // SELL
      {
         highOut = swingHigh - range * 0.62;   // OTE 0.62
         lowOut = swingHigh - range * 0.786;  // OTE 0.786
      }

      Print("ð SMC_OTE - Zone OTE calculÃĐe | Low: ", DoubleToString(lowOut, _Digits),
            " | High: ", DoubleToString(highOut, _Digits),
            " | Range: ", DoubleToString(range, _Digits));
      return true;
   }

   return false;
}

// VÃĐrifier la confluence 5 ÃĐtoiles
bool IsFiveStarConfluence(string direction, double imbalanceTop, double imbalanceBottom, double oteLow, double oteHigh)
{
   // VÃĐrifier que l'imbalance et la zone OTE se chevauchent
   double zoneLow = MathMax(imbalanceBottom, oteLow);
   double zoneHigh = MathMin(imbalanceTop, oteHigh);

   if(zoneHigh <= zoneLow)
   {
      Print("â ïļ SMC_OTE - Pas de confluence entre Imbalance et OTE");
      return false;
   }

   double confluenceSize = zoneHigh - zoneLow;
   double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   
   // La confluence doit ÃŠtre significative (au moins 10 points)
   if(confluenceSize < point * 10.0)
   {
      Print("â ïļ SMC_OTE - Confluence trop petite: ", DoubleToString(confluenceSize, _Digits));
      return false;
   }

   Print("â­ SMC_OTE - Confluence 5 ÃĐtoiles validÃĐe! | Zone: ", 
         DoubleToString(zoneLow, _Digits), " - ", DoubleToString(zoneHigh, _Digits),
         " | Taille: ", DoubleToString(confluenceSize, _Digits));
   return true;
}

// VÃĐrifier si le prix est dans la zone d'entrÃĐe
bool IsPriceInEntryZone(double price, double imbalanceTop, double imbalanceBottom, double oteLow, double oteHigh)
{
   // Calculer la zone de confluence
   double zoneLow = MathMax(imbalanceBottom, oteLow);
   double zoneHigh = MathMin(imbalanceTop, oteHigh);

   // Ajouter une tolÃĐrance de 50% de la taille de la zone
   double tolerance = (zoneHigh - zoneLow) * 0.5;
   zoneLow -= tolerance;
   zoneHigh += tolerance;

   bool inZone = (price >= zoneLow && price <= zoneHigh);
   
   if(inZone)
   {
      Print("â SMC_OTE - Prix dans la zone d'entrÃĐe! | Prix: ", DoubleToString(price, _Digits),
            " | Zone: ", DoubleToString(zoneLow, _Digits), " - ", DoubleToString(zoneHigh, _Digits));
   }
   
   return inZone;
}

// ExÃĐcuter le trade SMC_OTE
void ExecuteSMC_OTETrade(string direction, double entry, double sl, double tp)
{
   if(!TryAcquireOpenLock()) return;

   // Boom/Crash: ÃĐviter d'ouvrir un OTE immÃĐdiatement aprÃĻs le dernier spike dÃĐtectÃĐ (entrÃĐes en queue de mouvement)
   if(SMC_GetSymbolCategory(_Symbol) == SYM_BOOM_CRASH && OTEBoomCrashCooldownSecondsAfterSpike > 0)
   {
      datetime lastSpikeT = 0;
      if(IsBoomSymbol(_Symbol))
         lastSpikeT = g_lastBoomSpikeTime;
      else if(IsCrashSymbol(_Symbol))
         lastSpikeT = g_lastCrashSpikeTime;
      if(lastSpikeT > 0)
      {
         int elapsed = (int)(TimeCurrent() - lastSpikeT);
         if(elapsed >= 0 && elapsed < OTEBoomCrashCooldownSecondsAfterSpike)
         {
            Print("ðŦ SMC_OTE BLOQUÃ (Boom/Crash) â cooldown spike: ", elapsed, "s < ",
                  OTEBoomCrashCooldownSecondsAfterSpike, "s (anti-chase aprÃĻs spike)");
            ReleaseOpenLock();
            return;
         }
      }
   }
   
   // NOUVEAU: Obtenir les prÃĐdictions de Protected Points futurs pour validation
   double futureSupport = 0.0, futureResistance = 0.0;
   bool hasFutureLevels = GetFutureProtectedPointLevels(futureSupport, futureResistance);
   double currentPrice = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   
   // VALIDATION SUPPLÃMENTAIRE BASÃE SUR LES PRÃDICTIONS FUTURES
   if(hasFutureLevels)
   {
      // Si BUY, vÃĐrifier qu'on n'est pas trop prÃĻs d'une rÃĐsistance future
      if(direction == "BUY" && futureResistance > 0)
      {
         double distanceToResistance = futureResistance - entry;
         double atr = GetATRValue(PERIOD_M15, 14);
         
         if(distanceToResistance < atr * 0.3) // Plus strict pour SMC_OTE
         {
            Print("ðŦ SMC_OTE BUY BLOQUÃ - Trop proche rÃĐsistance future: ", DoubleToString(futureResistance, _Digits));
            Print("   ð Distance: ", DoubleToString(distanceToResistance, _Digits), " < ", DoubleToString(atr * 0.3, _Digits));
            Print("   ðĄ SMC_OTE exige une meilleure distance des niveaux futurs");
            ReleaseOpenLock();
            return;
         }
      }
      
      // Si SELL, vÃĐrifier qu'on n'est pas trop prÃĻs d'un support futur
      if(direction == "SELL" && futureSupport > 0)
      {
         double distanceToSupport = entry - futureSupport;
         double atr = GetATRValue(PERIOD_M15, 14);
         
         if(distanceToSupport < atr * 0.3) // Plus strict pour SMC_OTE
         {
            Print("ðŦ SMC_OTE SELL BLOQUÃ - Trop proche support future: ", DoubleToString(futureSupport, _Digits));
            Print("   ð Distance: ", DoubleToString(distanceToSupport, _Digits), " < ", DoubleToString(atr * 0.3, _Digits));
            Print("   ðĄ SMC_OTE exige une meilleure distance des niveaux futurs");
            ReleaseOpenLock();
            return;
         }
      }
      
      // LOG DES PRÃDICTIONS UTILISÃES POUR SMC_OTE
      Print("ðŪ SMC_OTE AVEC PRÃDICTIONS FUTURES - ", _Symbol);
      Print("   ðŊ Support futur: ", (futureSupport > 0 ? DoubleToString(futureSupport, _Digits) : "N/A"));
      Print("   ðŊ RÃĐsistance future: ", (futureResistance > 0 ? DoubleToString(futureResistance, _Digits) : "N/A"));
      Print("   ð EntrÃĐe SMC_OTE: ", DoubleToString(entry, _Digits));
      Print("   ð Direction: ", direction, " | Validation: â");
   }

   double lot = CalculateLotSize();
   lot = NormalizeVolumeForSymbol(lot);

   sl = NormalizeDouble(sl, _Digits);
   tp = NormalizeDouble(tp, _Digits);

   // Ajuster SL/TP pour respecter le stop-level broker et le tick size
   // (sinon "Invalid stops" sur certains synth indices comme Crash 1000 Index).
   double mktPrice = (direction == "BUY") ? SymbolInfoDouble(_Symbol, SYMBOL_ASK)
                                          : SymbolInfoDouble(_Symbol, SYMBOL_BID);
   ValidateAndAdjustStopLossTakeProfit(direction, mktPrice, sl, tp);

   double tickSize = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_SIZE);
   if(tickSize <= 0) tickSize = _Point;
   if(tickSize > 0)
   {
      sl = MathRound(sl / tickSize) * tickSize;
      tp = MathRound(tp / tickSize) * tickSize;
      sl = NormalizeDouble(sl, _Digits);
      tp = NormalizeDouble(tp, _Digits);
   }
   // Re-valider aprÃĻs arrondi tick (sinon le rounding peut rÃĐduire lÃĐgÃĻrement la distance)
   ValidateAndAdjustStopLossTakeProfit(direction, mktPrice, sl, tp);
   sl = NormalizeDouble(sl, _Digits);
   tp = NormalizeDouble(tp, _Digits);

   // CohÃĐrence direction SL/TP (ÃĐvite des rejets supplÃĐmentaires)
   if(direction == "BUY")
   {
      if(sl >= mktPrice || tp <= mktPrice)
      {
         Print("â SMC_OTE_5STAR invalid SL/TP after adjust - sl=", DoubleToString(sl, _Digits),
               " tp=", DoubleToString(tp, _Digits), " price=", DoubleToString(mktPrice, _Digits));
         ReleaseOpenLock();
         return;
      }
   }
   else // SELL
   {
      if(sl <= mktPrice || tp >= mktPrice)
      {
         Print("â SMC_OTE_5STAR invalid SL/TP after adjust - sl=", DoubleToString(sl, _Digits),
               " tp=", DoubleToString(tp, _Digits), " price=", DoubleToString(mktPrice, _Digits));
         ReleaseOpenLock();
         return;
      }
   }

   bool success = false;
   string comment = "SMC_OTE_5STAR";

   if(direction == "BUY")
   {
      success = trade.Buy(lot, _Symbol, 0.0, sl, tp, comment);
   }
   else // SELL
   {
      success = trade.Sell(lot, _Symbol, 0.0, sl, tp, comment);
   }

   if(success)
   {
      // Ajouter les informations sur les prÃĐdictions futures dans le log de succÃĻs
      string predictionInfo = "";
      if(hasFutureLevels)
      {
         if(direction == "BUY" && futureResistance > 0)
            predictionInfo = " | R_future: " + DoubleToString(futureResistance, _Digits);
         else if(direction == "SELL" && futureSupport > 0)
            predictionInfo = " | S_future: " + DoubleToString(futureSupport, _Digits);
      }
      
      Print("ð SMC_OTE 5 ÃTOILES EXÃCUTÃ - ", direction, " ", _Symbol,
            " | Entry: ", DoubleToString(entry, _Digits),
            " | SL: ", DoubleToString(sl, _Digits),
            " | TP: ", DoubleToString(tp, _Digits),
            " | Lot: ", DoubleToString(lot, 2),
            " | Risk/Reward: 2R",
            predictionInfo);
   }
   else
   {
      Print("â SMC_OTE - Ãchec exÃĐcution ", direction, " sur ", _Symbol,
            " | Erreur: ", trade.ResultRetcode(), " - ", trade.ResultComment());
   }

   ReleaseOpenLock();
}

// Dessine un avertissement visuel de spike imminent - VERSION AMÃLIORÃE
void DrawSpikeWarning(double probability)
{
   string warningName = "SPIKE_WARNING_" + _Symbol;
   string probTextName = "SPIKE_PROB_TEXT_" + _Symbol;
   
   // Supprimer les avertissements prÃĐcÃĐdents
   if(ObjectFind(0, warningName) >= 0)
      ObjectDelete(0, warningName);
   if(ObjectFind(0, probTextName) >= 0)
      ObjectDelete(0, probTextName);
   
   // CrÃĐer un nouvel avertissement
   MqlRates r[];
   ArraySetAsSeries(r, true);
   if(CopyRates(_Symbol, PERIOD_CURRENT, 0, 1, r) < 1) return;
   
   // DÃĐterminer la couleur selon la probabilitÃĐ
   color spikeColor = clrRed;
   if(probability >= 0.85) spikeColor = clrRed;      // 85%+ = Rouge critique
   else if(probability >= 0.70) spikeColor = clrOrange; // 70-84% = Orange alerte
   else if(probability >= 0.60) spikeColor = clrYellow; // 60-69% = Jaune attention
   else spikeColor = clrWhite; // < 60% = Blanc info
   
   // Dessiner une flÃĻche d'avertissement
   ObjectCreate(0, warningName, OBJ_ARROW, 0, r[0].time, r[0].high);
   ObjectSetInteger(0, warningName, OBJPROP_ARROWCODE, 241); // Point d'exclamation
   ObjectSetInteger(0, warningName, OBJPROP_COLOR, spikeColor);
   ObjectSetInteger(0, warningName, OBJPROP_WIDTH, 4);
   ObjectSetInteger(0, warningName, OBJPROP_BACK, false);
   
   // Ajouter un texte avec la probabilitÃĐ
   string probText = "SPIKE " + DoubleToString(probability*100, 0) + "%";
   ObjectCreate(0, probTextName, OBJ_TEXT, 0, r[0].time, r[0].high + (r[0].high - r[0].low) * 0.5);
   ObjectSetString(0, probTextName, OBJPROP_TEXT, probText);
   ObjectSetInteger(0, probTextName, OBJPROP_COLOR, clrWhite);
   ObjectSetInteger(0, probTextName, OBJPROP_FONTSIZE, 12);
   ObjectSetString(0, probTextName, OBJPROP_FONT, "Arial Bold");
   ObjectSetInteger(0, probTextName, OBJPROP_ANCHOR, ANCHOR_LEFT_UPPER);
   ObjectSetInteger(0, probTextName, OBJPROP_BACK, true);
   
   // Log de l'affichage
   Print("?? SPIKE WARNING AFFICHÃ - ", _Symbol, 
         " | ProbabilitÃĐ: ", DoubleToString(probability*100, 1), "%",
         " | Couleur: ", (probability >= 0.85 ? "ROUGE CRITIQUE" : 
                         (probability >= 0.70 ? "ORANGE ALERTE" : 
                         (probability >= 0.60 ? "JAUNE ATTENTION" : "BLANC INFO"))));
}

// Affiche l'ÃĐtat IA et les prÃĐdictions sur le graphique
void DrawAIStatusAndPredictions()
{
   string statusBoxName = "AI_STATUS_BOX_" + _Symbol;
   string statusTextName = "AI_STATUS_TEXT_" + _Symbol;
   string chartTechTechName = "CHART_TECH_ENDPOINT_TEXT_" + _Symbol;
   
   // Supprimer les objets prÃĐcÃĐdents
   if(ObjectFind(0, statusBoxName) >= 0)
      ObjectDelete(0, statusBoxName);
   if(ObjectFind(0, statusTextName) >= 0)
      ObjectDelete(0, statusTextName);
   if(ObjectFind(0, chartTechTechName) >= 0)
      ObjectDelete(0, chartTechTechName);
   
   // CrÃĐer une boÃŪte de statut
   MqlRates r[];
   ArraySetAsSeries(r, true);
   if(CopyRates(_Symbol, PERIOD_CURRENT, 0, 1, r) < 1) return;
   
   // Position de la boÃŪte (coin supÃĐrieur gauche)
   datetime boxTime = r[0].time;
   double boxPrice = r[0].high + (r[0].high - r[0].low) * 0.8;
   
   // CrÃĐer le rectangle de fond
   ObjectCreate(0, statusBoxName, OBJ_RECTANGLE_LABEL, 0, 0, 0);
   ObjectSetInteger(0, statusBoxName, OBJPROP_XDISTANCE, 10);
   // Bas-gauche, sans chevaucher les autres labels (ex: canal ML Ã  ~50px)
   ObjectSetInteger(0, statusBoxName, OBJPROP_YDISTANCE, 90);
   ObjectSetInteger(0, statusBoxName, OBJPROP_XSIZE, 430);
   ObjectSetInteger(0, statusBoxName, OBJPROP_YSIZE, 138);
   ObjectSetInteger(0, statusBoxName, OBJPROP_BGCOLOR, clrBlack);
   ObjectSetInteger(0, statusBoxName, OBJPROP_BORDER_COLOR, clrGray);
   ObjectSetInteger(0, statusBoxName, OBJPROP_CORNER, CORNER_LEFT_LOWER); // Bas Ã  gauche
   
   // Texte de statut IA (source serveur + consensus MTF + direction rÃĐelle utilisÃĐe).
   string iaServer = UseAIServer ?
                     ("IA serveur: " + g_lastAIAction + " (" + DoubleToString(g_lastAIConfidence*100, 1) + "%)") :
                     "IA serveur: DÃSACTIVÃ";
   string iaMtf = "IA MTF: " + g_lastAIMTFAction + " (" + DoubleToString(g_lastAIMTFConfidence*100, 1) + "%)";
   string iaFinal = "IA ROBOT: " + g_lastAIAction + " (" + DoubleToString(g_lastAIConfidence*100, 1) + "%) [" +
                    (UseMTFConsensusAsPrimaryAI ? "SOURCE=MTF" : "SOURCE=SERVER") + "]";
   string chartTech = "IA chart-tech: " + g_lastChartTechAction + " (" + DoubleToString(g_lastChartTechConfidence*100, 1) +
                      "%) | spike=" + DoubleToString(g_lastChartTechSpikeProbability*100, 1) + "%";
   
   // Texte de prÃĐdiction spike
   double spikeProb = CalculateSpikeProbability();
   string spikeStatus = "SPIKE: " + DoubleToString(spikeProb*100, 1) + "%";
   
   // CrÃĐer le texte de statut
   ObjectCreate(0, statusTextName, OBJ_LABEL, 0, 0, 0);
   ObjectSetString(0, statusTextName, OBJPROP_TEXT,
                 iaFinal + "\n" + iaMtf + "\n" + iaServer + "\n" + chartTech + "\n" + spikeStatus + "\nSymbole: " + _Symbol);
   ObjectSetInteger(0, statusTextName, OBJPROP_XDISTANCE, 20);
   ObjectSetInteger(0, statusTextName, OBJPROP_YDISTANCE, 100); // AlignÃĐ avec la boÃŪte
   ObjectSetInteger(0, statusTextName, OBJPROP_COLOR, clrWhite);
   ObjectSetInteger(0, statusTextName, OBJPROP_FONTSIZE, 10);
   ObjectSetString(0, statusTextName, OBJPROP_FONT, "Arial");
   ObjectSetInteger(0, statusTextName, OBJPROP_CORNER, CORNER_LEFT_LOWER); // Bas Ã  gauche

   if(ShowChartTechStateBottomLeft)
   {
      string endpointTs = (g_lastChartTechResponseUtc > 0) ? TimeToString(g_lastChartTechResponseUtc, TIME_MINUTES|TIME_SECONDS) : "N/A";
      string endpointText = "ENDPOINT /ml/chart-tech-state\n" +
                            g_lastChartTechPayloadSummary + "\n" +
                            g_lastChartTechResponseSummary + " | t=" + endpointTs;
      ObjectCreate(0, chartTechTechName, OBJ_LABEL, 0, 0, 0);
      ObjectSetString(0, chartTechTechName, OBJPROP_TEXT, endpointText);
      ObjectSetInteger(0, chartTechTechName, OBJPROP_XDISTANCE, 20);
      ObjectSetInteger(0, chartTechTechName, OBJPROP_YDISTANCE, 165); // Remonte le bloc endpoint pour eviter la coupe en bas
      ObjectSetInteger(0, chartTechTechName, OBJPROP_COLOR, clrAqua);
      ObjectSetInteger(0, chartTechTechName, OBJPROP_FONTSIZE, 8);
      ObjectSetString(0, chartTechTechName, OBJPROP_FONT, "Consolas");
      ObjectSetInteger(0, chartTechTechName, OBJPROP_CORNER, CORNER_LEFT_LOWER);
   }
}

//| DÃTECTER UN SPIKE RÃCENT sur Boom/Crash                           |
bool DetectRecentSpike()
{
   Print("?? DEBUG - DÃĐtection de spike pour: ", _Symbol);
   
   // VÃĐrifier les 5 derniÃĻres bougies pour un spike significatif
   MqlRates rates[];
   ArraySetAsSeries(rates, true);
   
   if(CopyRates(_Symbol, PERIOD_M1, 0, 5, rates) < 5)
   {
      Print("? Impossible de copier les rates pour dÃĐtecter spike");
      return false;
   }
   
   // Calculer le mouvement moyen des bougies
   double avgMovement = 0.0;
   for(int i = 1; i < 5; i++) // Ignorer la bougie actuelle (0)
   {
      avgMovement += MathAbs(rates[i].high - rates[i].low);
   }
   avgMovement /= 4.0;
   
   // VÃĐrifier si la derniÃĻre bougie a un mouvement significatif
   double lastMovement = MathAbs(rates[0].high - rates[0].low);
   
   // Rendre la dÃĐtection plus permissive - seuil diffÃĐrent pour Boom/Crash
   double spikeMultiplier = 1.5; // 1.5x par dÃĐfaut
   if(StringFind(_Symbol, "Boom") >= 0 || StringFind(_Symbol, "Crash") >= 0)
   {
      spikeMultiplier = 1.2; // 1.2x pour Boom/Crash (plus sensible)
   }
   
   double spikeThreshold = avgMovement * spikeMultiplier;
   
   bool isSpike = lastMovement > spikeThreshold;
   
   Print("?? DEBUG - Analyse spike - Mouvement actuel: ", DoubleToString(lastMovement, _Digits), 
         " | Moyenne: ", DoubleToString(avgMovement, _Digits), 
         " | Seuil: ", DoubleToString(spikeThreshold, _Digits), 
         " | Ratio: ", DoubleToString(lastMovement/avgMovement, 1),
         " | Spike: ", isSpike ? "OUI" : "NON");
   
   // Ajouter une dÃĐtection alternative basÃĐe sur le prix
   double priceChange = MathAbs(rates[0].close - rates[1].close) / rates[1].close;
   
   // Seuil diffÃĐrent pour Boom/Crash vs autres symboles
   double priceThreshold = 0.001; // 0.1% par dÃĐfaut
   if(StringFind(_Symbol, "Boom") >= 0 || StringFind(_Symbol, "Crash") >= 0)
   {
      priceThreshold = 0.0001; // 0.01% pour Boom/Crash (plus sensible)
   }
   
   bool priceSpike = priceChange > priceThreshold;
   
   Print("?? DEBUG - Spike prix - Changement: ", DoubleToString(priceChange*100, 4), "% | Seuil: ", DoubleToString(priceThreshold*100, 4), "% | Spike: ", priceSpike ? "OUI" : "NON");
   
   // Ajouter une dÃĐtection basÃĐe sur le volume pour Boom/Crash
   bool volumeSpike = false;
   if(StringFind(_Symbol, "Boom") >= 0 || StringFind(_Symbol, "Crash") >= 0)
   {
      long volume[];
      ArraySetAsSeries(volume, true);
      if(CopyTickVolume(_Symbol, PERIOD_M1, 0, 3, volume) >= 3)
      {
         double recentVolume = (double)volume[0];
         double avgVolume = ((double)volume[1] + (double)volume[2]) / 2.0;
         volumeSpike = recentVolume > avgVolume * 1.3; // 30% plus ÃĐlevÃĐ
         
         Print("?? DEBUG - Spike volume - RÃĐcent: ", DoubleToString(recentVolume, 0), 
               " | Moyenne: ", DoubleToString(avgVolume, 0), 
               " | Spike: ", volumeSpike ? "OUI" : "NON");
      }
   }
   
   // ConsidÃĐrer comme spike si l'un des trois est vrai
   bool finalSpike = isSpike || priceSpike || volumeSpike;
   
   if(finalSpike)
   {
      string spikeType = "";
      if(isSpike) spikeType += "Mouvement";
      if(priceSpike) spikeType += (spikeType != "" ? "+" : "") + "Prix";
      if(volumeSpike) spikeType += (spikeType != "" ? "+" : "") + "Volume";
      
      Print("?? SPIKE DÃTECTÃ - Type: ", spikeType, 
            " | Mouvement: ", DoubleToString(lastMovement, _Digits), 
            " | Changement prix: ", DoubleToString(priceChange*100, 3), "%");
   }
   
   return finalSpike;
}

//+------------------------------------------------------------------+
//| 2e stratÃĐgie Boom/Crash: canal M5 + sÃĐrie de spikes M1 + consolidation |
//+------------------------------------------------------------------+
bool IsM5StackAlignedForBoomCrashSeries(const bool crash)
{
   double e9 = 0.0, e21 = 0.0, e50 = 0.0;
   if(!ReadEMAValue(PERIOD_M5, 9, e9)) return false;
   if(!ReadEMAValue(PERIOD_M5, 21, e21)) return false;
   if(!ReadEMAValue(PERIOD_M5, 50, e50)) return false;
   if(e9 <= 0.0 || e21 <= 0.0 || e50 <= 0.0) return false;
   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   if(crash)
      return (e9 < e21 && e21 < e50 && bid < e9);
   return (e9 > e21 && e21 > e50 && bid > e9);
}

bool M5Ch_ReadBarM1(const int shift, MqlRates &bar)
{
   MqlRates r[];
   ArraySetAsSeries(r, true);
   if(CopyRates(_Symbol, PERIOD_M1, shift, 1, r) != 1) return false;
   bar = r[0];
   return true;
}

bool M5Ch_IsSpikeBarM1(const int shift, const double atr20, const bool crash)
{
   if(atr20 <= 0.0) return false;
   MqlRates bar;
   if(!M5Ch_ReadBarM1(shift, bar)) return false;
   double range = bar.high - bar.low;
   if(range < atr20 * M5ChSpikeBarRangeAtrMult) return false;
   if(crash)
      return (bar.close < bar.open);
   return (bar.close > bar.open);
}

bool M5Ch_IsSmallBarM1(const int shift, const double atr20)
{
   if(atr20 <= 0.0) return false;
   MqlRates bar;
   if(!M5Ch_ReadBarM1(shift, bar)) return false;
   double body = MathAbs(bar.close - bar.open);
   return (body <= atr20 * M5ChSpikeSmallBodyAtrRatio);
}

bool EvaluateM5ChannelSpikeSeriesSetup(string &dirOut)
{
   dirOut = "";
   if(!UseM5ChannelSpikeSeriesEntry) return false;
   if(SMC_GetSymbolCategory(_Symbol) != SYM_BOOM_CRASH) return false;
   bool crash = IsCrashSymbol(_Symbol);
   bool boom = IsBoomSymbol(_Symbol);
   if(!crash && !boom) return false;

   if(!IsM5StackAlignedForBoomCrashSeries(crash)) return false;

   double atr20 = 0.0;
   {
      int hAtr = iATR(_Symbol, PERIOD_M1, 20);
      if(hAtr != INVALID_HANDLE)
      {
         double ab[];
         ArraySetAsSeries(ab, true);
         if(CopyBuffer(hAtr, 0, 0, 1, ab) >= 1)
            atr20 = ab[0];
         IndicatorRelease(hAtr);
      }
   }
   if(atr20 <= 0.0) return false;

   int lb = MathMax(15, M5ChSpikeLookbackM1);
   int spikeBars = 0;
   for(int i = 1; i < lb; i++)
   {
      if(M5Ch_IsSpikeBarM1(i, atr20, crash))
         spikeBars++;
   }
   if(spikeBars < M5ChSpikeMinSpikeBars) return false;

   int lastSpikeIdx = -1;
   for(int j = 1; j < lb; j++)
   {
      if(M5Ch_IsSpikeBarM1(j, atr20, crash))
      {
         lastSpikeIdx = j;
         break;
      }
   }
   if(lastSpikeIdx < 2) return false;

   int smallAfter = 0;
   for(int k = lastSpikeIdx - 1; k >= 1; k--)
   {
      if(M5Ch_IsSmallBarM1(k, atr20))
         smallAfter++;
      else
         break;
   }
   if(smallAfter < M5ChSpikeSmallM1CandlesMin || smallAfter > M5ChSpikeSmallM1CandlesMax)
      return false;

   dirOut = crash ? "SELL" : "BUY";

   if(M5ChSpikeRequirePremiumDiscount)
   {
      if(crash && !IsInPremiumZone()) return false;
      if(boom && !IsInDiscountZone()) return false;
   }
   return true;
}

void CheckAndExecuteM5ChannelSpikeSeriesEntry()
{
   if(!UseM5ChannelSpikeSeriesEntry) return;
   if(SMC_GetSymbolCategory(_Symbol) != SYM_BOOM_CRASH) return;
   if(M5ChSpikeCooldownSec > 0 && g_m5ChSpikeSeriesLastEntryTime > 0 &&
      (TimeCurrent() - g_m5ChSpikeSeriesLastEntryTime) < M5ChSpikeCooldownSec)
      return;

   string dir = "";
   if(!EvaluateM5ChannelSpikeSeriesSetup(dir)) return;
   if(!IsDirectionAllowedForBoomCrash(_Symbol, dir)) return;
   if(!IsSpreadAcceptable()) return;
   if(IsEntryCooldownActive()) return;
   if(!CanOpenAdditionalPositionForSymbol(_Symbol, dir)) return;

   int posBefore = CountPositionsForSymbol(_Symbol);
   g_m5ChSpikeSeriesActive = true;
   ExecuteSpikeTrade(dir);

   if(CountPositionsForSymbol(_Symbol) > posBefore)
   {
      g_m5ChSpikeSeriesLastEntryTime = TimeCurrent();
      Print("ð ENTRÃE M5-CH-SPIKE-SERIES | ", _Symbol, " | ", dir,
            " | petites bougies M1 aprÃĻs dernier spike OK");
   }
}

//| EXÃCUTER UN TRADE BASÃ SUR SPIKE (corps â rÃĐinitialise g_m5ChSpikeSeriesActive via ExecuteSpikeTrade) |
void ExecuteSpikeTradeBody(string direction)
{
   if(!IsHighVolatilityCapitalGatePassed(_Symbol, "SPIKE TRADE"))
      return;
   
   if(IsMaxPositionsReached()) return;

   const bool m5ch = g_m5ChSpikeSeriesActive;
   const bool oteChain = g_oteSpikeChainEntry;
   const bool inCorrectionZone = IsInEquilibriumCorrectionZone();
   const bool massiveMode = (SpikeMassiveEntryMode && SMC_GetSymbolCategory(_Symbol) == SYM_BOOM_CRASH);

   if(!m5ch && !oteChain && !IsTrendAlignedEntry(direction))
   {
      Print("ðŦ SPIKE TRADE BLOQUÃ - Filtre de tendance SMC sur ", _Symbol, " : ", direction);
      return;
   }

   // Zone ÃĐquilibre ICT / serveur: pas d'entrÃĐe par dÃĐfaut. DÃĐrogations explicites uniquement.
   if(inCorrectionZone)
   {
      bool allowInCorrection = false;
      if(SpikeAllowInCorrectionZone)
         allowInCorrection = true;
      else if(m5ch && M5ChSpikeAllowInCorrectionZone)
         allowInCorrection = true;
      else if(oteChain && OteSpikeChainAllowInCorrectionZone)
         allowInCorrection = true;

      if(!allowInCorrection)
      {
         Print("ðŦ SPIKE TRADE BLOQUÃ - Zone de correction autour de l'ÃĐquilibre sur ", _Symbol);
         return;
      }
      if(SpikeAllowInCorrectionZone)
      {
         static datetime lastCorrBypassLog = 0;
         if(TimeCurrent() - lastCorrBypassLog >= 20)
         {
            Print("â SPIKE - Zone correction autorisÃĐe (SpikeAllowInCorrectionZone) sur ", _Symbol);
            lastCorrBypassLog = TimeCurrent();
         }
      }
   }

   if(!IsDirectionAllowedForBoomCrash(_Symbol, direction))
   {
      Print("ðŦ SPIKE TRADE BLOQUÃ - Direction interdite sur ", _Symbol, " : ", direction);
      return;
   }

   if(!IsBoomCrashDirectionAllowedByIA(_Symbol, direction))
   {
      Print("ðŦ SPIKE TRADE BLOQUÃ - Direction vs IA (Boom/Crash) sur ", _Symbol, " : ", direction);
      return;
   }

   if(!IsSpreadAcceptable()) return;
   if(!(massiveMode && SpikeMassiveBypassCooldown) && IsEntryCooldownActive()) return;
   if(!m5ch && !oteChain && !(massiveMode && SpikeMassiveBypassLastCandleConfirm) &&
      !IsLastCandleConfirmingDirection(direction)) return;

   // ContrÃīle anti-duplication centralisÃĐ par catÃĐgorie
   if(!CanOpenAdditionalPositionForSymbol(_Symbol, direction))
   {
      Print("ðŦ SPIKE TRADE BLOQUÃ - duplication non autorisÃĐe sur ", _Symbol,
            " | dir=", direction, " | positions=", CountPositionsForSymbol(_Symbol));
      return;
   }

   // Confiance IA minimum globale (75% ou plus bas si entrÃĐe M5-ch sÃĐrie + IA HOLD)
   {
      double minU = 0.75;
      if(massiveMode) minU = SpikeMassiveMinAIConfidence;
      if(m5ch) minU = M5ChSpikeMinAIConfidenceForHold;
      else if(oteChain) minU = OteSpikeChainMinAIConfidencePct / 100.0;
      if(!IsAIConfidenceAtLeast(minU, "SPIKE TRADE"))
         return;
   }

   // Spike trades: modÃĻle ML fiable (sauf bypass entrÃĐe M5-ch sÃĐrie ou chaÃŪne OTE)
   if((!m5ch || !M5ChSpikeBypassMLTrust) && !(oteChain && OteSpikeChainBypassMLTrust))
   {
      if(!IsMLModelTrustedForCurrentSymbol(direction))
      {
         Print("ðŦ SPIKE TRADE BLOQUÃ - ModÃĻle ML non fiable pour ", _Symbol);
         return;
      }
   }

   // En mode touch-entry (Boom/Crash), la logique peut aussi vouloir entrer
   // directement sur apparition de la flÃĻche DERIV (scalping spikes).
   // Donc on n'ignore plus SPIKE TRADE juste parce que "touch arm" est activÃĐ.

   // Boom/Crash: armer l'entrÃĐe via touch future protect (low=Boom, high=Crash)
   if(RequireFutureProtectTouchForBoomCrashDerivArrow &&
      (!m5ch || !M5ChSpikeBypassFutureProtect) && !oteChain &&
      !(inCorrectionZone && SpikeAllowInCorrectionZone))
   {
      bool isBoom = (StringFind(_Symbol, "Boom") >= 0);
      bool isCrash = (StringFind(_Symbol, "Crash") >= 0);
      // Si la flÃĻche DERIV est rÃĐcente pour cette direction, on bypass le "touch arm".
      bool hasRecentDerivArrow = HasRecentSMCDerivArrowForDirection(direction);
      datetime now = TimeCurrent();

      if(isBoom && direction == "BUY")
      {
         bool armed = hasRecentDerivArrow ||
                       (g_boomFutureProtectTouchTime > 0 &&
                        (now - g_boomFutureProtectTouchTime) <= FutureProtectTouchArmSeconds);
         if(!armed)
         {
            Print("?? SPIKE TRADE bloquÃĐ (Boom) - Attendre touch future protect low avant flÃĻche BUY",
                  " | touchTime=", (g_boomFutureProtectTouchTime > 0 ? TimeToString(g_boomFutureProtectTouchTime, TIME_SECONDS) : "N/A"),
                  " | level=", DoubleToString(g_boomFutureProtectTouchLevel, _Digits));
            return;
         }
      }
      else if(isCrash && direction == "SELL")
      {
         bool armed = hasRecentDerivArrow ||
                       (g_crashFutureProtectTouchTime > 0 &&
                        (now - g_crashFutureProtectTouchTime) <= FutureProtectTouchArmSeconds);
         if(!armed)
         {
            Print("?? SPIKE TRADE bloquÃĐ (Crash) - Attendre touch future protect high avant flÃĻche SELL",
                  " | touchTime=", (g_crashFutureProtectTouchTime > 0 ? TimeToString(g_crashFutureProtectTouchTime, TIME_SECONDS) : "N/A"),
                  " | level=", DoubleToString(g_crashFutureProtectTouchLevel, _Digits));
            return;
         }
      }
   }

   // Calculer lot size (recovery: doubler le lot min sur un autre symbole aprÃĻs une perte)
   double lot = CalculateLotSize();
   lot = ApplyRecoveryLot(lot, direction);
   if(lot <= 0) 
   {
      Print("? Erreur calcul lot size - trade annulÃĐ");
      return;
   }
   
   // Calculer SL/TP basÃĐs sur l'ATR
   double atrValue = 0.0;
   if(atrHandle != INVALID_HANDLE)
   {
      double atr[];
      ArraySetAsSeries(atr, true);
      if(CopyBuffer(atrHandle, 0, 0, 1, atr) >= 1)
         atrValue = atr[0];
   }
   
   if(atrValue == 0) atrValue = SymbolInfoDouble(_Symbol, SYMBOL_BID) * 0.002; // 0.2% par dÃĐfaut
   
   Print("?? DEBUG - ATR pour SL/TP: ", DoubleToString(atrValue, _Digits), " | Symbol: ", _Symbol);
   
   // Perte max par trade (3$): perte en $ = (SL en prix) * (tickValue/tickSize) * lot
   double tickSize = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_SIZE);
   double tickVal  = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_VALUE);
   if(tickSize <= 0) tickSize = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   if(tickVal <= 0) tickVal = 1.0;
   double riskPerLotDollars = (atrValue * 2.0) * (tickVal / tickSize); // $ par lot si SL 2x ATR touchÃĐ
   if(riskPerLotDollars <= 0) riskPerLotDollars = 1.0;
   double potentialLoss = lot * riskPerLotDollars;
   if(potentialLoss > MaxLossPerSpikeTradeDollars)
   {
      double minLot = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN);
      double maxLot = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MAX);
      double lotStep = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_STEP);
      if(lotStep <= 0) lotStep = 0.01;
      double lotCap = MaxLossPerSpikeTradeDollars / riskPerLotDollars;
      lot = MathFloor(lotCap / lotStep) * lotStep;
      lot = MathMax(minLot, MathMin(maxLot, lot));
      lot = NormalizeVolumeForSymbol(lot);
      potentialLoss = lot * riskPerLotDollars;
      if(potentialLoss > MaxLossPerSpikeTradeDollars * 1.01)
      {
         Print("? TRADE BLOQUÃ - Perte min (lot min ", DoubleToString(minLot, 2), ") = ", DoubleToString(potentialLoss, 2), "$ > ", MaxLossPerSpikeTradeDollars, "$");
         return;
      }
      Print("?? Lot rÃĐduit pour perte max ", MaxLossPerSpikeTradeDollars, "$ ? Lot: ", DoubleToString(lot, 2), " | Perte potentielle: ", DoubleToString(potentialLoss, 2), "$");
   }
   else
      Print("? Perte potentielle VALIDÃE: ", DoubleToString(potentialLoss, 2), "$ <= ", MaxLossPerSpikeTradeDollars, "$");
   
   // Envoyer notification
   double currentPrice = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double notificationSL = 0, notificationTP = 0;
   
   if(direction == "BUY")
   {
      notificationSL = currentPrice - (currentPrice * 0.001);
      notificationTP = currentPrice + (currentPrice * 0.003);
   }
   else // SELL
   {
      notificationSL = currentPrice + (currentPrice * 0.001);
      notificationTP = currentPrice - (currentPrice * 0.003);
   }
   
   SendDerivArrowNotification(direction, currentPrice, notificationSL, notificationTP);
   
   // ExÃĐcuter l'ordre
   bool orderExecuted = false;
   
   // DEBUG: VÃĐrifier l'option NoSLTP_BoomCrash
   Print("?? DEBUG - NoSLTP_BoomCrash: ", NoSLTP_BoomCrash ? "OUI" : "NON", " | CatÃĐgorie: ", (SMC_GetSymbolCategory(_Symbol) == SYM_BOOM_CRASH ? "BOOM_CRASH" : "AUTRE"));
   
   if(direction == "BUY")
   {
      if((!m5ch || !M5ChSpikeBypassDerivArrow) && !oteChain && !(massiveMode && SpikeMassiveBypassDerivArrow))
      {
         if(!HasRecentSMCDerivArrowForDirection("BUY"))
         {
            Print("?? SPIKE TRADE BUY bloquÃĐ - Attendre flÃĻche SMC_DERIV_ARROW BUY sur ", _Symbol);
            return;
         }
      }
      double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
      double sl = 0, tp = 0;
      
      // Appliquer SL/TP seulement si NoSLTP_BoomCrash est dÃĐsactivÃĐ
      if(!NoSLTP_BoomCrash || SMC_GetSymbolCategory(_Symbol) != SYM_BOOM_CRASH)
      {
         sl = ask - atrValue * 2.0;  // Pour BUY: SL en-dessous (plus bas)
         tp = ask + atrValue * 3.0;  // Pour BUY: TP au-dessus (plus haut)
      }
      
      Print("?? DEBUG - BUY - Ask: ", DoubleToString(ask, _Digits), " | SL: ", DoubleToString(sl, _Digits), " | TP: ", DoubleToString(tp, _Digits));
      Print("?? DEBUG - VÃĐrification SL/TP BUY - SL < Ask: ", (sl < ask || sl == 0) ? "OK" : "ERREUR", " | TP > Ask: ", (tp > ask || tp == 0) ? "OK" : "ERREUR");
      
      if(!oteChain && !IsMinimumProfitPotentialMet(ask, tp, "BUY", lot)) return;
      
      string cmtBuy = m5ch ? "SPIKE_M5CH_SERIES_BUY" : "SPIKE TRADE BUY";
      if(trade.Buy(lot, _Symbol, 0.0, sl, tp, cmtBuy))
      {
         orderExecuted = true;
         g_lastEntryTimeForSymbol = TimeCurrent();
         Print("? SPIKE TRADE BUY EXÃCUTÃ - ", _Symbol, " @", DoubleToString(ask, _Digits), " | Lot: ", DoubleToString(lot, 2), " | Magic: ", trade.RequestMagic());
         Print("?? DEBUG - Ticket d'ordre: ", trade.ResultOrder());
      }
      else
      {
         Print("? Ãchec SPIKE TRADE BUY - Erreur: ", trade.ResultRetcode(), " - ", trade.ResultRetcodeDescription());
      }
   }
   else // SELL
   {
      if((!m5ch || !M5ChSpikeBypassDerivArrow) && !oteChain && !(massiveMode && SpikeMassiveBypassDerivArrow))
      {
         if(!HasRecentSMCDerivArrowForDirection("SELL"))
         {
            Print("?? SPIKE TRADE SELL bloquÃĐ - Attendre flÃĻche SMC_DERIV_ARROW SELL sur ", _Symbol);
            return;
         }
      }
      double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
      double sl = 0, tp = 0;
      
      // Appliquer SL/TP seulement si NoSLTP_BoomCrash est dÃĐsactivÃĐ
      if(!NoSLTP_BoomCrash || SMC_GetSymbolCategory(_Symbol) != SYM_BOOM_CRASH)
      {
         sl = bid + atrValue * 2.0;  // Pour SELL: SL au-dessus (plus haut)
         tp = bid - atrValue * 3.0;  // Pour SELL: TP en-dessous (plus bas)
      }
      
      Print("?? DEBUG - SELL - Bid: ", DoubleToString(bid, _Digits), " | SL: ", DoubleToString(sl, _Digits), " | TP: ", DoubleToString(tp, _Digits));
      Print("?? DEBUG - VÃĐrification SL/TP SELL - SL > Bid: ", (sl > bid || sl == 0) ? "OK" : "ERREUR", " | TP < Bid: ", (tp < bid || tp == 0) ? "OK" : "ERREUR");
      
      string cmtSell = m5ch ? "SPIKE_M5CH_SERIES_SELL" : "SPIKE TRADE SELL";
      if(trade.Sell(lot, _Symbol, 0.0, sl, tp, cmtSell))
      {
         orderExecuted = true;
         g_lastEntryTimeForSymbol = TimeCurrent();
         Print("? SPIKE TRADE SELL EXÃCUTÃ - ", _Symbol, " @", DoubleToString(bid, _Digits), " | Lot: ", DoubleToString(lot, 2), " | Magic: ", trade.RequestMagic());
         Print("?? DEBUG - Ticket d'ordre: ", trade.ResultOrder());
      }
      else
      {
         Print("? Ãchec SPIKE TRADE SELL - Erreur: ", trade.ResultRetcode(), " - ", trade.ResultRetcodeDescription());
      }
   }
   
   if(orderExecuted)
   {
      int burstDone = 0;
      int burstTarget = MathMax(1, SpikeBurstEntries);
      // Mode "massif": tenter des entrees additionnelles immediates tant que le symbole peut encore ouvrir.
      if(massiveMode && burstTarget > 1)
      {
         for(int b = 1; b < burstTarget; b++)
         {
            if(!CanOpenAdditionalPositionForSymbol(_Symbol, direction))
               break;

            bool burstOk = false;
            string burstCmt = (direction == "BUY") ? "SPIKE TRADE BUY BURST" : "SPIKE TRADE SELL BURST";
            if(direction == "BUY")
               burstOk = trade.Buy(lot, _Symbol, 0.0, 0.0, 0.0, burstCmt);
            else
               burstOk = trade.Sell(lot, _Symbol, 0.0, 0.0, 0.0, burstCmt);

            if(!burstOk)
               break;
            burstDone++;
         }
      }

      Print("?? SPIKE TRADE EXÃCUTÃ AVEC SUCCÃS - Direction: ", direction, " | Symbole: ", _Symbol);
      if(burstDone > 0)
         Print("ð SPIKE MASSIF - entrÃĐes burst ajoutÃĐes: ", burstDone, " | total=", (1 + burstDone));
      NotifyTradeEvent("â SPIKE TRADE EXÃCUTÃ - " + direction + " " + _Symbol, EntryTradeSoundFile);

      // Marquer le temps du dernier spike (utilisÃĐ par la recovery exceptionnelle Boom/Crash)
      datetime now = TimeCurrent();
      string dirUpper = direction;
      StringToUpper(dirUpper);
      if(IsBoomSymbol(_Symbol) && dirUpper == "BUY")
      {
         g_lastBoomSpikeTime = now;
         g_boomSellEntryArmed = false;
         g_boomSellEntryArmedTouchTime = 0;
      }
      else if(IsCrashSymbol(_Symbol) && dirUpper == "SELL")
      {
         g_lastCrashSpikeTime = now;
         g_crashBuyEntryArmed = false;
         g_crashBuyEntryArmedTouchTime = 0;
      }

      // Consommer le touch (une fois utilisÃĐ pour l'entrÃĐe)
      bool isBoom = (StringFind(_Symbol, "Boom") >= 0);
      bool isCrash = (StringFind(_Symbol, "Crash") >= 0);
      if(isBoom)
      {
         g_boomFutureProtectTouchTime = 0;
         g_boomFutureProtectTouchLevel = 0.0;
      }
      if(isCrash)
      {
         g_crashFutureProtectTouchTime = 0;
         g_crashFutureProtectTouchLevel = 0.0;
      }
      
      // DÃĐmarrer la surveillance pour clÃīture immÃĐdiate en gain positif
      StartSpikePositionMonitoring(direction);
   }
}

// Wrapper: rÃĐinitialise toujours le flag sÃĐrie M5-ch aprÃĻs tentative d'entrÃĐe spike
void ExecuteSpikeTrade(string direction)
{
   ExecuteSpikeTradeBody(direction);
   g_m5ChSpikeSeriesActive = false;
}

