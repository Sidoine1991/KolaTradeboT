input int    PendingLimitArrowScalpCooldownSec = 15; // Cooldown (s) entre deux entrÃĐes scalp
input double PendingLimitArrowScalpLotFactor = 0.40; // Fraction du lot calculÃĐ (ex. 0.4)
input bool   PendingLimitArrowScalpUseTrendFilter = false; // Si true, exiger IsTrendAlignedEntry comme DERIV ARROW
input bool   WeltradeSpikeOnlyExit = true; // PAINX/GAINX: ne pas faire de sortie active hors spike captÃĐ (sauf perte mini ci-dessous)
input double WeltradeMinLossBeforeNonSpikeExitUSD = 1.0; // PAINX/GAINX: si pas de spike, autoriser une sortie active seulement Ã  partir de -1$
input double BoomCrashSpikePct = 0.50;   // Pourcentage de mouvement pour dÃĐtecter spike (50% - beaucoup plus ÃĐlevÃĐ)
input double BoomCrashSecondSpikeImminentProb = 0.85; // Si proba spike >= seuil, fermer quand mÃŠme puis armer une rÃĐentrÃĐe
input bool   UseOteSpikeScalpChain = true; // Boom/Crash: enchaÃŪner les spikes tant qu'un setup OTE reste valide et l'IA n'est pas HOLD
input int    OTEBoomCrashCooldownSecondsAfterSpike = 45; // 0=dÃĐsactivÃĐ â ÃĐvite une entrÃĐe OTE immÃĐdiatement aprÃĻs le dernier spike dÃĐtectÃĐ (anti ÂŦ chase Âŧ en queue de spike)
input double OTEBoomCrashGivebackMinPeakUSD = 0.12; // Seuil de pic ($) pour activer la protection giveback sur positions OTE (souvent < SpikePeakGivebackMinProfitUSD)
input double OteSpikeChainMinAIConfidencePct = 78.0; // Confiance IA min (%) pour armer / maintenir la chaÃŪne OTE (ex. SELL Crash)
input int    OteSpikeChainMinSmallM1AfterClose = 3; // Petites bougies M1 aprÃĻs fermeture spike avant rÃĐentrÃĐe (mode chaÃŪne OTE)
input int    MinSmallM1CandlesAfterCloseOteChain = 2; // Avec chaÃŪne OTE armÃĐe: min entre ce nombre et MinSmallM1CandlesAfterClose pour le cooldown post-close (0=dÃĐsactivÃĐ)
input bool   OteSpikeChainBypassMLTrust = true; // ChaÃŪne OTE: ne pas bloquer sur IsMLModelTrusted si IA dÃĐjÃ  au-dessus du seuil chaÃŪne
input int    OteSpikeChainReentryTimeoutSec = 3600; // Timeout (s) rester armÃĐ en mode chaÃŪne OTE (le mode proba seule reste Ã  900s)
input bool   AlwaysReenterAfterSpikeClose = true; // AprÃĻs fermeture spike: armer une rÃĐentrÃĐe mÃŠme si proba/OTE nâont pas armÃĐ
input int    AlwaysReentryAfterSpikeCloseMinSmallM1 = 2; // Petites M1 avant tentative de rÃĐentrÃĐe (mode rÃĐentrÃĐe systÃĐmatique)
input int    AlwaysReentryAfterSpikeCloseTimeoutSec = 900; // Timeout (s) rester armÃĐ en mode rÃĐentrÃĐe systÃĐmatique (0 = 900 appliquÃĐ dans le code)
input int    MinSmallM1CandlesAfterCloseAlwaysReentry = 1; // Avec rÃĐentrÃĐe systÃĐmatique armÃĐe: min entre ce nombre et MinSmallM1CandlesAfterClose (0=dÃĐsactivÃĐ)
input double TargetProfitBoomCrashUSD = 2.0; // Gain Ã  capter ($) - fermer si profit >= ce seuil (Spike_Close)
input double MaxLossDollars    = 15.0;   // Fermer toute position si perte atteint ($) - augmentÃĐ pour ÃĐviter fermetures prÃĐmaturÃĐes
input double TakeProfitDollars = 2.0;    // Fermer si bÃĐnÃĐfice atteint ($) - Volatility/Forex/Commodity
