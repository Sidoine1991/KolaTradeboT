         Print("?? SH trop loin (", MathAbs(lastSH - currentPrice), " > 0.5 ATR) - Ordre SELL annulÃĐ pour petits mouvements");
      }
   }
   
   if(ordersToPlace > 0)
   {
      Print("?? STRATÃGIE HISTORIQUE - ", (2 - existingLimitOrders), " ordres placÃĐs sur SH/SL historiques");
   }
   else
   {
      Print("?? AUCUN SH/SL HISTORIQUE VALIDE - Analyse continue...");
   }
}
*/

void DetectAndPlaceBoomCrashSpikeOrders(MqlRates &rates[], double currentPrice, double currentATR, bool isBoom, int existingLimitOrders)
{
   // VÃRIFICATION ANTI-DUPLICATION - Si position dÃĐjÃ  en cours, ne pas placer d'ordres
   int existingPositionsOnSymbol = CountPositionsForSymbol(_Symbol);
   if(existingPositionsOnSymbol > 0)
   {
      Print("?? ORDRES SPIKE BLOQUÃS - ", existingPositionsOnSymbol, " position(s) dÃĐjÃ  en cours sur ", _Symbol, " - Attente fermeture");
      return;
   }
   
   // Anti-duplication: 1 seul pending LIMIT par symbole
   int totalLimits = CountOpenLimitOrdersForSymbol(_Symbol);
   if(totalLimits >= 1)
   {
      Print("?? ORDRES SPIKE BLOQUÃS - DUP LIMIT sur ", _Symbol);
      return;
   }

   // RÃGLE IA PRIORITAIRE SUR BOOM/CRASH:
   // - Sur Boom: aucun BUY si IA = SELL
   // - Sur Crash: aucun SELL si IA = BUY
   string aiDir = g_lastAIAction;
   StringToUpper(aiDir);
   
   // BLOCAGE SÃCURITÃ: NE PAS PLACER D'ORDRES SI IA EST EN HOLD
   if(aiDir == "HOLD")
   {
      Print("?? ORDRES SPIKE BLOQUÃS - IA en HOLD sur ", _Symbol, " - SÃĐcuritÃĐ activÃĐe");
      return;
   }
   
   if(aiDir == "buy")  aiDir = "BUY";
   if(aiDir == "sell") aiDir = "SELL";
   bool isCrash = !isBoom;
   if(isBoom && aiDir == "SELL")
   {
      Print("?? ORDRES SPIKE BOOM BLOQUÃS - IA = SELL (", DoubleToString(g_lastAIConfidence*100, 1), "%) | Aucun BUY LIMIT autorisÃĐ");
      return;
   }
   if(isCrash && aiDir == "BUY")
   {
      Print("?? ORDRES SPIKE CRASH BLOQUÃS - IA = BUY (", DoubleToString(g_lastAIConfidence*100, 1), "%) | Aucun SELL LIMIT autorisÃĐ");
      return;
   }
   double spikeEntryPoints[];
   ArrayResize(spikeEntryPoints, 20);
   int spikeCount = 0;
   
   // Analyser les 30 derniÃĻres bougies pour dÃĐtecter les points de spike
   for(int i = 2; i < 32 && spikeCount < 20; i++)
   {
      // DÃĐtection de compression avant spike (volatilitÃĐ faible)
      bool isCompression = true;
      double avgRange = 0;
      for(int j = i-5; j <= i-1; j++)
      {
         if(j >= 0)
         {
            avgRange += rates[j].high - rates[j].low;
         }
      }
      if(i >= 5) avgRange /= 5;
      
      // VÃĐrifier si les 5 bougies prÃĐcÃĐdentes ont une faible volatilitÃĐ
      for(int j = i-5; j <= i-1 && j >= 0; j++)
      {
         double currentRange = rates[j].high - rates[j].low;
         if(currentRange > avgRange * 1.5) // VolatilitÃĐ trop ÃĐlevÃĐe
         {
            isCompression = false;
            break;
         }
      }
      
      // DÃĐtection du point d'entrÃĐe du spike
      if(isCompression && i >= 2)
      {
         double prevClose = rates[i-1].close;
         double currentClose = rates[i].close;
         double priceChange = MathAbs(currentClose - prevClose) / prevClose;
         
         // Spike significatif dÃĐtectÃĐ
         if(priceChange > 0.008) // 0.8% de mouvement minimum
         {
            spikeEntryPoints[spikeCount] = currentClose;
            spikeCount++;
            
            // Marquer le point d'entrÃĐe sur le graphique + activer l'avertisseur clignotant
            string spikeName = "SPIKE_ENTRY_" + IntegerToString(i);
            color spikeColor = isBoom ? clrOrange : clrPurple;
            
            // Positionner l'affichage du spike dans la zone prÃĐdite (dÃĐcalÃĐ dans le futur)
            datetime spikeTime = TimeCurrent() + (datetime)(SpikePredictionOffsetMinutes * 60);
            
            if(ObjectCreate(0, spikeName, OBJ_ARROW, 0, spikeTime, currentClose))
            {
               ObjectSetInteger(0, spikeName, OBJPROP_COLOR, spikeColor);
               ObjectSetInteger(0, spikeName, OBJPROP_WIDTH, 5);
               ObjectSetInteger(0, spikeName, OBJPROP_ARROWCODE, isBoom ? 233 : 234);
               ObjectSetString(0, spikeName, OBJPROP_TEXT, isBoom ? "SPIKE BUY" : "SPIKE SELL");
               ObjectSetInteger(0, spikeName, OBJPROP_FONTSIZE, 12);
               ObjectSetInteger(0, spikeName, OBJPROP_ANCHOR, isBoom ? ANCHOR_LOWER : ANCHOR_UPPER);
               ObjectSetInteger(0, spikeName, OBJPROP_TIMEFRAMES, OBJ_ALL_PERIODS);
               ObjectSetInteger(0, spikeName, OBJPROP_BACK, false);
            }
            
            // FlÃĻche unique d'avertissement clignotante
            if(ObjectFind(0, "SMC_Spike_Warning") < 0)
            {
               if(ObjectCreate(0, "SMC_Spike_Warning", OBJ_ARROW, 0, spikeTime, currentClose))
               {
                  ObjectSetInteger(0, "SMC_Spike_Warning", OBJPROP_COLOR, clrYellow);
                  ObjectSetInteger(0, "SMC_Spike_Warning", OBJPROP_WIDTH, 6);
                  ObjectSetInteger(0, "SMC_Spike_Warning", OBJPROP_ARROWCODE, isBoom ? 233 : 234);
                  ObjectSetString(0, "SMC_Spike_Warning", OBJPROP_TEXT, "SPIKE IMMINENT");
                  ObjectSetInteger(0, "SMC_Spike_Warning", OBJPROP_FONTSIZE, 14);
                  ObjectSetInteger(0, "SMC_Spike_Warning", OBJPROP_ANCHOR, isBoom ? ANCHOR_LOWER : ANCHOR_UPPER);
                  ObjectSetInteger(0, "SMC_Spike_Warning", OBJPROP_TIMEFRAMES, OBJ_ALL_PERIODS);
                  ObjectSetInteger(0, "SMC_Spike_Warning", OBJPROP_BACK, false);
               }
            }
            else
            {
               ObjectMove(0, "SMC_Spike_Warning", 0, rates[i].time, currentClose);
               ObjectSetInteger(0, "SMC_Spike_Warning", OBJPROP_COLOR, clrYellow);
            }
            
            g_spikeWarningActive = true;
            g_spikeWarningStart = TimeCurrent();
            g_spikeWarningVisible = true;
         }
      }
   }
   
   // PLACER LES ORDRES LIMITES AUX POINTS D'ENTRÃE DÃTECTÃS
   if(spikeCount > 0)
   {
      int ordersToPlace = MathMin(MathMax(0, 1 - existingLimitOrders), spikeCount); // Anti-duplication: max 1
      
      for(int i = 0; i < ordersToPlace && i < spikeCount; i++)
      {
         // Prendre les points de spike en partant du PLUS RÃCENT
         // spikeEntryPoints[0] = plus ancien, spikeEntryPoints[spikeCount-1] = plus rÃĐcent
         int idx = spikeCount - 1 - i;
         if(idx < 0 || idx >= spikeCount)
            break;
         
         double entryPrice = spikeEntryPoints[idx];
         string spikeType = isBoom ? "BOOM SPIKE BUY" : "CRASH SPIKE SELL";
         
         // Placer ordre limite exactement au point d'entrÃĐe
         MqlTradeRequest request = {};
         MqlTradeResult result = {};
         
         request.action = TRADE_ACTION_PENDING;
         request.symbol = _Symbol;
         request.volume = CalculateLotSizeForPendingOrders();
         if(request.volume <= 0.0) continue;
         request.type = isBoom ? ORDER_TYPE_BUY_LIMIT : ORDER_TYPE_SELL_LIMIT;
         request.price = entryPrice;
         request.sl = entryPrice - (isBoom ? currentATR * 2.0 : -currentATR * 2.0);
         request.tp = entryPrice + (isBoom ? currentATR * 4.0 : -currentATR * 4.0);
         request.magic = InpMagicNumber;
         request.comment = spikeType;
         
         // VALIDATION ET AJUSTEMENT DES PRIX AVANT ENVOI
         ENUM_ORDER_TYPE orderType = isBoom ? ORDER_TYPE_BUY_LIMIT : ORDER_TYPE_SELL_LIMIT;
         if(!ValidateAndAdjustLimitPrice(request.price, request.sl, request.tp, orderType))
         {
            Print("? Ãchec validation prix ", spikeType, " - Ordre annulÃĐ");
            continue;
         }
         
         if(OrderSend(request, result))
         {
            Print("?? ", spikeType, " PLACÃ - EntrÃĐe: ", request.price, " | Vol=", DoubleToString(request.volume, 2),
                  " | TP: ", request.tp, " | SL: ", request.sl);
         }
         else
         {
            Print("? ÃCHEC PLACEMENT ", spikeType, " - Erreur: ", result.comment);
         }
      }
      
      if(ordersToPlace < spikeCount)
      {
         Print("?? ", (spikeCount - ordersToPlace), " spikes supplÃĐmentaires dÃĐtectÃĐs mais ordres limites non disponibles");
      }
   }
   else
   {
      Print("?? AUCUN SPIKE BOOM/CRASH DÃTECTÃ - Analyse continue...");
   }
}

void PlaceNormalScalpingOrders(MqlRates &rates[], int futureBars, double currentPrice, double currentATR, double trendSlope)
{
   // VÃRIFICATION ANTI-DUPLICATION - Si position dÃĐjÃ  en cours, ne pas placer d'ordres
   int existingPositionsOnSymbol = CountPositionsForSymbol(_Symbol);
   if(existingPositionsOnSymbol > 0)
   {
      Print("?? ORDRES NORMAUX BLOQUÃS - ", existingPositionsOnSymbol, " position(s) dÃĐjÃ  en cours sur ", _Symbol, " - Attente fermeture");
      return;
   }
   
   // Anti-duplication: 1 seul pending LIMIT par symbole
   {
      int totalLimits = CountOpenLimitOrdersForSymbol(_Symbol);
      if(totalLimits >= 1)
      {
         Print("?? ORDRES NORMAUX BLOQUÃS - DUP LIMIT sur ", _Symbol);
         return;
      }
   }
   
   // Chercher les prochains SL/SH significatifs dans les 30 prochaines minutes (900 bougies M1)
   int lookAheadBars = MathMin(900, futureBars);
   double bestSLPrice = 0, bestSHPrice = 0;
   datetime bestSLTime = 0, bestSHTime = 0;
   
   for(int predIndex = 30; predIndex < lookAheadBars; predIndex += 30) // VÃĐrifier toutes les 30 bougies
   {
      datetime futureTime = TimeCurrent() + PeriodSeconds(LTF) * predIndex;
      double progressionFactor = (double)predIndex / futureBars;
      double trendComponent = trendSlope * predIndex * 0.5;
      double volatilityComponent = currentATR * progressionFactor * 1.5;
      
      // Calculer les prix prÃĐdits
      double shPrice = (currentPrice + currentATR * 2.0) + trendComponent + volatilityComponent * MathSin(predIndex * 0.1);
      double slPrice = (currentPrice - currentATR * 2.0) + trendComponent - volatilityComponent * MathSin(predIndex * 0.1);
      
      // Garder les SL/SH les plus proches et significatifs
      if(slPrice < currentPrice && (bestSLPrice == 0 || slPrice > bestSLPrice))
      {
         bestSLPrice = slPrice;
         bestSLTime = futureTime;
      }
      
      if(shPrice > currentPrice && (bestSHPrice == 0 || shPrice < bestSHPrice))
      {
         bestSHPrice = shPrice;
         bestSHTime = futureTime;
      }
   }
   
   // Calculer la distance par rapport au prix actuel
   double distanceToSL = (bestSLPrice > 0) ? currentPrice - bestSLPrice : DBL_MAX;
   double distanceToSH = (bestSHPrice > 0) ? bestSHPrice - currentPrice : DBL_MAX;
   
   // Placer UN SEUL ordre limite au niveau le plus proche du prix
   if(distanceToSL < distanceToSH && bestSLPrice > 0)
   {
      // Placer BUY LIMIT au SL le plus proche (niveau exact)
      double buyLimitPrice = bestSLPrice;
      double tpPrice = buyLimitPrice + (currentATR * 1.5 * MathMax(3.0, InpRiskReward));
      
      MqlTradeRequest request = {};
      MqlTradeResult result = {};
      
      request.action = TRADE_ACTION_PENDING;
      request.symbol = _Symbol;
      request.volume = CalculateLotSizeForPendingOrders();
      if(request.volume <= 0.0) return;
      request.type = ORDER_TYPE_BUY_LIMIT;
      request.price = buyLimitPrice;
      request.sl = buyLimitPrice - currentATR * 1.5;
      request.tp = tpPrice;
      request.magic = InpMagicNumber;
      request.comment = "Scalp SL Near";
      
      // VALIDATION ET AJUSTEMENT DES PRIX AVANT ENVOI
      if(!ValidateAndAdjustLimitPrice(request.price, request.sl, request.tp, ORDER_TYPE_BUY_LIMIT))
      {
         Print("? Ãchec validation prix BUY LIMIT scalping - Ordre annulÃĐ");
         return;
      }
      
      if(OrderSend(request, result))
      {
         Print("?? SEUL ORDRE LIMIT BUY PLACÃ - Prix: ", request.price, " | Vol=", DoubleToString(request.volume, 2),
               " | TP: ", request.tp, " | SL: ", request.sl, " | Distance: ", distanceToSL, " points");
      }
   }
   else if(bestSHPrice > 0)
   {
      // Placer SELL LIMIT au SH le plus proche (niveau exact)
      double sellLimitPrice = bestSHPrice;
      double tpPrice = sellLimitPrice - (currentATR * 1.5 * MathMax(3.0, InpRiskReward));
      
      MqlTradeRequest request = {};
      MqlTradeResult result = {};
      
      request.action = TRADE_ACTION_PENDING;
      request.symbol = _Symbol;
      request.volume = CalculateLotSizeForPendingOrders();
      if(request.volume <= 0.0) return;
      request.type = ORDER_TYPE_SELL_LIMIT;
      request.price = sellLimitPrice;
      request.sl = sellLimitPrice + currentATR * 1.5;
      request.tp = tpPrice;
      request.magic = InpMagicNumber;
      request.comment = "Scalp SH Near";
      
      // VALIDATION ET AJUSTEMENT DES PRIX AVANT ENVOI
      if(!ValidateAndAdjustLimitPrice(request.price, request.sl, request.tp, ORDER_TYPE_SELL_LIMIT))
      {
         Print("? Ãchec validation prix SELL LIMIT scalping - Ordre annulÃĐ");
         return;
      }
      
      if(OrderSend(request, result))
      {
         Print("?? SEUL ORDRE LIMIT SELL PLACÃ - Prix: ", request.price, " | Vol=", DoubleToString(request.volume, 2),
               " | TP: ", request.tp, " | SL: ", request.sl, " | Distance: ", distanceToSH, " points");
      }
   }
   else
   {
      Print("? AUCUN NIVEAU VALIDE TROUVÃ pour ordre de scalping");
   }
}

void DrawHistoricalSwingPoints(MqlRates &rates[], int bars, double point)
{
   int swingLookback = 5; // Nombre de bougies de chaque cÃītÃĐ pour valider un swing point
   int maxSwings = 20; // Nombre maximum de swing points Ã  afficher
   int swingCount = 0;
   
   // Parcourir les bougies historiques pour dÃĐtecter les swing points
   for(int i = swingLookback; i < bars - swingLookback && swingCount < maxSwings; i++)
   {
      // DÃĐtecter Swing High (le high de la bougie i est plus ÃĐlevÃĐ que les swingLookback bougies avant et aprÃĻs)
      bool isSwingHigh = true;
      for(int j = i - swingLookback; j <= i + swingLookback; j++)
      {
         if(j != i && rates[j].high >= rates[i].high)
         {
            isSwingHigh = false;
            break;
         }
      }
      
      if(isSwingHigh)
      {
         string shName = "SMC_Hist_SH_" + IntegerToString(i);
         if(ObjectCreate(0, shName, OBJ_ARROW, 0, rates[i].time, rates[i].high))
         {
            ObjectSetInteger(0, shName, OBJPROP_COLOR, clrCrimson);
            ObjectSetInteger(0, shName, OBJPROP_WIDTH, 3);
            ObjectSetInteger(0, shName, OBJPROP_ARROWCODE, 233); // FlÃĻche vers le haut
            ObjectSetString(0, shName, OBJPROP_TEXT, "SH");
            ObjectSetInteger(0, shName, OBJPROP_FONTSIZE, 10);
            ObjectSetInteger(0, shName, OBJPROP_ANCHOR, ANCHOR_LOWER);
            ObjectSetInteger(0, shName, OBJPROP_TIMEFRAMES, OBJ_ALL_PERIODS); // Visible sur tous les timeframes
            ObjectSetInteger(0, shName, OBJPROP_BACK, false); // Au premier plan
            swingCount++;
         }
      }
      
      // DÃĐtecter Swing Low (le low de la bougie i est plus bas que les swingLookback bougies avant et aprÃĻs)
      bool isSwingLow = true;
      for(int j = i - swingLookback; j <= i + swingLookback; j++)
      {
         if(j != i && rates[j].low <= rates[i].low)
         {
            isSwingLow = false;
            break;
         }
      }
      
      if(isSwingLow)
      {
         string slName = "SMC_Hist_SL_" + IntegerToString(i);
         if(ObjectCreate(0, slName, OBJ_ARROW, 0, rates[i].time, rates[i].low))
         {
            ObjectSetInteger(0, slName, OBJPROP_COLOR, clrDodgerBlue);
            ObjectSetInteger(0, slName, OBJPROP_WIDTH, 3);
            ObjectSetInteger(0, slName, OBJPROP_ARROWCODE, 234); // FlÃĻche vers le bas
            ObjectSetString(0, slName, OBJPROP_TEXT, "SL");
            ObjectSetInteger(0, slName, OBJPROP_FONTSIZE, 10);
            ObjectSetInteger(0, slName, OBJPROP_ANCHOR, ANCHOR_UPPER);
            ObjectSetInteger(0, slName, OBJPROP_TIMEFRAMES, OBJ_ALL_PERIODS); // Visible sur tous les timeframes
            ObjectSetInteger(0, slName, OBJPROP_BACK, false); // Au premier plan
            swingCount++;
         }
      }
   }
   
   Print("?? SWING HISTORIQUES - ", swingCount, " points dÃĐtectÃĐs (SH: rouge, SL: bleu)");
}

void DrawFVGOnChart()
{
   MqlRates rates[];
   ArraySetAsSeries(rates, true);
   int bars = 80;
   if(CopyRates(_Symbol, LTF, 0, bars, rates) < bars) return;
   ObjectsDeleteAll(0, "SMC_FVG_");
   ObjectsDeleteAll(0, "SMC_IFVG_");
   int cnt = 0;
   for(int fvgIndex = 2; fvgIndex < bars - 2 && cnt < 15; fvgIndex++)
   {
      if(rates[fvgIndex].close > rates[fvgIndex].open && rates[fvgIndex+1].high < rates[fvgIndex-1].low)
      {
         double top = rates[fvgIndex-1].low, bot = rates[fvgIndex+1].high;
         datetime t1 = rates[fvgIndex+1].time, t2 = TimeCurrent() + PeriodSeconds(LTF)*20;
         string name = "SMC_FVG_Bull_" + IntegerToString(fvgIndex);
         if(ObjectCreate(0, name, OBJ_RECTANGLE, 0, t1, bot, t2, top))
         {
            ObjectSetInteger(0, name, OBJPROP_COLOR, clrGreen);
            ObjectSetInteger(0, name, OBJPROP_WIDTH, 1);
            ObjectSetInteger(0, name, OBJPROP_BACK, false);
            ObjectSetInteger(0, name, OBJPROP_FILL, false);
            cnt++;
         }
      }
      if(rates[fvgIndex].close < rates[fvgIndex].open && rates[fvgIndex+1].low > rates[fvgIndex-1].high)
      {
         double top = rates[fvgIndex+1].low, bot = rates[fvgIndex-1].high;
         datetime t1 = rates[fvgIndex+1].time, t2 = TimeCurrent() + PeriodSeconds(LTF)*20;
         string name = "SMC_FVG_Bear_" + IntegerToString(fvgIndex);
         if(ObjectCreate(0, name, OBJ_RECTANGLE, 0, t1, bot, t2, top))
         {
            ObjectSetInteger(0, name, OBJPROP_COLOR, clrRed);
            ObjectSetInteger(0, name, OBJPROP_WIDTH, 1);
            ObjectSetInteger(0, name, OBJPROP_BACK, false);
            ObjectSetInteger(0, name, OBJPROP_FILL, false);
            cnt++;
         }
      }
   }

   FVGData ifvgSell, ifvgBuy;
   datetime t2ifvg = TimeCurrent() + PeriodSeconds(LTF)*20;
   if(ICT_DetectInvertedFVG(_Symbol, LTF, -1, MathMax(80, ICTLookbackBars), ifvgSell))
   {
      string n1 = "SMC_IFVG_SELL";
      if(ObjectCreate(0, n1, OBJ_RECTANGLE, 0, ifvgSell.time, ifvgSell.bottom, t2ifvg, ifvgSell.top))
      {
         ObjectSetInteger(0, n1, OBJPROP_COLOR, clrTomato);
         ObjectSetInteger(0, n1, OBJPROP_WIDTH, 2);
         ObjectSetInteger(0, n1, OBJPROP_STYLE, STYLE_DASHDOT);
         ObjectSetInteger(0, n1, OBJPROP_FILL, false);
      }
   }
   if(ICT_DetectInvertedFVG(_Symbol, LTF, 1, MathMax(80, ICTLookbackBars), ifvgBuy))
   {
      string n2 = "SMC_IFVG_BUY";
      if(ObjectCreate(0, n2, OBJ_RECTANGLE, 0, ifvgBuy.time, ifvgBuy.bottom, t2ifvg, ifvgBuy.top))
      {
         ObjectSetInteger(0, n2, OBJPROP_COLOR, clrLimeGreen);
         ObjectSetInteger(0, n2, OBJPROP_WIDTH, 2);
         ObjectSetInteger(0, n2, OBJPROP_STYLE, STYLE_DASHDOT);
         ObjectSetInteger(0, n2, OBJPROP_FILL, false);
      }
   }
}

void DrawOBOnChart()
{
   MqlRates rates[];
   ArraySetAsSeries(rates, true);
   int bars = 80;
   if(CopyRates(_Symbol, LTF, 0, bars, rates) < bars) return;
   double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   double tol = MathMax(point, ICTSweepTolerancePoints * point);
   ObjectsDeleteAll(0, "SMC_OB_");
   int cnt = 0;

   // Confluence Fibonacci (OTE) pour ÃĐviter d'afficher des OB non exploitables.
   double swingHigh = rates[1].high, swingLow = rates[1].low;
   for(int s = 2; s < bars; s++)
   {
      if(rates[s].high > swingHigh) swingHigh = rates[s].high;
      if(rates[s].low < swingLow) swingLow = rates[s].low;
   }
   double rg = MathMax(point * 20.0, swingHigh - swingLow);
   double buyFibLow = swingLow + rg * 0.618;
   double buyFibHigh = swingLow + rg * 0.786;
   if(buyFibLow > buyFibHigh) { double t = buyFibLow; buyFibLow = buyFibHigh; buyFibHigh = t; }
   double sellFibA = swingHigh - rg * 0.618;
   double sellFibB = swingHigh - rg * 0.786;
   double sellFibLow = MathMin(sellFibA, sellFibB);
   double sellFibHigh = MathMax(sellFibA, sellFibB);

   for(int fvgIndex = 3; fvgIndex < bars - 4 && cnt < MathMax(1, MaxConfirmedOBToDraw); fvgIndex++)
   {
      if(rates[fvgIndex].close < rates[fvgIndex].open && rates[fvgIndex+1].close > rates[fvgIndex+1].open && (rates[fvgIndex+1].high - rates[fvgIndex].low) > point*20
         && ICT_HasLiquiditySweepBeforeIndex(rates, bars, fvgIndex, 1, tol))
      {
         double obLow = rates[fvgIndex].low;
         double obHigh = rates[fvgIndex].high;
         double obMid = (obLow + obHigh) * 0.5;
         bool fibConfluence = (obMid >= buyFibLow && obMid <= buyFibHigh);
         bool confirmed = false;
         for(int t = 1; t < fvgIndex; t++)
         {
            bool touched = (rates[t].low <= (obHigh + tol) && rates[t].high >= (obLow - tol));
            bool reacted = (rates[t].close > obMid);
            if(touched && reacted) { confirmed = true; break; }
         }
         if(OnlyDrawConfirmedOBWithFibConfluence && (!fibConfluence || !confirmed))
            continue;

         datetime t2 = TimeCurrent() + PeriodSeconds(LTF)*30;
         string name = "SMC_OB_Bull_" + IntegerToString(fvgIndex);
         if(ObjectCreate(0, name, OBJ_RECTANGLE, 0, rates[fvgIndex].time, rates[fvgIndex].low, t2, rates[fvgIndex].high))
         {
            ObjectSetInteger(0, name, OBJPROP_COLOR, clrDodgerBlue);
            ObjectSetInteger(0, name, OBJPROP_WIDTH, confirmed ? 2 : 1);
            ObjectSetInteger(0, name, OBJPROP_BACK, true);
            ObjectSetInteger(0, name, OBJPROP_FILL, false);
            cnt++;
         }
      }
      if(rates[fvgIndex].close > rates[fvgIndex].open && rates[fvgIndex+1].close < rates[fvgIndex+1].open && (rates[fvgIndex].high - rates[fvgIndex+1].low) > point*20
         && ICT_HasLiquiditySweepBeforeIndex(rates, bars, fvgIndex, -1, tol))
      {
         double obLow = rates[fvgIndex].low;
         double obHigh = rates[fvgIndex].high;
         double obMid = (obLow + obHigh) * 0.5;
         bool fibConfluence = (obMid >= sellFibLow && obMid <= sellFibHigh);
         bool confirmed = false;
         for(int t = 1; t < fvgIndex; t++)
         {
            bool touched = (rates[t].low <= (obHigh + tol) && rates[t].high >= (obLow - tol));
            bool reacted = (rates[t].close < obMid);
            if(touched && reacted) { confirmed = true; break; }
         }
         if(OnlyDrawConfirmedOBWithFibConfluence && (!fibConfluence || !confirmed))
            continue;

         datetime t2 = TimeCurrent() + PeriodSeconds(LTF)*30;
         string name = "SMC_OB_Bear_" + IntegerToString(fvgIndex);
         if(ObjectCreate(0, name, OBJ_RECTANGLE, 0, rates[fvgIndex].time, rates[fvgIndex].low, t2, rates[fvgIndex].high))
         {
            ObjectSetInteger(0, name, OBJPROP_COLOR, clrCrimson);
            ObjectSetInteger(0, name, OBJPROP_WIDTH, confirmed ? 2 : 1);
            ObjectSetInteger(0, name, OBJPROP_BACK, true);
            ObjectSetInteger(0, name, OBJPROP_FILL, false);
            cnt++;
         }
      }
   }
}

void DrawFibonacciOnChart()
{
   double high[], low[];
   datetime time[];
   ArraySetAsSeries(high, true); ArraySetAsSeries(low, true); ArraySetAsSeries(time, true);
   int n = 100; // AugmentÃĐ pour meilleure analyse des swings
   if(CopyHigh(_Symbol, LTF, 0, n, high) < n || CopyLow(_Symbol, LTF, 0, n, low) < n || CopyTime(_Symbol, LTF, 0, n, time) < n) return;
   
   // Identifier les vrais swings significatifs (pas juste le plus haut/plus bas)
   int iHigh = FindSignificantSwingHigh(high, low, n);
   int iLow = FindSignificantSwingLow(high, low, n);
   if(iHigh < 0 || iLow < 0) return;
   
   double h = high[iHigh], l = low[iLow];
   datetime tHigh = time[iHigh], tLow = time[iLow];
   
   // S'assurer que le high est avant le low pour une analyse correcte
   if(tHigh > tLow) {
      // Inverser pour avoir le swing high avant le swing low
      int tempIdx = iHigh;
      iHigh = iLow;
      iLow = tempIdx;
      double tempPrice = h;
      h = l;
      l = tempPrice;
      datetime tempTime = tHigh;
      tHigh = tLow;
      tLow = tempTime;
   }
   
   ObjectsDeleteAll(0, "SMC_Fib_");
   
   // Niveaux Fibonacci amÃĐliorÃĐs pour OTE
   double levels[] = {0.0, 0.236, 0.382, 0.5, 0.618, 0.786, 1.0};
   color colors[] = {clrGray, clrDodgerBlue, clrAqua, clrYellow, clrOrange, clrOrangeRed, clrMagenta};
   string descriptions[] = {"Start", "23.6%", "38.2%", "50%", "61.8% (OTE)", "78.6% (OTE)", "100%"};
   
   for(int i = 0; i < 7; i++)
   {
      double price = l + (h - l) * levels[i];
      string name = "SMC_Fib_" + IntegerToString(i);
      if(ObjectCreate(0, name, OBJ_HLINE, 0, 0, price))
      {
         ObjectSetInteger(0, name, OBJPROP_COLOR, colors[i]);
         ObjectSetInteger(0, name, OBJPROP_STYLE, STYLE_DASH);
         ObjectSetInteger(0, name, OBJPROP_WIDTH, (i == 4 || i == 5) ? 2 : 1); // OTE plus ÃĐpais
         ObjectSetString(0, name, OBJPROP_TOOLTIP, "Fib " + descriptions[i]);
         
         // Mettre en ÃĐvidence les zones OTE (61.8% et 78.6%)
         if(i == 4 || i == 5) {
            ObjectSetInteger(0, name, OBJPROP_STYLE, STYLE_SOLID);
            ObjectSetInteger(0, name, OBJPROP_BACK, true);
            if(i == 4) {
               ObjectSetInteger(0, name, OBJPROP_COLOR, clrOrange);
            } else {
               ObjectSetInteger(0, name, OBJPROP_COLOR, clrOrangeRed);
            }
         }
      }
   }
   
   // Dessiner le retracement Fibonacci principal
   string fibName = "SMC_FIB_MAIN";
   if(ObjectCreate(0, fibName, OBJ_FIBO, 0, tLow, l, tHigh, h))
   {
      ObjectSetInteger(0, fibName, OBJPROP_COLOR, clrGold);
      ObjectSetInteger(0, fibName, OBJPROP_LEVELS, 7);
      ObjectSetInteger(0, fibName, OBJPROP_LEVELCOLOR, clrOrange);
      ObjectSetInteger(0, fibName, OBJPROP_LEVELSTYLE, STYLE_DASH);
      ObjectSetInteger(0, fibName, OBJPROP_LEVELWIDTH, 1);
      
      // Configurer les niveaux
      for(int i = 0; i < 7; i++)
      {
         ObjectSetDouble(0, fibName, OBJPROP_LEVELVALUE, i, levels[i]);
         ObjectSetString(0, fibName, OBJPROP_LEVELTEXT, i, descriptions[i]);
      }
   }
   
   // Analyser et stocker les zones OTE futures pour le trading
   AnalyzeFutureOTEZones(h, l, tHigh, tLow);
}

// Fonction pour trouver les swings significatifs
int FindSignificantSwingHigh(double &high[], double &low[], int n)
{
   for(int i = 5; i < n - 5; i++) {
      bool isSwingHigh = true;
      for(int j = i - 5; j <= i + 5; j++) {
         if(j != i && high[j] >= high[i]) {
            isSwingHigh = false;
            break;
         }
      }
      if(isSwingHigh) return i;
   }
   return ArrayMaximum(high, 0, n);
}

// Fonction pour trouver les swings significatifs
int FindSignificantSwingLow(double &high[], double &low[], int n)
{
   for(int i = 5; i < n - 5; i++) {
      bool isSwingLow = true;
      for(int j = i - 5; j <= i + 5; j++) {
         if(j != i && low[j] <= low[i]) {
            isSwingLow = false;
            break;
         }
      }
      if(isSwingLow) return i;
   }
   return ArrayMinimum(low, 0, n);
}

// Analyser les zones OTE futures et prendre position si validÃĐes
void AnalyzeFutureOTEZones(double swingHigh, double swingLow, datetime swingHighTime, datetime swingLowTime)
{
   // VÃĐrifier si nous avons dÃĐjÃ  une position sur ce symbole
   if(HasAnyExposureForSymbol(_Symbol)) return;
   
   // VÃĐrifier si le trading est activÃĐ
   if(!EnableTrading) return;
   
   // Obtenir le prix actuel
   double currentPrice = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   if(currentPrice <= 0) return;
   
   // Calculer les zones OTE
   double range = swingHigh - swingLow;
   if(range <= 0) return;
   
   // Zone OTE BUY (pour les mouvements baissiers qui vont rebondir)
   double oteBuyLow = swingLow + range * 0.62;   // 61.8%
   double oteBuyHigh = swingLow + range * 0.786;  // 78.6%
   
   // Zone OTE SELL (pour les mouvements haussiers qui vont corriger)
   double oteSellLow = swingHigh - range * 0.786;  // 78.6%
   double oteSellHigh = swingHigh - range * 0.62; // 61.8%
   
   double entryBuy = OTE_UseStructuralMidForEntry ? (oteBuyLow + oteBuyHigh) * 0.5 : currentPrice;
   double entrySell = OTE_UseStructuralMidForEntry ? (oteSellLow + oteSellHigh) * 0.5 : currentPrice;
   entryBuy = NormalizeDouble(entryBuy, _Digits);
   entrySell = NormalizeDouble(entrySell, _Digits);
   
   // Analyser la tendance actuelle pour dÃĐterminer la direction probable
   string trendDirection = GetCurrentTrendDirection();
   
   // VÃĐrifier si nous sommes dans une zone OTE future valide
   bool oteBuyValid = (currentPrice >= oteBuyLow && currentPrice <= oteBuyHigh);
   bool oteSellValid = (currentPrice >= oteSellLow && currentPrice <= oteSellHigh);
   double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   double buyZoneSize = MathMax(point, oteBuyHigh - oteBuyLow);
   double sellZoneSize = MathMax(point, oteSellHigh - oteSellLow);
   double maxDistRatio = MathMax(0.0, OTE_RealEntryMaxDistanceZoneRatio);
   double maxBuyDist = buyZoneSize * maxDistRatio;
   double maxSellDist = sellZoneSize * maxDistRatio;
   bool buyRealEntry = (!OTE_RequireRealEntryPrecision) || (MathAbs(currentPrice - entryBuy) <= maxBuyDist);
   bool sellRealEntry = (!OTE_RequireRealEntryPrecision) || (MathAbs(currentPrice - entrySell) <= maxSellDist);
   bool oteBuyExecutable = oteBuyValid && buyRealEntry;
   bool oteSellExecutable = oteSellValid && sellRealEntry;
   
   // Validation supplÃĐmentaire avec IA
   string aiAction = g_lastAIAction;
   double aiConfidence = g_lastAIConfidence;
   bool isBoomCrash = (StringFind(_Symbol, "Boom") >= 0 || StringFind(_Symbol, "Crash") >= 0);
   
   // Logs de debugging
   if(DebugMode) {
      Print("ð OTE FUTURE ANALYSIS - ", _Symbol);
      Print("   ð Prix actuel: ", DoubleToString(currentPrice, _Digits));
      Print("   ðŊ Zone OTE BUY: ", DoubleToString(oteBuyLow, _Digits), " - ", DoubleToString(oteBuyHigh, _Digits));
      Print("   ðŊ Zone OTE SELL: ", DoubleToString(oteSellLow, _Digits), " - ", DoubleToString(oteSellHigh, _Digits));
      Print("   ð Tendance: ", trendDirection);
      Print("   ðĪ IA: ", aiAction, " (", FormatAIConfidencePct(), ")");
      Print("   â OTE BUY valide: ", oteBuyValid ? "OUI" : "NON");
      Print("   â OTE SELL valide: ", oteSellValid ? "OUI" : "NON");
      if(OTE_RequireRealEntryPrecision)
      {
         Print("   ðŊ OTE BUY prÃĐcis: ", oteBuyExecutable ? "OUI" : "NON",
               " | |Prix-Entry|=", DoubleToString(MathAbs(currentPrice - entryBuy), _Digits),
               " <= ", DoubleToString(maxBuyDist, _Digits));
         Print("   ðŊ OTE SELL prÃĐcis: ", oteSellExecutable ? "OUI" : "NON",
               " | |Prix-Entry|=", DoubleToString(MathAbs(currentPrice - entrySell), _Digits),
               " <= ", DoubleToString(maxSellDist, _Digits));
      }
   }
   
   // Mode prioritaire Boom/Crash: en zone OTE + direction IA correcte => exÃĐcution marchÃĐ immÃĐdiate
   if(isBoomCrash)
   {
      bool aiBuy = (aiAction == "BUY" || aiAction == "buy");
      bool aiSell = (aiAction == "SELL" || aiAction == "sell");
      bool aiOkConf = (aiConfidence <= 0.0 || aiConfidence >= MinAIConfidence);

      if(oteBuyExecutable && aiBuy && aiOkConf && IsDirectionAllowedForBoomCrash(_Symbol, "BUY"))
      {
         Print("â OTE_BC_MARKET_AUTO_EXEC | ", _Symbol,
               " | Dir=BUY | Bid=", DoubleToString(currentPrice, _Digits),
               " | EntryRef=", DoubleToString(entryBuy, _Digits),
               " | IA=", aiAction, "(", FormatAIConfidencePct(), ")");
         ExecuteFutureOTETrade("BUY", entryBuy, swingLow, swingHigh);
         return;
      }
      if(oteSellExecutable && aiSell && aiOkConf && IsDirectionAllowedForBoomCrash(_Symbol, "SELL"))
      {
         Print("â OTE_BC_MARKET_AUTO_EXEC | ", _Symbol,
               " | Dir=SELL | Bid=", DoubleToString(currentPrice, _Digits),
               " | EntryRef=", DoubleToString(entrySell, _Digits),
               " | IA=", aiAction, "(", FormatAIConfidencePct(), ")");
         ExecuteFutureOTETrade("SELL", entrySell, swingLow, swingHigh);
         return;
      }
   }

   // ExÃĐcuter un trade si les conditions OTE sont remplies (logique standard)
   if(oteBuyExecutable && ShouldExecuteOTETrade("BUY", aiAction, aiConfidence, trendDirection))
   {
      ExecuteFutureOTETrade("BUY", entryBuy, swingLow, swingHigh);
   }
   else if(oteSellExecutable && ShouldExecuteOTETrade("SELL", aiAction, aiConfidence, trendDirection))
   {
      ExecuteFutureOTETrade("SELL", entrySell, swingLow, swingHigh);
   }
}

// DÃĐterminer si un trade OTE doit ÃŠtre exÃĐcutÃĐ
bool ShouldExecuteOTETrade(string direction, string aiAction, double aiConfidence, string trendDirection)
{
   // VÃĐrifier si le trading est autorisÃĐ par la protection des gains
   if(!IsTradingAllowedForGainPreservation())
   {
      if(DebugMode) Print("â OTE BLOQUÃ - Protection gains accumulÃĐs active");
      return false;
   }

   if(!IsOTEEntryDirectionSafeForPremiumDiscount(_Symbol, direction))
   {
      if(DebugMode) Print("â OTE BLOQUÃ - Premium/Discount (Boom/Crash/Weltrade) | ", _Symbol, " | ", direction);
      return false;
   }
   if(!PassFutureDirectionConfidenceGate(direction, "OTE", false))
      return false;
   if(!PassFutureDirectionConfidenceGate(direction, "OTE", false))
      return false;

   double aiConfUnit = aiConfidence;
   if(aiConfUnit > 1.0)
      aiConfUnit /= 100.0;

   // VÃĐrifier la concordance avec l'IA (normaliser cas)
   string aiU = aiAction;
   string dirU = direction;
   StringToUpper(aiU);
   StringToUpper(dirU);
   if(aiU != dirU && aiAction != "") {
      if(DebugMode) Print("â OTE NON ALIGNÃ - Direction: ", direction, " | IA: ", aiAction);
      return false;
   }

   bool highOteBypass = OTE_BypassExpectancyAndICTOnHighAI && UseAIServer &&
      aiAction != "" && aiU == dirU && aiConfUnit >= OTE_HighAIConfidenceUnit;
   
   // Calculer l'espÃĐrance mathÃĐmatique du trade
   double stopLoss, takeProfit;
   if(direction == "BUY")
   {
      stopLoss = 0; // Sera calculÃĐ plus tard
      takeProfit = 0; // Sera calculÃĐ plus tard
   }
   else
   {
      stopLoss = 0;
      takeProfit = 0;
   }
   
   // Estimation pour le calcul d'espÃĐrance
   double estimatedEntry = SymbolInfoDouble(_Symbol, (direction == "BUY") ? SYMBOL_ASK : SYMBOL_BID);
   if(!PassOteFibSwingEquilibriumFilter(direction, estimatedEntry))
   {
      if(DebugMode) Print("â OTE BLOQUÃ - Fib swing 0.5 (discount/premium structure)");
      return false;
   }
   double estimatedRisk = SymbolInfoDouble(_Symbol, SYMBOL_POINT) * 50; // Estimation 50 pips
   double estimatedReward = estimatedRisk * MathMax(2.0, InpRiskReward);
   
   double expectancy = CalculateTradeExpectancy(direction, estimatedEntry, 
                                       (direction == "BUY") ? (estimatedEntry - estimatedRisk) : (estimatedEntry + estimatedRisk),
                                       (direction == "BUY") ? (estimatedEntry + estimatedReward) : (estimatedEntry - estimatedReward));
   
   if(!highOteBypass && expectancy < MinExpectancyThreshold)
   {
      if(DebugMode) Print("â OTE BLOQUÃ - EspÃĐrance: ", DoubleToString(expectancy, 3), " < ", DoubleToString(MinExpectancyThreshold, 3));
      return false;
   }
   
   if(!highOteBypass && UseICTEvidenceSequence)
   {
      int ictScore = 0;
      string ictReason = "";
      if(!ICT_ValidateEvidenceSequence(_Symbol, LTF, direction, ictScore, ictReason))
      {
         if(DebugMode) Print("â OTE CHECKLIST ICT INVALIDE - ", direction, " | Score=", ictScore, "/", ICTMinSignatures, " | ", ictReason);
         return false;
      }
      if(DebugMode) Print("â OTE CHECKLIST ICT VALIDÃE - ", direction, " | Score=", ictScore, "/", ICTMinSignatures, " | ", ictReason);
   }
   
   // VÃĐrifier la confiance IA minimum dÃĐdiÃĐe aux setups OTE marchÃĐ
   double oteMinConfU = OTESetupMarketMinAIConfidencePercent;
   if(oteMinConfU > 1.0) oteMinConfU /= 100.0;
   if(oteMinConfU <= 0.0) oteMinConfU = 0.60;
   if(aiConfUnit < oteMinConfU && aiConfidence > 0) {
      if(DebugMode) Print("â OTE CONFIANCE INSUFFISANTE - IA: ", DoubleToString(aiConfUnit * 100.0, 1), "% < ", DoubleToString(oteMinConfU * 100.0, 1), "%");
      return false;
   }
   
   // VÃĐrifier la cohÃĐrence de la tendance
   if(!highOteBypass && direction == "BUY" && trendDirection == "DOWNTREND") {
      if(DebugMode) Print("â OTE CONTRE-TENDANCE - BUY sur tendance baissiÃĻre");
      return false;
   }
   
   if(!highOteBypass && direction == "SELL" && trendDirection == "UPTREND") {
      if(DebugMode) Print("â OTE CONTRE-TENDANCE - SELL sur tendance haussiÃĻre");
      return false;
   }
   
   // VÃĐrifier la protection capital
   if(IsMaxPositionsReached()) {
      if(DebugMode) Print("â OTE BLOQUÃ - Protection capital activÃĐe");
      return false;
   }
   
   return true;
}

// ExÃĐcuter un trade basÃĐ sur l'OTE future validÃĐe
void ExecuteFutureOTETrade(string direction, double entryPrice, double swingLow, double swingHigh)
{
   if(!IsOTEEntryDirectionSafeForPremiumDiscount(_Symbol, direction))
   {
      Print("ðŦ OTE FUTURE BLOQUÃ - PrÃĐcaution Premium/Discount sur ", _Symbol, " : ", direction);
      return;
   }
   {
      const double refFib = (entryPrice > 0.0 ? entryPrice
                                              : ((direction == "BUY") ? SymbolInfoDouble(_Symbol, SYMBOL_ASK)
                                                                      : SymbolInfoDouble(_Symbol, SYMBOL_BID)));
      if(!PassOteFibSwingEquilibriumFilter(direction, refFib))
         return;
   }
   if(!IsDirectionAllowedForBoomCrash(_Symbol, direction))
   {
      Print("ðŦ OTE FUTURE BLOQUÃ - Direction interdite sur ", _Symbol, " : ", direction);
      return;
   }
   if(UseAIServer && IsBoomCrashOrWeltradeDirectionalSynth(_Symbol) &&
      !IsBoomCrashDirectionAllowedByIA(_Symbol, direction))
   {
      Print("ðŦ OTE FUTURE BLOQUÃ - Direction vs IA serveur sur ", _Symbol,
            " dir=", direction, " IA=", g_lastAIAction);
      return;
   }
   if(!CanOpenAdditionalPositionForSymbol(_Symbol, direction))
   {
      Print("ðŦ OTE FUTURE BLOQUÃ - Position dÃĐjÃ  prise sur ", _Symbol, " | dir=", direction);
      return;
   }

   double lot = NormalizeVolumeForSymbol(GetMinLotForSymbol(_Symbol));
   if(lot <= 0.0)
   {
      Print("â OTE FUTURE BLOQUÃ - lot minimum broker indisponible sur ", _Symbol);
      return;
   }
   // SÃĐcuritÃĐ: S'assurer que swingLow est bien le plus bas et swingHigh le plus haut
   double sLow = MathMin(swingLow, swingHigh);
   double sHigh = MathMax(swingLow, swingHigh);

   double stopLoss, takeProfit;
   
   // Calculer SL et TP selon la direction OTE
   if(direction == "BUY")
   {
      // SL: sous le swing low
      stopLoss = sLow - SymbolInfoDouble(_Symbol, SYMBOL_POINT) * 15;
      // TP: ratio >= 3:1 (min via RR clamp)
      takeProfit = entryPrice + (entryPrice - stopLoss) * MathMax(3.0, InpRiskReward);
   }
   else // SELL
   {
      // SL: au-dessus du swing high
      stopLoss = sHigh + SymbolInfoDouble(_Symbol, SYMBOL_POINT) * 15;
      // TP: ratio >= 3:1 (min via RR clamp)
      takeProfit = entryPrice - (stopLoss - entryPrice) * MathMax(3.0, InpRiskReward);
   }

   // [FIX] SÃĐcuritÃĐ ultra : forcer l'orientation correcte si elle est inversÃĐe malgrÃĐ tout
   ValidateAndAdjustStopLossTakeProfit(direction, entryPrice, stopLoss, takeProfit);
   
   // MatÃĐrialiser visuellement le setup OTE dÃĻs qu'il est validÃĐ cÃītÃĐ logique.
   DrawOTESetup(entryPrice, stopLoss, takeProfit, direction);
   
   // Calculer l'espÃĐrance mathÃĐmatique finale
   double expectancy = CalculateTradeExpectancy(direction, entryPrice, stopLoss, takeProfit);

   bool highOteFinalizeBypass = false;
   if(OTE_BypassExpectancyAndICTOnHighAI && UseAIServer)
   {
      string iaF = g_lastAIAction;
      StringToUpper(iaF);
      string dirF = direction;
      StringToUpper(dirF);
      double cF = NormalizeAIConfidenceUnit();
      highOteFinalizeBypass = (iaF == dirF && iaF != "" && iaF != "HOLD" && cF >= OTE_HighAIConfidenceUnit);
   }
   
   if(!highOteFinalizeBypass && expectancy < MinExpectancyThreshold)
   {
      Print("ðŦ OTE FUTURE BLOQUÃ - EspÃĐrance finale: ", DoubleToString(expectancy, 3), " < ", DoubleToString(MinExpectancyThreshold, 3));
      return;
   }
   
   // AJOUT: VÃĐrifier si on doit faire une entrÃĐe avant l'OTE pour capturer les spikes
   if(UsePreOTEEntry)
   {
      Print("ð DÃTECTION ENTRÃE PRÃ-OTE - ", direction, " sur ", _Symbol);
      ExecutePreOTESpikeEntry(direction, entryPrice, stopLoss, takeProfit);
      
      // Ajouter le setup OTE au suivi pour validation future
      int setupId = AddOTESetup(entryPrice, stopLoss, takeProfit, direction);
      if(setupId > 0)
      {
         Print("ð SETUP OTE EN SUIVI - ID: ", setupId, " | Attente toucher niveau");
      }
      return; // L'entrÃĐe prÃĐ-OTE est prioritaire
   }
   
   // Valider et ajuster les distances minimales
   ValidateAndAdjustStopLossTakeProfit(direction, entryPrice, stopLoss, takeProfit);
   
   bool success = false;
   string comment = "OTE_FUTURE_" + direction;
   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   double pt = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   if(pt <= 0.0) pt = _Point;
   double ep = NormalizeDouble(entryPrice, _Digits);
   double minOff = (double)OTE_StructuralMinDistancePts * pt;

   double usedEntry = ep;
   double usedSL = stopLoss;
   double usedTP = takeProfit;
   if(OTE_PlaceLimitWhenStructuralBetter && direction == "SELL" && ep > bid + minOff)
   {
      ENUM_ORDER_TYPE ot = ORDER_TYPE_SELL_LIMIT;
      if(!ValidateAndAdjustLimitPrice(usedEntry, usedSL, usedTP, ot))
         success = false;
      else
         success = trade.SellLimit(lot, usedEntry, _Symbol, usedSL, usedTP, ORDER_TIME_GTC, 0, comment);
      if(!success)
      {
         Print("â ïļ OTE FUTURE SELL LIMIT ÃĐchec (", trade.ResultRetcode(), ") â marchÃĐ");
         success = trade.Sell(lot, _Symbol, 0.0, stopLoss, takeProfit, comment);
      }
      else
      {
         ulong pend = trade.ResultOrder();
         if(pend > 0)
            AddOTESetup(usedEntry, usedSL, usedTP, direction, pend);
      }
   }
   else if(OTE_PlaceLimitWhenStructuralBetter && direction == "BUY" && ep < ask - minOff)
   {
      ENUM_ORDER_TYPE ot = ORDER_TYPE_BUY_LIMIT;
      usedEntry = ep; usedSL = stopLoss; usedTP = takeProfit;
      if(!ValidateAndAdjustLimitPrice(usedEntry, usedSL, usedTP, ot))
         success = false;
      else
         success = trade.BuyLimit(lot, usedEntry, _Symbol, usedSL, usedTP, ORDER_TIME_GTC, 0, comment);
      if(!success)
      {
         Print("â ïļ OTE FUTURE BUY LIMIT ÃĐchec (", trade.ResultRetcode(), ") â marchÃĐ");
         success = trade.Buy(lot, _Symbol, 0.0, stopLoss, takeProfit, comment);
      }
      else
      {
         ulong pend = trade.ResultOrder();
         if(pend > 0)
            AddOTESetup(usedEntry, usedSL, usedTP, direction, pend);
      }
   }
   else if(direction == "BUY")
      success = trade.Buy(lot, _Symbol, 0.0, stopLoss, takeProfit, comment);
   else
      success = trade.Sell(lot, _Symbol, 0.0, stopLoss, takeProfit, comment);
   
   if(success)
   {
      Print("â OTE FUTURE EXÃCUTÃ - ", direction, " sur ", _Symbol);
      Print("   ð Entry: ", DoubleToString(entryPrice, _Digits));
      Print("   ðĄïļ SL: ", DoubleToString(stopLoss, _Digits));
      Print("   ðŊ TP: ", DoubleToString(takeProfit, _Digits));
      Print("   ð° Lot: ", DoubleToString(lot, 2));
      Print("   ð EspÃĐrance: ", DoubleToString(expectancy, 3));
      Print("   ð Comment: ", comment);
      NotifyTradeEvent("â OTE EXÃCUTÃ - " + direction + " " + _Symbol, EntryTradeSoundFile);
   }
   else
   {
      Print("â OTE FUTURE ÃCHOUÃ - ", direction, " sur ", _Symbol);
      Print("   â Erreur: ", trade.ResultRetcode(), " - ", trade.ResultComment());
   }
}

// Obtenir la direction de la tendance actuelle
string GetCurrentTrendDirection()
{
   // Utiliser les EMA pour dÃĐterminer la tendance
   double emaFast = 0.0, emaSlow = 0.0;
   
   if(hEmaFast != INVALID_HANDLE && hEmaSlow != INVALID_HANDLE)
   {
      double a1[], a2[];
      ArraySetAsSeries(a1, true);
      ArraySetAsSeries(a2, true);
      if(CopyBuffer(hEmaFast, 0, 0, 1, a1) >= 1 && CopyBuffer(hEmaSlow, 0, 0, 1, a2) >= 1)
      {
         emaFast = a1[0];
         emaSlow = a2[0];
      }
   }
   
   double currentPrice = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   
   if(emaFast > emaSlow && currentPrice > emaFast)
      return "UPTREND";
   else if(emaFast < emaSlow && currentPrice < emaFast)
      return "DOWNTREND";
   else
      return "SIDEWAYS";
}

//+------------------------------------------------------------------+
//| FILTRE TENDANCE STRICTE - EMA + Order Block + OTE Fibonacci      |
//| Retourne true uniquement si les 3 filtres activÃĐs sont alignÃĐs   |
//+------------------------------------------------------------------+
bool IsTrendAlignedEntry(const string direction)
{
   if(!UseTrendAlignedEntryFilter) return true; // filtre dÃĐsactivÃĐ â toujours OK

   bool isBuy  = (direction == "BUY"  || direction == "buy");
   bool isSell = (direction == "SELL" || direction == "sell");
   if(!isBuy && !isSell) return false;

   // âââ 1. EMA STACK ALIGNMENT ââââââââââââââââââââââââââââââââââââ
   // Fast EMA doit ÃŠtre au-dessus de Slow EMA (BUY) ou en-dessous (SELL)
   // ET le prix doit ÃŠtre du bon cÃītÃĐ de la Fast EMA.
   double emaFastVal = 0.0, emaSlowVal = 0.0;
   if(hEmaFast != INVALID_HANDLE && hEmaSlow != INVALID_HANDLE)
   {
      double fa[], sl[];
      ArraySetAsSeries(fa, true);
      ArraySetAsSeries(sl, true);
      if(CopyBuffer(hEmaFast, 0, 0, 1, fa) >= 1 && CopyBuffer(hEmaSlow, 0, 0, 1, sl) >= 1)
      {
         emaFastVal = fa[0];
         emaSlowVal = sl[0];
      }
   }

   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   bool emaStackOk = false;
   if(emaFastVal > 0.0 && emaSlowVal > 0.0)
   {
      if(isBuy)  emaStackOk = (emaFastVal > emaSlowVal && bid > emaFastVal);
      if(isSell) emaStackOk = (emaFastVal < emaSlowVal && bid < emaFastVal);
   }
   else
   {
      // handles invalides â on passe le filtre EMA gracieusement
      emaStackOk = true;
   }

   if(!emaStackOk)
   {
      Print("ðŦ TREND FILTER - EMA stack non alignÃĐ pour ", direction, " sur ", _Symbol,
            " | FastEMA=", DoubleToString(emaFastVal, _Digits),
            " | SlowEMA=", DoubleToString(emaSlowVal, _Digits),
            " | Bid=", DoubleToString(bid, _Digits));
      return false;
   }

   // Boom/Crash: OB + OTE exigent souvent un prix encore "dans la structure" alors que le spike a dÃĐjÃ  cassÃĐ ces zones.
   // Si la pile EMA est bonne et que l'IA (ou le canal ML) confirme le sens naturel, on valide sans OB/OTE pour ne pas rater la descente/montÃĐe.
   if(BoomCrashRelaxTrendFilterForSpikes &&
      (SMC_GetSymbolCategory(_Symbol) == SYM_BOOM_CRASH || SMC_GetSymbolCategory(_Symbol) == SYM_WELTRADE_SYNTH))
   {
      bool naturalDir = (isBuy && IsBoomSymbol(_Symbol)) || (isSell && IsCrashSymbol(_Symbol)) ||
                        (isBuy && IsWeltradeGainSynthSymbol(_Symbol)) || (isSell && IsWeltradePainSynthSymbol(_Symbol));
      if(naturalDir)
      {
         string ia = g_lastAIAction;
         StringToUpper(ia);
         double confu = NormalizeAIConfidenceUnit();
         bool iaDirOk = (isBuy && ia == "BUY") || (isSell && ia == "SELL");
         bool strongTf = UseAggressiveScalpOnStrongM1M5 && IsStrongM1M5TrendByEMAs(direction);
         bool mlSpikeOk = UseMlChannelEarlySpikeEntry &&
                          g_lastAIConfidence * 100.0 >= MlChannelEarlyEntryMinConfidencePct &&
                          IsMlChannelTrendAlignedForBoomCrash(direction);
         bool iaSpikeOk = iaDirOk && confu >= 0.75 && (strongTf || confu >= 0.82);
         bool stairRelaxed = UseStairEntry &&
            g_lastAIConfidence * 100.0 >= StairEntryMinAIConfidencePercent &&
            (!StairEntryRequireStrongM1M5EMA || IsStrongM1M5TrendByEMAs(direction)) &&
            (!StairEntryUseM1StairDetector || IsSyntheticStairPatternM1(direction));
         if(iaSpikeOk || mlSpikeOk || stairRelaxed)
         {
            Print("â TREND FILTER OK (Boom/Crash spike) - ", direction, " sur ", _Symbol,
                  " | OB/OTE ignorÃĐs | IA=", g_lastAIAction, " ",
                  DoubleToString(confu * 100.0, 1), "%",
                  strongTf ? " | M1+M5 fort" : "",
                  mlSpikeOk ? " | Canal ML" : "",
                  stairRelaxed ? " | stairEntry" : "");
            return true;
         }
      }
   }

   // âââ 2. ORDER BLOCK CONFIRMÃ ââââââââââââââââââââââââââââââââââââ
   if(RequireOBForEntry)
   {
      OrderBlockData ob;
      bool hasOB = SMC_DetectOrderBlock(_Symbol, LTF, ob);
      if(hasOB)
      {
         bool obAligned = (isBuy  && ob.direction == 1)  ||
                          (isSell && ob.direction == -1);
         // Le prix doit ÃŠtre Ã  l'intÃĐrieur ou juste au-dessus/dessous de l'OB
         bool priceInOB = (bid >= ob.low && bid <= ob.high);

         if(!obAligned || !priceInOB)
         {
            Print("ðŦ TREND FILTER - OB non alignÃĐ ou prix hors OB pour ", direction, " sur ", _Symbol,
                  " | OB dir=", ob.direction, " | OB [", DoubleToString(ob.low, _Digits),
                  " - ", DoubleToString(ob.high, _Digits), "] | Bid=", DoubleToString(bid, _Digits));
            return false;
         }
      }
      else
      {
         Print("ðŦ TREND FILTER - Aucun Order Block trouvÃĐ pour ", direction, " sur ", _Symbol);
         return false;
      }
   }

   // âââ 3. OTE FIBONACCI ZONE (0.618 - 0.786) âââââââââââââââââââââ
   if(RequireOTEFiboZone)
   {
      double swingHigh = 0.0, swingLow = 0.0;
      datetime tSH = 0, tSL = 0;
      GetLatestConfirmedSwings(swingHigh, tSH, swingLow, tSL);

      bool inOTE = false;
      if(swingHigh > 0.0 && swingLow > 0.0 && swingHigh > swingLow)
      {
         double range   = swingHigh - swingLow;
         if(isBuy)
         {
            // Pullback haussier: retour entre 61.8% et 78.6% de la montÃĐ
            double ote62  = swingLow + range * 0.618;
            double ote786 = swingLow + range * 0.786;
            inOTE = (bid >= ote62 && bid <= ote786);
         }
         else // SELL
         {
            // Pullback baissier: retour entre 61.8% et 78.6% de la descente
            double ote62  = swingHigh - range * 0.618;
            double ote786 = swingHigh - range * 0.786;
            // ote786 <= ote62 pour SELL
            double lo = MathMin(ote62, ote786);
            double hi = MathMax(ote62, ote786);
            inOTE = (bid >= lo && bid <= hi);
         }
      }
      else
      {
         // Pas de swings trouvÃĐs â passe le filtre Fibo gracieusement
         inOTE = true;
      }

      if(!inOTE)
      {
         Print("ðŦ TREND FILTER - Prix hors zone OTE Fibo pour ", direction, " sur ", _Symbol,
               " | Bid=", DoubleToString(bid, _Digits),
               " | SH=", DoubleToString(swingHigh, _Digits),
               " | SL=", DoubleToString(swingLow, _Digits));
         return false;
      }
   }

   Print("â TREND FILTER OK - ", direction, " confirmÃĐ (EMA+OB+Fibo) sur ", _Symbol);
   NotifyRobotEventOncePerBar("TREND_OK_" + _Symbol + "_" + direction,
                              "â OB+Fibo vÃĐrifiÃĐ (" + direction + ") - " + _Symbol,
                              EntryTradeSoundFile,
                              PERIOD_M1);
   return true;
}

// Valider et ajuster les distances minimales pour SL/TP
void ValidateAndAdjustStopLossTakeProfit(string direction, double entryPrice, double &stopLoss, double &takeProfit)
{
   double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   if(point <= 0) point = 0.0001;
   double tickSize = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_SIZE);
   if(tickSize <= 0) tickSize = point;
   
   // IMPORTANT: stops/freeze level sont exprimÃĐs en "points", donc conversion via SYMBOL_POINT.
   double stopsLevel = (double)SymbolInfoInteger(_Symbol, SYMBOL_TRADE_STOPS_LEVEL) * point;
   double freezeLevel = (double)SymbolInfoInteger(_Symbol, SYMBOL_TRADE_FREEZE_LEVEL) * point;
   
   // Distance minimale adaptÃĐe selon le type de symbole
   double minDistance;
   if(StringFind(_Symbol, "XAG") >= 0 || StringFind(_Symbol, "XAU") >= 0)
   {
      // MÃĐtaux prÃĐcieux : distances plus grandes
      minDistance = MathMax(MathMax(stopsLevel, freezeLevel), 50 * tickSize); // Minimum 50 ticks pour les mÃĐtaux
   }
   else if(StringFind(_Symbol, "Boom") >= 0 || StringFind(_Symbol, "Crash") >= 0)
   {
      // Indices synthÃĐtiques : utiliser contrainte broker stricte + marge.
      minDistance = MathMax(MathMax(stopsLevel, freezeLevel), 80 * tickSize);
   }
   else if(IsWeltradeGainSynthSymbol(_Symbol) || IsWeltradePainSynthSymbol(_Symbol))
   {
      // Weltrade synth (GAINX/PAINX): ÃĐlargir le SL mini pour ÃĐviter des sorties trop serrÃĐes.
      minDistance = MathMax(MathMax(stopsLevel, freezeLevel), 120 * tickSize);
   }
   else
   {
      // Forex et autres : standard
      minDistance = MathMax(MathMax(stopsLevel, freezeLevel), 30 * tickSize); // Minimum 30 ticks pour Forex
   }
   minDistance = MathMax(minDistance, 2.0 * tickSize); // marge anti-arrondi

   // Prix de rÃĐfÃĐrence broker au moment de la validation.
   // Pour BUY, la fermeture se fait au Bid; pour SELL, au Ask.
   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   
   if(direction == "BUY")
   {
      // Orientation correcte avant ajustements de distance.
      if(stopLoss >= entryPrice) stopLoss = entryPrice - minDistance;
      if(takeProfit <= entryPrice) takeProfit = entryPrice + (2.0 * minDistance);

      // Ajuster SL si trop proche
      if(entryPrice - stopLoss < minDistance)
         stopLoss = entryPrice - minDistance;
      
      // Ajuster TP si trop proche
      if(takeProfit - entryPrice < minDistance * 2)
         takeProfit = entryPrice + minDistance * 2;

      // Contrainte stricte contre le prix de clÃīture (Bid) pour limiter Invalid stops.
      if(bid > 0.0)
      {
         if(bid - stopLoss < minDistance) stopLoss = bid - minDistance;
         if(takeProfit - bid < minDistance) takeProfit = bid + minDistance;
      }

      // Alignement au tick sans rÃĐduire la distance: SL vers le bas, TP vers le haut.
      stopLoss = MathFloor(stopLoss / tickSize) * tickSize;
      takeProfit = MathCeil(takeProfit / tickSize) * tickSize;
   }
   else // SELL
   {
      // Orientation correcte avant ajustements de distance.
      if(stopLoss <= entryPrice) stopLoss = entryPrice + minDistance;
      if(takeProfit >= entryPrice) takeProfit = entryPrice - (2.0 * minDistance);

      // Ajuster SL si trop proche
      if(stopLoss - entryPrice < minDistance)
         stopLoss = entryPrice + minDistance;
      
      // Ajuster TP si trop proche
      if(entryPrice - takeProfit < minDistance * 2)
         takeProfit = entryPrice - minDistance * 2;

      // Contrainte stricte contre le prix de clÃīture (Ask) pour limiter Invalid stops.
      if(ask > 0.0)
      {
         if(stopLoss - ask < minDistance) stopLoss = ask + minDistance;
         if(ask - takeProfit < minDistance) takeProfit = ask - minDistance;
      }

      // Alignement au tick sans rÃĐduire la distance: SL vers le haut, TP vers le bas.
      stopLoss = MathCeil(stopLoss / tickSize) * tickSize;
      takeProfit = MathFloor(takeProfit / tickSize) * tickSize;
   }

   stopLoss = NormalizeDouble(stopLoss, _Digits);
   takeProfit = NormalizeDouble(takeProfit, _Digits);
}

// Force un SL monÃĐtaire minimum sur Boom/Crash/Weltrade synth pour ÃĐviter des sorties SL trop petites
// (ex: -0.78$), afin de respecter la tolÃĐrance de perte paramÃĐtrÃĐe.
void EnforceMinBoomCrashStopLossDollarRisk(const string symbol, const string direction, const double entryPrice, const double volume, double &stopLoss)
{
   if(volume <= 0.0) return;
   bool isWeltradeSynth = IsWeltradeGainSynthSymbol(symbol) || IsWeltradePainSynthSymbol(symbol);
   if(StringFind(symbol, "Boom") < 0 && StringFind(symbol, "Crash") < 0 && !isWeltradeSynth) return;

   double targetLoss = MaxLossBoomCrashPerTradeUSD;
   if(targetLoss <= 0.0) return;

   double point = SymbolInfoDouble(symbol, SYMBOL_POINT);
   double tickSize = SymbolInfoDouble(symbol, SYMBOL_TRADE_TICK_SIZE);
   if(point <= 0.0) point = _Point;
   if(tickSize <= 0.0) tickSize = point;
   if(point <= 0.0 || tickSize <= 0.0) return;

   ENUM_ORDER_TYPE orderType = (direction == "BUY") ? ORDER_TYPE_BUY : ORDER_TYPE_SELL;
   double sl = stopLoss;

   // 3 essais suffisent pour ÃĐlargir progressivement le SL si la perte calculÃĐe est trop faible.
   for(int attempt = 0; attempt < 3; attempt++)
   {
      double pnlAtSL = 0.0;
      if(!OrderCalcProfit(orderType, symbol, volume, entryPrice, sl, pnlAtSL))
         break;

      double absLoss = MathAbs(MathMin(0.0, pnlAtSL));
      if(absLoss + 0.01 >= targetLoss)
         break;

      // Ãlargir la distance SL proportionnellement au manque de risque monÃĐtaire.
      double scale = targetLoss / MathMax(absLoss, 0.01);
      scale = MathMin(6.0, MathMax(1.2, scale));
      double dist = MathAbs(entryPrice - sl) * scale;
      dist = MathMax(dist, 80.0 * tickSize);

      if(direction == "BUY")
         sl = entryPrice - dist;
      else
         sl = entryPrice + dist;

      // Alignement tick orientÃĐ
      if(direction == "BUY")
         sl = MathFloor(sl / tickSize) * tickSize;
      else
         sl = MathCeil(sl / tickSize) * tickSize;

      sl = NormalizeDouble(sl, _Digits);
   }

   stopLoss = sl;
}

// Valider et ajuster le SL pour les modifications de position
bool ValidateStopLossForModification(string symbol, string direction, double currentPrice, double &newSL)
{
   double point = SymbolInfoDouble(symbol, SYMBOL_POINT);
   if(point <= 0) point = 0.0001;
   double tickSize = SymbolInfoDouble(symbol, SYMBOL_TRADE_TICK_SIZE);
   if(tickSize <= 0) tickSize = point;
   
   // Obtenir les distances minimales du courtier
   double stopsLevel = (double)SymbolInfoInteger(symbol, SYMBOL_TRADE_STOPS_LEVEL) * tickSize;
   
   // Distance minimale adaptÃĐe selon le type de symbole
   double minDistance;
   if(StringFind(symbol, "XAG") >= 0 || StringFind(symbol, "XAU") >= 0)
   {
      // MÃĐtaux prÃĐcieux : distances plus grandes
      minDistance = MathMax(stopsLevel, 50 * tickSize); // Minimum 50 ticks pour les mÃĐtaux
   }
   else if(IsBoomCrashOrWeltradeDirectionalSynth(symbol))
   {
      // Indices synthÃĐtiques : plancher alignÃĐ sur BoomCrashFixedSlPoints (points ~ ticks)
      minDistance = MathMax(stopsLevel, (double)MathMax(1, BoomCrashFixedSlPoints) * tickSize);
   }
   else
   {
      // Forex et autres : standard
      minDistance = MathMax(stopsLevel, 30 * tickSize); // Minimum 30 ticks pour Forex
   }
   
   // Valider et ajuster le SL selon la direction
   if(direction == "BUY")
   {
      // Pour BUY, SL doit ÃŠtre infÃĐrieur au prix actuel
      if(newSL >= currentPrice)
      {
         Print("â SL invalide pour BUY - SL (", DoubleToString(newSL, _Digits), ") >= prix (", DoubleToString(currentPrice, _Digits), ")");
         return false;
      }
      
      // VÃĐrifier la distance minimale
      if(currentPrice - newSL < minDistance)
      {
         double adjustedSL = currentPrice - minDistance;
         Print("ð§ SL ajustÃĐ pour BUY sur ", symbol, " | Original: ", DoubleToString(newSL, _Digits), " -> Adjusted: ", DoubleToString(adjustedSL, _Digits), " (distance min: ", DoubleToString(minDistance, _Digits), ")");
         newSL = adjustedSL;
      }
   }
   else // SELL
   {
      // Pour SELL, SL doit ÃŠtre supÃĐrieur au prix actuel
      if(newSL <= currentPrice)
      {
         Print("â SL invalide pour SELL - SL (", DoubleToString(newSL, _Digits), ") <= prix (", DoubleToString(currentPrice, _Digits), ")");
         return false;
      }
      
      // VÃĐrifier la distance minimale
      if(newSL - currentPrice < minDistance)
      {
         double adjustedSL = currentPrice + minDistance;
         Print("ð§ SL ajustÃĐ pour SELL sur ", symbol, " | Original: ", DoubleToString(newSL, _Digits), " -> Adjusted: ", DoubleToString(adjustedSL, _Digits), " (distance min: ", DoubleToString(minDistance, _Digits), ")");
         newSL = adjustedSL;
      }
   }
   
   return true;
}

// Duplicate function AnalyzeFutureOTEZones removed - implementation exists at line 101
// Duplicate function ShouldExecuteOTETrade removed - implementation exists at line 102
// Duplicate function ExecuteFutureOTETrade removed - implementation exists at line 103
// Duplicate function GetCurrentTrendDirection removed - implementation exists at line 104

void DrawEMACurveOnChart()
{
   // Trace les EMA 9/21/50/100/200 (LTF) et prolonge dans la zone future
   struct EmaCurveCfg { int handle; string prefix; color col; int width; };
   EmaCurveCfg cfgs[5];
   cfgs[0].handle = emaHandle;  cfgs[0].prefix = "SMC_EMA_CURVE_9_";   cfgs[0].col = clrLime;        cfgs[0].width = 2;
   cfgs[1].handle = ema21LTF;   cfgs[1].prefix = "SMC_EMA_CURVE_21_";  cfgs[1].col = clrAqua;        cfgs[1].width = 1;
   cfgs[2].handle = ema50LTF;   cfgs[2].prefix = "SMC_EMA_CURVE_50_";  cfgs[2].col = clrGold;        cfgs[2].width = 1;
   cfgs[3].handle = ema100LTF;  cfgs[3].prefix = "SMC_EMA_CURVE_100_"; cfgs[3].col = clrOrangeRed;   cfgs[3].width = 1;
   cfgs[4].handle = ema200LTF;  cfgs[4].prefix = "SMC_EMA_CURVE_200_"; cfgs[4].col = clrViolet;      cfgs[4].width = 1;

   int len = 60;
   datetime time[];
   ArraySetAsSeries(time, true);
   if(CopyTime(_Symbol, LTF, 0, len, time) < len) return;

   for(int c = 0; c < 5; c++)
   {
      if(cfgs[c].handle == INVALID_HANDLE) continue;

      double ema[];
      ArraySetAsSeries(ema, true);
      if(CopyBuffer(cfgs[c].handle, 0, 0, len, ema) < len) continue;

      // Nettoyer uniquement les objets de cette EMA
      ObjectsDeleteAll(0, cfgs[c].prefix);

      for(int i = 0; i < len - 1; i++)
      {
         string name = cfgs[c].prefix + IntegerToString(i);
         if(ObjectCreate(0, name, OBJ_TREND, 0, time[i], ema[i], time[i+1], ema[i+1]))
         {
            ObjectSetInteger(0, name, OBJPROP_COLOR, cfgs[c].col);
            ObjectSetInteger(0, name, OBJPROP_WIDTH, cfgs[c].width);
            // Prolonger le dernier segment vers la droite pour l'afficher dans la zone future
            ObjectSetInteger(0, name, OBJPROP_RAY_RIGHT, (i == (len - 2)));
            ObjectSetInteger(0, name, OBJPROP_BACK, true);
         }
      }
   }
}

void DrawLiquidityZonesOnChart()
{
   MqlRates rates[];
   ArraySetAsSeries(rates, true);
   int bars = 30;
   if(CopyRates(_Symbol, LTF, 0, bars, rates) < bars) return;
   double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   ObjectsDeleteAll(0, "SMC_Liq_");
   int cnt = 0;
   for(int i = 5; i < bars - 5 && cnt < 8; i++)
   {
      double zHigh = rates[i].high, zLow = rates[i].low;
      for(int j = i; j < i + 10 && j < bars; j++)
      {
         if(rates[j].high > zHigh) zHigh = rates[j].high;
         if(rates[j].low < zLow) zLow = rates[j].low;
      }
      if(zHigh - zLow > point * 5)
      {
         string name = "SMC_Liq_" + IntegerToString(i);
         if(ObjectCreate(0, name, OBJ_RECTANGLE, 0, rates[i+5].time, zLow, rates[i].time, zHigh))
         {
            ObjectSetInteger(0, name, OBJPROP_COLOR, clrPurple);
            ObjectSetInteger(0, name, OBJPROP_STYLE, STYLE_DOT);
            ObjectSetInteger(0, name, OBJPROP_WIDTH, 1);
            ObjectSetInteger(0, name, OBJPROP_BACK, true);
            ObjectSetInteger(0, name, OBJPROP_FILL, false);
            cnt++;
         }
      }
   }
}

void DrawPremiumDiscountZones()
{
   double high[], low[], close[];
   ArraySetAsSeries(high, true); ArraySetAsSeries(low, true); ArraySetAsSeries(close, true);
   ENUM_TIMEFRAMES tf = PERIOD_H1;
   if(CopyHigh(_Symbol, PERIOD_H1, 0, 100, high) < 100 || CopyLow(_Symbol, PERIOD_H1, 0, 100, low) < 100 || CopyClose(_Symbol, PERIOD_H1, 0, 100, close) < 100)
   {
      tf = LTF;
      int n = MathMin(100, Bars(_Symbol, tf));
      if(n < 30 || CopyHigh(_Symbol, tf, 0, n, high) < n || CopyLow(_Symbol, tf, 0, n, low) < n || CopyClose(_Symbol, tf, 0, n, close) < n) return;
   }
   int n = ArraySize(close);
   if(n < 25) return;
   double sma20[];
   ArrayResize(sma20, n);
   ArraySetAsSeries(sma20, true);
   for(int i = 0; i < n - 20; i++)
   {
      double sum = 0;
      for(int j = 0; j < 20; j++) sum += close[i + j];
      sma20[i] = sum / 20;
   }
   for(int i = n - 20; i < n; i++) sma20[i] = sma20[MathMax(0, n - 21)];
   double eq = sma20[0];
   datetime t0 = TimeCurrent() - 7200;
   datetime t1 = TimeCurrent();
   ObjectDelete(0, "SMC_ICT_PREMIUM_ZONE");
   ObjectDelete(0, "SMC_ICT_DISCOUNT_ZONE");
   ObjectDelete(0, "SMC_ICT_PREMIUM_LABEL");
   ObjectDelete(0, "SMC_ICT_DISCOUNT_LABEL");
   ObjectDelete(0, "SMC_ICT_EQUILIBRE");
   ObjectDelete(0, "SMC_ICT_EQUILIBRE_LABEL");
   ObjectDelete(0, "SMC_ICT_CORRECTION_ZONE");
   ObjectDelete(0, "SMC_ICT_CORRECTION_LABEL");
   double premHigh = high[ArrayMaximum(high, 0, 20)];
   double discLow = low[ArrayMinimum(low, 0, 20)];
   if(premHigh <= eq || discLow >= eq) return;
   ObjectCreate(0, "SMC_ICT_PREMIUM_ZONE", OBJ_RECTANGLE, 0, t0, eq, t1, premHigh);
   ObjectSetInteger(0, "SMC_ICT_PREMIUM_ZONE", OBJPROP_COLOR, clrOrange);
   ObjectSetInteger(0, "SMC_ICT_PREMIUM_ZONE", OBJPROP_BACK, true);
   ObjectSetInteger(0, "SMC_ICT_PREMIUM_ZONE", OBJPROP_FILL, true);
   ObjectCreate(0, "SMC_ICT_PREMIUM_LABEL", OBJ_TEXT, 0, t0 + 600, (eq + premHigh) / 2);
   ObjectSetString(0, "SMC_ICT_PREMIUM_LABEL", OBJPROP_TEXT, "Premium (vente)");
   ObjectSetInteger(0, "SMC_ICT_PREMIUM_LABEL", OBJPROP_COLOR, clrWhite);
   ObjectSetInteger(0, "SMC_ICT_PREMIUM_LABEL", OBJPROP_FONTSIZE, 9);
   ObjectSetInteger(0, "SMC_ICT_PREMIUM_LABEL", OBJPROP_ANCHOR, ANCHOR_LEFT);
   ObjectCreate(0, "SMC_ICT_DISCOUNT_ZONE", OBJ_RECTANGLE, 0, t0, discLow, t1, eq);
   ObjectSetInteger(0, "SMC_ICT_DISCOUNT_ZONE", OBJPROP_COLOR, clrDodgerBlue);
   ObjectSetInteger(0, "SMC_ICT_DISCOUNT_ZONE", OBJPROP_BACK, true);
   ObjectSetInteger(0, "SMC_ICT_DISCOUNT_ZONE", OBJPROP_FILL, true);
   ObjectCreate(0, "SMC_ICT_DISCOUNT_LABEL", OBJ_TEXT, 0, t0 + 1800, (discLow + eq) / 2);
   ObjectSetString(0, "SMC_ICT_DISCOUNT_LABEL", OBJPROP_TEXT, "Discount (achat)");
   ObjectSetInteger(0, "SMC_ICT_DISCOUNT_LABEL", OBJPROP_COLOR, clrWhite);
   ObjectSetInteger(0, "SMC_ICT_DISCOUNT_LABEL", OBJPROP_FONTSIZE, 9);
   ObjectSetInteger(0, "SMC_ICT_DISCOUNT_LABEL", OBJPROP_ANCHOR, ANCHOR_LEFT);
   ObjectCreate(0, "SMC_ICT_EQUILIBRE", OBJ_HLINE, 0, 0, eq);
   ObjectSetInteger(0, "SMC_ICT_EQUILIBRE", OBJPROP_COLOR, clrYellow);
   ObjectSetInteger(0, "SMC_ICT_EQUILIBRE", OBJPROP_STYLE, STYLE_DASH);
   ObjectSetInteger(0, "SMC_ICT_EQUILIBRE", OBJPROP_WIDTH, 2);
   ObjectCreate(0, "SMC_ICT_EQUILIBRE_LABEL", OBJ_TEXT, 0, t0 + 3600, eq);
   ObjectSetString(0, "SMC_ICT_EQUILIBRE_LABEL", OBJPROP_TEXT, "ZONE D'ÃQUILIBRE");
   ObjectSetInteger(0, "SMC_ICT_EQUILIBRE_LABEL", OBJPROP_COLOR, clrYellow);
   ObjectSetInteger(0, "SMC_ICT_EQUILIBRE_LABEL", OBJPROP_FONTSIZE, 8);
   ObjectSetInteger(0, "SMC_ICT_EQUILIBRE_LABEL", OBJPROP_ANCHOR, ANCHOR_LEFT);

   if(AlwaysShowCorrectionZone && EquilibriumCorrectionBandPercent > 0.0)
   {
      double range = premHigh - discLow;
      if(range > 0.0)
      {
         double band = range * (EquilibriumCorrectionBandPercent / 100.0);
         double half = band * 0.5;
         double corrTop = eq + half;
         double corrBot = eq - half;
         datetime corrT2 = TimeCurrent() + PeriodSeconds(PERIOD_M1) * MathMax(20, CorrectionZoneVisualForwardBarsM1);

         ObjectCreate(0, "SMC_ICT_CORRECTION_ZONE", OBJ_RECTANGLE, 0, t0, corrBot, corrT2, corrTop);
         ObjectSetInteger(0, "SMC_ICT_CORRECTION_ZONE", OBJPROP_COLOR, clrTomato);
         ObjectSetInteger(0, "SMC_ICT_CORRECTION_ZONE", OBJPROP_BACK, true);
         ObjectSetInteger(0, "SMC_ICT_CORRECTION_ZONE", OBJPROP_FILL, true);
         ObjectSetInteger(0, "SMC_ICT_CORRECTION_ZONE", OBJPROP_STYLE, STYLE_SOLID);
         ObjectSetInteger(0, "SMC_ICT_CORRECTION_ZONE", OBJPROP_WIDTH, 1);

         ObjectCreate(0, "SMC_ICT_CORRECTION_LABEL", OBJ_TEXT, 0, t0 + 1200, eq);
         ObjectSetString(0, "SMC_ICT_CORRECTION_LABEL", OBJPROP_TEXT, "ZONE CORRECTION - NO TRADE");
         ObjectSetInteger(0, "SMC_ICT_CORRECTION_LABEL", OBJPROP_COLOR, clrTomato);
         ObjectSetInteger(0, "SMC_ICT_CORRECTION_LABEL", OBJPROP_FONTSIZE, 9);
         ObjectSetInteger(0, "SMC_ICT_CORRECTION_LABEL", OBJPROP_ANCHOR, ANCHOR_LEFT);
      }
   }
   
   // Ligne verticale pour sÃĐparer clairement la zone passÃĐe de la zone prÃĐdite
   ObjectDelete(0, "SMC_PAST_FUTURE_DIVIDER");
   if(ObjectCreate(0, "SMC_PAST_FUTURE_DIVIDER", OBJ_VLINE, 0, t1, 0))
   {
      ObjectSetInteger(0, "SMC_PAST_FUTURE_DIVIDER", OBJPROP_COLOR, clrWhite);
      ObjectSetInteger(0, "SMC_PAST_FUTURE_DIVIDER", OBJPROP_WIDTH, 2);
      ObjectSetInteger(0, "SMC_PAST_FUTURE_DIVIDER", OBJPROP_STYLE, STYLE_SOLID);
   }
}

//+------------------------------------------------------------------+
//| Helpers graphiques HMS (MQL5: pas de lambdas)                      |
