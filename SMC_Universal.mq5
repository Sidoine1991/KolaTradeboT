int GetTradingZoneIndexUTC(datetime t)
{
   MqlDateTime dt;
   TimeToStruct(t, dt);
   int h = dt.hour;

   if(h >= Zone1StartHourUTC && h < Zone1EndHourUTC) return 1;
   if(h >= Zone2StartHourUTC && h < Zone2EndHourUTC) return 2;
   if(h >= Zone3StartHourUTC && h < Zone3EndHourUTC) return 3;
   if(h >= Zone4StartHourUTC && h < Zone4EndHourUTC) return 4;
   return 0;
}

int CountTodayOpenedTradesEA(datetime dayStart, datetime nowTime)
{
   int count = 0;
   if(!HistorySelect(dayStart, nowTime)) return 0;

   int total = HistoryDealsTotal();
   for(int i = total - 1; i >= 0; i--)
   {
      ulong dealTicket = HistoryDealGetTicket(i);
      if(dealTicket == 0) continue;
      if((long)HistoryDealGetInteger(dealTicket, DEAL_MAGIC) != InpMagicNumber) continue;
      if((ENUM_DEAL_ENTRY)HistoryDealGetInteger(dealTicket, DEAL_ENTRY) != DEAL_ENTRY_IN) continue;
      ENUM_DEAL_TYPE dt = (ENUM_DEAL_TYPE)HistoryDealGetInteger(dealTicket, DEAL_TYPE);
      if(dt != DEAL_TYPE_BUY && dt != DEAL_TYPE_SELL) continue;
      count++;
   }
   return count;
}

int CountTodayOpenedTradesEASymbol(datetime dayStart, datetime nowTime, const string symbol)
{
   int count = 0;
   if(!HistorySelect(dayStart, nowTime)) return 0;

   int total = HistoryDealsTotal();
   for(int i = total - 1; i >= 0; i--)
   {
      ulong dealTicket = HistoryDealGetTicket(i);
      if(dealTicket == 0) continue;
      if((long)HistoryDealGetInteger(dealTicket, DEAL_MAGIC) != InpMagicNumber) continue;
      if((ENUM_DEAL_ENTRY)HistoryDealGetInteger(dealTicket, DEAL_ENTRY) != DEAL_ENTRY_IN) continue;
      ENUM_DEAL_TYPE dt = (ENUM_DEAL_TYPE)HistoryDealGetInteger(dealTicket, DEAL_TYPE);
      if(dt != DEAL_TYPE_BUY && dt != DEAL_TYPE_SELL) continue;
      if(HistoryDealGetString(dealTicket, DEAL_SYMBOL) != symbol) continue;
      count++;
   }
   return count;
}

int CountTodayOpenedTradesEAInZone(datetime dayStart, datetime nowTime, int zoneIndex)
{
   if(zoneIndex < 1 || zoneIndex > 4) return 0;
   int count = 0;
   if(!HistorySelect(dayStart, nowTime)) return 0;

   int total = HistoryDealsTotal();
   for(int i = total - 1; i >= 0; i--)
   {
      ulong dealTicket = HistoryDealGetTicket(i);
      if(dealTicket == 0) continue;
      if((long)HistoryDealGetInteger(dealTicket, DEAL_MAGIC) != InpMagicNumber) continue;
      if((ENUM_DEAL_ENTRY)HistoryDealGetInteger(dealTicket, DEAL_ENTRY) != DEAL_ENTRY_IN) continue;
      ENUM_DEAL_TYPE dt = (ENUM_DEAL_TYPE)HistoryDealGetInteger(dealTicket, DEAL_TYPE);
      if(dt != DEAL_TYPE_BUY && dt != DEAL_TYPE_SELL) continue;

      datetime dealTime = (datetime)HistoryDealGetInteger(dealTicket, DEAL_TIME);
      if(GetTradingZoneIndexUTC(dealTime) == zoneIndex)
         count++;
   }
   return count;
}

int CountTodayOpenedTradesEAInZoneSymbol(datetime dayStart, datetime nowTime, int zoneIndex, const string symbol)
{
   if(zoneIndex < 1 || zoneIndex > 4) return 0;
   int count = 0;
   if(!HistorySelect(dayStart, nowTime)) return 0;

   int total = HistoryDealsTotal();
   for(int i = total - 1; i >= 0; i--)
   {
      ulong dealTicket = HistoryDealGetTicket(i);
      if(dealTicket == 0) continue;
      if((long)HistoryDealGetInteger(dealTicket, DEAL_MAGIC) != InpMagicNumber) continue;
      if((ENUM_DEAL_ENTRY)HistoryDealGetInteger(dealTicket, DEAL_ENTRY) != DEAL_ENTRY_IN) continue;
      ENUM_DEAL_TYPE dt = (ENUM_DEAL_TYPE)HistoryDealGetInteger(dealTicket, DEAL_TYPE);
      if(dt != DEAL_TYPE_BUY && dt != DEAL_TYPE_SELL) continue;
      if(HistoryDealGetString(dealTicket, DEAL_SYMBOL) != symbol) continue;

      datetime dealTime = (datetime)HistoryDealGetInteger(dealTicket, DEAL_TIME);
      if(GetTradingZoneIndexUTC(dealTime) == zoneIndex)
         count++;
   }
   return count;
}

string NormalizeSymbolToken(string v)
{
   string t = v;
   StringToUpper(t);
   StringReplace(t, " ", "");
   StringReplace(t, ".", "");
   StringReplace(t, "_", "");
   StringReplace(t, "-", "");
   return t;
}

bool IsHighVolatilityRestrictedSymbol(const string symbol)
{
   string s = NormalizeSymbolToken(symbol);
   string csv = HighVolatilityBlockedSymbolsCsv;
   string parts[];
   int n = StringSplit(csv, ',', parts);
   if(n <= 0) return false;
   for(int i = 0; i < n; i++)
   {
      string k = NormalizeSymbolToken(parts[i]);
      if(k == "") continue;
      if(StringFind(s, k) >= 0)
         return true;
   }
   return false;
}

bool IsHighVolatilityCapitalGatePassed(const string symbol, const string context = "")
{
   if(!EnableHighVolatilityCapitalGate)
      return true;
   if(!IsHighVolatilityRestrictedSymbol(symbol))
      return true;

   double minCap = MinCapitalForHighVolatilitySymbols;
   if(minCap <= 0.0)
      return true;

   double eq = AccountInfoDouble(ACCOUNT_EQUITY);
   double bal = AccountInfoDouble(ACCOUNT_BALANCE);
   if(eq >= minCap || bal >= minCap)
      return true;

   string ctx = context;
   if(ctx == "") ctx = "ENTRY";
   Print("ðŦ ", ctx, " BLOQUÃ - Symbole volatil restreint: ", symbol,
         " | Equity=", DoubleToString(eq, 2),
         " | Balance=", DoubleToString(bal, 2),
         " | Seuil min=", DoubleToString(minCap, 2));
   return false;
}

bool IsAllowedByTradingTimeAndQuota(const string symbol, const string action)
{
   if(!IsHighVolatilityCapitalGatePassed(symbol, "CAPITAL FILTER"))
      return false;

   datetime nowT = TimeCurrent();
   MqlDateTime md;
   TimeToStruct(nowT, md);
   md.hour = 0; md.min = 0; md.sec = 0;
   datetime dayStart = StructToTime(md);

   int totalToday = CountTodayOpenedTradesEASymbol(dayStart, nowT, symbol);
   if(totalToday >= MaxDailyTrades)
   {
      Print("âļ ROBOT EN PAUSE - Limite journaliÃĻre atteinte pour ", symbol, ": ", totalToday, "/", MaxDailyTrades,
            " | Symbole=", symbol, " | Action=", action);
      return false;
   }

   // Sessions LO/NYO + zones UTC + quota par zone: actifs seulement aprÃĻs perte journaliÃĻre >= MaxDailyLossDollars ($)
   // (ÃĐquitÃĐ vs dÃĐbut de journÃĐe, voir IsDailyLossPauseActive). Sinon le robot trade sans ces contraintes horaires.
   bool enforceSessionAndUtcTime = IsDailyLossPauseActive();

   // Exception opportunitÃĐs Boom/Crash:
   // si canal ML alignÃĐ + confiance suffisante, on autorise hors sessions/zones horaires.
   string actionUpper = action;
   StringToUpper(actionUpper);
   bool allowBoomCrashMlBypass = false;
   if((SMC_GetSymbolCategory(symbol) == SYM_BOOM_CRASH || SMC_GetSymbolCategory(symbol) == SYM_WELTRADE_SYNTH) &&
      symbol == _Symbol)
   {
      double confPct = g_lastAIConfidence * 100.0;
      double mlMin = MlChannelEarlyMinConfPctForSymbol(symbol);
      double stairMin = StairEntryEffectiveMinAiPctForSymbol(symbol);
      if(UseMlChannelEarlySpikeEntry &&
         confPct >= mlMin &&
         DirectionMatchesBoomCrashOrWeltradeSynth(symbol, actionUpper) &&
         IsMlChannelTrendAlignedForBoomCrash(actionUpper))
      {
         allowBoomCrashMlBypass = true;
      }
      if(!allowBoomCrashMlBypass && UseStairEntry &&
         confPct >= stairMin &&
         DirectionMatchesBoomCrashOrWeltradeSynth(symbol, actionUpper) &&
         IsStrongM1M5TrendByEMAs(actionUpper) &&
         IsSyntheticStairPatternM1(actionUpper))
      {
         allowBoomCrashMlBypass = true;
      }
   }

   if(enforceSessionAndUtcTime)
   {
      // FenÃŠtres classiques LO/NYO (si activÃĐes) avant mÃŠme les 4 zones personnalisÃĐes.
      if(UseSessions && !SMC_IsKillZone(LondonStart, LondonEnd, NYOStart, NYOEnd))
      {
         if(allowBoomCrashMlBypass)
         {
            static datetime lastSessionBypassLog = 0;
            if(TimeCurrent() - lastSessionBypassLog >= 30)
            {
               Print("âĄ TIME FILTER BYPASS - OpportunitÃĐ Boom/Crash validÃĐe par canal ML (hors session LO/NYO autorisÃĐ) | Symbole=",
                     symbol, " | Action=", actionUpper);
               lastSessionBypassLog = TimeCurrent();
            }
         }
         else
         {
            Print("TRADE BLOQUE - Hors session LO/NYO | Symbole=", symbol, " | Action=", action);
            return false;
         }
      }

      if(!EnforceTradingTimeZones) return true;

      int zone = GetTradingZoneIndexUTC(nowT);
      if(zone == 0)
      {
         if(allowBoomCrashMlBypass)
         {
            static datetime lastZoneBypassLog = 0;
            if(TimeCurrent() - lastZoneBypassLog >= 30)
            {
               Print("âĄ TIME FILTER BYPASS - OpportunitÃĐ Boom/Crash validÃĐe par canal ML (hors zones UTC autorisÃĐ) | Symbole=",
                     symbol, " | Action=", actionUpper);
               lastZoneBypassLog = TimeCurrent();
            }
         }
         else
         {
            Print("âļ ROBOT EN PAUSE - Hors des 4 zones horaires UTC (3h) | Symbole=", symbol, " | Action=", action);
            return false;
         }
      }

      int zoneCount = CountTodayOpenedTradesEAInZoneSymbol(dayStart, nowT, zone, symbol);
      if(zoneCount >= MaxTradesPerZonePerDay)
      {
         Print("âļ ROBOT EN PAUSE - Quota zone ", zone, " atteint pour ", symbol, ": ", zoneCount, "/", MaxTradesPerZonePerDay,
               " | Symbole=", symbol, " | Action=", action);
         return false;
      }
   }

   return true;
}

double GetCategoryMinAIConfidencePercent(const string symbol)
{
   if(!UseCategorySpecificThresholds)
      return MinAIConfidencePercent;

   ENUM_SYMBOL_CATEGORY cat = SMC_GetSymbolCategory(symbol);
   if(cat == SYM_BOOM_CRASH)
      return MinAIConfidenceBoomCrashPercent;

   return MinAIConfidenceOtherPercent;
}

double GetCategoryMinSetupScore(const string symbol)
{
   if(!UseCategorySpecificThresholds)
      return MinSetupScoreEntry;

   ENUM_SYMBOL_CATEGORY cat = SMC_GetSymbolCategory(symbol);
   if(cat == SYM_BOOM_CRASH)
      return MinSetupScoreBoomCrash;

   return MinSetupScoreOther;
}

// Structure pour suivre les setups OTE actifs
struct OTESetupTracker
{
   datetime   setupTime;
   double     entryPrice;
   double     stopLoss;
   double     takeProfit;
   string     direction;
   bool       isValid;
   ulong      orderId;     // Ordre pending associÃĐ
   int        setupId;     // ID unique du setup
   double     snapshotAIConfUnit; // Confiance IA (0..1) au moment de la pose du limite
   string     snapshotAIAction;   // Action IA au moment de la pose
   bool       limitPreTouchPassed; // RevÃĐrification prÃĐ-touch OK (ne plus annuler pour ce rapprochement)
   datetime   lastPreTouchCheckUtc;
   datetime   preTouchZoneEnterUtc; // PremiÃĻre fois que le cours entre dans la zone prÃĐ-touch
};
OTESetupTracker g_activeOTESetups[10]; // Maximum 10 setups actifs
int g_nextOTESetupId = 1;

// NOUVEAU: ParamÃĻtre pour contrÃīler la stratÃĐgie SMC_OTE complÃĻte
input bool   UseSMC_OTEStrategy    = true;  // Activer la stratÃĐgie SMC_OTE complÃĻte (3 ÃĐtapes)

input group "=== SMC_OTE â MARCHÃS AUTORISÃS ==="
input bool   SMC_OTE_AllowForex         = true;
input bool   SMC_OTE_AllowMetals        = true;
input bool   SMC_OTE_AllowCommodities   = true;
input bool   SMC_OTE_AllowBoomCrash     = true;
input bool   SMC_OTE_AllowWeltradeSynth = true;  // PAINX / GAINX
input bool   SMC_OTE_AllowVolatility    = false; // Volatility indices: dÃĐsactivÃĐ par dÃĐfaut (peut ÃŠtre bruyant)

input group "=== TIMEFRAMES ==="
input ENUM_TIMEFRAMES HTF      = PERIOD_H4;  // Structure (HTF)
input ENUM_TIMEFRAMES LTF      = PERIOD_M15; // EntrÃĐe (LTF)
input bool   UsePriceActionM15Strategy = true; // 3e strategie: Price Action pure sur M15
input int    PriceActionM15LookbackBars = 40;  // Fenetre structurelle M15 (barres)
input double PriceActionM15BufferATRMult = 0.15; // Buffer breakout/retest (x ATR M15)
input double PriceActionM15RiskReward = 2.2;   // Ratio R:R pour TP
input bool   ShowPriceActionM15Visuals = true; // Afficher fleche + Entry/SL/TP Price Action M15
input bool   ShowPriceActionScenarioProjection = true; // Zone setup prix actuel + projection M15 (structure reelle)
input int    PriceActionScenarioProjectionBars = 32;   // Horizon projection (bougies M15)
input int    PriceActionScenarioStructureBars = 22;  // Fenetre analyse structure / momentum (M15)
input double PriceActionScenarioRangeATRMult = 0.95;   // Si range < ATR*ce facteur => scenario RANGE
input double PriceActionScenarioBiasATRMult = 0.28;  // Seuil delta close vs N barres (x ATR) pour BULL/BEAR
input double PriceActionScenarioMaxMoveATRMult = 3.2; // Plafond |projection - prix| (x ATR M15)
input int    PriceActionScenarioFutureZoneBars = 10; // Largeur (bougies M15) du rectangle setup en zone FUTUR
input bool   UseFutureDirectionConfidenceGate = true; // Exiger une confluence forte dans la zone de projection future avant entree
input double FutureDirectionMinScore = 80.0; // Score mini (0-100) de certitude direction future
input int    FutureDirectionMinConfirmations = 3; // Nombre mini de confirmations structure/momentum/IA
input bool   FutureDirectionRequireSweepReclaim = true; // Exiger sweep + reclaim de liquidite pour valider l'entree
input int    FutureDirectionLookbackBars = 36; // Fenetre de sweep/reclaim et stats de bougies
input int    PriceActionScenarioDisplayMaxBars = 18; // Horizon dessine depuis maintenant (M15) â reste dans la marge vide a droite
input int    HistoricalPatternLookbackBars = 1000; // Profondeur historique pour analyser les patterns passes
input int    PatternSimilarityContextBars = 24; // Taille du pattern courant compare a l'historique
input int    PatternPredictionHorizonBars = 12; // Horizon futur (M15) estime a partir des patterns similaires
input bool   EnableChartPatternDetection = true; // DÃĐtecter figures chartistes + chandeliers sur M15
input bool   ChartPatternAffectTradeDecision = true; // Utiliser les figures dÃĐtectÃĐes dans le score final de setup
input bool   ChartPatternDrawProjection = true; // Dessiner des segments obliques de projection directionnelle future
input bool   ChartPatternNotifyInSignals = true; // Inclure la figure dÃĐtectÃĐe dans les notifications signal
input double ChartPatternDirectionalWeight = 12.0; // Bonus/malus max appliquÃĐ au score setup selon direction figure
input bool   OnlyDrawConfirmedOBWithFibConfluence = true; // Filtrer les OB: uniquement confirmÃĐs + confluence Fibonacci OTE
input int    MaxConfirmedOBToDraw = 3; // Limiter le nombre d'OB validÃĐs affichÃĐs (anti-encombrement)
input bool   OTECurrentZoneUseTrendFallback = true; // Si IA non FOR, autoriser entrÃĐe OTE_CURR selon tendance alignÃĐe
input bool   M5EntryLimitRequirePatternValidation = true; // LIMIT M5_ENTRY/M5_TREND_ENTRY uniquement si pattern validÃĐ
input bool   KeepScenarioObjectsPersistent = true; // Ne pas faire disparaitre les objets: mise a jour en place
input bool   KeepSMCOTEObjectsPersistent = true; // Garder OTE/FVG/5star visibles (mise a jour au lieu d'effacer)
input int    SMCOTE_LookbackBarsLTF = 1000; // Profondeur bougies LTF pour swings/OTE/FVG (M15 par defaut)
input int    SMCOTE_LookbackBarsHTF = 240;  // Profondeur bougies HTF pour trend/structure (H4 par defaut)

input group "=== FVG_Kill PRO (Smart Money) ==="
