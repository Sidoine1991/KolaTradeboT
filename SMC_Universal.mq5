input bool   EnableTrading      = true;   // Activer/Désactiver le trading
input int    MaxPositionsTerminal = 2;   // Nombre max de positions (tout le terminal MT5) - LIMITÉ À 2 pour protéger le capital
input bool   OnePositionPerSymbol = true; // Une seule position par symbole - MAINTENU pour éviter duplication
input int    InpMagicNumber       = 202502; // Magic Number
input double MaxTotalLossDollars = 10.0;   // Perte maximale totale en dollars avant de couper toutes les positions
input double HoldAutoCloseLossDefaultDollars = 2.0; // Seuil perte ($) pour auto-fermeture quand IA passe en HOLD
input double HoldAutoCloseLossFxVol40Dollars = 3.5; // Exception FX VOL 40: seuil perte HOLD plus large
input bool   EnableHoldAutoScalping = true;  // Activer scalping automatique quand IA est HOLD
input double HoldScalpingEntryTolerancePct = 0.05; // Tolérance de touche point d'entrée (5%)
input double HoldScalpingSLPct = 0.15; // Stop Loss scalping HOLD (15%)
input double HoldScalpingTPPct = 0.30; // Take Profit scalping HOLD (30%)
input int    HoldScalpingMinTrendStrength = 60; // Force de tendance minimale M5 (0-100) pour scalping HOLD
input bool   HoldScalpingRequireClearTrend = true; // Exiger tendance claire (pas de consolidation) pour scalping HOLD
input double HoldScalpingConsolidationThreshold = 0.003; // Seuil de consolidation (0.3% de variation)
input bool   HoldScalpingUseEMA = true; // Utiliser EMA au lieu de SuperTrend pour entrées plus rapides
input double HoldScalpingStrongTrendAdvancePct = 0.002; // Avancer ordres en tendance forte (0.2% avant niveau)
input int    HoldScalpingStrongTrendThreshold = 80; // Seuil tendance forte pour avancer ordres (0-100)
input double DailyProfitTarget = 20.0;     // Objectif de profit journalier en dollars
input int    PauseAfterProfitHours = 4;    // Durée de la pause en heures après avoir atteint l'objectif de profit la plus perdante
input double MaxLossPerSpikeTradeDollars = 3.0;  // Perte max par trade Spike Boom/Crash ($) - lot réduit si dépassement
input double MaxLossPerSymbolDollars = 4.0;   // Perte maximale par symbole avant blocage complet de ce symbole
input double MaxRiskPerTradePercent   = 1.5;  // Risque normal par trade (% de l'équité)
input double MaxDailyDrawdownPercent  = 10.0; // Drawdown max journalier (%) avant blocage des nouvelles entrées
input double DailyProfitTargetDollars = 20.0; // Gain journalier max ($) - stop trading jusqu'à fin de journée
input double MaxDailyLossDollars      = 10.0; // Perte journalière max ($) - pause 2h
input double CumulativeLossPauseThresholdDollars = 5.0; // Pertes consécutives cumulées ($) avant pause

input group "=== TRADING ALGO GUI (Interface Manuel Charles) ==="
input bool   UseTradingAlgoGUI = false;  // Activer l'interface graphique manuelle (Charles Robot)
input int    GUI_PanelX = 20;             // Position X du panneau GUI
input int    GUI_PanelY = 20;             // Position Y du panneau GUI
input int    GUI_PanelWidth = 280;        // Largeur du panneau GUI
input color  GUI_PanelBgColor = clrNavy;   // Couleur fond panneau GUI
input color  GUI_PanelTextColor = clrWhite; // Couleur texte GUI
input int    GUI_UpdateIntervalSec = 2;    // Intervalle minimum entre les mises à jour GUI (évite détachement)
input color  GUI_BuyColor = clrLime;        // Couleur BUY GUI
input color  GUI_SellColor = clrRed;        // Couleur SELL GUI
input int    GUI_FontSize = 9;             // Taille police GUI
input string GUI_FontName = "Arial";       // Police GUI
input double GUI_DefaultRiskPercent = 0.5; // Risque % par défaut GUI
input double GUI_DefaultTP1 = 50.0;       // TP1 points par défaut GUI
input double GUI_DefaultTP2 = 100.0;      // TP2 points par défaut GUI
input double GUI_DefaultTP3 = 150.0;      // TP3 points par défaut GUI
input double GUI_DefaultTP4 = 200.0;      // TP4 points par défaut GUI
input double GUI_DefaultSL = 30.0;        // SL points par défaut GUI
input bool   GUI_UseAIServer = true;      // GUI: Utiliser le serveur IA pour l'analyse
input string GUI_AI_ServerURL = "https://kolatradebot.onrender.com";  // GUI: URL primaire (Render)
input int    GUI_AI_Timeout_ms = 5000;    // GUI: Timeout WebRequest (ms)
input double GUI_InpRSI = 50.0;           // GUI: RSI (0 = auto-calculé)
input double GUI_InpEMA_Fast_H1 = 0;      // GUI: EMA Fast H1 (0 = auto)
input double GUI_InpEMA_Slow_H1 = 0;      // GUI: EMA Slow H1 (0 = auto)
input double GUI_InpEMA_Fast_M1 = 0;      // GUI: EMA Fast M1 (0 = auto)
input double GUI_InpEMA_Slow_M1 = 0;      // GUI: EMA Slow M1 (0 = auto)
input double GUI_InpEMA_Fast_M5 = 0;      // GUI: EMA Fast M5 (0 = auto)
input double GUI_InpEMA_Slow_M5 = 0;      // GUI: EMA Slow M5 (0 = auto)
input double GUI_InpATR = 0;              // GUI: ATR (0 = auto)
input int    GUI_InpDirRule = 0;          // GUI: Direction rule (0=neutre, 1=buy, -1=sell)
input bool   GUI_InpIsSpikeMode = false;  // GUI: Mode spike
input double GUI_InpVWAP = 0;             // GUI: VWAP (0 = auto)
input double GUI_InpVWAPDistance = 0;     // GUI: Distance VWAP (0 = auto)
input bool   GUI_InpAboveVWAP = false;    // GUI: Au-dessus VWAP
input int    GUI_InpSuperTrendTrend = 0;  // GUI: SuperTrend trend (0=neutre, 1=up, -1=down)
input double GUI_InpSuperTrendLine = 0;   // GUI: SuperTrend line (0 = auto)
input int    GUI_InpVolatilityRegime = 0; // GUI: Volatility regime (0=neutre)
input double GUI_InpVolatilityRatio = 1.0;// GUI: Volatility ratio
input int    CumulativeLossPauseMinutes = 30; // Durée de pause après pertes consécutives (min)
input bool   EnableProfitLock             = true;  // Stop si gros giveback après gros gain
input double ProfitLockStartDollars       = 10.0;  // Active après ce gain max journalier ($)
input double ProfitLockMaxGivebackDollars = 5.0;   // Giveback max depuis le pic d'équité ($)
input bool   ProfitLockClosePositions     = true;  // Fermer positions + supprimer pending lors du stop
input bool   UsePerSymbolDailyObjectiveOnly = true; // Objectif journée: pause par symbole uniquement (pas de stop global)
input bool   UseHighConfidenceFilterWhenSomeSymbolsProfitLocked = true; // Quand des symboles sont déjà "verrouillés" par profit, exiger plus de probabilité
input int    LockedSymbolsMinCountForFilter = 1; // Seuil du nombre de symboles déjà verrouillés pour activer le filtre
input double ExtraMinAIConfidenceWhenLockedPercent = 10.0; // +% confiance minimale (en plus des seuils internes)
input double ExtraMinSetupScoreWhenLocked = 10.0; // +score minimum setup (0-100) quand des symboles sont verrouillés
input bool   EnableHighVolatilityCapitalGate = true; // Bloquer certains symboles très volatils si capital trop faible
input double MinCapitalForHighVolatilitySymbols = 25.0; // Autoriser ces symboles si Equity OU Balance >= seuil ($)
input string HighVolatilityBlockedSymbolsCsv = "CRASH600,BOOM50,CRASH50,GAINX400,PAINX400"; // Mot-clé symbole (CSV, normalisé sans espaces)
input bool   BlockEquilibriumCorrectionTrades = true; // Bloquer les trades en zone de correction (autour de l'équilibre ICT)
input bool   UseServerCorrectionZoneFilter = true;    // Bloquer aussi selon prédiction correction serveur/Supabase
input double ServerCorrectionMinConfidence = 63.0;    // Seuil confiance (%) pour bloquer quand le serveur signale correction (plus bas = plus de blocage)
input double EquilibriumCorrectionBandPercent = 26.0; // Largeur zone correction (% Premium↔Discount) — plus large = moins de trades en zone chop
input bool   AlwaysShowCorrectionZone = true;         // Toujours afficher la zone de correction colorée sur le graphique
input int    CorrectionZoneVisualForwardBarsM1 = 120; // Extension visuelle de la zone de correction (en barres M1)
input int    CorrectionRangeLookbackBarsM1 = 60;      // Lookback M1 pour détecter une correction (range)
input double CorrectionMaxRangePctM1 = 0.15;          // Range max (%) M1 pour "correction" (plus haut = détection plus large)
input double CorrectionMaxAtrPctM1 = 0.026;           // ATR M1 max (%) pour "marché calme" (plus haut = plus de blocage en calme)
input bool   DebugCorrectionZoneFilter = false;       // Logs détaillés du filtre correction (throttlé)
input bool   DebugMLMetricsHttp = false;                // true: logs WebRequest ML (URL, fallback, JSON, canal) + layout dashboard — sinon Experts silencieux
input bool   CorrectionZoneStrictBlocking = true;     // true: dans la bande équilibre ICT → bloquer (sans attendre range M1 serré / ATR bas)
input int    HoldBypassAfterM5TouchSeconds = 20;      // Fenêtre de bypass si IA=HOLD après touch M5
input double HoldBypassMovePoints = 25.0;             // Mouvement min (points) après touch M5 pour bypass HOLD
input bool   RecoveryLotOnlyHighConviction = true;    // Double lot "recovery" seulement si confiance + score setup très élevés
input double RecoveryMinAIConfidencePercent = 88.0;   // Confiance IA min (%) pour appliquer le recovery lot
input double RecoveryMinSetupScore = 82.0;              // Score setup (0-100) min pour appliquer le recovery lot
enum ENUM_EXECUTION_PROFILE
{
   EXEC_PROFILE_SAFE = 0,
   EXEC_PROFILE_AGGRESSIVE = 1
};
input ENUM_EXECUTION_PROFILE ExecutionProfile = EXEC_PROFILE_AGGRESSIVE; // SAFE: plus strict | AGGRESSIVE: plus réactif
input double MinSetupScoreEntry      = 65.0;  // Score minimum (0-100) pour autoriser une nouvelle entrée
input double MinAIConfidencePercent   = 65.0;  // Confiance IA minimum (%) pour exécuter un trade
input bool   UseCategorySpecificThresholds = true; // Seuils différenciés selon catégorie symbole
input double MinAIConfidenceBoomCrashPercent = 75.0; // Seuil IA min pour Boom/Crash
input double MinAIConfidenceOtherPercent = 68.0; // Seuil IA min pour Forex/Metal/Volatility/Commodity
input double MinSetupScoreBoomCrash = 70.0; // Setup score min pour Boom/Crash
input double MinSetupScoreOther = 62.0; // Setup score min pour autres catégories
input bool   CloseOnlyOnAIHoldOrBrokerSLTP = true; // Empêche les fermetures actives (sauf IA=HOLD). Laisser SL/TP broker gérer le reste.
input bool   BlockManualLossCloseBeforeSL = true; // Si la position est en perte et que le SL broker n'est pas touché, bloquer toute fermeture active.
input group "=== ENTRÉES PLUS POINTUES (fiabilité) ==="
input int    MaxSpreadPoints          = 80;   // Spread max (points) - éviter entrée si spread trop élevé

input group "=== SPREAD STATS (moyenne glissante) ==="
input bool   ShowSpreadStatsOnDashboard = true; // Afficher spread courant + moyen dans le dashboard
input int    SpreadStatsSampleIntervalSec = 1;  // Intervalle d'échantillonnage (sec)
input int    SpreadStatsWindowSec         = 120; // Fenêtre moyenne (sec)
input int    EntryCooldownSeconds     = 90;   // Cooldown min (sec) après dernière entrée sur ce symbole
input int    MinSmallM1CandlesAfterClose = 3; // Après fermeture: attendre au moins N petites bougies M1 avant nouvelle entrée
input int    BoomCrashSmallM1CandlesBeforeEntry = 3; // Boom/Crash (recovery touch M5): petites bougies M1 après spike avant entrée — 2 ou 3
input bool   BoomCrashLossGuardEnabled = true; // Boom/Crash: garde-fou anti-pertes basé sur historique récent
input int    BoomCrashLossGuardLookbackMinutes = 120; // Fenêtre historique (min) pour évaluer les pertes récentes
input int    BoomCrashLossGuardMaxConsecutiveLosses = 2; // Pause si >= N pertes consécutives sur la fenêtre
input double BoomCrashLossGuardMaxNetLossUSD = 2.50; // Pause si net <= -N$ sur la fenêtre
input int    BoomCrashLossGuardPauseMinutes = 45; // Durée de pause auto après déclenchement du garde-fou
input bool   BoomCrashBlockEntriesInConsolidation = true; // Boom/Crash: bloquer les nouvelles entrées si M5 est en consolidation/range
input bool   RequireConfirmationCandle = true; // Exiger 1 bougie M1 dans le sens (close>open BUY, close<open SELL)
input double MinProfitPotentialUSD    = 2.0;  // Gain potentiel min ($) - ex: 2$ pour capital 10$ = mouvement franc requis
input double InpRiskReward        = 3.0;   // Ratio Risque/Rendement pour TP (3.0 = 1:3)

input group "=== ENTRÉE RÉFLÉCHIE (score + IA + vetos) ==="
input bool   UseReflectiveEntryGate = true; // Exiger score setup ET IA alignée + vetos (complète les filtres existants)
input double ReflectiveExtraMinSetupScore = 3.0; // Points ajoutés au seuil catégorie (0-100) pour exiger un signal plus fort
input double ReflectiveMinAIConfidencePercent = 0.0; // 0 = même seuil que catégorie (GetCategoryMinAIConfidencePercent) ; sinon min strict en %
input bool   ReflectiveVetoEquilibriumZone = true; // Veto: pas d'entrée en zone équilibre ICT (sauf STAIR si bypass équilibre actif)
input bool   ReflectiveVetoWhenAIDisagrees = true; // Veto: IA doit être BUY/SELL = direction (pas neutre / pas contre)
input bool   ReflectiveAllowStairHoldWithoutIaDirection = true; // STAIR + IA=HOLD: ne pas veto sur direction IA (confiance + score restent exigés)
input bool   ReflectiveApplyToStairEntry = false; // true: STAIR_ENTRY aussi soumis au gate (plus rare ; HOLD exception gérée ci-dessus)

// === DÉTECTION SPIKES SANS IA ===
input bool   UseSpikeDetectionWithoutAI = true;  // Activer détection spikes même si IA faible
input int    SpikeDetectionMinSignals = 3;       // Nombre minimum de signaux spike requis (sur 6)
input double SpikeVolumeMultiplier = 2.0;       // Multiplicateur pour détecter spike de volume
input double SpikePriceMultiplier = 1.5;        // Multiplicateur pour détecter spike de prix
input double SpikeCompressionThreshold = 0.5;    // Seuil de compression ATR (0.5 = 50% de la moyenne)
input int    SpikeCalmBarsMin = 3;               // Nombre minimum de bougies calmes requises
input double SpikeMomentumChange = 5.0;         // Changement RSI minimum pour momentum accélérant
input bool   DebugSpikeDetection = false;       // Logs détaillés de détection spike
input bool   EnableSpikeCountdownAutoEntry = false; // Compte a rebours spike (<=60s) + entree marche auto (DÉSACTIVÉ - anti-détachement)
input double SpikeCountdownTriggerProbability = 0.82; // Seuil proba pour lancer le compte a rebours
input int    SpikeCountdownMaxSeconds = 60; // Fenetre max du compte a rebours
input double SpikeAutoEntryMinAIConfidence = 0.80; // Confiance IA min pour auto-entree spike
input int    SpikeAutoEntryCooldownSeconds = 45; // Cooldown entre deux auto-entrees spike
input bool   SpikeMassiveEntryMode = true; // Mode agressif: spike sans retard (filtres assouplis)
input int    SpikeBurstEntries = 1; // Nombre d'entrees a tenter par signal spike (1=normal)
input double SpikeMassiveMinAIConfidence = 0.62; // Confiance IA min (0..1) en mode agressif
input bool   SpikeMassiveBypassCooldown = true; // Ignorer EntryCooldown sur spikes agressifs
input bool   SpikeMassiveBypassLastCandleConfirm = true; // Ignorer confirmation derniere bougie M1
input bool   SpikeMassiveBypassDerivArrow = true; // Ne pas attendre la fleche DERIV en mode agressif

// === ZONE DE CONFLUENCE "SPIKE CLUSTER" (Boom/Crash + PAINX/GAINX) ===
input bool   ShowSpikeClusterZone = true;     // Afficher la zone de confluence spikes (cluster)
input int    SpikeClusterLookbackBarsM1 = 60; // Fenêtre M1 pour estimer la fréquence des spikes (cluster)
input int    SpikeClusterMinSpikeBars = 4;    // Nb min de bougies "spike" sur la fenêtre pour considérer un cluster
input double SpikeClusterMinScore = 0.72;     // Score min (0..1) pour autoriser les entrées "spike/series"
input double SpikeClusterZoneAtrMult = 1.25;  // Largeur de zone autour du prix (± ATR*M)
input bool   SpikeClusterRequireDirectionalStructure = true; // Crash: cluster valide seulement si structure descendante (Boom/GainX inverse)
input int    SpikeClusterFutureShiftMinutes = 1; // Décaler visuellement la zone cluster vers le futur (minutes)
input double SpikeClusterAnchorSmoothing = 0.65; // Lissage ancre cluster (0..1, plus haut=plus stable)
input int    SpikeClusterProjectionMinutes = 20; // Projection de la zone dans le futur (minutes)
input int    SpikeClusterRefreshSec = 5;      // Fréquence de recalcul/rafraîchissement (secondes)

input bool   UseSessions       = true;   // LO/NYO: appliqué seulement si perte jour >= MaxDailyLossDollars ($)
input bool   ShowChartGraphics = true;   // FVG, OB, Fibo, EMA, Swing H/L sur le graphique
input bool   OTEOnlyStrictMode = true;   // true: aucune nouvelle entrée hors logique OTE
input bool   BoomCrashOnlyOTEAndEMAPullback = true; // Boom/Crash: n'autoriser que OTE protocole + EMA pullback confirmé
input bool   EnableMinuteChartAnalysis = false; // Anti-détachement: analyse timer désactivée par défaut
input int    MinuteChartAnalysisIntervalSec = 60; // Intervalle (secondes) du timer d'analyse (>=30 recommandé)
input bool   MinuteChartAnalysisForceTechSync = true; // Force PushChartTechStateToAIServer() à chaque minute (si IA active)
input bool   EnableScanner360Timer = false; // Anti-détachement: scanner 360 désactivé par défaut (activer seulement si stable)
input bool   ShowPremiumDiscount = true; // Zones Premium (vente) / Discount (achat) / Équilibre
input bool   ShowSignalArrow     = true; // Flèche dynamique clignotante BUY/SELL
input bool   RequireSMCDerivArrowForMarketOrders = true; // Avant tout ordre au marché, attendre SMC_DERIV_ARROW
input bool   BypassSecondaryMarketFiltersWhenAIDerivArrow = true; // IA déjà au seuil + flèche DERIV alignée → ne pas bloquer sur score setup / range / proximité niveaux futurs
input int    SMCDerivArrowMaxAgeBars = 3; // La flèche doit être sur les N dernières bougies (timeframe courant)
input bool   ExecuteMarketOnDerivArrowAppearance = true; // À l'apparition d'une nouvelle flèche SMC_DERIV_ARROW, tenter un ordre marché immédiat
input double DerivArrowAppearanceMinAIConfidence = 0.80; // "Meilleures conditions": confiance IA min (0..1 ou %)
input int    DerivArrowAppearanceCooldownSeconds = 20;   // Cooldown anti-duplication par direction sur apparition
input bool   DerivArrowAppearanceBypassEntryCooldown = true; // Bypass EntryCooldown pour exécution immédiate sur apparition
input bool   DerivArrowAppearanceBypassLastCandleConfirm = true; // Bypass confirmation dernière bougie (flèche = confirmation)
input bool   AllowScalpEntryByEMA1EMA5WithoutDerivArrow = true; // Scalping: EMA(1)/EMA(5) fort => autoriser même sans flèche récente
input double EMA1EMA5StrongMinGapPct = 0.01; // Gap minimum EMA1-EMA5 (%) pour considérer "fort"
input bool   RequireFutureProtectTouchForBoomCrashDerivArrow = true; // Boom/Crash: armer entrée sur touch future protect avant flèche DERIV
input int    FutureProtectTouchArmSeconds = 120; // Fenêtre après touch pour accepter la flèche (secondes)
input double FutureProtectTouchToleranceATRMult = 0.4; // Tolérance de touch autour du niveau (x ATR M15)
input int    FutureProtectTouchCheckIntervalSec = 2; // Throttle calcul touch (secondes)
input bool   UseTouchProtectScalpExitOnDerivArrow = true; // Boom/Crash: fermer le scalp au moment où la flèche DERIV apparaît
input int    TouchProtectScalpMinHoldSeconds = 10; // Délai min avant fermeture scalp (évite fermeture immédiate)
input int    TouchProtectScalpReentryCooldownSeconds = 60; // Cooldown après sortie sur flèche (évite boucle entrée/sortie au même niveau)
input bool   UseSR20TouchEntryForBoomCrashDerivArrow = true; // Boom/Crash: activer entrée sur support/résistance 20 bars
input double SR20TouchToleranceATRMult = 0.5; // Tolérance autour de SR20 via ATR M1
input int    SR20TouchATRPeriod = 20; // Période ATR pour tolérance SR20 (M1)
input bool   AllowBoomCrashTrendEntryWithoutArrow = true; // Autoriser entrée Boom/Crash en tendance forte sans flèche
input double BoomCrashTrendEntryMinConfidencePct = 90.0;  // Confiance ML min (%) pour bypass flèche en tendance forte
input int    BoomCrashTrendLookbackBarsM1 = 60;           // Lookback M1 pour détecter tendance "escalier"
input double BoomCrashTrendMinMovePct = 0.10;             // Mouvement min (%) sur lookback M1 (ex: 0.10 = 0.10%)
input double BoomCrashTrendMaxDrawdownPct = 0.35;         // Drawdown max (%) du mouvement (0.35 = 35% du move)
input double BoomCrashTrendMinBullishCandleRatio = 0.60;  // % bougies dans le sens de la tendance
input bool   StairUseEarlyRelaxedM1 = true;   // Escalier « jeune » : lookback M1 plus court + seuils assouplis
input int    StairEarlyLookbackBarsM1 = 28;
input double StairEarlyMinMovePct = 0.07;
input double StairEarlyMinAlignedRatio = 0.52;
input double StairEarlyMaxDrawdownPct = 0.48;
input bool   StairUseFormingPhaseM1 = true;   // Phase marche : tendance contexte + range réduit en fin de fenêtre (avant spike)
input int    StairFormingContextBarsM1 = 36;
input int    StairFormingStepBarsM1 = 8;
input double StairFormingMinContextMovePct = 0.055;
input double StairFormingMaxEndRangeVsContext = 0.48; // range(step)/range(context) max
input double StairFormingMaxStepRangeAtrMult = 3.2;   // range(step) <= X * ATR(M1)
input bool   StairFormingUseRsiPullbackSell = true;   // PainX/Crash : RSI remonte sur la micro-marche
input int    StairFormingRsiPullbackBars = 5;
input double StairChartSignalMinAIConfidencePct = 0.0; // Min IA (%) pour dessin STAIR (0 = même seuil que notify pattern)
input bool   ShowStairSetupOnChart = true;    // Rectangle + lignes type OTE quand pattern stair M1 détecté
input group "=== STAIR ENTRY (Boom/Crash + GainX/PainX Weltrade, complément OTE) ==="
input bool   UseStairEntry = false; // DÉSACTIVÉ: Seul OTE+Fibo avec confirmation M5 autorisé
input int    StairEntryCooldownSeconds = 120; // Anti-spam entre deux stairEntry sur le même graphique
input double StairEntryMinAIConfidencePercent = 60.0; // Confiance IA min (%) pour stairEntry (Boom/Crash)
input double StairEntryWeltradeMinAIConfidencePercent = 60.0; // Confiance IA min (%) pour stairEntry (Weltrade synth)
input bool   StairEntryRequireStrongM1M5EMA = true; // Exiger pile EMA M1+M5 alignée (même logique que scalp agressif)
input bool   StairEntryUseM1StairDetector = true;   // Exiger IsSyntheticStairPatternM1 (classique + jeune + forming si activés)
input bool   StairEntryBypassEquilibriumCorrectionZone = false; // true: stair autorisé même en bande équilibre ICT (ExecuteM5TouchOrder)
input bool   StairEntryIgnoreLastM1Confirmation = false; // true: stair sans exiger close>open sur dernière M1 fermée (pullbacks)
input bool   StairEntryDebugLog = false; // Journal (max 1 ligne / 20s): raison du refus stair
input bool   StairEntryHoldZoneSpikeException = true; // Exception HOLD: BUY en discount (Boom/GAINX) / SELL en premium (Crash/PAINX) jusqu'à zone d'équilibre
input bool   StairEntryPushOnPatternM1 = false; // Push « SIGNAL STAIR M1 » (1×/bougie M1) — désactivé par défaut: seul l’ordre réel envoie « STAIR ENTRY » (moins de bruit)
input double StairEntryPatternNotifyMinAIConfidencePct = 45.0; // Seuil IA min (%) pour cette alerte seule (0 = utiliser StairEntryMinAIConfidencePercent)
input bool   StairEntryPushIgnoreIADirection = true; // true: alerte stair si escalier M1 OK + seuil confiance ci-dessus, sans exiger IA=BUY/SELL (l’entrée marché reste filtrée)
input bool   StairEntryPushMatchExecution = false; // true: push stair seulement si toutes les conditions d’exécution marché sont OK
input bool   StairEntryExecuteMarketOnPushWhenEMAAligned = true; // Après push STAIR M1: si EMA M1+M5 alignées, tenter l'entrée marché immédiatement
input bool   StairEntryRequireEma13M1AndEma21M5TouchForBoomGainBuy = true; // Boom/GAINX BUY: attendre retouche EMA13 M1 + confluence EMA21 M5 avant entrée marché
input int    StairEntryFastTrackAfterSpikeSeconds = 180; // Après spike directionnel récent (Boom/Crash/GainX/PainX), fenêtre d'exécution STAIR accélérée
input bool   StairEntryFastTrackBypassCooldown = true; // En fenêtre fast-track, ignorer cooldown STAIR pour ne pas rater l'impulsion
input bool   StairEntryFastTrackBypassEmaTouch = true; // En fenêtre fast-track, ne pas attendre retouche EMA13/EMA21
input double StairEntryEmaTouchMaxDistancePct = 0.020; // Tolérance touch EMA (%) du prix (0.020 = 0.02%)
input double StairEntryEmaTouchAtrMult = 0.45; // Tolérance min via ATR M1 (abs = ATR * multiplicateur)
input double StairEntryEma21M5ConfluenceMult = 1.35; // Tolérance EMA21 M5 = tolérance de base * multiplicateur
input bool   StairEntryEmaTouchDebug = false; // Logs throttlés du filtre touch EMA13/EMA21
input bool   UseStairEmaTouchScalpEntry = true; // Boom/GAINX BUY: entrée marché immédiate en escalier haussier sur touch EMA13 M1 + EMA21 M5
input int    StairEmaTouchScalpCooldownSeconds = 35; // Cooldown dédié (s) entre 2 entrées scalp EMA touch
input bool   StairEntryBypassWeakScissorPrudent = true; // Stair: ne pas bloquer/réduire le lot par le mode prudent « canal ciseau » (souvent la cause des non-entrées malgré l’escalier)
input group "=== SORTIE SUR INVERSION LIGNE M1 TREND ==="
input bool   UseM1TrendReversalExit     = true;   // Fermer la position si la ligne M1 trend change de sens
input int    M1TrendReversalLookback    = 20;     // Lookback M1 (bougies) pour la régression linéaire de tendance
input double M1TrendReversalMinSlope    = 0.0;    // Pente min absolue pour confirmer un vrai changement (0 = tout signal)
input int    M1TrendReversalMinSeconds  = 30;     // Délai min (s) après ouverture avant de sortir sur inversion

input group "=== STAIR ESCALIER (niveau A=marché existant, niveau B=1 limite d'attente, sorties) ==="
input bool   UseStairEscalierMode = true; // Activer limite niveau B + trailing / sorties dédiées positions STAIR
input bool   StairEscPlaceLimitLevelB = true; // Si escalier M1 OK mais pas niveau A (EMA et/ou IA), placer 1 seul BUY_LIMIT/SELL_LIMIT (pullback)
input double StairEscLimitPullbackATRMult = 0.45; // Boom/GainX: sous le bid ; Crash/PainX: au-dessus de l’ask (× ATR M1)
input double StairEscLimitLotMult = 0.65; // Volume relatif à GetOptimalLotSize() pour la limite
input int    StairEscLimitCooldownSeconds = 300; // Entre deux tentatives de limite niveau B
input int    StairEscLimitExpireMinutes = 360; // 0 = pas d’expiration MetaTrader
input double StairEscLimitBlockIAAgainstMinPct = 62.0; // Au-dessus: IA clairement contre → pas de limite (ex. SELL 62 %+ sur Boom)
input bool   StairEscTrailTighten = true; // Trailing ATR M1 sur commentaires STAIR_ENTRY / STAIR_ESC_LIMIT
input double StairEscTrailATRMult = 2.25; // Distance SL suiveur (× ATR M1) ; 0 = désactive le trailing dédié
input bool   StairEscExitOnIAAgainst = true; // Fermer si IA repasse fortement contre la position
input double StairEscExitIAAgainstMinPct = 68.0; // Seuil confiance IA (%) pour cette sortie
input bool   StairEscExitOnEMABreak = true; // Fermer si la pile EMA M1+M5 ne soutient plus le sens du trade
input int    StairEscMinSecondsBeforeExit = 25; // Anti-fermeture immédiate après entrée
input bool   StairPostLossUseSrLimitInsteadOfMarket = true; // Après perte sur position STAIR_ENTRY: plus de marché STAIR tant qu’aucun nouveau spike (Boom/Crash) ; placer 1 LIMIT au SR le plus proche de la ligne M5
input int    StairPostLossSrLimitExpireMinutes = 240; // 0 = pas d’expiration (GV)
input int    StairPostLossSrLimitCooldownSeconds = 45; // Anti-spam entre deux tentatives de LIMIT SR
input bool   StairEntryFallbackMarketIfPostLossLimitFails = true; // Si LIMIT post-perte echoue, autoriser fallback marche pour ne pas rater les spikes
input bool   UseAggressiveChannelEntry = true; // Entrée agressive sur tendance/canal
input bool   ICT_RequireOBInOTEZone = true; // Exiger OB en zone OTE pour validation ICT
input bool   UseAggressiveScalpOnStrongM1M5 = true; // Scalp agressif si tendance forte alignée M1+M5
input bool   UsePrudentScalpInWeakScissorChannel = true; // Scalp prudent si marché en ciseau / canal peu prononcé
input double StrongM1M5MinConfidencePercent = 78.0; // Confiance IA min pour scalp agressif M1+M5
input double PrudentScalpLotMultiplier = 0.60; // Réduction du lot en mode prudent
input double PrudentScalpMinSetupScore = 72.0; // Score setup min en mode prudent
input bool   UseMlChannelEarlySpikeEntry = true; // Boom/Crash: entrée plus tôt si canal ML haussier (Boom) / baissier (Crash) confirmé (sans attendre touch protect)
input double MlChannelEarlyEntryMinConfidencePct = 70.0; // Confiance ML min (%) pour ce bypass (sous le seuil escalier 90%)
input double MlChannelMinSlopeVsAtr = 0.00020; // Pente (par bar) / ATR : filtre canal plat vs vraie tendance
input double MlChannelBoomMaxPosInChannel = 0.80; // Boom BUY: pas d'entrée anticipée si prix déjà au-delà de X% du bas du canal (évite achat en haut)
input double MlChannelCrashMinPosFromBottom = 0.22; // Crash SELL: prix doit être au moins à X% du bas (zone haute du canal)
input bool   DebugDerivArrowCapture = true;              // Debug capture flèche SMC_DERIV_ARROW (logs)
input bool   ShowPredictedSwing  = true; // SL/SH prédits (futurs) sur le canal
input bool   ShowEMASupportResistance = true; // EMA M1, M5, H1 en support/résistance
input bool   RequireEMATouchBeforeEntry = true;   // Exiger une retouche EMA (9/21/50/100/200) avant une nouvelle entrée
input int    EMATouchLookbackBarsM1 = 30;         // Nb bougies M1 max pour considérer une "retouche" récente
input double EMATouchMaxDistancePct = 0.03;       // Distance max (%) prix↔EMA pour valider la retouche (0.03 = 0.03%)
input bool   DebugEMATouchFilter = false;         // Logs EMA-touch (throttlé)
input bool   UltraLightMode      = false; // Mode ultra léger: pas de graphiques ni IA, exécution trading minimale
input bool   BlockAllTrades      = false; // BLOQUER toutes les entrées/sorties (mode observation seul)
input int    SpikePredictionOffsetMinutes = 60; // Décalage dans le futur pour afficher l'entrée de spike dans la zone prédite
input group "=== TIMING TRADING (UTC) ==="
input bool   EnforceTradingTimeZones = true; // Zones UTC + quota/jour: appliqués seulement si perte jour >= MaxDailyLossDollars ($)
input int    Zone1StartHourUTC = 8;
input int    Zone1EndHourUTC   = 11; // Zone 1 = 3h
input int    Zone2StartHourUTC = 12;
input int    Zone2EndHourUTC   = 15; // Zone 2 = 3h
input int    Zone3StartHourUTC = 16;
input int    Zone3EndHourUTC   = 19; // Zone 3 = 3h
input int    Zone4StartHourUTC = 20;
input int    Zone4EndHourUTC   = 23; // Zone 4 = 3h
input int    MaxTradesPerZonePerDay = 5; // 4 zones x 5 trades = 20 max/jour
input int    MaxDailyTrades         = 20; // Au-delà => robot en pause (plus d'entrées)

input group "=== PRESET XAU (DERIV) — SCALP 2 TRADES/JOUR ==="
input bool   XAU_DerivScalpPresetEnabled = true;   // Appliquer règles spéciales OR (scalp Deriv)
input int    XAU_MaxDailyTrades          = 2;      // Max positions/jour sur XAU (EA)
input int    XAU_MaxSpreadPoints         = 80;     // Bloquer si spread > N points (SYMBOL_SPREAD)
input bool   XAU_EnforceH1TrendFilter    = true;   // Exiger tendance H1 claire (EMA50 vs EMA200) sur XAU
input double XAU_MinAIConfidencePercent  = 90.0;   // XAU: IA minimum pour autoriser toute entrée
input bool   XAU_RequireOTEActive        = true;   // XAU: exiger setup OTE actif avant toute entrée

input group "=== FAST SETUPS (hors OTE strict) ==="
input bool   UseEMAPullbackDynamicEntry       = true;  // Entrée sur touch/rejet EMA 21/50 en tendance forte
input double EMAPullbackMaxDistanceATRMult    = 0.30;  // Distance max au cluster EMA (x ATR M1)
input bool   EMAPullbackRequireTrendH1M15     = true;  // Exiger alignement tendance H1+M15
input int    EMAPullbackCooldownSeconds       = 30;    // Cooldown entre 2 tentatives EMA pullback
input bool   EMAPullbackAllowOnVolatility     = false; // Step/Volatility: désactiver pullback EMA seul (évite pertes en chop)
input double EMAPullbackMinAIConfidencePercent = 85.0; // Seuil IA mini (%) pour autoriser un pullback EMA
input bool   UseLiquiditySweepReclaimEntry    = true;  // Entrée après sweep de liquidité + reclaim
input int    SweepReclaimTolerancePoints      = 15;    // Tolérance reclaim autour du niveau sweep (points)
input bool   SweepReclaimRequireTrendFilter   = true;  // Exiger alignement H1+M15 du reclaim
input int    SweepReclaimCooldownSeconds      = 45;    // Cooldown entre 2 tentatives sweep reclaim
input bool   WeltradeAllowStrongSignalInCorrection = true; // Weltrade: autoriser entrée en correction si signal fort aligné
input double WeltradeCorrectionBypassMinAIConfidencePercent = 78.0; // Seuil IA (%) pour bypass correction Weltrade
input int    FastSetupMinSLPoints             = 180;   // Eviter SL trop serré (positions timides)
input int    FastSetupMinTPPoints             = 280;   // Eviter TP trop court (positions timides)
input double FastSetupMinRR                   = 1.30;  // RR minimum pour setups rapides
input double FastSetupMinExpectedProfitUSD    = 0.70;  // Profit potentiel minimum estimé ($)

bool   g_cfgAllowBoomCrashTrendEntryWithoutArrow = false;
double g_cfgBoomCrashTrendEntryMinConfidencePct = 90.0;
bool   g_cfgUseAggressiveChannelEntry = false;
bool   g_cfgICTRequireOBInOTEZone = false;

void ApplyExecutionProfileSettings()
{
   // Base: respecter les inputs utilisateur.
   g_cfgAllowBoomCrashTrendEntryWithoutArrow = AllowBoomCrashTrendEntryWithoutArrow;
   g_cfgBoomCrashTrendEntryMinConfidencePct = BoomCrashTrendEntryMinConfidencePct;
   g_cfgUseAggressiveChannelEntry = UseAggressiveChannelEntry;
   g_cfgICTRequireOBInOTEZone = ICT_RequireOBInOTEZone;

   // Presets rapides par profil.
   if(ExecutionProfile == EXEC_PROFILE_SAFE)
   {
      g_cfgAllowBoomCrashTrendEntryWithoutArrow = false;
      g_cfgBoomCrashTrendEntryMinConfidencePct = MathMax(g_cfgBoomCrashTrendEntryMinConfidencePct, 92.0);
      g_cfgUseAggressiveChannelEntry = false;
      g_cfgICTRequireOBInOTEZone = true;
      Print("[PROFILE] SAFE active");
   }
   else if(ExecutionProfile == EXEC_PROFILE_AGGRESSIVE)
   {
      g_cfgAllowBoomCrashTrendEntryWithoutArrow = true;
      g_cfgBoomCrashTrendEntryMinConfidencePct = MathMin(g_cfgBoomCrashTrendEntryMinConfidencePct, 85.0);
      g_cfgUseAggressiveChannelEntry = true;
      g_cfgICTRequireOBInOTEZone = true;
      Print("[PROFILE] AGGRESSIVE active");
   }
}

// --- LIMIT: SL plus large basé sur le range moyen M1 ---
double GetAverageM1CandleRange(const int bars)
{
   int n = MathMax(1, bars);
   MqlRates r[];
   ArraySetAsSeries(r, true);
   int copied = CopyRates(_Symbol, PERIOD_M1, 1, n, r);
   if(copied <= 0) return 0.0;
   int useN = MathMin(copied, n);
   if(useN <= 0) return 0.0;
   double sum = 0.0;
   for(int i = 0; i < useN; i++)
      sum += (r[i].high - r[i].low);
   return (sum / useN);
}

double GetLimitOrderExtraSLDistance()
{
   if(LimitOrdersExtraStopLossM1Candles <= 0) return 0.0;
   double avgRange = GetAverageM1CandleRange(LimitOrdersAvgRangeBarsM1);
   double extraRange = (avgRange > 0.0 ? avgRange * (double)LimitOrdersExtraStopLossM1Candles : 0.0);
   double atrM1Val = GetATRValue(PERIOD_M1, 14);
   double extraAtr = (atrM1Val > 0.0 ? atrM1Val * MathMax(0.0, LimitOrdersExtraSLMinAtrMultM1) : 0.0);
   double extra = MathMax(extraRange, extraAtr);
   if(extra <= 0.0) return 0.0;
   if(IsWeltradeGainSynthSymbol(_Symbol) || IsWeltradePainSynthSymbol(_Symbol))
      extra *= MathMax(1.0, LimitOrdersWeltradeExtraSLMultiplier);
   return extra;
}

void ApplyExtraStopLossForLimitOrders(double entryPrice, double &stopLoss, const ENUM_ORDER_TYPE orderType)
{
   double extra = GetLimitOrderExtraSLDistance();
   if(extra <= 0.0) return;
   if(orderType == ORDER_TYPE_BUY_LIMIT)
      stopLoss -= extra;
   else if(orderType == ORDER_TYPE_SELL_LIMIT)
      stopLoss += extra;
   stopLoss = NormalizeDouble(stopLoss, _Digits);
}

input group "=== PANEL D'INPUTS MANUEL (SL/TP/RISK/REWARD) ==="
input bool   UseManualPanelInputs = false; // Activer le panel d'inputs manuel (TP1-TP4, SL, Risk%, Reward)
input double ManualTP1Points    = 0.0;    // TP1 en points (0 = désactivé)
input double ManualTP2Points    = 0.0;    // TP2 en points (0 = désactivé)
input double ManualTP3Points    = 0.0;    // TP3 en points (0 = désactivé)
input double ManualTP4Points    = 0.0;    // TP4 en points (0 = désactivé)
input double ManualSLPoints     = 0.0;    // SL en points (0 = désactivé)
input double ManualRiskPercent  = 0.5;    // Risque en % du capital pour calcul auto position size
input double ManualRewardUSD    = 0.0;    // Reward cible en USD (0 = calcul auto via RR ratio)
input double ManualPositionSize = 0.0;    // Position size manuelle en lots (0 = calcul auto via risk%)

input group "=== DASHBOARD MANUEL MM + SIMULATION ==="
input bool   UseManualAssistantDashboard = true; // Afficher panneau manuel MM/simulation (n'agit pas sur l'auto-trading)
input bool   ManualAssistantPush360ToMobile = true; // Bouton Analyse 360 envoie aussi une notification push MT5

input group "=== SL/TP DYNAMIQUES (prudent / sécuriser gain) ==="
input double SL_ATRMult        = 1.5;    // Stop Loss (x ATR) — réduit pour petit capital
input double TP_ATRMult        = 3.0;    // Take Profit (x ATR) - réduit pour petit capital
input int    SLTightenPoints   = 5;      // Rapprocher le SL de N points (sans violer les contraintes broker)
input group "=== SL marchés / LIMIT Boom-Crash (plus bas = SL plus proche) ==="
input double BoomCrashSlMinPointsFloor    = 340.0; // Points min SL si stopsLevel broker = 0 (ex-Boom ~500 pts)
input double BoomCrashSlBrokerFloorPoints = 340.0; // Avec stopsLevel : plancher en points (max avec distance broker)
input double BoomCrashSlSafeDistanceMult  = 2.05; // x distance min avant SL/TP marché (ex-2.5 Boom/Crash)
input int    BoomCrashFixedSlPoints       = 150;  // SL en points : réduit pour petit capital
input int    BoomCrashFixedTpPoints       = 300;  // TP en points : réduit pour petit capital
input group "=== ORDRES LIMITES: FILTRE TENDANCE + SL PLUS LARGE ==="
input bool   LimitOrdersRequireTrendConfirmation = true; // Avant tout ordre LIMIT, exiger filtres tendance (EMA+OB+OTE selon config)
input int    LimitOrdersExtraStopLossM1Candles   = 18;   // Augmenter SL des LIMIT d'environ N bougies M1 (élargi de +8 bougies)
input int    LimitOrdersAvgRangeBarsM1           = 10;   // Nb bougies M1 pour estimer la "petite bougie" (range moyen)
input double LimitOrdersWeltradeExtraSLMultiplier = 2.0; // GAINX/PAINX: SL LIMIT plus large (multiplicateur du buffer M1)
input double LimitOrdersExtraSLMinAtrMultM1      = 1.0; // SL LIMIT: distance mini supplémentaire = ATR(M1) * mult (en plus du range moyen)
input bool   LimitOrdersDisableAutoCancel        = true; // Ne plus annuler automatiquement les pending LIMIT (IA flip/HOLD/pré-touch)
input bool   UseMovingEntryPointLimitOrders      = true; // Placer un LIMIT au BUY/SELL ENTRY POINT et le déplacer si la ligne bouge
input bool   MovingEntryPointLimitFollowIAOnly   = true; // Suivre seulement la direction IA (BUY/SELL) pour éviter 2 LIMIT simultanés
input int    MovingEntryPointLimitRefreshSeconds = 1;    // Fréquence de synchronisation du LIMIT suiveur
input int    MovingEntryPointLimitMoveThresholdPoints = 1; // Écart mini (points) avant modification d'un LIMIT existant
input group "=== TRAILING STOP (sécuriser les gains) ==="
input bool   UseTrailingStop    = true;   // Activer le Trailing Stop automatique
input double TrailingStop_ATRMult = 1.5;  // Distance Trailing Stop (x ATR) - réduit pour petit capital
input double TrailingStartProfitDollars = 0.10; // Activer le trailing dès petit gain ($)
input bool   UseHardGiveback50From1USD = true; // Si pic >= 1$, fermer quand le profit redescend de 50% du pic
input double HardGivebackMinPeakUSD = 1.0;     // Seuil d'activation du filet anti-giveback
input double HardGivebackMaxGivebackPct = 50.0; // 50 = ne tolérer qu'une reprise max de 50% du gain
input bool   DynamicSL_Enable = true;               // SL dynamique (BE + trailing + lock gain max)
input double DynamicSL_StartProfitDollars = 0.15;   // Commencer à protéger à partir de ce profit ($) - réduit pour petit capital
input double DynamicSL_LockPctOfMax = 0.70;         // Protéger au moins X% du gain max (0.70 = 70% - protection renforcée)
input int    DynamicSL_BE_BufferPoints = 5;         // Marge break-even (points) - réduite pour M1
input bool   DynamicSL_OnBoomCrash = true;          // Boom/Crash: ACTIVÉ pour trailing stop avec petit capital
input bool   DynamicSL_OnWeltradeSynth = true;      // PAINX/GAINX: ACTIVÉ pour trailing stop avec petit capital
input bool   DynamicSL_OnCryptoForexIndices = true; // ACTIVÉ: SL dynamique sur Crypto/Forex/Indices pour protéger les gains

input group "=== SL DYNAMIQUE PRÉCOCE (sortie si entrée non prometteuse) ==="
