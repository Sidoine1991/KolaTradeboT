// et se recalculent par pÃĐriode (jour/mois) pour ÃĐviter toute "invention".

int OnInit()
{
   ApplyExecutionProfileSettings();
   g_oteImbPendingAfterCorrection = false;
   g_oteImbPendingDir = "";
   g_oteImbPendingSymbol = "";
   g_oteImbPendingUseFlexible = false;
   g_oteImbPendingSince = 0;
   trade.SetExpertMagicNumber(InpMagicNumber);
   trade.SetDeviationInPoints(20);
   trade.SetTypeFilling(ORDER_FILLING_IOC);
   if(NoSLTP_BoomCrash)
      Print("â ïļ NoSLTP_BoomCrash est ignorÃĐ: chaque ordre dÃĐmarre avec SL et TP calculÃĐs.");

   // Nettoyer tous les anciens dessins sur le chart au dÃĐmarrage (si activÃĐ)
   if(CleanChartOnStartup)
   {
      CleanupAllChartObjects();
      Print("ð§đ Nettoyage complet des anciens dessins effectuÃĐ au dÃĐmarrage");
   }
   
   atrHandle = iATR(_Symbol, LTF, 14);
   emaHandle = iMA(_Symbol, LTF, 9, 0, MODE_EMA, PRICE_CLOSE);
   hEmaFast = iMA(_Symbol, LTF, 9, 0, MODE_EMA, PRICE_CLOSE);   // EMA rapide
   hEmaSlow = iMA(_Symbol, LTF, 21, 0, MODE_EMA, PRICE_CLOSE);  // EMA lente
   ema50H = iMA(_Symbol, HTF, EMA50_Period, 0, MODE_EMA, PRICE_CLOSE);
   ema200H = iMA(_Symbol, HTF, EMA200_Period, 0, MODE_EMA, PRICE_CLOSE);
   // EMAs SMC sur le timeframe d'entrÃĐe (LTF)
   ema21LTF = iMA(_Symbol, LTF, 21, 0, MODE_EMA, PRICE_CLOSE);
   ema31LTF = iMA(_Symbol, LTF, 31, 0, MODE_EMA, PRICE_CLOSE);
   ema50LTF = iMA(_Symbol, LTF, 50, 0, MODE_EMA, PRICE_CLOSE);
   ema100LTF = iMA(_Symbol, LTF, 100, 0, MODE_EMA, PRICE_CLOSE);
   ema200LTF = iMA(_Symbol, LTF, 200, 0, MODE_EMA, PRICE_CLOSE);
   
   // Initialiser le systÃĻme de gestion des pauses
   InitializeSymbolPauseSystem();
   
   // Initialiser le systÃĻme de prÃĐservation des gains
   InitializeGainPreservationSystem();
   
   Print("?? SMC Universal + FVG_Kill PRO | 1 pos/symbole | StratÃĐgie visible");
   emaM1H = iMA(_Symbol, PERIOD_M1, 20, 0, MODE_EMA, PRICE_CLOSE);
   emaM5H = iMA(_Symbol, PERIOD_M5, 20, 0, MODE_EMA, PRICE_CLOSE);
   emaH1H = iMA(_Symbol, PERIOD_H1, 20, 0, MODE_EMA, PRICE_CLOSE);

   // EMA(1)/EMA(5) pour bypass flÃĻche (scalping rapide)
   ema1M1 = iMA(_Symbol, PERIOD_M1, 1, 0, MODE_EMA, PRICE_CLOSE);
   ema5M1 = iMA(_Symbol, PERIOD_M1, 5, 0, MODE_EMA, PRICE_CLOSE);
   
   // Handles pour EMA Supertrend Multi-TF
   emaFastM1 = iMA(_Symbol, PERIOD_M1, EMAFastPeriod, 0, MODE_EMA, PRICE_CLOSE);
   emaSlowM1 = iMA(_Symbol, PERIOD_M1, EMASlowPeriod, 0, MODE_EMA, PRICE_CLOSE);
   emaFastM5 = iMA(_Symbol, PERIOD_M5, EMAFastPeriod, 0, MODE_EMA, PRICE_CLOSE);
   emaSlowM5 = iMA(_Symbol, PERIOD_M5, EMASlowPeriod, 0, MODE_EMA, PRICE_CLOSE);
   emaFastH1 = iMA(_Symbol, PERIOD_H1, EMAFastPeriod, 0, MODE_EMA, PRICE_CLOSE);
   emaSlowH1 = iMA(_Symbol, PERIOD_H1, EMASlowPeriod, 0, MODE_EMA, PRICE_CLOSE);
   atrM1 = iATR(_Symbol, PERIOD_M1, 14);
   rsi14M1 = iRSI(_Symbol, PERIOD_M1, 14, PRICE_CLOSE);
   atrM5 = iATR(_Symbol, PERIOD_M5, 14);
   atrH1 = iATR(_Symbol, PERIOD_H1, 14);
   // VÃĐrification robuste des handles
   if(atrHandle == INVALID_HANDLE)
   {
      Print("? Erreur crÃĐation ATR - Tentative de rÃĐcupÃĐration...");
      atrHandle = iATR(_Symbol, LTF, 14);
      if(atrHandle == INVALID_HANDLE)
      {
         Print("?? Erreur ATR - Utilisation ATR calculÃĐ manuellement pour ÃĐviter dÃĐtachement");
         Comment("?? ATR MANUEL - Robot fonctionnel");
         atrHandle = INVALID_HANDLE; // Garder INVALID_HANDLE mais continuer
      }
   }
   // Les indicateurs seront ajoutÃĐs dynamiquement si nÃĐcessaire pour ÃĐviter le dÃĐtachement
   GlobalVariableSet("SMC_OPEN_LOCK_" + IntegerToString(InpMagicNumber), 0);
   Print("?? SMC Universal + FVG_Kill PRO | 1 pos/symbole | StratÃĐgie visible");
   Print("   CatÃĐgorie: ", EnumToString(SMC_GetSymbolCategory(_Symbol)));
   Print("   IA: ", UseAIServer ? AI_ServerURL : "DÃĐsactivÃĐ");

   // Diagnostiquer la connectivitÃĐ Supabase au dÃĐmarrage
   if(UseAIServer)
   {
      TestSupabaseConnectivity();
   }

   // DÃĐmarrer/relancer l'apprentissage continu cÃītÃĐ backend (si activÃĐ)
   if(ShowMLMetrics && AutoStartMLContinuousTraining)
   {
      EnsureMLContinuousTrainingRunning(true);
      UpdateMLMetricsDisplay();      // Remplir g_mlMetricsStr rapidement
      DrawMLMetricsOnChart();        // Affichage immÃĐdiat sur le graphique
   }

   // Timer: analyse/rafraÃŪchissement pÃĐriodique du graphique attachÃĐ.
   // Important: cette passe est "observation" (pas de trading), utile quand il n'y a pas de ticks.
   if(EnableMinuteChartAnalysis)
   {
      int sec = (int)MathMax(5, MinuteChartAnalysisIntervalSec); // RÃĐduit Ã  5s pour le scanner 360
      EventSetTimer(sec);
   }

   // Initialiser le scanner 360Â°
   Init360Scanner();

   return INIT_SUCCEEDED;
}

bool TryAcquireOpenLock()
{
   string lockName = "SMC_OPEN_LOCK_" + IntegerToString(InpMagicNumber);
   
   // VÃĐrification simple sans Sleep pour ÃĐviter dÃĐtachement
   if(GlobalVariableGet(lockName) != 0) return false;
   GlobalVariableSet(lockName, 1);
   if(IsMaxPositionsReached()) { GlobalVariableSet(lockName, 0); return false; }
   return true;
}
void ReleaseOpenLock() { GlobalVariableSet("SMC_OPEN_LOCK_" + IntegerToString(InpMagicNumber), 0); }

void OnDeinit(const int reason)
{
   // Diagnostic du dÃĐtachement - identifier la cause exacte
   string reasonStr = "";
   switch(reason)
   {
      case REASON_PROGRAM:     reasonStr = "EA supprimÃĐ manuellement"; break;
      case REASON_REMOVE:      reasonStr = "EA retirÃĐ du graphique"; break;
      case REASON_RECOMPILE:   reasonStr = "EA recompilÃĐ"; break;
      case REASON_CHARTCHANGE: reasonStr = "Symbole/pÃĐriode changÃĐ"; break;
      case REASON_CHARTCLOSE:  reasonStr = "Graphique fermÃĐ"; break;
      case REASON_PARAMETERS:  reasonStr = "ParamÃĻtres modifiÃĐs"; break;
      case REASON_ACCOUNT:     reasonStr = "Compte changÃĐ"; break;
      case REASON_TEMPLATE:    reasonStr = "Template appliquÃĐ"; break;
      case REASON_INITFAILED:  reasonStr = "OnInit a ÃĐchouÃĐ (CRASH)"; break;
      case REASON_CLOSE:       reasonStr = "Terminal fermÃĐ"; break;
      default:                 reasonStr = "Autre (code " + IntegerToString(reason) + ")"; break;
   }
   Print("?? DÃTACHEMENT ROBOT SMC | ", _Symbol, " | Raison: ", reasonStr);
   if(reason == REASON_INITFAILED)
      Print("?? CAUSE: Erreur dans OnInit ou crash (indicateurs, mÃĐmoire, etc.)");

   if(atrHandle != INVALID_HANDLE) { IndicatorRelease(atrHandle); atrHandle = INVALID_HANDLE; }
   if(emaHandle != INVALID_HANDLE) { IndicatorRelease(emaHandle); emaHandle = INVALID_HANDLE; }
   if(hEmaFast != INVALID_HANDLE) { IndicatorRelease(hEmaFast); hEmaFast = INVALID_HANDLE; }
   if(hEmaSlow != INVALID_HANDLE) { IndicatorRelease(hEmaSlow); hEmaSlow = INVALID_HANDLE; }
   if(ema50H != INVALID_HANDLE) { IndicatorRelease(ema50H); ema50H = INVALID_HANDLE; }
   if(ema200H != INVALID_HANDLE) { IndicatorRelease(ema200H); ema200H = INVALID_HANDLE; }
   if(fractalH != INVALID_HANDLE) { IndicatorRelease(fractalH); fractalH = INVALID_HANDLE; }
   if(emaM1H != INVALID_HANDLE) { IndicatorRelease(emaM1H); emaM1H = INVALID_HANDLE; }
   if(emaM5H != INVALID_HANDLE) { IndicatorRelease(emaM5H); emaM5H = INVALID_HANDLE; }
   if(emaH1H != INVALID_HANDLE) { IndicatorRelease(emaH1H); emaH1H = INVALID_HANDLE; }
   if(ema1M1 != INVALID_HANDLE) { IndicatorRelease(ema1M1); ema1M1 = INVALID_HANDLE; }
   if(ema5M1 != INVALID_HANDLE) { IndicatorRelease(ema5M1); ema5M1 = INVALID_HANDLE; }
   if(emaFastM1 != INVALID_HANDLE) { IndicatorRelease(emaFastM1); emaFastM1 = INVALID_HANDLE; }
   if(emaSlowM1 != INVALID_HANDLE) { IndicatorRelease(emaSlowM1); emaSlowM1 = INVALID_HANDLE; }
   if(emaFastM5 != INVALID_HANDLE) { IndicatorRelease(emaFastM5); emaFastM5 = INVALID_HANDLE; }
   if(emaSlowM5 != INVALID_HANDLE) { IndicatorRelease(emaSlowM5); emaSlowM5 = INVALID_HANDLE; }
   if(emaFastH1 != INVALID_HANDLE) { IndicatorRelease(emaFastH1); emaFastH1 = INVALID_HANDLE; }
   if(emaSlowH1 != INVALID_HANDLE) { IndicatorRelease(emaSlowH1); emaSlowH1 = INVALID_HANDLE; }
   if(atrM1 != INVALID_HANDLE) { IndicatorRelease(atrM1); atrM1 = INVALID_HANDLE; }
   if(rsi14M1 != INVALID_HANDLE) { IndicatorRelease(rsi14M1); rsi14M1 = INVALID_HANDLE; }
   if(atrM5 != INVALID_HANDLE) { IndicatorRelease(atrM5); atrM5 = INVALID_HANDLE; }
   if(atrH1 != INVALID_HANDLE) { IndicatorRelease(atrH1); atrH1 = INVALID_HANDLE; }
   if(ema21LTF != INVALID_HANDLE) { IndicatorRelease(ema21LTF); ema21LTF = INVALID_HANDLE; }
   if(ema31LTF != INVALID_HANDLE) { IndicatorRelease(ema31LTF); ema31LTF = INVALID_HANDLE; }
   if(ema50LTF != INVALID_HANDLE) { IndicatorRelease(ema50LTF); ema50LTF = INVALID_HANDLE; }
   if(ema100LTF != INVALID_HANDLE) { IndicatorRelease(ema100LTF); ema100LTF = INVALID_HANDLE; }
   if(ema200LTF != INVALID_HANDLE) { IndicatorRelease(ema200LTF); ema200LTF = INVALID_HANDLE; }

   // Nettoyer les objets graphiques du robot
   CleanupSMCChartObjects();

   // ArrÃŠt timer (si activÃĐ)
   if(EnableMinuteChartAnalysis)
      EventKillTimer();
}

// Passe d'analyse pÃĐriodique du graphique attachÃĐ.
// Objectif: garder les analyses/affichages Ã  jour mÃŠme sans ticks.
void RunMinuteChartAnalysis()
{
   if(!EnableMinuteChartAnalysis) return;
   if(UltraLightMode) return; // mode ultra lÃĐger = pas d'IA ni graphiques (intentionnel)

   datetime now = TimeCurrent();
   int intervalSec = (int)MathMax(30, MinuteChartAnalysisIntervalSec);
   if(g_lastMinuteChartAnalysisUtc > 0 && (now - g_lastMinuteChartAnalysisUtc) < intervalSec)
      return;
   g_lastMinuteChartAnalysisUtc = now;

   // Analyse "observation" uniquement: aucune action de trading ici.
   if(UseAIServer)
   {
      // RafraÃŪchir la "direction rÃĐelle" via consensus MTF (utile pour dashboard/filtrage).
      ApplyMTFConsensusToAIDecision(true);

      // Forcer un snapshot technique M1->serveur si demandÃĐ (indÃĐpendant du throttle interne).
      if(MinuteChartAnalysisForceTechSync)
         PushChartTechStateToAIServer(true);
   }
   UpdateChartPatternContext(ShowChartGraphics);

   // RafraÃŪchir mÃĐtriques ML affichÃĐes si activÃĐes.
   if(ShowMLMetrics && (TimeCurrent() - g_lastMLMetricsUpdate) >= 30)
      UpdateMLMetricsDisplay();

   // Mise Ã  jour des visuels/dashboards.
   DisplayDailyStatisticsOnChart();
   UpdateDashboard();

   if(ShowChartGraphics)
   {
      DrawAllIndicatorGraphics();
      DrawSMC_OTEStrategy();
      UpdateM5EntryLevelsAndLines();
   }
}

void OnTimer()
{
   RunMinuteChartAnalysis();
   Run360AnalysisScanner(); // Analyse 360Â° multi-symbols
}

bool IsBullishHTF()
{
   if(ema50H == INVALID_HANDLE || ema200H == INVALID_HANDLE) return false;
   double f[], s[];
   ArraySetAsSeries(f, true); ArraySetAsSeries(s, true);
   if(CopyBuffer(ema50H, 0, 0, 1, f) < 1 || CopyBuffer(ema200H, 0, 0, 1, s) < 1) return false;
   return f[0] > s[0];
}
bool IsBearishHTF()
{
   if(ema50H == INVALID_HANDLE || ema200H == INVALID_HANDLE) return false;
   double f[], s[];
   ArraySetAsSeries(f, true); ArraySetAsSeries(s, true);
   if(CopyBuffer(ema50H, 0, 0, 1, f) < 1 || CopyBuffer(ema200H, 0, 0, 1, s) < 1) return false;
   return f[0] < s[0];
}
bool FVGKill_LiquiditySweepDetected()
{
   double prevHigh = iHigh(_Symbol, LTF, 2);
   double prevLow  = iLow(_Symbol, LTF, 2);
   double h1 = iHigh(_Symbol, LTF, 1);
   double l1 = iLow(_Symbol, LTF, 1);
   return (h1 > prevHigh || l1 < prevLow);
}
bool FVGKill_SweepConfirmed(int minBarsAgo = 2)
{
   string lsType;
   int barsAgo = 0;
   if(!SMC_DetectLiquiditySweepEx(_Symbol, LTF, lsType, barsAgo)) return false;
   return (barsAgo >= minBarsAgo);
}

bool IsInDiscountZone()
{
   double high[], low[], close[];
   ArraySetAsSeries(high, true); ArraySetAsSeries(low, true); ArraySetAsSeries(close, true);
   if(CopyHigh(_Symbol, PERIOD_H1, 0, 100, high) < 100 || CopyLow(_Symbol, PERIOD_H1, 0, 100, low) < 100 || CopyClose(_Symbol, PERIOD_H1, 0, 100, close) < 100) return false;
   int n = ArraySize(close);
   if(n < 25) return false;
   double sma20[];
   ArrayResize(sma20, n);
   ArraySetAsSeries(sma20, true);
   for(int i = 0; i < n - 20; i++) { double s = 0; for(int j = 0; j < 20; j++) s += close[i + j]; sma20[i] = s / 20; }
   for(int i = n - 20; i < n; i++) sma20[i] = sma20[MathMax(0, n - 21)];
   double eq = sma20[0];
   double discLow = low[ArrayMinimum(low, 0, 20)];
   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   return (bid >= discLow && bid <= eq && discLow < eq);
}
bool IsInPremiumZone()
{
   double high[], low[], close[];
   ArraySetAsSeries(high, true); ArraySetAsSeries(low, true); ArraySetAsSeries(close, true);
   if(CopyHigh(_Symbol, PERIOD_H1, 0, 100, high) < 100 || CopyLow(_Symbol, PERIOD_H1, 0, 100, low) < 100 || CopyClose(_Symbol, PERIOD_H1, 0, 100, close) < 100) return false;
   int n = ArraySize(close);
   if(n < 25) return false;
   double sma20[];
   ArrayResize(sma20, n);
   ArraySetAsSeries(sma20, true);
   for(int i = 0; i < n - 20; i++) { double s = 0; for(int j = 0; j < 20; j++) s += close[i + j]; sma20[i] = s / 20; }
   for(int i = n - 20; i < n; i++) sma20[i] = sma20[MathMax(0, n - 21)];
   double eq = sma20[0];
   double premHigh = high[ArrayMaximum(high, 0, 20)];
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   return (ask >= eq && ask <= premHigh && premHigh > eq);
}

// Exception HOLD dÃĐdiÃĐe STAIR:
// - Boom/GainX (BUY)  : autorisÃĐ uniquement en zone Discount
// - Crash/PainX (SELL): autorisÃĐ uniquement en zone Premium
// - DÃĻs entrÃĐe en bande d'ÃĐquilibre ICT, on stoppe les nouvelles exÃĐcutions STAIR tant que IA=HOLD
bool IsStairHoldExceptionZoneActive(const string symbol, const string direction)
{
   if(symbol != _Symbol)
      return false;

   string dir = direction;
   StringToUpper(dir);

   bool buySide = (IsBoomSymbol(symbol) || IsWeltradeGainSynthSymbol(symbol));
   bool sellSide = (IsCrashSymbol(symbol) || IsWeltradePainSynthSymbol(symbol));
   if((buySide && dir != "BUY") || (sellSide && dir != "SELL") || (!buySide && !sellSide))
      return false;

   if(IsInEquilibriumCorrectionZone())
      return false;

   if(buySide)
      return IsInDiscountZone();

   return IsInPremiumZone();
}

// Protection capital: vrai si en zone Discount et prix a touchÃĐ le bord infÃĐrieur (zone d'achat)
// UtilisÃĐ pour exiger confiance IA >= 85% avant d'exÃĐcuter un SELL dans ce cas.
bool IsAtDiscountLowerEdge()
{
   double high[], low[], close[];
   ArraySetAsSeries(high, true); ArraySetAsSeries(low, true); ArraySetAsSeries(close, true);
   if(CopyHigh(_Symbol, PERIOD_H1, 0, 100, high) < 100 || CopyLow(_Symbol, PERIOD_H1, 0, 100, low) < 100 || CopyClose(_Symbol, PERIOD_H1, 0, 100, close) < 100) return false;
   int n = ArraySize(close);
   if(n < 25) return false;
   double sma20[];
   ArrayResize(sma20, n);
   ArraySetAsSeries(sma20, true);
   for(int i = 0; i < n - 20; i++) { double s = 0; for(int j = 0; j < 20; j++) s += close[i + j]; sma20[i] = s / 20; }
   for(int i = n - 20; i < n; i++) sma20[i] = sma20[MathMax(0, n - 21)];
   double eq = sma20[0];
   double discLow = low[ArrayMinimum(low, 0, 20)];
   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   if(discLow >= eq) return false;
   if(bid < discLow || bid > eq) return false; // pas en zone discount
   double zoneHeight = eq - discLow;
   double edgeThreshold = discLow + zoneHeight * 0.15; // bord infÃĐrieur = 15% du bas de la zone
   return (bid <= edgeThreshold);
}

// Protection capital: vrai si en zone Premium et prix au bord supÃĐrieur (zone de vente)
// UtilisÃĐ pour exiger confiance IA >= 85% avant d'exÃĐcuter un BUY sur Boom dans ce cas.
bool IsAtPremiumUpperEdge()
{
   double high[], low[], close[];
   ArraySetAsSeries(high, true); ArraySetAsSeries(low, true); ArraySetAsSeries(close, true);
   if(CopyHigh(_Symbol, PERIOD_H1, 0, 100, high) < 100 || CopyLow(_Symbol, PERIOD_H1, 0, 100, low) < 100 || CopyClose(_Symbol, PERIOD_H1, 0, 100, close) < 100) return false;
   int n = ArraySize(close);
   if(n < 25) return false;
   double sma20[];
   ArrayResize(sma20, n);
   ArraySetAsSeries(sma20, true);
   for(int i = 0; i < n - 20; i++) { double s = 0; for(int j = 0; j < 20; j++) s += close[i + j]; sma20[i] = s / 20; }
   for(int i = n - 20; i < n; i++) sma20[i] = sma20[MathMax(0, n - 21)];
   double eq = sma20[0];
   double premHigh = high[ArrayMaximum(high, 0, 20)];
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   if(premHigh <= eq) return false;
   if(ask < eq || ask > premHigh) return false; // pas en zone premium
   double zoneHeight = premHigh - eq;
   double edgeThreshold = premHigh - zoneHeight * 0.15; // bord supÃĐrieur = 15% du haut de la zone
   return (ask >= edgeThreshold);
}

// Scalping agressif sur canal haussier Boom - achÃĻte Ã  chaque touch de la trend line infÃĐrieure
void CheckBoomChannelScalping()
{
   if(!IsBoomSymbol(_Symbol)) return;
   
   // VÃĐrifier si on est dans un canal haussier clair
   string upperName = "SMC_CH_H1_UPPER";
   string lowerName = "SMC_CH_H1_LOWER";
   
   if(ObjectFind(0, upperName) < 0 || ObjectFind(0, lowerName) < 0) 
   {
      Print("ðŦ Canal Boom non dÃĐtectÃĐ");
      return;
   }
   
   double upperPrice = ObjectGetDouble(0, upperName, OBJPROP_PRICE);
   double lowerPrice = ObjectGetDouble(0, lowerName, OBJPROP_PRICE);
   
   if(upperPrice <= 0 || lowerPrice <= 0) return;
   
   // VÃĐrifier si le canal est haussier (trend line supÃĐrieure > trend line infÃĐrieure)
   if(upperPrice <= lowerPrice)
   {
      Print("ðŦ Canal non haussier - upper: ", DoubleToString(upperPrice, _Digits), " <= lower: ", DoubleToString(lowerPrice, _Digits));
      return;
   }
   
   double currentBid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double atrVal = GetCurrentATRValue();
   double tolerance = atrVal * 0.3; // TolÃĐrance plus serrÃĐe pour scalping
   
   bool touchesLower = (currentBid >= lowerPrice - tolerance && currentBid <= lowerPrice + tolerance);
   
   if(touchesLower)
   {
      Print("ðŊ SCALPING CANAL BOOM - Touch trend line infÃĐrieure!");
      Print("   Prix Bid: ", DoubleToString(currentBid, _Digits));
      Print("   Trend Line Inf: ", DoubleToString(lowerPrice, _Digits));
      Print("   Trend Line Sup: ", DoubleToString(upperPrice, _Digits));
      Print("   Largeur Canal: ", DoubleToString((upperPrice - lowerPrice) / atrVal, 1), " ATR");
      
      // VÃĐrifier si on a dÃĐjÃ  une position BUY Boom
      if(CountPositionsForSymbol(_Symbol) > 0)
      {
         Print("   â ïļ Position dÃĐjÃ  existante - skip");
         return;
      }
      
      // Filtre tendance EMA + OB + Fibo
      if(!IsTrendAlignedEntry("BUY"))
      {
         Print("ðŦ SCALPING CANAL BOOM bloquÃĐ - TREND FILTER sur ", _Symbol);
         return;
      }
      
      // ExÃĐcuter l'achat immÃĐdiat pour scalping
      bool success = ExecuteBoomChannelScalpingOrder(lowerPrice, upperPrice, atrVal);
      if(success)
      {
         Print("â SCALPING CANAL BOOM - Ordre BUY exÃĐcutÃĐ!");
      }
      else
      {
         Print("â SCALPING CANAL BOOM - Ãchec exÃĐcution");
      }
   }
}

// ExÃĐcute un ordre de scalping sur canal Boom
bool ExecuteBoomChannelScalpingOrder(double entryPrice, double channelUpper, double atrVal)
{
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   
   // SL juste en dessous de la trend line infÃĐrieure
   double stopLoss = entryPrice - (2 * atrVal);
   
   // TP Ã  la trend line supÃĐrieure pour scalping
   double takeProfit = channelUpper - (1 * atrVal); // LÃĐgÃĻrement avant la sup pour assurer le fill
   
   // Calculer le lot size
   double lotSize = CalculateLotSize();
   if(lotSize <= 0)
   {
      Print("â Lot size invalide pour scalping canal");
      return false;
   }
   
   Print("ð EXÃCUTION SCALPING CANAL BOOM:");
   Print("   Entry: ", DoubleToString(ask, _Digits));
   Print("   SL: ", DoubleToString(stopLoss, _Digits), " (", DoubleToString((ask - stopLoss) / point, 0), " points)");
   Print("   TP: ", DoubleToString(takeProfit, _Digits), " (", DoubleToString((takeProfit - ask) / point, 0), " points)");
   Print("   Lot: ", DoubleToString(lotSize, 2));
   
   MqlTradeRequest request = {};
   MqlTradeResult result = {};
   
   request.action = TRADE_ACTION_DEAL;
   request.symbol = _Symbol;
   request.volume = lotSize;
   request.type = ORDER_TYPE_BUY;
   request.price = ask;
   request.sl = stopLoss;
   request.tp = takeProfit;
   request.deviation = 20;
   request.magic = InpMagicNumber;
   request.comment = "SCALPING_CANAL_BOOM";
   
   bool success = OrderSend(request, result);
   if(success && result.retcode == TRADE_RETCODE_DONE)
   {
      Print("â SCALPING CANAL BOOM RÃUSSI - Ticket: ", result.order);
      return true;
   }
   else
   {
      Print("â SCALPING CANAL BOOM ÃCHOUÃ - Code: ", result.retcode, " | ", result.comment);
      return false;
   }
}

bool PriceTouchesLowerChannel()
{
   string lowerName = "SMC_CH_H1_LOWER";
   if(ObjectFind(0, lowerName) < 0) return false;
   double lowerPrice = ObjectGetDouble(0, lowerName, OBJPROP_PRICE);
   if(lowerPrice <= 0) return false;
   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double atrVal = 0;
   if(atrHandle != INVALID_HANDLE)
   {
      double atr[];
      ArraySetAsSeries(atr, true);
      if(CopyBuffer(atrHandle, 0, 0, 1, atr) >= 1) atrVal = atr[0];
   }
   if(atrVal <= 0) atrVal = SymbolInfoDouble(_Symbol, SYMBOL_BID) * 0.002;
   double tolerance = atrVal * 0.4;
   return (bid >= lowerPrice - tolerance && bid <= lowerPrice + tolerance);
}

bool PriceTouchesUpperChannel()
{
   string upperName = "SMC_CH_H1_UPPER";
   if(ObjectFind(0, upperName) < 0) return false;
   double upperPrice = ObjectGetDouble(0, upperName, OBJPROP_PRICE);
   if(upperPrice <= 0) return false;
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   double atrVal = 0;
   if(atrHandle != INVALID_HANDLE)
   {
      double atr[];
      ArraySetAsSeries(atr, true);
      if(CopyBuffer(atrHandle, 0, 0, 1, atr) >= 1) atrVal = atr[0];
   }
   if(atrVal <= 0) atrVal = SymbolInfoDouble(_Symbol, SYMBOL_BID) * 0.002;
   double tolerance = atrVal * 0.4;
   return (ask >= upperPrice - tolerance && ask <= upperPrice + tolerance);
}

void ExecuteFVGKillBuy()
{
   // VÃĐrifier si l'ATR handle est valide
   if(atrHandle == INVALID_HANDLE) return;
   // STRATÃGIE UNIQUE SPIKE POUR BOOM/CRASH: ne pas utiliser FVG_Kill sur ces indices
   if(SMC_GetSymbolCategory(_Symbol) == SYM_BOOM_CRASH) return;
   
   double atr[];
   ArraySetAsSeries(atr, true);
   if(CopyBuffer(atrHandle, 0, 0, 1, atr) < 1) return;
   MqlRates r[];
   ArraySetAsSeries(r, true);
   if(CopyRates(_Symbol, LTF, 0, 3, r) < 3) return;
   double sl = r[1].low - atr[0] * ATR_Mult;
   double tp = SymbolInfoDouble(_Symbol, SYMBOL_ASK) + (SymbolInfoDouble(_Symbol, SYMBOL_ASK) - sl) * 2.0;
   if(IsMaxPositionsReached()) return;
   if(!IsDirectionAllowedForBoomCrash(_Symbol, "BUY")) return;
   if(!TryAcquireOpenLock()) return;
   
   // RÃĻgle duplication / IA avant ouverture d'une nouvelle position
   if(!CanOpenAdditionalPositionForSymbol(_Symbol, "BUY"))
   {
      Print("? FVG_Kill BUY bloquÃĐ (rÃĻgle duplication / IA) sur ", _Symbol);
      ReleaseOpenLock();
      return;
   }
   double lot = CalculateLotSize();
   if(lot <= 0) { ReleaseOpenLock(); return; }
   
   // Exiger une dÃĐcision IA forte pour tous les marchÃĐs non Boom/Crash
   if(!IsAITradeAllowedForDirection("BUY") || !IsMLModelTrustedForCurrentSymbol("BUY"))
   {
      ReleaseOpenLock();
      return;
   }

   // RÃĐentrÃĐe aprÃĻs perte sur ce symbole: exiger conditions exceptionnelles (context FVG = setup fort)
   if(!AllowReentryAfterRecentLoss(_Symbol, "BUY", false))
   {
      ReleaseOpenLock();
      return;
   }
   
   // RÃĐinitialiser le gain maximum pour la nouvelle position
   g_maxProfit = 0;
   
   if(!HasRecentSMCDerivArrowForDirection("BUY"))
   {
      Print("?? FVG_Kill BUY bloquÃĐ - Attendre flÃĻche SMC_DERIV_ARROW BUY sur ", _Symbol);
      ReleaseOpenLock();
      return;
   }
   if(!IsTrendAlignedEntry("BUY"))
   {
      Print("ðŦ FVG_Kill BUY bloquÃĐ - TREND FILTER sur ", _Symbol);
      ReleaseOpenLock();
      return;
   }
   trade.Buy(lot, _Symbol, 0, sl, tp, "FVG_Kill BUY");
   ReleaseOpenLock();
   if(trade.ResultRetcode() == TRADE_RETCODE_DONE)
      NotifyTradeEvent("â POSITION OUVERTE - FVG_Kill BUY " + _Symbol, EntryTradeSoundFile);
}
void ExecuteFVGKillSell()
{
   // VÃĐrifier si l'ATR handle est valide
   if(atrHandle == INVALID_HANDLE) return;
   // STRATÃGIE UNIQUE SPIKE POUR BOOM/CRASH: ne pas utiliser FVG_Kill sur ces indices
   if(SMC_GetSymbolCategory(_Symbol) == SYM_BOOM_CRASH) return;
   
   double atr[];
   ArraySetAsSeries(atr, true);
   if(CopyBuffer(atrHandle, 0, 0, 1, atr) < 1) return;
   MqlRates r[];
   ArraySetAsSeries(r, true);
   if(CopyRates(_Symbol, LTF, 0, 3, r) < 3) return;
   double sl = r[1].high + atr[0] * ATR_Mult;
   double tp = SymbolInfoDouble(_Symbol, SYMBOL_BID) - (sl - SymbolInfoDouble(_Symbol, SYMBOL_BID)) * 2.0;
   if(IsMaxPositionsReached()) return;
   if(!IsDirectionAllowedForBoomCrash(_Symbol, "SELL")) return;
   if(!TryAcquireOpenLock()) return;
   
   if(!CanOpenAdditionalPositionForSymbol(_Symbol, "SELL"))
   {
      Print("? FVG_Kill SELL bloquÃĐ (rÃĻgle duplication / IA) sur ", _Symbol);
      ReleaseOpenLock();
      return;
   }
   double lot = CalculateLotSize();
   if(lot <= 0) { ReleaseOpenLock(); return; }
   
   // Exiger une dÃĐcision IA forte pour tous les marchÃĐs non Boom/Crash
   if(!IsAITradeAllowedForDirection("SELL") || !IsMLModelTrustedForCurrentSymbol("SELL"))
   {
      ReleaseOpenLock();
      return;
   }

   // RÃĐentrÃĐe aprÃĻs perte sur ce symbole: exiger conditions exceptionnelles (context FVG = setup fort)
   if(!AllowReentryAfterRecentLoss(_Symbol, "SELL", false))
   {
      ReleaseOpenLock();
      return;
   }
   
   // RÃĐinitialiser le gain maximum pour la nouvelle position
   g_maxProfit = 0;
   
   if(!HasRecentSMCDerivArrowForDirection("SELL"))
   {
      Print("?? FVG_Kill SELL bloquÃĐ - Attendre flÃĻche SMC_DERIV_ARROW SELL sur ", _Symbol);
      ReleaseOpenLock();
      return;
   }
   if(!IsTrendAlignedEntry("SELL"))
   {
      Print("ðŦ FVG_Kill SELL bloquÃĐ - TREND FILTER sur ", _Symbol);
      ReleaseOpenLock();
      return;
   }
   trade.Sell(lot, _Symbol, 0, sl, tp, "FVG_Kill SELL");
   ReleaseOpenLock();
   if(trade.ResultRetcode() == TRADE_RETCODE_DONE)
      NotifyTradeEvent("â POSITION OUVERTE - FVG_Kill SELL " + _Symbol, EntryTradeSoundFile);
}

int CountPositionsForSymbol(string symbol)
{
   int n = 0;
   for(int i = PositionsTotal() - 1; i >= 0; i--)
      if(posInfo.SelectByIndex(i) && posInfo.Magic() == InpMagicNumber && posInfo.Symbol() == symbol)
         n++;
   return n;
}

int CountOrdersForSymbol(string symbol)
{
   int n = 0;
   for(int i = OrdersTotal() - 1; i >= 0; i--)
      if(orderInfo.SelectByIndex(i) && orderInfo.Magic() == InpMagicNumber && orderInfo.Symbol() == symbol)
         n++;
   return n;
}

// Retourne true si une position "SPIKE TRADE" est dÃĐjÃ  ouverte sur ce symbole
bool HasOpenSpikeTradeForSymbol(string symbol)
{
   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      if(!posInfo.SelectByIndex(i)) 
         continue;
      if(posInfo.Magic() != InpMagicNumber) 
         continue;
      if(posInfo.Symbol() != symbol) 
         continue;
      
      string comment = posInfo.Comment();
      if(StringFind(comment, "SPIKE TRADE") >= 0)
         return true;
   }
   return false;
}

int CountPositionsOurEA()
{
   int n = 0;
   for(int i = PositionsTotal() - 1; i >= 0; i--)
      if(posInfo.SelectByIndex(i) && posInfo.Magic() == InpMagicNumber)
         n++;
   return n;
}

void CloseWorstPositionIfTotalLossExceeded()
{
   double totalProfit = 0;
   double worstProfit = 0;
   ulong worstTicket = 0;
   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      if(!posInfo.SelectByIndex(i)) continue;
      if(posInfo.Magic() != InpMagicNumber) continue;
      double p = posInfo.Profit() + posInfo.Swap() + posInfo.Commission();
      totalProfit += p;
      if(worstTicket == 0 || p < worstProfit)
      {
         worstProfit = p;
         worstTicket = posInfo.Ticket();
      }
   }
   if(totalProfit > -MaxTotalLossDollars) return;
   if(worstTicket != 0 && PositionCloseWithLog(worstTicket, "Perte totale max atteinte"))
      Print("?? Perte totale (", DoubleToString(totalProfit, 2), "$) >= ", DoubleToString(MaxTotalLossDollars, 0), "$ ? position la plus perdante fermÃĐe (", DoubleToString(worstProfit, 2), "$)");
}

void CloseAllPositionsIfTotalProfitReached()
{
   double totalProfit = 0;
   ulong allTickets[];
   ArrayResize(allTickets, 0);
   
   // Calculer le profit total pour tous les symboles
   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      if(!posInfo.SelectByIndex(i)) continue;
      if(posInfo.Magic() != InpMagicNumber) continue;
      double p = posInfo.Profit() + posInfo.Swap() + posInfo.Commission();
      totalProfit += p;
      ArrayResize(allTickets, ArraySize(allTickets) + 1);
      allTickets[ArraySize(allTickets) - 1] = posInfo.Ticket();
   }
   
   // Fermer toutes les positions si le profit total atteint 3$
   if(totalProfit >= 3.0)
   {
      Print("?? PROFIT TOTAL ATTEINT (", DoubleToString(totalProfit, 2), "$ >= 3.00$) ? Fermeture de toutes les positions...");
      
      for(int i = 0; i < ArraySize(allTickets); i++)
      {
         ulong ticket = allTickets[i];
         // VALIDATION: VÃĐrifier que la position existe toujours avant de fermer
         if(!PositionSelectByTicket(ticket))
         {
            Print("?? Position dÃĐjÃ  fermÃĐe avant profit total close - ticket=", ticket);
            continue;
         }
         
         double profit = PositionGetDouble(POSITION_PROFIT) + PositionGetDouble(POSITION_SWAP);
         string symbol = PositionGetString(POSITION_SYMBOL);
         
         if(PositionCloseWithLog(ticket, "Profit total atteint"))
         {
            Print("? Position fermÃĐe - ", symbol, ": ", DoubleToString(profit, 2), "$");
         }
         else
         {
            Print("? Ãchec fermeture - ", symbol, ": ", DoubleToString(profit, 2), "$");
         }
      }
      
      Print("?? FERMETURE COMPLÃTE - Profit total rÃĐalisÃĐ: ", DoubleToString(totalProfit, 2), "$");
   }
}

//+------------------------------------------------------------------+
//| Fermeture profit-only par symbole (POSITION_PROFIT seulement)   |
//| Ferme toutes les positions du symbole dÃĻs que la somme de      |
//| POSITION_PROFIT (sans swap/commission) >= targetProfitUSD      |
//+------------------------------------------------------------------+
void CloseAllPositionsIfSymbolProfitReached(double targetProfitUSD)
{
   if(targetProfitUSD <= 0.0) return;

   // 1) Collecte des symboles prÃĐsents sur nos positions EA
   string symbols[];
   ArrayResize(symbols, 0);
   
   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      if(!posInfo.SelectByIndex(i)) continue;
      if(posInfo.Magic() != InpMagicNumber) continue;
      string sym = posInfo.Symbol();
      if(sym == "") continue;

      bool exists = false;
      for(int k = 0; k < ArraySize(symbols); k++)
      {
         if(symbols[k] == sym)
         {
            exists = true;
            break;
         }
      }
      if(!exists)
      {
         ArrayResize(symbols, ArraySize(symbols) + 1);
         symbols[ArraySize(symbols) - 1] = sym;
      }
   }

   if(ArraySize(symbols) <= 0) return;

   // 2) Pour chaque symbole: somme POSITION_PROFIT puis fermeture
   string reason = "Symbol profit-only >= " + DoubleToString(targetProfitUSD, 2) + "$";
   for(int s = 0; s < ArraySize(symbols); s++)
   {
      string sym = symbols[s];
      if(sym == "") continue;

      double symbolProfit = 0.0; // POSITION_PROFIT uniquement
      ulong tickets[];
      ArrayResize(tickets, 0);

      for(int i = PositionsTotal() - 1; i >= 0; i--)
      {
         if(!posInfo.SelectByIndex(i)) continue;
         if(posInfo.Magic() != InpMagicNumber) continue;
         if(posInfo.Symbol() != sym) continue;

         symbolProfit += posInfo.Profit();

         ArrayResize(tickets, ArraySize(tickets) + 1);
         tickets[ArraySize(tickets) - 1] = posInfo.Ticket();
      }

      if(symbolProfit < targetProfitUSD) continue;

      Print("ðŊ PROFIT PAR SYMBOLE (profit-only) ATTEINT - ", sym,
            " | Profit: ", DoubleToString(symbolProfit, 2), "$ >= ",
            DoubleToString(targetProfitUSD, 2), "$ - Fermeture immÃĐdiate.");

      for(int t = 0; t < ArraySize(tickets); t++)
      {
         ulong ticket = tickets[t];
         if(ticket == 0) continue;
         PositionCloseWithLog(ticket, reason);
      }
   }
}

// Fermeture par ordre inverse (comme Spike_Close_BoomCrash) pour compatibilitÃĐ brokers
bool ClosePositionByDeal(ulong ticket)
{
   if(!PositionSelectByTicket(ticket)) return false;
   ENUM_ORDER_TYPE orderType = (PositionGetInteger(POSITION_TYPE) == POSITION_TYPE_BUY) ? ORDER_TYPE_SELL : ORDER_TYPE_BUY;
   string symbol = PositionGetString(POSITION_SYMBOL);
   double volume = PositionGetDouble(POSITION_VOLUME);
   MqlTradeRequest request;
   MqlTradeResult  result;
   ZeroMemory(request);
   request.action   = TRADE_ACTION_DEAL;
   request.position = ticket;
   request.symbol   = symbol;
   request.volume   = volume;
   request.type     = orderType;
   request.price    = (orderType == ORDER_TYPE_SELL) ? SymbolInfoDouble(symbol, SYMBOL_BID) : SymbolInfoDouble(symbol, SYMBOL_ASK);
   request.deviation = 50;
   return OrderSend(request, result);
}

bool CloseBoomCrashPosition(ulong ticket, const string symbol)
{
   if(ClosePositionByDeal(ticket))
   {
      Print("?? EA CLOSE DEAL OK - ", symbol, " | ticket=", ticket);
      return true;
   }
   if(PositionCloseWithLog(ticket, "Boom/Crash position close"))
   {
      Print("?? EA POSITION CLOSE OK - ", symbol, " | ticket=", ticket);
      return true;
   }
   int err = GetLastError();
   Print("? EA ÃCHEC FERMETURE Boom/Crash - ", symbol, " | ticket=", ticket, " | code=", err);
   return false;
}

// Trades OTE / imbalance / touch OTE â mÃŠme logique de fermeture spike que M5/DERIV (les commentaires SMC_OTE_5STAR n'ÃĐtaient pas couverts avant)
bool IsBoomCrashOteFamilyComment(const string comment)
{
   if(StringFind(comment, "SMC_OTE") >= 0) return true;
   if(StringFind(comment, "OTE_IMBALANCE") >= 0) return true;
   if(StringFind(comment, "OTE_FUTURE_") >= 0) return true;
   if(StringFind(comment, "OTE_TOUCH_MARKET") >= 0) return true;
   if(StringFind(comment, "OTE_APPEAR_MARKET") >= 0) return true;
   return false;
}

// Commentaires d'entrÃĐe Boom/Crash Ã  gÃĐrer comme capture de spike (fermeture auto identique Boom/Crash)
bool IsBoomCrashSpikeStyleCloseComment(const string comment)
{
   if(StringFind(comment, "SPIKE TRADE") >= 0) return true;
   if(StringFind(comment, "SPIKE_M5CH") >= 0) return true;
   if(StringFind(comment, "M5_TOUCH_ENTRY") >= 0) return true;
   if(StringFind(comment, "STAIR_ENTRY") >= 0) return true;
   if(StringFind(comment, "STAIR_ESC") >= 0) return true;
   if(StringFind(comment, "PRE_OTE_SPIKE_") >= 0) return true;
   if(StringFind(comment, "DERIV ARROW") >= 0) return true;
   if(StringFind(comment, "PEND_LIM_PURE_ARROW") >= 0) return true;
   if(StringFind(comment, "IA80_ARROW_AUTO") >= 0) return true;
   if(IsBoomCrashOteFamilyComment(comment)) return true;
   return false;
}

void AnnounceOTEApproach()
{
   if(!EnableOTEApproachAnnouncement || OTEApproachDistancePoints <= 0) return;

   double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   if(point <= 0.0) return;

   static datetime lastAnnounceTime[10];
   static string   lastAnnounceKey[10];

   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   datetime now = TimeCurrent();
   int cooldown = MathMax(5, OTEApproachAnnouncementCooldownSeconds);
   double threshold = point * (double)OTEApproachDistancePoints;

   for(int i = 0; i < ArraySize(g_activeOTESetups); i++)
   {
      if(!g_activeOTESetups[i].isValid) continue;

      OTESetupTracker setup = g_activeOTESetups[i];
      double px = (setup.direction == "BUY") ? ask : bid;
      double dist = MathAbs(px - setup.entryPrice);
      if(dist > threshold) continue;

      string key = _Symbol + "_" + IntegerToString(setup.setupId) + "_" + setup.direction;
      if((now - lastAnnounceTime[i]) < cooldown && key == lastAnnounceKey[i])
         continue;

      double distPts = dist / point;
      string msg = "ð OTE APPROCHE - " + setup.direction + " " + _Symbol +
                   " | dist=" + DoubleToString(distPts, 1) + " pts | OTE=" +
                   DoubleToString(setup.entryPrice, _Digits);
      Print(msg);
      NotifyRobotEventOncePerBar("OTE_APPROACH_" + _Symbol + "_" + IntegerToString(setup.setupId),
                                 msg, EntryTradeSoundFile, PERIOD_M1);

      lastAnnounceTime[i] = now;
      lastAnnounceKey[i] = key;
   }
}

void CloseBoomCrashAfterSpike(ulong ticket, string symbol, double currentProfit)
{
   if(posInfo.Magic() != InpMagicNumber) return;
   if(SMC_GetSymbolCategory(symbol) != SYM_BOOM_CRASH) return;
   
   // RÃGLE BOOM/CRASH: 2 dollars pour ces symboles (inchangÃĐ)
if(currentProfit >= 2.0)
   {
      if(CloseBoomCrashPosition(ticket, symbol))
      {
         Print("? Boom/Crash fermÃĐ: bÃĐnÃĐfice 2$ atteint (", DoubleToString(currentProfit, 2), "$) - ", symbol);
         if(symbol == _Symbol) { g_lastBoomCrashPrice = 0; }
      }
      return;
   }
   
   // Ensuite, les rÃĻgles spÃĐcifiques Boom/Crash si < 2$
   if(currentProfit >= TargetProfitBoomCrashUSD && currentProfit < 2.0)
   {
      if(CloseBoomCrashPosition(ticket, symbol))
      {
         Print("?? Boom/Crash fermÃĐ (gain >= ", DoubleToString(TargetProfitBoomCrashUSD, 2), "$): ", DoubleToString(currentProfit, 2), "$) - ", symbol);
         if(symbol == _Symbol) { g_lastBoomCrashPrice = 0; }
      }
      return;
   }
   
   // Spike detection (si < 2$) - DÃSACTIVÃ par dÃĐfaut pour ÃĐviter fermetures prÃĐmaturÃĐes
   if(g_lastBoomCrashPrice > 0 && false) // false = DÃSACTIVÃ
   {
      double price = SymbolInfoDouble(symbol, SYMBOL_BID);
      double movePct = (price - g_lastBoomCrashPrice) / g_lastBoomCrashPrice * 100.0;
      if(StringFind(symbol, "Boom") >= 0 && movePct >= BoomCrashSpikePct)
      {
         if(CloseBoomCrashPosition(ticket, symbol))
         {
            Print("?? Boom/Crash fermÃĐ (spike prix ", DoubleToString(currentProfit, 2), "$) - ", symbol);
            g_lastBoomCrashPrice = 0;
            s_lastRefUpdate = 0;
         }
      }
      if(StringFind(symbol, "Crash") >= 0 && movePct <= -BoomCrashSpikePct)
      {
         if(CloseBoomCrashPosition(ticket, symbol))
         {
            Print("?? Boom/Crash fermÃĐ (spike prix ", DoubleToString(currentProfit, 2), "$) - ", symbol);
            g_lastBoomCrashPrice = 0;
            s_lastRefUpdate = 0;
         }
      }
   }
}

// DÃĐlai min avant close ÂŦ spike ref Âŧ : IA80+flÃĻche + IA âĨ seuil sur graph courant â IA80ArrowSpikeCloseMinSecondsAfterEntry (souvent 0)
int EffectiveBoomCrashSpikeCloseMinSeconds(const string comment, const string symbol)
{
   if(!IA80ArrowImmediateSpikeClose || StringFind(comment, "IA80_ARROW_AUTO") < 0 || !UseIA80ArrowAutoEntry)
      return BoomCrashSpikeCloseMinSecondsAfterEntry;
   if(symbol != _Symbol)
      return BoomCrashSpikeCloseMinSecondsAfterEntry;
   double minC = IA80ArrowAutoMinConfidence;
   if(minC > 1.0) minC /= 100.0;
   if(NormalizeAIConfidenceUnit() + 1e-9 < minC)
      return BoomCrashSpikeCloseMinSecondsAfterEntry;
   return MathMax(0, IA80ArrowSpikeCloseMinSecondsAfterEntry);
}

// Parcourt toutes les positions et ferme Boom/Crash rapidement aprÃĻs spike
void ManageBoomCrashSpikeClose()
{
   // Si aucune fermeture automatique n'est activÃĐe, sortir immÃĐdiatement
   if(!UseSpikeAutoClose && !UseTouchProtectScalpExitOnDerivArrow && !UseAdverseSpikeCloseOnBoomCrash)
      return;
   
   if(PositionsTotal() == 0) return;

   // Throttle CPU â dÃĐsactivÃĐ tant quâune position IA80+flÃĻche existe et IA âĨ seuil (fermeture spike plus rÃĐactive)
   static datetime s_lastSpikeCloseEval = 0;
   double ia80ThrU = IA80ArrowAutoMinConfidence;
   if(ia80ThrU > 1.0) ia80ThrU /= 100.0;
   if(ia80ThrU < 0.0 || ia80ThrU > 1.0) ia80ThrU = 0.80;
   bool skipSpikeEvalThrottle = false;
   if(IA80ArrowImmediateSpikeClose && NormalizeAIConfidenceUnit() + 1e-9 >= ia80ThrU)
   {
      for(int j = PositionsTotal() - 1; j >= 0; j--)
      {
         if(!posInfo.SelectByIndex(j)) continue;
         if(posInfo.Magic() != InpMagicNumber) continue;
         if(posInfo.Symbol() != _Symbol) continue;
         if(SMC_GetSymbolCategory(posInfo.Symbol()) != SYM_BOOM_CRASH) continue;
         if(StringFind(posInfo.Comment(), "IA80_ARROW_AUTO") >= 0)
         {
            skipSpikeEvalThrottle = true;
            break;
         }
      }
   }
   if(BoomCrashSpikeCloseEvalMinSeconds > 0 && !skipSpikeEvalThrottle)
   {
      datetime nowT = TimeCurrent();
      if(s_lastSpikeCloseEval > 0 && (nowT - s_lastSpikeCloseEval) < BoomCrashSpikeCloseEvalMinSeconds)
         return;
      s_lastSpikeCloseEval = nowT;
   }
   else if(BoomCrashSpikeCloseEvalMinSeconds > 0)
      s_lastSpikeCloseEval = TimeCurrent();

   // Exception: attendre 2e spike avant de fermer si impulsion M1 trÃĻs forte
   static bool             s_waitingSecondSpikeClose = false;
   static string           s_waitingSecondSpikeSymbol = "";
   static ENUM_POSITION_TYPE s_waitingSecondSpikePosType = POSITION_TYPE_BUY;
   static datetime         s_waitingSecondSpikeStart = 0;

   bool touchExitMode = (UseTouchProtectScalpExitOnDerivArrow && RequireFutureProtectTouchForBoomCrashDerivArrow);

   // DÃĐtection flÃĻche DERIV Arrow une seule fois (pour sortie scalp)
   string arrowDirection = "";
   bool hasDerivArrow = false;
   if(touchExitMode)
      hasDerivArrow = GetDerivArrowDirection(arrowDirection);
   
   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      if(!posInfo.SelectByIndex(i)) continue;
      if(posInfo.Magic() != InpMagicNumber) continue;
      
      string symbol = posInfo.Symbol();
      ENUM_SYMBOL_CATEGORY cat = SMC_GetSymbolCategory(symbol);
      datetime openTime = posInfo.Time();
      int secondsSinceOpen = (int)(TimeCurrent() - openTime);
      string comment = posInfo.Comment();
      int minSecSpike = EffectiveBoomCrashSpikeCloseMinSeconds(comment, symbol);
      bool isWeltradeSynth = (cat == SYM_WELTRADE_SYNTH);
      if(cat != SYM_BOOM_CRASH && !isWeltradeSynth) continue;
      bool isSpikeTrade = (StringFind(comment, "SPIKE TRADE") >= 0);
      bool spikeStyleClose = IsBoomCrashSpikeStyleCloseComment(comment);

      // 1) Fermer si la flÃĻche alignÃĐe (Boom vert / Crash rouge) disparaÃŪt â quel que soit le gain (dÃĐlai + hold = mÃŠme logique que push)
      if(!isSpikeTrade && (StringFind(comment, "DERIV ARROW") >= 0 || StringFind(comment, "PEND_LIM_PURE_ARROW") >= 0) && symbol == _Symbol)
      {
         int minSecDerivGone = MathMax(8, BoomCrashSpikeCloseMinSecondsAfterEntry);
         if(secondsSinceOpen >= minSecDerivGone)
         {
            string posDir = (posInfo.PositionType() == POSITION_TYPE_BUY) ? "BUY" : "SELL";
            static ulong s_derivArrowGoneTicket = 0;
            static datetime s_derivArrowAbsentSince = 0;

            if(posInfo.Ticket() != s_derivArrowGoneTicket)
            {
               s_derivArrowGoneTicket = posInfo.Ticket();
               s_derivArrowAbsentSince = 0;
            }

            bool arrowHere = ChartHasColoredSignalArrowForBoomCrashDir(posDir);
            datetime nowG = TimeCurrent();
            if(arrowHere)
               s_derivArrowAbsentSince = 0;
            else
            {
               if(s_derivArrowAbsentSince == 0)
                  s_derivArrowAbsentSince = nowG;
               int holdG = MathMax(1, NotifyDerivArrowDisappearHoldSec);
               if((int)(nowG - s_derivArrowAbsentSince) >= holdG)
               {
                  if(PositionCloseWithLog(posInfo.Ticket(), "Spike close - DERIV flÃĻche disparue graphique"))
                  {
                     s_derivArrowAbsentSince = 0;
                     s_derivArrowGoneTicket = 0;
                  }
                  continue;
               }
            }
         }
      }

      // 2) Recovery exceptionnel (5 bougies)
      if(StringFind(comment, "EXC_RECOVERY_") >= 0)
      {
         if(CountSmallM1CandlesSince(openTime) >= 5)
         {
            PositionCloseWithLog(posInfo.Ticket(), "EXC_RECOVERY close - 5 petites bougies");
         }
         continue;
      }
      
      // Spike adverse M1 (contre le trade): calcul tÃīt pour contourner minHold sur OTE / entrÃĐes non-scalp
      bool adverseSpikeM1 = false;
      if(UseAdverseSpikeCloseOnBoomCrash &&
         secondsSinceOpen >= minSecSpike)
         adverseSpikeM1 = IsAdverseBoomCrashSpikeForPosition(symbol, (ENUM_POSITION_TYPE)posInfo.PositionType());
      
      // 3) DÃĐlai minimal pour trades classiques (pas les entrÃĐes "style spike" M5/DERIV/PRE_OTE/SPIKE TRADE)
      int minHold = MathMax(1, TouchProtectScalpMinHoldSeconds);
      if(!spikeStyleClose && secondsSinceOpen < minHold && !adverseSpikeM1)
         continue;

      // 4) Sortie scalp sur flÃĻche opposÃĐe (si activÃĐ)
      if(!isSpikeTrade && touchExitMode && hasDerivArrow)
      {
         bool isBoomPos = (StringFind(symbol, "Boom") >= 0);
         bool isCrashPos = (StringFind(symbol, "Crash") >= 0);
         bool shouldCloseOnArrow =
            (isBoomPos && arrowDirection == "BUY" && posInfo.PositionType() == POSITION_TYPE_BUY) ||
            (isCrashPos && arrowDirection == "SELL" && posInfo.PositionType() == POSITION_TYPE_SELL);

         if(shouldCloseOnArrow)
         {
            if(PositionCloseWithLog(posInfo.Ticket(), "Scalp close - TouchProtect + DERIV Arrow"))
            {
               if(symbol == _Symbol)
               {
                  if(isBoomPos)  g_boomTouchReentryCooldownUntil  = TimeCurrent() + TouchProtectScalpReentryCooldownSeconds;
                  if(isCrashPos) g_crashTouchReentryCooldownUntil = TimeCurrent() + TouchProtectScalpReentryCooldownSeconds;
               }
            }
            continue;
         }
      }
      
      double profit = posInfo.Profit() + posInfo.Swap() + posInfo.Commission();
      bool shouldClose = false;
      string closeReason = "";

      bool isBoomPos  = IsBoomSymbol(symbol);
      bool isCrashPos = IsCrashSymbol(symbol);
      bool isGainPos  = IsWeltradeGainSynthSymbol(symbol);
      bool isPainPos  = IsWeltradePainSynthSymbol(symbol);
      bool naturalDirOk =
         (isBoomPos && posInfo.PositionType() == POSITION_TYPE_BUY) ||
         (isCrashPos && posInfo.PositionType() == POSITION_TYPE_SELL) ||
         (isGainPos && posInfo.PositionType() == POSITION_TYPE_BUY) ||
         (isPainPos && posInfo.PositionType() == POSITION_TYPE_SELL);

      // TolÃĐrance: posInfo.Time() peut ÃŠtre un peu en retard/avance vs TimeCurrent() (rÃĐsolution seconde)
      bool afterLastBoomSpikeRef   = (isBoomPos && g_lastBoomSpikeTime  > 0 && openTime >= (g_lastBoomSpikeTime  - BoomCrashSpikeRefTimeToleranceSec));
      bool afterLastCrashSpikeRef = (isCrashPos && g_lastCrashSpikeTime > 0 && openTime >= (g_lastCrashSpikeTime - BoomCrashSpikeRefTimeToleranceSec));
      bool afterSpikeRef = afterLastBoomSpikeRef || afterLastCrashSpikeRef;

      bool captureCandidate = (isSpikeTrade || spikeStyleClose);
      bool spikeActiveNow = false;
      if(UseSpikeAutoClose)
      {
         spikeActiveNow = (IsPriceSpikeDetectedForSymbol(symbol) ||
                           IsBoomCrashM1SpikeRangeBars01(symbol) ||
                           IsVolumeSpikeDetectedForSymbol(symbol));
         if(!spikeActiveNow)
            spikeActiveNow = IsDirectionalBoomCrashSpikeForPosition(symbol, (ENUM_POSITION_TYPE)posInfo.PositionType());
      }

      // RÃĻgle principale: fermer dÃĻs qu'un spike est captÃĐ, mÃŠme avec un petit gain.
      if(spikeActiveNow && naturalDirOk)
      {
         shouldClose = true;
         closeReason = "Spike captÃĐ immÃĐdiat | PnL=" + DoubleToString(profit, 2) + "$";
      }

      // Protection anti-retournement: mÃĐmoriser le pic de profit par ticket
      static ulong  peakTickets[];
      static double peakProfits[];
      int peakIdx = -1;
      for(int p = 0; p < ArraySize(peakTickets); p++)
      {
         if(peakTickets[p] == posInfo.Ticket())
         {
            peakIdx = p;
            break;
         }
      }
      if(peakIdx < 0)
      {
         int newSize = ArraySize(peakTickets) + 1;
         ArrayResize(peakTickets, newSize);
         ArrayResize(peakProfits, newSize);
         peakIdx = newSize - 1;
         peakTickets[peakIdx] = posInfo.Ticket();
         peakProfits[peakIdx] = profit;
      }
      else if(profit > peakProfits[peakIdx])
      {
         peakProfits[peakIdx] = profit;
      }

      // PrioritÃĐs protections (toujours)
      if(!shouldClose && isWeltradeSynth && WeltradeSpikeOnlyExit)
      {
         // Sur PAINX/GAINX: pas de sortie active tant qu'aucun spike n'est captÃĐ,
         // sauf sÃĐcuritÃĐ minimale de perte.
         double eqNow = AccountInfoDouble(ACCOUNT_EQUITY);
         bool lowEquity = (eqNow < SpikeNoArrivalAllowSLAboveEquityUSD);
         double minLoss = lowEquity ? MathMax(0.0, SpikeNoArrivalEarlyCutLossUSD) : DBL_MAX;
         // Compat: si on veut encore un seuil plus petit via ancien input, appliquer seulement en ÃĐquitÃĐ faible
         if(lowEquity)
            minLoss = MathMax(minLoss, MathMax(1.0, WeltradeMinLossBeforeNonSpikeExitUSD));

         if(profit <= -minLoss)
         {
            shouldClose = true;
            closeReason = "Weltrade sÃĐcuritÃĐ perte atteinte (" + DoubleToString(profit, 2) + "$)";
         }
      }
      else if(!shouldClose && profit >= TargetProfitBoomCrashUSD)
      {
         shouldClose = true;
         closeReason = "Profit cible atteint (" + DoubleToString(profit, 2) + "$)";
      }
      else if(!shouldClose && profit <= -MaxLossBoomCrashPerTradeUSD)
      {
         shouldClose = true;
         closeReason = "Perte max atteinte (" + DoubleToString(profit, 2) + "$)";
      }
      else if(!shouldClose)
      {
         if(UseAdverseSpikeCloseOnBoomCrash && adverseSpikeM1)
         {
            shouldClose = true;
            closeReason = "Spike adverse M1 | PnL=" + DoubleToString(profit, 2) + "$";
         }

         if(!shouldClose && EnableSpikePeakGivebackClose && captureCandidate)
         {
            double peakProfit = peakProfits[peakIdx];
            double giveback = peakProfit - profit;
            double peakMinUsd = SpikePeakGivebackMinProfitUSD;
            if(IsBoomCrashOteFamilyComment(comment))
               peakMinUsd = MathMin(peakMinUsd, OTEBoomCrashGivebackMinPeakUSD);
            if(peakProfit >= MathMax(0.0, peakMinUsd) &&
               giveback >= MathMax(0.01, SpikePeakGivebackDeltaUSD))
            {
               shouldClose = true;
               closeReason = "Giveback spike protÃĐgÃĐ | peak=" + DoubleToString(peakProfit, 2) +
                             "$ | now=" + DoubleToString(profit, 2) + "$";
            }
         }

         if(shouldClose)
         {
            // fermeture dÃĐcidÃĐe via giveback ou spike adverse
         }
         else
         {
         // 1) Si on attend un 2e spike (exception impulsion trÃĻs forte)
         if(s_waitingSecondSpikeClose &&
            symbol == s_waitingSecondSpikeSymbol &&
            posInfo.PositionType() == s_waitingSecondSpikePosType)
         {
            bool spikeActive = false;
            if(UseSpikeAutoClose)
            {
               spikeActive = (IsPriceSpikeDetectedForSymbol(symbol) ||
                              IsBoomCrashM1SpikeRangeBars01(symbol) ||
                              IsVolumeSpikeDetectedForSymbol(symbol));
               if(!spikeActive)
                  spikeActive = IsDirectionalBoomCrashSpikeForPosition(symbol, (ENUM_POSITION_TYPE)posInfo.PositionType());
            }

            if(UseSpikeAutoClose && spikeActive)
            {
               shouldClose = true;
               closeReason = "Second spike captÃĐ (exception)";
            }
            else if( BoomCrashSecondSpikeWaitTimeoutSec > 0 &&
                     (TimeCurrent() - s_waitingSecondSpikeStart) >= BoomCrashSecondSpikeWaitTimeoutSec )
            {
               shouldClose = true;
               closeReason = "Timeout attente 2e spike - fermeture";
            }
         }
         // 2) Sinon: fermer au spike ref captÃĐ (sans dÃĐpendre de spikeActive)
         else
         {
            if(UseSpikeAutoClose && captureCandidate && afterSpikeRef &&
               secondsSinceOpen >= minSecSpike)
            {
               bool impulseStrong = false;
               if(BoomCrashWaitSecondSpikeOnExceptionalImpulse)
               {
                  // impulsion M1 trÃĻs forte si range >= ATR * SpikePriceMultiplier * coeff
                  double atr = iATR(symbol, PERIOD_M1, 20);
                  if(atr > 0.0)
                  {
                     double h0 = iHigh(symbol, PERIOD_M1, 0), l0 = iLow(symbol, PERIOD_M1, 0);
                     double h1 = iHigh(symbol, PERIOD_M1, 1), l1 = iLow(symbol, PERIOD_M1, 1);
                     if(h0 > 0 && l0 > 0 && h1 > 0 && l1 > 0)
                     {
                        double rangeMax = MathMax(h0 - l0, h1 - l1);
                        bool naturalDirOk =
                           (isBoomPos && posInfo.PositionType() == POSITION_TYPE_BUY) ||
                           (isCrashPos && posInfo.PositionType() == POSITION_TYPE_SELL);

                        double thr = atr * SpikePriceMultiplier * BoomCrashExceptionalImpulseAtrMult;
                        impulseStrong = naturalDirOk && (rangeMax >= thr);
                     }
                  }
               }

               // Scalps OTE / IA80+flÃĻche: ne pas attendre un 2e spike (fermeture au premier spike ref captÃĐ)
               const bool ia80NoSecondSpikeWait = (IA80ArrowImmediateSpikeClose && StringFind(comment, "IA80_ARROW_AUTO") >= 0);
               if(BoomCrashWaitSecondSpikeOnExceptionalImpulse && impulseStrong && !IsBoomCrashOteFamilyComment(comment) && !ia80NoSecondSpikeWait)
               {
                  s_waitingSecondSpikeClose = true;
                  s_waitingSecondSpikeSymbol = symbol;
                  s_waitingSecondSpikePosType = posInfo.PositionType();
                  s_waitingSecondSpikeStart = TimeCurrent();
                  // On garde le trade ouvert jusqu'au 2e spike (si valide)
               }
               else
               {
                  shouldClose = true;
                  closeReason = "Spike ref captÃĐ (fermeture)";
               }
            }
            // 3) Fallback: si pas de ref spike (ex: autre chemin), fermer dÃĻs spike dÃĐtectÃĐ â sans seuil de gain/perte
            else if(UseSpikeAutoClose)
            {
               bool spikeActive = spikeActiveNow;
               if(!spikeActive)
                  spikeActive = IsDirectionalBoomCrashSpikeForPosition(symbol, (ENUM_POSITION_TYPE)posInfo.PositionType());

               if(spikeActive)
               {
                  shouldClose = true;
                  if(isSpikeTrade)
                     closeReason = "Spike captÃĐ (trade SPIKE) PnL=" + DoubleToString(profit, 2) + "$";
                  else if(spikeStyleClose)
                     closeReason = "Spike captÃĐ [M5/DERIV/PRE_OTE] PnL=" + DoubleToString(profit, 2) + "$";
                  else
                     closeReason = "Spike dÃĐtectÃĐ PnL=" + DoubleToString(profit, 2) + "$";
               }
            }
         }
         }
      }
      
      if(shouldClose)
      {
         ulong ticket = posInfo.Ticket();
         string closedDir = (posInfo.PositionType() == POSITION_TYPE_BUY) ? "BUY" : "SELL";
         const bool spikeThemeClose = (StringFind(closeReason, "Spike") >= 0 ||
                                       StringFind(closeReason, "spike") >= 0 ||
                                       StringFind(closeReason, "DERIV") >= 0 ||
                                       StringFind(closeReason, "Scalp") >= 0);
         if(PositionCloseWithLog(ticket, "Spike close - " + closeReason))
         {
            // Reset ÃĐtats pour ÃĐviter de fermer immÃĐdiatement un nouveau trade
            s_waitingSecondSpikeClose = false;
            s_waitingSecondSpikeSymbol = "";
            s_waitingSecondSpikeStart = 0;
            if(IsBoomSymbol(symbol))  g_lastBoomSpikeTime = 0;
            if(IsCrashSymbol(symbol)) g_lastCrashSpikeTime = 0;

            // OPTIMISATION: Log minimal pour ÃĐviter le lag
            Print("?? EA FERMETURE SPIKE - ", symbol, " | ticket=", ticket, " | Profit: ", DoubleToString(profit, 2));

            if(spikeThemeClose)
               NotifyTradeLifecycle("Spike captÃĐ â " + symbol + " â " + closeReason, SpikeCapturedSoundFile);
            NotifyTradeLifecycle("Trade fermÃĐ â " + symbol + " | " + closeReason +
                                 " | P/L " + DoubleToString(profit, 2) + "$", TradeClosedSoundFile);

            // RÃĐentrÃĐe spike: (1) proba ML imminente, ou (2) chaÃŪne OTE+IA tant que setup OTE valide et IA â  HOLD
            double spikeProbArm = (symbol == _Symbol) ? CalculateSpikeProbability() : g_lastSpikeProbability;
            bool probArm = (spikeProbArm >= BoomCrashSecondSpikeImminentProb);
            bool oteChainOk = UseOteSpikeScalpChain &&
               cat == SYM_BOOM_CRASH &&
               ((IsCrashSymbol(symbol) && closedDir == "SELL") || (IsBoomSymbol(symbol) && closedDir == "BUY")) &&
               HasActiveValidOTESetupForDirection(closedDir) &&
               IsBoomCrashDirectionAllowedByIA(symbol, closedDir) &&
               (g_lastAIConfidence * 100.0 >= OteSpikeChainMinAIConfidencePct);

            if(oteChainOk)
            {
               g_secondSpikeReentryArmed = true;
               g_secondSpikeReentryArmTime = TimeCurrent();
               g_secondSpikeReentryDirection = closedDir;
               g_secondSpikeReentryMode = 2;
               Print("ð ChaÃŪne OTE+IA â rÃĐentrÃĐe spike armÃĐe | ", symbol, " | dir=", closedDir,
                     " | IA=", DoubleToString(g_lastAIConfidence * 100.0, 1), "%");
            }
            else if(probArm)
            {
               g_secondSpikeReentryArmed = true;
               g_secondSpikeReentryArmTime = TimeCurrent();
               if(IsBoomSymbol(symbol) || IsWeltradeGainSynthSymbol(symbol))
                  g_secondSpikeReentryDirection = "BUY";
               else
                  g_secondSpikeReentryDirection = "SELL";
               g_secondSpikeReentryMode = 1;
               Print("ðŊ 2e spike imminent - rÃĐentrÃĐe armÃĐe | dir=", g_secondSpikeReentryDirection,
                     " | p=", DoubleToString(spikeProbArm * 100.0, 1), "%");
            }
            else if(AlwaysReenterAfterSpikeClose &&
                    UseSpikeAutoClose &&
                    (cat == SYM_BOOM_CRASH || isWeltradeSynth))
            {
               g_secondSpikeReentryArmed = true;
               g_secondSpikeReentryArmTime = TimeCurrent();
               g_secondSpikeReentryDirection = closedDir;
               g_secondSpikeReentryMode = 3;
               Print("RÃĐentrÃĐe systÃĐmatique aprÃĻs spike captÃĐ â armÃĐe | ", symbol, " | dir=", closedDir);
            }
         }
         else
         {
            int err = GetLastError();
            Print("? EA ÃCHEC FERMETURE SPIKE - ", symbol, " | ticket=", ticket, " | code=", err);
         }
      }
   }
}



void ManageDollarExits()
{
   // Si les sorties en dollars sont dÃĐsactivÃĐes, sortir immÃĐdiatement
   if(!UseDollarExits)
      return;
   
   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      if(!posInfo.SelectByIndex(i)) continue;
      if(posInfo.Magic() != InpMagicNumber) continue;

      string symbol = posInfo.Symbol();
      ulong ticket = posInfo.Ticket();
      double profit = posInfo.Profit();
      double swap = posInfo.Swap();
      double commission = posInfo.Commission();
      double totalPnL = profit + swap + commission;
      ENUM_SYMBOL_CATEGORY cat = SMC_GetSymbolCategory(symbol);
      
      datetime openTime = (datetime)posInfo.Time();
      int secondsSinceOpen = (int)(TimeCurrent() - openTime);
      
      // PROTECTION: Urgence Boom/Crash mÃŠme si trade rÃĐcent
      if(secondsSinceOpen < 30)
      {
         if(UseMaxLossBoomCrashPerTrade && cat == SYM_BOOM_CRASH && totalPnL <= -MaxLossBoomCrashPerTradeUSD)
         {
            Print("?? BOOM/CRASH MAX LOSS (urgence) | ", symbol, " | PnL=", DoubleToString(totalPnL, 2), "$");
            PositionCloseWithLog(ticket, "Boom/Crash max loss per trade (urgence)");
            continue;
         }
         continue; // Respirer 30s
      }
      
      // 1) Perte Max par Trade (Boom/Crash uniquement)
      if(UseMaxLossBoomCrashPerTrade && cat == SYM_BOOM_CRASH)
      {
         if(totalPnL <= -MaxLossBoomCrashPerTradeUSD)
         {
            Print("?? BOOM/CRASH MAX LOSS | ", symbol, " | PnL=", DoubleToString(totalPnL, 2), "$");
            PositionCloseWithLog(ticket, "Boom/Crash max loss per trade");
            continue;
         }
      }
      
      // 2) Perte Max Globale (Hors Boom/Crash)
      if(cat != SYM_BOOM_CRASH)
      {
         if(totalPnL <= -MaxLossDollars)
         {
            Print("?? TENTATIVE FERMETURE PERTE MAX | ", symbol, " | PnL=", DoubleToString(totalPnL, 2), "$");
            PositionCloseWithLog(ticket, "Profit total atteint (perte max)");
            continue;
         }
      }
   }
}

// Ferme les positions et ordres en conflit avec l'IA (optionnel)
void ClosePositionsOnDirectionConflict()
{
   // SÃĐcuritÃĐ : ne rien faire si la fermeture sur conflit est dÃĐsactivÃĐe
   if(!UseDirectionConflictClose || !UseAIServer)
      return;

   // IA doit ÃŠtre clairement BUY ou SELL avec une confiance suffisante
   string ai = g_lastAIAction;
   StringToUpper(ai);
   if(ai != "BUY" && ai != "SELL")
      return;

   double conf = g_lastAIConfidence;
   if(conf < MinAIConfidence)
      return;

   string sym = _Symbol;
   ENUM_SYMBOL_CATEGORY symCat = SMC_GetSymbolCategory(sym);

   // 1) Fermer les POSITIONS en conflit sur ce symbole (BUY vs SELL)
   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      ulong ticket = PositionGetTicket(i);
      if(ticket == 0)
         continue;

      if(!PositionSelectByTicket(ticket))
         continue;

      string psym = PositionGetString(POSITION_SYMBOL);
      ulong pmagic = (ulong)PositionGetInteger(POSITION_MAGIC);
      if(psym != sym || pmagic != InpMagicNumber)
         continue;

      ENUM_POSITION_TYPE ptype = (ENUM_POSITION_TYPE)PositionGetInteger(POSITION_TYPE);
      bool conflict = false;

      if(ptype == POSITION_TYPE_SELL && ai == "BUY")
         conflict = true;
      else if(ptype == POSITION_TYPE_BUY && ai == "SELL")
         conflict = true;

      if(!conflict)
         continue;

      // IMPORTANT: sur Boom/Crash, ne pas fermer les positions issues d'ordres LIMIT canal/retour
      // (sinon on "coupe" immÃĐdiatement aprÃĻs un fill et on rate le spike).
      if(symCat == SYM_BOOM_CRASH)
      {
         string cmt = PositionGetString(POSITION_COMMENT);
         // Recovery exceptionnel: on ne coupe pas la position avant la fermeture "par prÃĐcaution"
         if(StringFind(cmt, "EXC_RECOVERY_") >= 0)
         {
            Print("?? SKIP CLOSE (conflit IA) - Boom/Crash EXC_RECOVERY protÃĐgÃĐ | ", psym,
                  " | Ticket=", ticket,
                  " | Type=", (ptype == POSITION_TYPE_BUY ? "BUY" : "SELL"),
                  " | IA=", ai, " ", DoubleToString(conf * 100.0, 1), "% | Comment=", cmt);
            continue;
         }
         if(StringFind(cmt, "SMC_CH") >= 0 || StringFind(cmt, "RETURN_MOVE") >= 0)
         {
            Print("?? SKIP CLOSE (conflit IA) - Boom/Crash LIMIT protÃĐgÃĐ | ", psym,
                  " | Ticket=", ticket,
                  " | Type=", (ptype == POSITION_TYPE_BUY ? "BUY" : "SELL"),
                  " | IA=", ai, " ", DoubleToString(conf * 100.0, 1), "% | Comment=", cmt);
            continue;
         }
      }

      double profit = PositionGetDouble(POSITION_PROFIT);

      // RÃGLE STRICTE: Fermer TOUTES les positions en conflit avec l'IA
      // mÃŠme si elles sont en perte - pour ÃĐviter de maintenir des positions opposÃĐes Ã  l'IA
      // Log: afficher si la position est en perte ou en profit

      if(PositionCloseWithLog(ticket, "IA DIRECTION CONFLICT - ferm. aprÃĻs conflit IA"))
      {
         string profitStatus = (profit >= 0) ? "GAIN" : "PERTE";
         Print("?? POSITION FERMÃE (conflit IA) - ", psym,
               " | Type=", (ptype == POSITION_TYPE_BUY ? "BUY" : "SELL"),
               " | IA=", ai, " ",
               DoubleToString(conf * 100.0, 1), "% | ",
               profitStatus, "=", DoubleToString(MathAbs(profit), 2), "$");
      }
      else
      {
         Print("? ECHEC FERMETURE (conflit IA) - ", psym,
               " | Ticket=", ticket,
               " | Erreur=", _LastError);
      }
   }
}

// Ferme toutes les positions de l'EA quand l'IA passe en HOLD
void ClosePositionsOnIAHold()
{
   // SÃĐcuritÃĐ : ne rien faire si la fermeture sur HOLD est dÃĐsactivÃĐe
   if(!UseIAHoldClose || !UseAIServer)
      return;
   
   // VÃĐrifier si l'IA est en HOLD
   string aiAction = g_lastAIAction;
   StringToUpper(aiAction);
   
   if(aiAction != "HOLD") return;
   
   // Parcourir toutes les positions de l'EA
   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      if(PositionGetSymbol(i) == _Symbol && PositionGetInteger(POSITION_MAGIC) == InpMagicNumber)
      {
         ulong ticket = PositionGetInteger(POSITION_TICKET);
         string symbol = PositionGetString(POSITION_SYMBOL);
         double profit = PositionGetDouble(POSITION_PROFIT);
         ENUM_POSITION_TYPE type = (ENUM_POSITION_TYPE)PositionGetInteger(POSITION_TYPE);
         string cmt = PositionGetString(POSITION_COMMENT);

         // IMPORTANT: sur Boom/Crash, ne pas fermer automatiquement les positions issues d'ordres LIMIT canal/retour
         // mÃŠme si l'IA passe en HOLD (sinon on rate le spike juste aprÃĻs le fill).
         if(SMC_GetSymbolCategory(symbol) == SYM_BOOM_CRASH)
         {
            // Recovery exceptionnel: on laisse le trade recovery finir ses 5 petites bougies M1
            if(StringFind(cmt, "EXC_RECOVERY_") >= 0)
            {
               Print("?? SKIP CLOSE (IA HOLD) - Boom/Crash EXC_RECOVERY protÃĐgÃĐ | ",
                     (type == POSITION_TYPE_BUY ? "BUY" : "SELL"),
                     " sur ", symbol,
                     " | Ticket=", ticket,
                     " | Profit=", DoubleToString(profit, 2), "$",
                     " | Comment=", cmt);
               continue;
            }

            if(StringFind(cmt, "SMC_CH") >= 0 || StringFind(cmt, "RETURN_MOVE") >= 0)
            {
               Print("?? SKIP CLOSE (IA HOLD) - Boom/Crash LIMIT protÃĐgÃĐ | ",
                     (type == POSITION_TYPE_BUY ? "BUY" : "SELL"),
                     " sur ", symbol,
                     " | Ticket=", ticket,
                     " | Profit=", DoubleToString(profit, 2), "$",
                     " | Comment=", cmt);
               continue;
            }
         }
         
         // Fermer la position
         bool closed = PositionCloseWithLog(ticket, "IA HOLD - Fermeture automatique");
         
         if(closed)
         {
            Print("?? POSITION FERMÃE - IA HOLD | ", 
                  (type == POSITION_TYPE_BUY ? "BUY" : "SELL"), 
                  " sur ", symbol, 
                  " | Profit: ", DoubleToString(profit, 2), "$",
                  " | En attente d'un nouveau signal IA");
         }
         else
         {
            Print("? ÃCHEC FERMETURE - IA HOLD | Erreur: ", GetLastError());
         }
      }
   }
}

// Dessine UNIQUEMENT les graphiques/indicateurs sur le chart (pas d'ordres).
// Objectif: ne rien laisser visuellement, mÃŠme en mode observation / pause.
void DrawAllIndicatorGraphics()
{
   // DÃTECTION ANTI-REPAINT DES SWING POINTS
   DetectNonRepaintingSwingPoints();
   DrawConfirmedSwingPoints();
   
   // DÃTECTION SPÃCIALE BOOM/CRASH (ANTI-SPIKE)
   if(StringFind(_Symbol, "Boom") >= 0 || StringFind(_Symbol, "Crash") >= 0)
   {
      DetectBoomCrashSwingPoints();
      CheckImminentSpike();
      
      // NOUVEAU: VÃĐrifier le scalping agressif sur canal Boom
      CheckBoomChannelScalping();
      
      // Disabled: cette routine place des ordres pending LIMIT via PlaceReturnMovementLimitOrder()
      // (objectif: aucune crÃĐation BUY_LIMIT/SELL_LIMIT, uniquement market via touch M5).
      // CheckSMCChannelReturnMovements();
   }
   
   // AFFICHAGE STATUT IA ET PRÃDICTIONS
   DrawAIStatusAndPredictions();
   
   // Graphiques essentiels et zones Premium/Discount
   DrawSwingHighLow();
   DrawBookmarkLevels();
   DrawFVGOnChart();
   DrawOBOnChart();
   if(DrawICTChecklistGraphics) DrawICTValidationGraphics();
   DrawFibonacciOnChart();
   DrawEMACurveOnChart();
   DrawLiquidityZonesOnChart();
   
   // Toujours afficher les zones Premium/Discount + ÃĐquilibre/correction sur le graphique.
   DrawPremiumDiscountZones();

   if(ShowHMSZonesOnChart)
      DrawHMSZonesOnChart();
   else
      ObjectsDeleteAll(0, "SMC_HMS_");
   
   // Autres graphiques optionnels
   if(ShowSignalArrow) { DrawSignalArrow(); UpdateSignalArrowBlink(); }
   
   // Avertisseur visuel des spikes imminents sur Boom/Crash
   UpdateSpikeWarningBlink();
   
   if(ShowPredictedSwing) DrawPredictedSwingPoints();
   if(ShowEMASupportResistance) DrawEMASupportResistance();
   if(ShowPredictionChannel) DrawPredictionChannel();
   if(ShowFutureCandlesM1) DrawFutureCandlesM1();
   if(ShowSMCChannelsMultiTF) DrawSMCChannelsMultiTF();
   if(ShowEMASupertrendMultiTF) DrawEMASupertrendMultiTF();
   //if(ShowLimitOrderLevels) DrawLimitOrderLevels(); // SUPPRIMÃ - Plus d'affichage ordres limit

   if(ShowOTEImbalanceOnChart) DrawOTEImbalanceOnChart();
   
   // NOUVEAU: PrÃĐdiction des Protected High/Low Points futurs
   PredictFutureProtectedPoints();
}

// Dessine sur le graphique la confluence OTE(0.62-0.786) + Imbalance(FVG)
// pour Forex/Metal/Commodity (style ICT visuel).
void DrawOTEImbalanceOnChart()
{
   ENUM_SYMBOL_CATEGORY cat = SMC_GetSymbolCategory(_Symbol);
   if(!(cat == SYM_FOREX || cat == SYM_METAL || cat == SYM_COMMODITY)) return;
   if(!UseFVG || !UseOTE) return;

   // Supprimer les anciens dessins OTE/Imbalance (pour ne pas saturer le chart)
   ObjectsDeleteAll(0, "SMC_OTEIMB_");
   
   // NETTOYAGE COMPLÃMENTAIRE - Supprimer toutes les lignes OTE visibles
   ObjectsDeleteAll(0, "SMC_OTEIMB_ENTRY");
   ObjectsDeleteAll(0, "SMC_OTEIMB_SL");
   ObjectsDeleteAll(0, "SMC_OTEIMB_TP");
   
   // NETTOYAGE DES ZONES OTE BUY/SELL - Supprimer tous les objets OTE visuels
   ObjectsDeleteAll(0, "SMC_OTE_BUY_");
   ObjectsDeleteAll(0, "SMC_OTE_SELL_");

   bool bullHTF = IsBullishHTF();
   bool bearHTF = IsBearishHTF();

   // fail-open visuel: si pas de tendance HTF claire, dÃĐcider via EMA LTF
   string dir = "";
   if(bullHTF) dir = "BUY";
   else if(bearHTF) dir = "SELL";
   else
   {
      double bidNow = SymbolInfoDouble(_Symbol, SYMBOL_BID);
      double emaNow = 0.0;
      if(emaHandle != INVALID_HANDLE)
      {
         double e[];
         ArraySetAsSeries(e, true);
         if(CopyBuffer(emaHandle, 0, 0, 1, e) >= 1) emaNow = e[0];
      }
      if(emaNow <= 0.0) emaNow = bidNow; // fallback
      dir = (bidNow >= emaNow) ? "BUY" : "SELL";
   }

   // RÃĐcupÃĐrer derniers swing anchors (non-repaint)
   double lastSH = 0.0, lastSL = 0.0;
   datetime tSH = 0, tSL = 0;
   GetLatestConfirmedSwings(lastSH, tSH, lastSL, tSL);
   if(lastSH <= 0.0 || lastSL <= 0.0) return;

   double high = lastSH;
   double low  = lastSL;
   if(high <= low) return;

   double range = high - low;

   // OTE zone
   double oteLow = 0.0, oteHigh = 0.0;
   if(dir == "BUY")
   {
      oteHigh = low + range * 0.62;
      oteLow  = low + range * 0.786;
   }
   else
   {
      oteLow  = high - range * 0.62;
      oteHigh = high - range * 0.786;
      if(oteLow > oteHigh)
      {
         double tmp = oteLow;
         oteLow = oteHigh;
         oteHigh = tmp;
      }
   }

   // FVG (imbalance) optionnel: si trouvÃĐ et alignÃĐ, on dessine aussi la confluence
   bool hasFvg = false;
   FVGData fvg;
   double fvgLow = 0.0, fvgHigh = 0.0;
   double zoneLow = 0.0, zoneHigh = 0.0;
   bool confluenceOk = false;

   if(SMC_DetectFVG(_Symbol, LTF, 40, fvg))
   {
      if((dir == "BUY" && fvg.direction == 1) || (dir == "SELL" && fvg.direction == -1))
      {
         hasFvg = true;
         fvgLow  = fvg.bottom;
         fvgHigh = fvg.top;
      }
   }

   // Intersection confluence (si FVG trouvÃĐe)
   double oteZLow = MathMin(oteLow, oteHigh);
   double oteZHigh = MathMax(oteLow, oteHigh);
   if(hasFvg && fvgLow > 0.0 && fvgHigh > 0.0)
   {
      zoneLow  = MathMax(fvgLow, oteZLow);
      zoneHigh = MathMin(fvgHigh, oteZHigh);
      confluenceOk = (zoneHigh > zoneLow);
   }

   datetime now = TimeCurrent();
   datetime futureTime = now + (datetime)(PeriodSeconds(LTF) * OTEImbalanceProjectionBars / 5.0);
   if(futureTime <= now) futureTime = now + 60;

   color oteClr = confluenceOk ? clrGold : clrSilver;
   
   // NOTIFICATION OTE SETUP (Une seule fois par setup)
   if(confluenceOk)
   {
      static datetime lastOteTime = 0;
      static string lastOteSymbol = "";
      static string lastOteDir = "";
      
      if(lastOteTime != now || lastOteSymbol != _Symbol || lastOteDir != dir)
      {
         string oteMsg = "ðŊ OTE SETUP DÃTECTÃ (" + dir + ") sur " + _Symbol + " | Confluence: OUI";
         Print("?? " + oteMsg);
         lastOteTime = now;
         lastOteSymbol = _Symbol;
         lastOteDir = dir;
      }
   }

   // Rectangle OTE
   string nameOTE = "SMC_OTEIMB_OTE";
   if(ObjectFind(0, nameOTE) < 0)
      ObjectCreate(0, nameOTE, OBJ_RECTANGLE, 0, now, oteZHigh, futureTime, oteZLow);
   ObjectSetInteger(0, nameOTE, OBJPROP_COLOR, oteClr);
   ObjectSetInteger(0, nameOTE, OBJPROP_BACK, true);
   ObjectSetInteger(0, nameOTE, OBJPROP_FILL, true);
   ObjectSetInteger(0, nameOTE, OBJPROP_WIDTH, 1);

   // Rectangle FVG (optionnel)
   if(hasFvg)
   {
      color fvgClr = (dir == "BUY") ? clrGreen : clrRed;
      string nameFVG = "SMC_OTEIMB_FVG";
      if(ObjectFind(0, nameFVG) < 0)
         ObjectCreate(0, nameFVG, OBJ_RECTANGLE, 0, fvg.time, fvgHigh, futureTime, fvgLow);
      ObjectSetInteger(0, nameFVG, OBJPROP_COLOR, fvgClr);
      ObjectSetInteger(0, nameFVG, OBJPROP_BACK, false);
      ObjectSetInteger(0, nameFVG, OBJPROP_FILL, false);
      ObjectSetInteger(0, nameFVG, OBJPROP_WIDTH, 1);
   }

   if(confluenceOk)
   {
      // Entry/SL/TP visuels RR ~ InpRiskReward
      double entry = (dir == "BUY") ? zoneHigh : zoneLow;
      double sl    = (dir == "BUY") ? lastSL : lastSH;
      double risk  = (dir == "BUY") ? (entry - sl) : (sl - entry);
      if(risk > SymbolInfoDouble(_Symbol, SYMBOL_POINT) * 5.0)
      {
         double tp = (dir == "BUY") ? (entry + (MathMax(3.0, InpRiskReward) * risk)) : (entry - (MathMax(3.0, InpRiskReward) * risk));

         string nameEntry = "SMC_OTEIMB_ENTRY";
         string nameSL    = "SMC_OTEIMB_SL";
         string nameTP    = "SMC_OTEIMB_TP";

         // MASQUER LES LIGNES OTE - Ne pas dessiner les lignes Entry/SL/TP
         // CommentÃĐ pour masquer visuellement les lignes OTE sur le graphique
         /*
         ObjectCreate(0, nameEntry, OBJ_HLINE, 0, 0, entry);
         ObjectSetInteger(0, nameEntry, OBJPROP_COLOR, clrDodgerBlue);
         ObjectSetInteger(0, nameEntry, OBJPROP_STYLE, STYLE_SOLID);
         ObjectSetInteger(0, nameEntry, OBJPROP_WIDTH, 2);

         ObjectCreate(0, nameSL, OBJ_HLINE, 0, 0, sl);
         ObjectSetInteger(0, nameSL, OBJPROP_COLOR, clrRed);
         ObjectSetInteger(0, nameSL, OBJPROP_STYLE, STYLE_DASH);
         ObjectSetInteger(0, nameSL, OBJPROP_WIDTH, 2);

         ObjectCreate(0, nameTP, OBJ_HLINE, 0, 0, tp);
         ObjectSetInteger(0, nameTP, OBJPROP_COLOR, clrLimeGreen);
         ObjectSetInteger(0, nameTP, OBJPROP_STYLE, STYLE_SOLID);
         ObjectSetInteger(0, nameTP, OBJPROP_WIDTH, 2);
         */
      }
   }
}

void OnTick()
{
   // Push mobile Boom/Crash: flÃĻche DERIV (chaque tick, hors throttle 2s du reste du robot)
   PollDerivArrowAppearDisappearPush();

   // RÃĐinitialiser les pauses de profit target au dÃĐbut de chaque journÃĐe
   ResetDailyProfitTargetPauses();
   
   // METTRE Ã JOUR LE SYSTÃME DE PRÃSERVATION DES GAINS
   UpdateGainPreservationSystem();
   
   // GESTION DES POSITIONS EN CORRECTION CONTRE TENDANCE
   ManagePositionsAgainstTrendCorrection();
   
   // GESTION DU TEMPS DE DÃTENTION MAXIMUM
   ManageMaximumHoldingTime();
   
   static datetime lastStatsUpdate = 0;
   if(EnableStatisticsTracking && TimeCurrent() - lastStatsUpdate >= 60) // Mise Ã  jour toutes les minutes
   {
      DisplayDailyStatisticsOnChart();
      lastStatsUpdate = TimeCurrent();
   }
   
   // MODE IA ULTRA STABLE - PAS DE DÃTACHEMENT
   static datetime lastProcess = 0;
   static datetime lastGraphicsUpdate = 0;
   static datetime lastAIUpdate = 0;
   static datetime lastDashboardUpdate = 0;
   static datetime lastPropiceInfoLog = 0;
   static datetime lastForexM5BypassLog = 0;
   datetime currentTime = TimeCurrent();
   
   // Traitement contrÃīlÃĐ pour stabilitÃĐ (max ~1 tick toutes les 2 secondes)
   if(currentTime - lastProcess < 2) return;
   lastProcess = currentTime;
   
   // Log informatif sur la prioritÃĐ du symbole actuel (toutes les 2 minutes)
   if(UsePropiceSymbolsFilter && (currentTime - lastPropiceInfoLog >= 120))
   {
      string mostPropice = GetMostPropiceSymbol();
      if(mostPropice != "" && mostPropice != _Symbol)
      {
         Print("ð INFO PRIORITÃ - Symbole actuel: ", _Symbol, " (position #", g_currentSymbolPriority + 1, "ÃĻme)");
         Print("   ðĨ Symbole le plus propice: ", mostPropice, " - prioritÃĐ active, autres symboles restent autorisÃĐs");
         Print("   ðĄ Verrous qualitÃĐ conservÃĐs (confiance IA, spread, confirmation, anti-dup)");
      }
      lastPropiceInfoLog = currentTime;
   }
   
   // BLOCAGE TOTAL DES TRADES - Mode observation seul
   if(BlockAllTrades)
   {
      static datetime lastBlockLog = 0;
      if(currentTime - lastBlockLog >= 30) // Log toutes les 30 secondes
      {
         Print("?? MODE BLOCAGE ACTIVÃ - Aucune entrÃĐe/sortie autorisÃĐe - Observation seule");
         lastBlockLog = currentTime;
      }
      
      // Garder seulement les graphiques et IA pour observation
      if(!UltraLightMode)
      {
         // MISE Ã JOUR IA pour observation
         if(UseAIServer && currentTime - lastAIUpdate >= AI_UpdateInterval_Seconds)
         {
            lastAIUpdate = currentTime;
            UpdateAIDecision(AI_Timeout_ms);
         }
         
         // GRAPHIQUES pour observation
         if(ShowChartGraphics && currentTime - lastGraphicsUpdate >= 30)
         {
            lastGraphicsUpdate = currentTime;
            DrawAllIndicatorGraphics();
         }
         
         // TABLEAU DE BORD pour observation (15 s pour mise Ã  jour plus rÃĐactive)
         if(currentTime - lastDashboardUpdate >= 15)
         {
            lastDashboardUpdate = currentTime;
            UpdateDashboard();
         }
      }
      return; // Sortir immÃĐdiatement - aucun trading
   }
   
   // VÃRIFICATION DE LA PAUSE APRÃS PROFIT JOURNALIER
   if(!UsePerSymbolDailyObjectiveOnly && CheckDailyProfitPause())
   {
      static datetime lastPauseLog = 0;
      if(currentTime - lastPauseLog >= 60) // Log toutes les minutes pendant la pause
      {
         datetime pauseEndTime = (g_dailyPauseUntil > 0 ? g_dailyPauseUntil : (g_dailyProfitPauseStartTime + PauseAfterProfitHours * 3600));
         int remainingSeconds = (int)(pauseEndTime - currentTime);
         int remainingHours = remainingSeconds / 3600;
         int remainingMinutes = (remainingSeconds % 3600) / 60;
         Print("ðŦ TRADES BLOQUÃS - Pause aprÃĻs profit journalier (", remainingHours, "h ", remainingMinutes, "min restantes)");
         lastPauseLog = currentTime;
      }
      
      // Garder les fonctions d'observation pendant la pause
      if(!UltraLightMode)
      {
         // MISE Ã JOUR IA pour observation
         if(UseAIServer && currentTime - lastAIUpdate >= AI_UpdateInterval_Seconds)
         {
            lastAIUpdate = currentTime;
            UpdateAIDecision(AI_Timeout_ms);
         }
         
         // GRAPHIQUES pour observation
         if(ShowChartGraphics && currentTime - lastGraphicsUpdate >= 30)
         {
            lastGraphicsUpdate = currentTime;
            DrawAllIndicatorGraphics();
         }
         
         // TABLEAU DE BORD pour observation
         if(currentTime - lastDashboardUpdate >= 15)
         {
            lastDashboardUpdate = currentTime;
            UpdateDashboard();
         }
      }
      return; // Sortir - aucun trading pendant la pause
   }
   
   // STRATÃGIES PAR CATÃGORIE DE SYMBOLE (Boom/Crash, Volatility, Forex/Metals)
   // Anti-duplication pending (scan ordres) peut ÃŠtre coÃŧteux -> throttle
   static datetime lastEnsurePending = 0;
   if(currentTime - lastEnsurePending >= 3)
   {
      EnsureSinglePendingLimitOrderForSymbol(_Symbol);
      lastEnsurePending = currentTime;
   }
   // Injecter un consensus MTF frais avant les dÃĐcisions d'entrÃĐe.
   ApplyMTFConsensusToAIDecision(false);
   UpdateChartPatternContext(ShowChartGraphics);
   // Synchro technique lÃĐgÃĻre vers l'AI server (indicateurs, sans image).
   PushChartTechStateToAIServer(false);
   RunCategoryStrategy();
   UpdatePriceActionM15ScenarioProjectionDraw();
   
   // Gestion des positions existantes (fermeture rapide aprÃĻs spike)
   ManageBoomCrashSpikeClose();
   ManageStairEscalierTrailingAndExit();
   // AprÃĻs spike: timeouts IA80 (flÃĻche disparue / petites M1) â la fermeture spike reste prioritaire (traitÃĐe ci-dessus)
   ManageIA80ArrowScalpExits();
   // Gestion des sorties en dollars (TP/SL globaux + BoomCrashSpikeTP)
   ManageDollarExits();

   // Protection "profit lock": ÃĐviter de rendre un gros gain du jour
   if(!UsePerSymbolDailyObjectiveOnly)
   {
      UpdateDailyEquityStats();
      ActivateProfitLockIfNeeded();
      if(IsDailyProfitPauseActive())
         return;
   }
   
   // Modification SL dynamique OBLIGATOIRE (plus de condition)
   // Le SL dynamique est maintenant obligatoire pour toutes les positions
   // Si on vient de fermer une position, ÃĐviter de modifier immÃĐdiatement (fenÃŠtre de course MT5)
   if(g_lastCloseActionTime > 0 && (currentTime - g_lastCloseActionTime) <= 1)
   {
      Print("ð SL dynamique suspendu 1s aprÃĻs fermeture position");
   }
   else
   {
      ManageTrailingStop(); // OBLIGATOIRE - s'exÃĐcute toujours
   }
   
   // Si on est en mode ultra lÃĐger: ne pas lancer l'IA ni mettre Ã  jour les graphiques/dashboard
   if(UltraLightMode)
      return;
   
   // MISE Ã JOUR IA - Appel au serveur IA pour obtenir les dÃĐcisions
   if(UseAIServer && currentTime - lastAIUpdate >= AI_UpdateInterval_Seconds)
   {
      lastAIUpdate = currentTime;
      UpdateAIDecision(AI_Timeout_ms);
      ApplyMTFConsensusToAIDecision(true);
      
      // Mettre Ã  jour les mÃĐtriques ML si activÃĐes (30 s pour affichage rÃĐactif)
      if(ShowMLMetrics && (TimeCurrent() - g_lastMLMetricsUpdate) >= 30)
      {
         UpdateMLMetricsDisplay();
      }
   }
   else
   {
      // Garder une direction IA "rÃĐelle" fraÃŪche via consensus MTF mÃŠme entre deux polls serveur.
      ApplyMTFConsensusToAIDecision(false);
   }

   // Boom/Crash: entrÃĐe ÂŦ IA forte + flÃĻche Âŧ aprÃĻs rafraÃŪchissement IA (ne modifie pas OTE / StairEntry / DERIV touch)
   if(SMC_GetSymbolCategory(_Symbol) == SYM_BOOM_CRASH)
      TryOpenIA80DerivArrowAutoEntry();

   // Mettre Ã  jour le Top N "propice" (affichage + filtre optionnel)
   if(UsePropiceSymbolsFilter || UseDashboard)
      UpdatePropiceTopSymbols();
   
   // Si l'IA est passÃĐe en HOLD, couper immÃĐdiatement les positions de l'EA
   // RÃĐduire la frÃĐquence des logs DEBUG pour ÃĐviter la surcharge
   static datetime lastDebugLog = 0;
   if(TimeCurrent() - lastDebugLog >= 120) // Log toutes les 2 minutes maximum
   {
      Print("?? DEBUG - VÃĐrification IA HOLD | g_lastAIAction: '", g_lastAIAction, "' | UseAIServer: ", UseAIServer);
      lastDebugLog = TimeCurrent();
   }
   ClosePositionsOnIAHold();
   
   // NOUVEAU: Surveillance des changements IA vers HOLD et fermeture automatique
   MonitorAndClosePositionsOnHold();
   
   // NOUVEAU: VÃĐrifier les conflits de direction sur Boom/Crash
   ClosePositionsOnDirectionConflict();
   
   // NOUVEAU: VÃĐrifier le toucher des niveaux OTE pour exÃĐcution au marchÃĐ
   AnnounceOTEApproach();
   MonitorOTEPendingLimitPreTouch();
   CheckAndExecuteMarketOnOTETouch();
   CheckAndExecuteMarketOnCurrentOTETouchWhenIAFor();
   
   // NOUVEAU: Annuler les setups OTE invalidÃĐs
   CancelOTESetupsOnInvalidation();
   ManageOTEPositionsWhenSetupGoneFromChart();
   
   // ROTATION AUTOMATIQUE DES POSITIONS pour ÃĐviter de rester bloquÃĐ sur un symbole
   static datetime lastRotationCheck = 0;
   if(currentTime - lastRotationCheck >= 60) // VÃĐrifier toutes les minutes
   {
      lastRotationCheck = currentTime;
      AutoRotatePositions();
   }
   
   // VÃĐrifier en continu les ordres LIMIT en attente vs dÃĐcision IA (HOLD/direction/confiance)
   // Version amÃĐliorÃĐe avec remplacement automatique des ordres non alignÃĐs
   //if(ReplaceMisalignedLimitOrders) // SUPPRIMÃ - Plus d'ordres limit
   //   GuardPendingLimitOrdersWithAI_Enhanced();
   //else
   //   GuardPendingLimitOrdersWithAI();
   
   // NOUVEAU: DÃĐtection de spikes sans IA pour ne manquer aucune opportunitÃĐ
   CheckAndExecuteSpikeTrade();

   // 2e stratÃĐgie Boom/Crash: canal M5 + sÃĐrie de spikes M1 + petites bougies (bypass IA HOLD si structure OK)
   CheckAndExecuteM5ChannelSpikeSeriesEntry();

   // Fermeture profit-only par symbole Ã  3$ (POSITION_PROFIT uniquement)
   // ExÃĐcutÃĐe avant les entrÃĐes M5 pour ÃĐviter toute rÃĐouverture sur le mÃŠme tick.
   CloseAllPositionsIfSymbolProfitReached(3.0);
   
   // Affichage graphique type OTE quand escalier M1 (classique / jeune / forming) est dÃĐtectÃĐ
   UpdateStairSetupChartDisplay();
   // Alerte push ÂŦ signal stair Âŧ (pattern M1) avant tentative dâentrÃĐe â indÃĐpendant des filtres dâexÃĐcution (EMA, etc.)
   NotifyStairPatternOnM1IfDetected();
   // EntrÃĐe scalp dÃĐdiÃĐe: Boom/GAINX BUY sur retouche EMA13 M1 + confluence EMA21 M5
   CheckAndExecuteStairEmaTouchScalpEntry();
   
   // EntrÃĐe stairEntry: escalier M1 + tendance M1/M5 (Boom BUY / Crash SELL), complÃĐment OTE / hors touch M5
   CheckAndExecuteStairEntry();
   // Niveau B: une limite dâattente si escalier OK mais IA/EMA pas encore niveau A
   CheckAndPlaceStairEscalierLimitOrder();
   
   // NOUVEAU: VÃĐrification des touches M5 pour exÃĐcution M1 (prioritÃĐ haute)
   SyncMovingEntryPointLimitOrders();
   SyncIAHoldLimitWithM5Entry();
   CheckAndExecutePendingLimitPureArrowScalp();
   CheckAndExecuteM5TouchEntryTrade();
   
   // NOUVEAU: Recovery exceptionnel Boom/Crash (touch M5 + N petites bougies M1, input BoomCrashSmallM1CandlesBeforeEntry)
   CheckAndExecuteExceptionalBoomCrashRecoveryEntries();
   
   // RÃĐentrÃĐe dÃĐdiÃĐe aprÃĻs fermeture spike si 2e spike imminent (attend 2 petites bougies M1)
   CheckAndExecuteSecondSpikeReentry();
   
   // DÃTECTION ULTRA-RAPIDE DE SPIKE (toutes les 5 secondes pour Boom/Crash)
   static datetime lastSpikeCheck = 0;
   if(StringFind(_Symbol, "Boom") >= 0 || StringFind(_Symbol, "Crash") >= 0)
   {
      if(currentTime - lastSpikeCheck >= 5)
      {
         lastSpikeCheck = currentTime;
         CheckImminentSpike(); // VÃĐrification rapide sans graphiques
      }
   }
   
   // GRAPHIQUES SMC CONTRÃLÃS (toutes les 15 secondes pour plus de rÃĐactivitÃĐ)
   if(ShowChartGraphics && currentTime - lastGraphicsUpdate >= 15)
   {
      lastGraphicsUpdate = currentTime;

      // Dessins complets des indicateurs (sans rien oublier visuellement)
      DrawAllIndicatorGraphics();
      
      // NOUVEAU: Dessiner la stratÃĐgie SMC_OTE complÃĻte
      DrawSMC_OTEStrategy();
      
      // LIMIT suiveurs (M5_ENTRY_TRACK_*, IA_HOLD_LIMIT_*) : voir SyncMovingEntryPointLimitOrders / SyncIAHoldLimitWithM5Entry chaque tick (throttle dÃĐdiÃĐ).
      // Ici : recalcul visuel des niveaux ENTRY M5 + lignes (throttle 15 s avec ShowChartGraphics).
      UpdateM5EntryLevelsAndLines();
   }
   
   // BLOCAGE DES ORDRES AU MARCHÃ CLASSIQUES - SEULS LES TOUCH M5 SONT AUTORISÃS (sauf Forex broker si bypass)
   // Les ordres au marchÃĐ ne sont autorisÃĐs que si le prix touche les lignes BUY/SELL ENTRY M5
   if(UsePropiceSymbolsFilter && g_currentSymbolIsPropice)
   {
      bool m5linesOk = (g_m5BuyLevelActive || g_m5SellLevelActive);
      bool forexM5Bypass = (PropiceForexBypassM5MarketGate && SMC_GetSymbolCategory(_Symbol) == SYM_FOREX);
      if(!m5linesOk && !forexM5Bypass)
      {
         Print("ðŦ PAS DE LIGNES M5 ACTIVES - Ordres au marchÃĐ bloquÃĐs sur ", _Symbol);
         Print("   ðĄ Seuls les trades au touch des lignes BUY/SELL ENTRY M5 sont autorisÃĐs (Forex: activer PropiceForexBypassM5MarketGate pour Weltrade/paires)");
      }
      else
      {
         if(!m5linesOk && forexM5Bypass)
         {
            if(TimeCurrent() - lastForexM5BypassLog >= 120)
            {
               Print("âĄ Forex: ordres marchÃĐ IA autorisÃĐs sans ligne M5 active sur ", _Symbol, " (PropiceForexBypassM5MarketGate)");
               lastForexM5BypassLog = TimeCurrent();
            }
         }
         ExecuteAIDecisionMarketOrder();
      }
   }
   else
   {
      // Si filtre non activÃĐ, comportement normal
      ExecuteAIDecisionMarketOrder();
   }

   // NOUVEAU: ExÃĐcuter la stratÃĐgie SMC_OTE complÃĻte (3 ÃĐtapes)
   ExecuteSMC_OTEStrategy();

   // Sync stats symboles (MT5 History -> serveur -> Supabase)
   SyncSymbolTradeStatsToServer();

   // RÃGLE STRICTE: PAS D'ORDRES LIMIT SI SYMBOLE NON PRIORITAIRE
   // Supprimer tous les ordres LIMIT si le symbole n'est pas prioritaire
   if(UsePropiceSymbolsFilter && !g_currentSymbolIsPropice)
   {
      // VÃĐrifier s'il y a des ordres LIMIT Ã  supprimer
      if(CountOpenLimitOrdersForSymbol(_Symbol) > 0)
      {
         Print("ðŦ SYMBOLE NON PRIORITAIRE - Suppression de tous les ordres LIMIT sur ", _Symbol);
         Print("   ðĄ Seuls les symboles prioritaires peuvent avoir des ordres LIMIT");
         
         // Supprimer tous les ordres LIMIT de ce symbole
         for(int i = OrdersTotal() - 1; i >= 0; i--)
         {
            if(OrderSelect(i) && OrderGetInteger(ORDER_MAGIC) == InpMagicNumber && 
               OrderGetString(ORDER_SYMBOL) == _Symbol)
            {
               ENUM_ORDER_TYPE ot = (ENUM_ORDER_TYPE)OrderGetInteger(ORDER_TYPE);
               if(ot == ORDER_TYPE_BUY_LIMIT || ot == ORDER_TYPE_SELL_LIMIT)
               {
                  MqlTradeRequest req = {};
                  MqlTradeResult  res = {};
                  req.action = TRADE_ACTION_REMOVE;
                  req.order = OrderGetInteger(ORDER_TICKET);
                  req.symbol = _Symbol;
                  
                  if(OrderSend(req, res))
                  {
                     Print("   ðïļ Ordre LIMIT supprimÃĐ: ", OrderGetInteger(ORDER_TICKET), " | Type: ", EnumToString(ot));
                  }
                  else
                  {
                     Print("   â Erreur suppression ordre: ", res.retcode, " | ", res.comment);
                  }
               }
            }
         }
      }
   }
   
   // RÃGLE STRICTE: PAS D'ORDRES LIMIT SI PAS DE TOUCH BUY/SELL ENTRY M5
   // Seuls les trades au touch des lignes M5 sont autorisÃĐs
   if(UsePropiceSymbolsFilter && g_currentSymbolIsPropice)
   {
      // VÃĐrifier si les lignes BUY/SELL ENTRY M5 sont actives
      if(!g_m5BuyLevelActive && !g_m5SellLevelActive)
      {
         // Si aucune ligne M5 active, supprimer les ordres LIMIT existants
         if(CountOpenLimitOrdersForSymbol(_Symbol) > 0)
         {
            Print("ðŦ PAS DE LIGNES M5 ACTIVES - Suppression ordres LIMIT sur ", _Symbol);
            Print("   ðĄ Les ordres LIMIT ne sont autorisÃĐs que si BUY/SELL ENTRY M5 sont actives");
            
            // Supprimer tous les ordres LIMIT
            for(int i = OrdersTotal() - 1; i >= 0; i--)
            {
               if(OrderSelect(i) && OrderGetInteger(ORDER_MAGIC) == InpMagicNumber && 
                  OrderGetString(ORDER_SYMBOL) == _Symbol)
               {
                  ENUM_ORDER_TYPE ot = (ENUM_ORDER_TYPE)OrderGetInteger(ORDER_TYPE);
                  if(ot == ORDER_TYPE_BUY_LIMIT || ot == ORDER_TYPE_SELL_LIMIT)
                  {
                     MqlTradeRequest req = {};
                     MqlTradeResult  res = {};
                     req.action = TRADE_ACTION_REMOVE;
                     req.order = OrderGetInteger(ORDER_TICKET);
                     req.symbol = _Symbol;
                     
                     if(OrderSend(req, res))
                     {
                        Print("   ðïļ Ordre LIMIT supprimÃĐ (pas de lignes M5): ", OrderGetInteger(ORDER_TICKET));
                     }
                  }
               }
            }
         }
      }
   }
   
   // BLOCAGE DES ORDRES LIMIT CLASSIQUES - SEULS LES TOUCH M5 SONT AUTORISÃS
   // CommentÃĐ: PlaceScalpingLimitOrders() - PLUS D'ORDRES LIMIT SANS TOUCH M5
   /*
   double atrVal = 0.0;
   if(atrHandle != INVALID_HANDLE)
   {
      double atrBuf[];
      ArraySetAsSeries(atrBuf, true);
      if(CopyBuffer(atrHandle, 0, 0, 1, atrBuf) >= 1)
         atrVal = atrBuf[0];
   }
   double mid = 0.0;
   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   if(bid > 0 && ask > 0) mid = (bid + ask) * 0.5;
   else mid = (bid > 0 ? bid : ask);

   MqlRates m1Rates[];
   ArraySetAsSeries(m1Rates, true);
   if(CopyRates(_Symbol, PERIOD_M1, 0, 60, m1Rates) >= 30)
      PlaceScalpingLimitOrders(m1Rates, 0, mid, atrVal, 0.0);
   */
   
   // Fermeture profit-only par symbole Ã  3$ (POSITION_PROFIT uniquement)
   CloseAllPositionsIfSymbolProfitReached(3.0);

   // TABLEAU DE BORD CONTRÃLÃ (toutes les 15 secondes)
   if(currentTime - lastDashboardUpdate >= 15)
   {
      lastDashboardUpdate = currentTime;
      UpdateDashboard();
   }
}

//| FONCTIONS DE GESTION DES PAUSES ET BLACKLIST TEMPORAIRE        |

void UpdateDashboard()
{
   // Nettoyage pÃĐriodique des objets graphiques pour ÃĐviter l'accumulation
   static datetime lastCleanupTime = 0;
   if(TimeCurrent() - lastCleanupTime >= 600) // Nettoyer toutes les 10 minutes
   {
      CleanupDashboardObjects();
      lastCleanupTime = TimeCurrent();
      Print("?? Nettoyage pÃĐriodique des objets dashboard effectuÃĐ");
   }
   
   if(!UseDashboard) return;
   string catStr = "UNKNOWN";
   switch(SMC_GetSymbolCategory(_Symbol))
   {
      case SYM_BOOM_CRASH:  catStr = "Boom/Crash"; break;
      case SYM_VOLATILITY:  catStr = "Volatility"; break;
      case SYM_FOREX:       catStr = "Forex"; break;
      case SYM_COMMODITY:   catStr = "Commodity"; break;
      case SYM_METAL:       catStr = "Metal"; break;
      case SYM_WELTRADE_SYNTH: catStr = "Weltrade synth"; break;
   }
   int posCount = CountPositionsForSymbol(_Symbol);
   int totalPos = CountPositionsOurEA();
   
   double totalPL = 0;
   for(int i = PositionsTotal() - 1; i >= 0; i--)
      if(posInfo.SelectByIndex(i) && posInfo.Magic() == InpMagicNumber)
         totalPL += posInfo.Profit() + posInfo.Swap() + posInfo.Commission();
   string swingStr = "";
   if(g_lastSwingHigh > 0) swingStr += " SH=" + DoubleToString(g_lastSwingHigh, _Digits);
   if(g_lastSwingLow > 0)  swingStr += " SL=" + DoubleToString(g_lastSwingLow, _Digits);
   double atrVal = 0, emaVal = 0;
   double atrArr[], emaArr[];
   ArraySetAsSeries(atrArr, true); ArraySetAsSeries(emaArr, true);
   if(atrHandle != INVALID_HANDLE && CopyBuffer(atrHandle, 0, 0, 1, atrArr) >= 1) atrVal = atrArr[0];
   if(emaHandle != INVALID_HANDLE && CopyBuffer(emaHandle, 0, 0, 1, emaArr) >= 1) emaVal = emaArr[0];
   string trendHTF = IsBullishHTF() ? "BULLISH" : "BEARISH";
   string lsStr = FVGKill_LiquiditySweepDetected() ? "YES" : "NO";
   if(ShowMLMetrics && (TimeCurrent() - g_lastMLMetricsUpdate) >= 30)
      UpdateMLMetricsDisplay();
   static datetime lastPredScoreFetch = 0;
   if(TimeCurrent() - lastPredScoreFetch >= 30)
   {
      if(!FetchPredictionScoreFromServer())
         g_predictionScoreSource = "N/A";
      if(!FetchTopNetSummaryFromServer())
         g_topNetSource = "N/A";
      lastPredScoreFetch = TimeCurrent();
   }
   string killStr = SMC_IsKillZone(LondonStart, LondonEnd, NYOStart, NYOEnd) ? "ACTIVE" : "OFF";
   string bcStr = IsBoomSymbol(_Symbol) ? "BOOM" : (IsCrashSymbol(_Symbol) ? "CRASH" : "FOREX");
   int totalLimits = CountOpenLimitOrdersForSymbol(_Symbol);
   int channelLimits = CountChannelLimitOrdersForSymbol(_Symbol);
   int otherLimits = totalLimits - channelLimits;

   // --- Contraintes horaires / quotas (visibles au dashboard) ---
   datetime nowT = TimeCurrent();
   MqlDateTime md;
   TimeToStruct(nowT, md);
   md.hour = 0; md.min = 0; md.sec = 0;
   datetime dayStart = StructToTime(md);
   int totalToday = CountTodayOpenedTradesEASymbol(dayStart, nowT, _Symbol);
   int zoneNow = GetTradingZoneIndexUTC(nowT);
   int zoneCount = (zoneNow > 0 ? CountTodayOpenedTradesEAInZoneSymbol(dayStart, nowT, zoneNow, _Symbol) : 0);

   string timeGate = "ALLOW";
   string timeReason = "OK";
   if(totalToday >= MaxDailyTrades)
   {
      timeGate = "BLOCK";
      timeReason = "ROBOT EN PAUSE: MaxDailyTrades " + _Symbol + " " + IntegerToString(totalToday) + "/" + IntegerToString(MaxDailyTrades);
   }
   else if(IsDailyLossPauseActive())
   {
      // Filtre temps (sessions + UTC) seulement aprÃĻs perte jour >= MaxDailyLossDollars
      if(UseSessions && !SMC_IsKillZone(LondonStart, LondonEnd, NYOStart, NYOEnd))
      {
         timeGate = "BLOCK";
         timeReason = "Hors session LO/NYO (aprÃĻs perte jour -" + DoubleToString(MaxDailyLossDollars, 0) + "$)";
      }
      else if(EnforceTradingTimeZones)
      {
         if(zoneNow == 0)
         {
            timeGate = "BLOCK";
            timeReason = "ROBOT EN PAUSE: Hors zones UTC (4x3h) (aprÃĻs perte jour -" + DoubleToString(MaxDailyLossDollars, 0) + "$)";
         }
         else if(zoneCount >= MaxTradesPerZonePerDay)
         {
            timeGate = "BLOCK";
            timeReason = "ROBOT EN PAUSE: Quota zone " + _Symbol + " " + IntegerToString(zoneNow) + " " + IntegerToString(zoneCount) + "/" + IntegerToString(MaxTradesPerZonePerDay);
         }
      }
   }
   else if(UseSessions || EnforceTradingTimeZones)
   {
      timeReason = "Sessions/UTC off (perte jour < " + DoubleToString(MaxDailyLossDollars, 0) + "$)";
   }
   
   // NETTOYAGE AGRESSIF des anciens objets dashboard avant de crÃĐer les nouveaux
   CleanupDashboardObjects();
   
   // Nettoyer l'ancien Comment() pour ÃĐviter les superpositions avec les labels
   if(!DashboardUseCommentFallback)
      Comment("");

   string lines[25]; // AugmentÃĐ Ã  25 pour inclure toutes les lignes
   color  cols[25];
   int n = 0;
   lines[n] = "[Contexte] SMC Universal + FVG_Kill PRO"; cols[n] = clrWhite; n++;
   lines[n] = "StratÃĐgie: SMC(FVG|OB|LS|BOS) + FVG_Kill(EMA HTF + LS)"; cols[n] = clrSilver; n++;
   lines[n] = "Trend HTF: " + trendHTF + " | LS: " + lsStr + " | KillZone: " + killStr; cols[n] = clrWhite; n++;
   lines[n] = catStr + " | " + bcStr + " | IA: " + ((g_lastAIAction != "") ? (g_lastAIAction + " " + DoubleToString(g_lastAIConfidence*100,1) + "%") : "OFF"); cols[n] = clrAqua; n++;
   lines[n] = "Positions: " + IntegerToString(totalPos) + "/" + IntegerToString(MaxPositionsTerminal) + " | " + _Symbol + ": " + IntegerToString(posCount) + "/1"; cols[n] = clrWhite; n++;
   lines[n] = "LIMIT: total=" + IntegerToString(totalLimits) + " | canal=" + IntegerToString(channelLimits) + " | autres=" + IntegerToString(otherLimits); cols[n] = clrKhaki; n++;
   lines[n] = "Rule: Boom=BUY only | Crash=SELL only"; cols[n] = clrAqua; n++;
   lines[n] = "TIME FILTER: " + timeGate + " | " + timeReason; cols[n] = (timeGate == "ALLOW" ? clrLimeGreen : clrTomato); n++;
   lines[n] = "UTC Zone: " + IntegerToString(zoneNow) +
              " | ZoneQuota: " + IntegerToString(zoneCount) + "/" + IntegerToString(MaxTradesPerZonePerDay) +
              " | DayTrades: " + IntegerToString(totalToday) + "/" + IntegerToString(MaxDailyTrades) +
              " | Sessions: " + (UseSessions ? "ON" : "OFF") + " | EnforceUTC: " + (EnforceTradingTimeZones ? "ON" : "OFF");
   cols[n] = clrSilver; n++;
   lines[n] = "P/L: " + DoubleToString(totalPL, 2) + "$ (max " + DoubleToString(MaxTotalLossDollars, 0) + "$) | Swing:" + swingStr; cols[n] = (totalPL >= 0 ? clrLime : clrTomato); n++;
   lines[n] = "ATR: " + DoubleToString(atrVal, _Digits) + " | EMA(9): " + DoubleToString(emaVal, _Digits) + " | Canal ML: " + string(g_channelValid ? "OK" : "â"); cols[n] = clrWhite; n++;
   if(ShowFutureCandlesM1 && n < 24)
   {
      string src = (g_futureCandlesSource == "" ? "NONE" : g_futureCandlesSource);
      lines[n] = "[IA/Prediction] Future M1: " + IntegerToString(FutureCandlesCount) + " candles | SourcePred: " + src;
      cols[n] = (src == "SERVER" ? clrLimeGreen : (src == "FALLBACK" ? clrYellow : clrTomato));
      n++;
   }
   if(n < 24)
   {
      string scoreTxt = (g_predictionScore >= 0.0 ? DoubleToString(g_predictionScore, 3) : "N/A");
      lines[n] = "PredScore M1(7d): " + scoreTxt + " | Samples: " + IntegerToString(g_predictionSamples) +
                 " | Source: " + g_predictionScoreSource;
      cols[n] = (g_predictionScore >= 0.70 ? clrLimeGreen : (g_predictionScore >= 0.0 ? clrYellow : clrSilver));
      n++;
   }
   if(n < 24)
   {
      bool corrActive = IsInServerPredictedCorrectionZone();
      lines[n] = "CorrZone(SRV): " + string(corrActive ? "ACTIVE" : "OFF") +
                 " | Conf: " + DoubleToString(g_serverCorrectionConfidence, 1) +
                 "% | Action: " + g_serverCorrectionAction;
      cols[n] = (corrActive ? clrTomato : clrSilver);
      n++;
   }
   if(n < 24)
   {
      string localState = (g_symbolStatsLastLocalUpdate > 0 && (TimeGMT() - g_symbolStatsLastLocalUpdate) <= 30) ? "OK" : "STALE";
      string syncState = g_symbolStatsSyncOk ? "OK" : "FAIL";
      string syncAt = (g_symbolStatsLastSyncOk > 0) ? TimeToString(g_symbolStatsLastSyncOk, TIME_DATE|TIME_SECONDS) : "N/A";
      lines[n] = "DataStatus: MT5_LOCAL=" + localState + " | SYNC_SUPABASE=" + syncState + " | LAST_SYNC=" + syncAt;
      cols[n] = (g_symbolStatsSyncOk ? clrSilver : clrTomato);
      n++;
   }
   
   // Afficher l'ÃĐtat de la pause aprÃĻs profit journalier (basÃĐ sur l'historique)
   if(g_dailyProfitTargetReached && g_dailyProfitPauseStartTime > 0)
   {
      datetime pauseEndTime = g_dailyPauseUntil;
      int remainingSeconds = (int)(pauseEndTime - TimeCurrent());
      int remainingHours = remainingSeconds / 3600;
      int remainingMinutes = (remainingSeconds % 3600) / 60;
      lines[n] = "ðŊ PROFIT TARGET ATTEINT - PAUSE " + IntegerToString(remainingHours) + "h " + IntegerToString(remainingMinutes) + "min"; cols[n] = clrYellow; n++;
      lines[n] = "ð° Profit: " + DoubleToString(g_dayNetProfit, 2) + "$ / " + DoubleToString(DailyProfitTarget, 2) + "$ (historique)"; cols[n] = clrLime; n++;
   }
   else if(g_dayNetProfit >= DailyProfitTarget * 0.8) // Approche de l'objectif
   {
      double progress = (g_dayNetProfit / DailyProfitTarget) * 100.0;
      lines[n] = "ðŊ Objectif: " + DoubleToString(g_dayNetProfit, 2) + "$ / " + DoubleToString(DailyProfitTarget, 2) + "$ (" + DoubleToString(progress, 1) + "%)"; cols[n] = clrAqua; n++;
   }
   else
   {
      // Afficher le profit journalier normal
      lines[n] = "ð° Profit jour: " + DoubleToString(g_dayNetProfit, 2) + "$ / " + DoubleToString(DailyProfitTarget, 2) + "$"; cols[n] = clrWhite; n++;
   }
   // ML metrics affichÃĐes sÃĐparÃĐment dans DrawMLMetricsOnChart() pour ÃĐviter les doublons
   // Stats agrÃĐgÃĐes cÃītÃĐ serveur Ã  partir des donnÃĐes issues MT5 (trade_feedback) puis stockÃĐes dans Supabase `symbol_trade_stats` (UTC)
   // Si les stats serveur sont encore Ã  0, complÃĐter via historique local MT5
   EnsureLocalSymbolStatsUpToDate();
   string dayStr = FormatWLNet(g_dayWins, g_dayLosses, g_dayNetProfit);
   string monthStr = FormatWLNet(g_monthWins, g_monthLosses, g_monthNetProfit);
   // Lignes compactes (ÃĐvite que \"Net=xx$\" soit coupÃĐ Ã  droite)
   lines[n] = "[Performance] StatsJ UTC(MT5): " + dayStr; cols[n] = clrWhite; n++;
   lines[n] = "StatsM UTC(MT5): " + monthStr; cols[n] = clrWhite; n++;
   
   // Ligne: Ãtat de protection par symbole
   string protectionStatus = "";
   color protectionColor = clrWhite;
   if(g_symbolTradingBlocked)
   {
      protectionStatus = "ðĻ SYMBOLE BLOQUÃ - Perte: " + DoubleToString(g_symbolCurrentLoss, 2) + "$ > " + DoubleToString(MaxLossPerSymbolDollars, 2) + "$";
      protectionColor = clrRed;
   }
   else if(g_symbolCurrentLoss > 0)
   {
      protectionStatus = "â ïļ Perte actuelle: " + DoubleToString(g_symbolCurrentLoss, 2) + "$ / " + DoubleToString(MaxLossPerSymbolDollars, 2) + "$";
      protectionColor = clrYellow;
   }
   else
   {
      protectionStatus = "â Symbole protÃĐgÃĐ - Aucune perte actuelle";
      protectionColor = clrLimeGreen;
   }
   lines[n] = protectionStatus; cols[n] = protectionColor; n++;
   
   // NOUVEAU: Afficher les prÃĐdictions de Protected Points futurs
   double futureSupport = 0.0, futureResistance = 0.0;
   bool hasFutureLevels = GetFutureProtectedPointLevels(futureSupport, futureResistance);
   
   if(hasFutureLevels)
   {
      string predictionStatus = "ðŪ PRÃDICTIONS FUTURES: ";
      color predictionColor = clrCyan;
      
      // Affichage spÃĐcifique selon le type de symbole pour les ordres limit
      bool isBoom = (StringFind(_Symbol, "Boom") >= 0);
      bool isCrash = (StringFind(_Symbol, "Crash") >= 0);
      
      if(isBoom && futureSupport > 0)
      {
         predictionStatus += "BUY LIMIT @ " + DoubleToString(futureSupport, _Digits) + " (Support futur)";
      }
      else if(isCrash && futureResistance > 0)
      {
         predictionStatus += "SELL LIMIT @ " + DoubleToString(futureResistance, _Digits) + " (RÃĐsistance future)";
      }
      else if(futureSupport > 0 && futureResistance > 0)
      {
         predictionStatus += "S:" + DoubleToString(futureSupport, _Digits) + " | R:" + DoubleToString(futureResistance, _Digits);
      }
      else if(futureSupport > 0)
      {
         predictionStatus += "Support: " + DoubleToString(futureSupport, _Digits);
      }
      else if(futureResistance > 0)
      {
         predictionStatus += "RÃĐsistance: " + DoubleToString(futureResistance, _Digits);
      }
      else
      {
         predictionStatus = "ðŪ Calcul en cours...";
      }
      
      lines[n] = predictionStatus; cols[n] = predictionColor; n++;
   }

   // --- Afficher les LIMIT pending rÃĐellement en place (BUY_LIMIT/SELL_LIMIT) ---
   // Utile pour confirmer que les prÃĐdictions futures ont bien ÃĐtÃĐ transformÃĐes en ordres.
   int shownPending = 0;
   for(int oi = OrdersTotal() - 1; oi >= 0 && shownPending < 2; oi--)
   {
      ulong oticket = OrderGetTicket(oi);
      if(oticket == 0) continue;
      if(OrderGetInteger(ORDER_MAGIC) != InpMagicNumber) continue;
      if(OrderGetString(ORDER_SYMBOL) != _Symbol) continue;

      ENUM_ORDER_TYPE ot = (ENUM_ORDER_TYPE)OrderGetInteger(ORDER_TYPE);
      if(ot != ORDER_TYPE_BUY_LIMIT && ot != ORDER_TYPE_SELL_LIMIT) continue;

      double op = OrderGetDouble(ORDER_PRICE_OPEN);
      double osl = OrderGetDouble(ORDER_SL);
      double otp = OrderGetDouble(ORDER_TP);

      string side = (ot == ORDER_TYPE_BUY_LIMIT ? "BUY_LIMIT" : "SELL_LIMIT");
      string slStr = (osl > 0 ? DoubleToString(osl, _Digits) : "â");
      string tpStr = (otp > 0 ? DoubleToString(otp, _Digits) : "â");

      if(n < 24) // garder de la place pour le reste
      {
         lines[n] = "ð PENDING " + side + " @ " + DoubleToString(op, _Digits) + " SL " + slStr + " TP " + tpStr;
         cols[n] = (ot == ORDER_TYPE_BUY_LIMIT ? clrLime : clrTomato);
         n++;
      }
      shownPending++;
   }

   // Si on a une prÃĐdiction mais aucun pending limit, on loggue une indication rapide cÃītÃĐ dashboard.
   if(hasFutureLevels && totalLimits == 0 && n < 24)
   {
      lines[n] = "â ïļ PrÃĐdiction future active mais aucun LIMIT pending envoyÃĐ";
      cols[n] = clrYellow;
      n++;
   }
   
   DrawDashboardOnChart(lines, cols, n);

   if(ShowMLMetrics)
      DrawMLMetricsOnChart();

   // Top symbols "propices" (profil horaire) : label sÃĐparÃĐ, placÃĐ sous le dashboard (ÃĐvite superposition)
   {
      // AmÃĐlioration: Afficher l'heure actuelle et les symbols propices de maniÃĻre plus claire
      datetime currentTime = TimeCurrent();
      string currentTimeStr = TimeToString(currentTime, TIME_MINUTES); // Format HH:MM
      string utcTimeStr = TimeToString(currentTime, TIME_MINUTES|TIME_SECONDS); // Format UTC complet
      
      // Construire un affichage plus informatif
      string propTxt;
      if(g_propiceTopSymbolsText == "" || g_propiceTopSymbolsText == "En attente...")
      {
         propTxt = "Mise Ã  jour en cours (" + currentTimeStr + ")";
      }
      else
      {
         propTxt = g_propiceTopSymbolsText + " (Heure: " + currentTimeStr + ")";
      }
      
      string propFlag = UsePropiceSymbolsFilter ? (g_currentSymbolIsPropice ? "â ACTIF" : "ðŦ BLOQUÃ") : "â ïļ FILTRE OFF";
      string propStatus = (g_propiceTopSymbolsStatus == "" ? "..." : g_propiceTopSymbolsStatus);
      
      // Ajouter la prioritÃĐ du symbole si propice
      string priorityInfo = "";
      if(UsePropiceSymbolsFilter && g_currentSymbolIsPropice && g_currentSymbolPriority >= 0)
      {
         if(g_currentSymbolPriority == 0)
            priorityInfo = " ðĨ PLUS PROPICE";
         else if(g_currentSymbolPriority == 1)
            priorityInfo = " ðĨ 2ÃĻme";
         else if(g_currentSymbolPriority == 2)
            priorityInfo = " ðĨ 3ÃĻme";
         else
            priorityInfo = " ð " + IntegerToString(g_currentSymbolPriority + 1) + "ÃĻme";
      }
      
      // Affichage amÃĐliorÃĐ avec plus de dÃĐtails et prioritÃĐ
      string propLine = "ð SYMBOLS PROPICES (UTC " + utcTimeStr + "): " + propTxt + " | " + _Symbol + ": " + propFlag + priorityInfo + " | " + propStatus;
      string name = "SMC_PROPICE_LINE";
      if(ObjectFind(0, name) < 0)
      {
         ObjectCreate(0, name, OBJ_LABEL, 0, 0, 0);
         ObjectSetInteger(0, name, OBJPROP_CORNER, CORNER_LEFT_UPPER);
         ObjectSetString(0, name, OBJPROP_FONT, "Consolas");
         ObjectSetInteger(0, name, OBJPROP_FONTSIZE, 7);  // RÃĐduit Ã  7 pour cohÃĐrence
         ObjectSetInteger(0, name, OBJPROP_BACK, false);  // Premier plan pour visibilitÃĐ
      }
      
      // Calculer la position Y pour ÃĐviter la superposition avec les ML Metrics
      int propiceY = MathMax(0, g_dashboardBottomY + PropiceLabelExtraYOffsetPixels + 25);  // +25px d'espacement supplÃĐmentaire
      int chartH = (int)ChartGetInteger(0, CHART_HEIGHT_IN_PIXELS, 0);
      if(chartH <= 0 || propiceY > (chartH - 30))
      {
         // Si on dÃĐpasse l'ÃĐcran, ancrer en bas-gauche pour garantir visibilitÃĐ
         ObjectSetInteger(0, name, OBJPROP_CORNER, CORNER_LEFT_LOWER);
         propiceY = 10;
      }
      else
      {
         ObjectSetInteger(0, name, OBJPROP_CORNER, CORNER_LEFT_UPPER);
      }
      
      ObjectSetInteger(0, name, OBJPROP_XDISTANCE, MathMax(0, DashboardLabelXOffsetPixels));
      ObjectSetInteger(0, name, OBJPROP_YDISTANCE, propiceY);
      ObjectSetInteger(0, name, OBJPROP_COLOR, g_currentSymbolIsPropice ? clrLime : clrYellow);
      ObjectSetString(0, name, OBJPROP_TEXT, propLine);
      
      static datetime lastPropiceDebugLog = 0;
      if(DebugMLMetricsHttp && TimeCurrent() - lastPropiceDebugLog >= 300)
      {
         Print("?? DEBUG Propice - y=", propiceY, " | dashboardBottom=", g_dashboardBottomY);
         lastPropiceDebugLog = TimeCurrent();
      }
   }

   // Top 3 net profit + performance globale modÃĻle (en bas Ã  droite)
   if(ShowTop3NetProfitBottomRight)
   {
      string nameRight = "SMC_TOP_NET_RIGHT";
      if(ObjectFind(0, nameRight) < 0)
      {
         ObjectCreate(0, nameRight, OBJ_LABEL, 0, 0, 0);
         ObjectSetString(0, nameRight, OBJPROP_FONT, "Consolas");
         ObjectSetInteger(0, nameRight, OBJPROP_FONTSIZE, 8);
         ObjectSetInteger(0, nameRight, OBJPROP_BACK, false);
      }
      ObjectSetInteger(0, nameRight, OBJPROP_CORNER, CORNER_RIGHT_LOWER);
      ObjectSetInteger(0, nameRight, OBJPROP_XDISTANCE, 10);
      ObjectSetInteger(0, nameRight, OBJPROP_YDISTANCE, 10);
      ObjectSetInteger(0, nameRight, OBJPROP_COLOR, clrAqua);
      string perfTxt = (g_globalModelPerfPct >= 0.0 ? DoubleToString(g_globalModelPerfPct, 1) + "%" : "N/A");
      string rightTxt =
         "Top3 Net$ (30j)\n" +
         "1) " + g_top1Symbol + " : " + DoubleToString(g_top1NetUSD, 2) + "$\n" +
         "2) " + g_top2Symbol + " : " + DoubleToString(g_top2NetUSD, 2) + "$\n" +
         "3) " + g_top3Symbol + " : " + DoubleToString(g_top3NetUSD, 2) + "$\n" +
         "Perf Globale ModÃĻle: " + perfTxt + " | Samples: " + IntegerToString(g_globalModelSamples);
      ObjectSetString(0, nameRight, OBJPROP_TEXT, rightTxt);
   }
   else
   {
      ObjectDelete(0, "SMC_TOP_NET_RIGHT");
   }

   // Fallback "si labels invisibles": afficher aussi en Comment()
   if(DashboardUseCommentFallback)
   {
      string cmt = "";
      for(int i = 0; i < n; i++)
      {
         if(i > 0) cmt += "\n";
         cmt += lines[i];
      }
      cmt += "\n";
      cmt += "Top propices (UTC): " + (g_propiceTopSymbolsText == "" ? "En attente..." : g_propiceTopSymbolsText);
      Comment(cmt);
   }
}

void UpdateMLMetricsDisplay()
{
   // RÃĐduire la frÃĐquence des logs DEBUG pour ÃĐviter la surcharge
   static datetime lastDebugLog = 0;
   if(DebugMLMetricsHttp && TimeCurrent() - lastDebugLog >= 60)
   {
      Print("?? DEBUG - UpdateMLMetricsDisplay appelÃĐe pour: ", _Symbol);
      lastDebugLog = TimeCurrent();
   }
   
   // Protection contre les appels excessifs - minimum 30 s entre les appels
   if((TimeCurrent() - g_lastMLMetricsUpdate) < 30)
   {
      static datetime s_lastSkipLog = 0;
      if(DebugMLMetricsHttp && TimeCurrent() - s_lastSkipLog >= 120)
      {
         Print("?? DEBUG - UpdateMLMetricsDisplay ignorÃĐe (trop rÃĐcent) | ", _Symbol);
         s_lastSkipLog = TimeCurrent();
      }
      return;
   }
   
   g_lastMLMetricsUpdate = TimeCurrent();
   string symEnc = _Symbol;
   StringReplace(symEnc, " ", "%20");
   string baseUrl = UseRenderAsPrimary ? AI_ServerRender : AI_ServerURL;
   string pathMetrics = "/ml/metrics?symbol=" + symEnc + "&timeframe=M1";
   string pathApiMetrics = "/api/ml/metrics/" + symEnc + "?timeframe=M1";
   string pathStatus = "/ml/continuous/status";
   string headers = "";
   char post[], result[];
   string resultHeaders;
   
   if(DebugMLMetricsHttp)
      Print("?? DEBUG - RequÃŠte ML vers: ", baseUrl, pathMetrics);
   
   // RÃĐcupÃĐrer les mÃĐtriques ML (primaire puis fallback)
   int res = WebRequest("GET", baseUrl + pathMetrics, headers, AI_Timeout_ms, post, result, resultHeaders);
   if(res != 200)
   {
      string fallbackUrl = UseRenderAsPrimary ? AI_ServerURL : AI_ServerRender;
      if(DebugMLMetricsHttp)
         Print("?? DEBUG - Fallback ML metrics vers: ", fallbackUrl, pathMetrics);
      res = WebRequest("GET", fallbackUrl + pathMetrics, headers, AI_Timeout_ms2, post, result, resultHeaders);
   }
   
   if(DebugMLMetricsHttp)
      Print("?? DEBUG - WebRequest ML metrics - Code: ", res, " | Taille: ", ArraySize(result));
   
   if(res == 200)
   {
      string metricsData = CharArrayToString(result);
      if(DebugMLMetricsHttp)
         Print("?? DEBUG - DonnÃĐes ML reÃ§ues: ", StringSubstr(metricsData, 0, MathMin(200, StringLen(metricsData))));
      
      // Parser les mÃĐtriques et les afficher (clÃĐs plates: accuracy, model_name, total_samples, status, feedback_wins, feedback_losses)
      if(StringFind(metricsData, "accuracy") >= 0)
      {
         string acc = ExtractJsonValue(metricsData, "accuracy");
         string model = ExtractJsonValue(metricsData, "model_name");
         string samples = ExtractJsonValue(metricsData, "total_samples");
         string status = ExtractJsonValue(metricsData, "status");
         string wins = ExtractJsonValue(metricsData, "feedback_wins");
         string losses = ExtractJsonValue(metricsData, "feedback_losses");
         string dataSource = ExtractJsonValue(metricsData, "data_source");
         string rel = ExtractJsonValue(metricsData, "reliability_score");
         string sbConn = ExtractJsonValue(metricsData, "supabase_connected");
         string sbSync = ExtractJsonValue(metricsData, "last_supabase_sync");
         g_mlMetricsStr = "PrÃĐcision: " + acc + "% | ModÃĻle: " + model + " | Samples: " + samples;
         // Mettre Ã  jour les variables numÃĐriques pour gating par catÃĐgorie
         g_mlLastAccuracy = (StringLen(acc) > 0 && acc != "N/A") ? StringToDouble(acc) : -1.0;
         g_mlLastModelName = model;
         if(rel != "N/A" && StringLen(rel) > 0)
            g_mlLastReliability = StringToDouble(rel);
         else
            g_mlLastReliability = -1.0;
         if(wins != "N/A" && losses != "N/A")
            g_mlMetricsStr += " | Feedback: " + wins + "W/" + losses + "L";
         if(status != "N/A" && status != "trained")
            g_mlMetricsStr += " | " + (status == "collecting_data" ? "Collecte donnÃĐes..." : status);
         if(dataSource != "N/A")
            g_mlMetricsStr += " | Source: " + dataSource;
         else if(sbConn != "N/A")
            g_mlMetricsStr += " | Supabase: " + sbConn;
         if(sbSync != "N/A")
            g_mlMetricsStr += " | Sync: " + sbSync;
         if(rel != "N/A")
            g_mlMetricsStr += " | Rel: " + rel;

         // 2e appel (throttlÃĐ par UpdateMLMetricsDisplay) pour rÃĐcupÃĐrer precision/recall depuis l'endpoint compat EA.
         // On ne bloque pas si indisponible.
         char result2[];
         string resultHeaders2;
         int res2 = WebRequest("GET", baseUrl + pathApiMetrics, headers, AI_Timeout_ms, post, result2, resultHeaders2);
         if(res2 != 200)
         {
            string fallbackUrl3 = UseRenderAsPrimary ? AI_ServerURL : AI_ServerRender;
            res2 = WebRequest("GET", fallbackUrl3 + pathApiMetrics, headers, AI_Timeout_ms2, post, result2, resultHeaders2);
         }
         if(res2 == 200)
         {
            string apiData = CharArrayToString(result2);
            string prec = ExtractJsonValue(apiData, "precision");
            string rec = ExtractJsonValue(apiData, "recall");
            // Valeurs 0..1 (mais tolÃĻre %)
            if(prec != "N/A" && StringLen(prec) > 0)
            {
               double pv = StringToDouble(prec);
               if(pv > 1.0) pv /= 100.0;
               g_mlLastPrecision = pv;
               g_mlMetricsStr += " | Prec: " + DoubleToString(pv * 100.0, 1) + "%";
            }
            else g_mlLastPrecision = -1.0;
            if(rec != "N/A" && StringLen(rec) > 0)
            {
               double rv = StringToDouble(rec);
               if(rv > 1.0) rv /= 100.0;
               g_mlLastRecall = rv;
               g_mlMetricsStr += " | Rec: " + DoubleToString(rv * 100.0, 1) + "%";
            }
            else g_mlLastRecall = -1.0;
         }
         else
         {
            g_mlLastPrecision = -1.0;
            g_mlLastRecall = -1.0;
         }
         if(DebugMLMetricsHttp)
            Print("? DEBUG - MÃĐtriques ML mises Ã  jour: ", g_mlMetricsStr);
      }
      else if(StringFind(metricsData, "status") >= 0)
      {
         string status = ExtractJsonValue(metricsData, "status");
         g_mlMetricsStr = (status == "collecting_data") ? "ML: Collecte de donnÃĐes en cours..." : "ML: " + status;
      }
      else
      {
         g_mlMetricsStr = "ML: En attente de donnÃĐes...";
         if(DebugMLMetricsHttp)
            Print("?? DEBUG - Pas de mÃĐtriques trouvÃĐes");
      }

      // Extraire aussi les stats jour/mois par symbole (source serveur/Supabase) si prÃĐsentes
      // (clÃĐs attendues: day_wins, day_losses, day_net_profit, month_wins, month_losses, month_net_profit)
      string sDW = ExtractJsonValue(metricsData, "day_wins");
      string sDL = ExtractJsonValue(metricsData, "day_losses");
      string sDNP = ExtractJsonValue(metricsData, "day_net_profit");
      string sMW = ExtractJsonValue(metricsData, "month_wins");
      string sML = ExtractJsonValue(metricsData, "month_losses");
      string sMNP = ExtractJsonValue(metricsData, "month_net_profit");
      if(sDW != "N/A") g_dayWins = (int)StringToInteger(sDW);
      if(sDL != "N/A") g_dayLosses = (int)StringToInteger(sDL);
      if(sDNP != "N/A") g_dayNetProfit = StringToDouble(sDNP);
      if(sMW != "N/A") g_monthWins = (int)StringToInteger(sMW);
      if(sML != "N/A") g_monthLosses = (int)StringToInteger(sML);
      if(sMNP != "N/A") g_monthNetProfit = StringToDouble(sMNP);
   }
   else
   {
      // Fallback (serveur indisponible)
      GenerateFallbackMLMetrics();
      g_mlMetricsStr = "ML: Serveur indisponible (fallback actif)";
      if(DebugMLMetricsHttp)
         Print("? DEBUG - Erreur WebRequest ML metrics: ", res);
   }
   
   // S'assurer que l'entraÃŪnement continu tourne (si activÃĐ)
   if(AutoStartMLContinuousTraining)
      EnsureMLContinuousTrainingRunning(false);

   // RÃĐcupÃĐrer le statut du canal
   int resStatus = WebRequest("GET", baseUrl + pathStatus, headers, AI_Timeout_ms, post, result, resultHeaders);
   if(resStatus != 200)
   {
      string fallbackUrl2 = UseRenderAsPrimary ? AI_ServerURL : AI_ServerRender;
      resStatus = WebRequest("GET", fallbackUrl2 + pathStatus, headers, AI_Timeout_ms2, post, result, resultHeaders);
   }
   
   if(DebugMLMetricsHttp)
      Print("?? DEBUG - WebRequest ML status - Code: ", resStatus);
   
   if(resStatus == 200)
   {
      string statusData = CharArrayToString(result);
      g_channelValid = (StringFind(statusData, "\"valid\": true") >= 0);
      if(DebugMLMetricsHttp)
         Print("? DEBUG - Canal ML valide: ", g_channelValid ? "OUI" : "NON");
   }
   else
   {
      g_channelValid = false;
      if(DebugMLMetricsHttp)
         Print("? DEBUG - Erreur WebRequest ML status: ", resStatus);
   }
}

string ExtractJsonValue(string json, string key)
{
   string searchKey = "\"" + key + "\":";
   int start = StringFind(json, searchKey);
   if(start < 0) return "N/A";
   
   start += StringLen(searchKey);
   while(start < StringLen(json) && (json[start] == ' ' || json[start] == '\t')) start++;
   
   int end = start;
   while(end < StringLen(json) && json[end] != ',' && json[end] != '}' && json[end] != '\n') end++;
   
   string value = StringSubstr(json, start, end - start);
   StringReplace(value, "\"", "");
   StringReplace(value, " ", "");
   
   return value;
}

//| FONCTIONS IA - COMMUNICATION AVEC LE SERVEUR (copie legacy)       |

bool UpdateAIDecision_Legacy(int timeoutMs = -1)
{
   // Protection contre les appels excessifs
   static datetime lastAttempt = 0;
   datetime currentTime = TimeCurrent();
   if(currentTime - lastAttempt < 5) return false; // Max 1 appel / 5 secondes
   lastAttempt = currentTime;
   
   string symEnc = _Symbol;
   StringReplace(symEnc, " ", "%20");
   
   // Utiliser Render en premier si configurÃĐ
   string baseUrl = UseRenderAsPrimary ? AI_ServerRender : AI_ServerURL;
   string path = "/ml/decision?symbol=" + symEnc + "&timeframe=M1";
   string headers = "";
   char post[], result[];
   string resultHeaders;
   
   int res = WebRequest("GET", baseUrl + path, headers, timeoutMs > 0 ? timeoutMs : AI_Timeout_ms, post, result, resultHeaders);
   
   if(res != 200)
   {
      // Fallback vers l'autre URL si ÃĐchec
      string fallbackUrl = UseRenderAsPrimary ? AI_ServerURL : AI_ServerRender;
      res = WebRequest("GET", fallbackUrl + path, headers, timeoutMs > 0 ? timeoutMs : AI_Timeout_ms, post, result, resultHeaders);
      
      if(res != 200)
      {
         Print("? ERREUR IA - Ãchec des deux serveurs: ", res);
         return false;
      }
   }
   
   string jsonData = CharArrayToString(result);
   ProcessAIDecision(jsonData);
   
   Print("? DÃĐcision IA reÃ§ue - Action: ", g_lastAIAction, " | Confiance: ", DoubleToString(g_lastAIConfidence*100, 1), "%");
   return true;
}

