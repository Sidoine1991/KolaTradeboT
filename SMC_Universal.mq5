      ObjectCreate(0, txtName, OBJ_LABEL, 0, 0, 0);

   ObjectSetInteger(0, txtName, OBJPROP_CORNER, CORNER_LEFT_LOWER);
   ObjectSetInteger(0, txtName, OBJPROP_COLOR, clrWhite);
