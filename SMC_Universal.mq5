//+------------------------------------------------------------------+
//| VRAI SETUP SMC DE PRÃDICTION - 200 BOUGIES M1                  |
//+------------------------------------------------------------------+
void DrawSMCPredictionSetup()
{
   // Supprimer les anciens setups de prÃĐdiction
   ObjectsDeleteAll(0, "SMC_PRED_");
   
   // ParamÃĻtres de base
   datetime timeStart = TimeCurrent();
   datetime timeEnd = timeStart + PeriodSeconds(PERIOD_M1) * 200; // 200 bougies M1
   
   // RÃĐcupÃĐrer les donnÃĐes pour identifier les niveaux clÃĐs
   MqlRates rates[];
   ArraySetAsSeries(rates, true);
   int copied = CopyRates(_Symbol, PERIOD_M1, 0, 50, rates);
   if(copied < 20) return;
   
   double currentPrice = rates[0].close;
   double swingHigh = rates[0].high;
   double swingLow = rates[0].low;
   
   // Trouver le swing high/low sur les derniÃĻres 30 bougies
   for(int i = 0; i < 30 && i < copied; i++)
   {
      swingHigh = MathMax(swingHigh, rates[i].high);
      swingLow = MathMin(swingLow, rates[i].low);
   }
   
   // DÃĐterminer la direction dominante
   string direction = (currentPrice > (swingHigh + swingLow) / 2) ? "HAUSSIER" : "BAISSIER";
   
   // ===== CONFIGURATION DU SETUP =====
   double bosHigh, bosLow, chochLevel, orderBlockHigh, orderBlockLow;
   double entry, stopLoss, takeProfit;
   color dirColor, entryColor;
   
   if(direction == "HAUSSIER")
   {
      // Setup HAUSSIER: cherche une zone Ã  casser vers le haut
      bosLow = swingLow;
      bosHigh = swingLow + (swingHigh - swingLow) * 0.618; // Fibonacci 61.8%
      chochLevel = bosHigh + (swingHigh - swingLow) * 0.2;
      orderBlockHigh = bosHigh + (swingHigh - swingLow) * 0.05;
      orderBlockLow = bosHigh - (swingHigh - swingLow) * 0.05;
      
      // Zones Fibonacci pour calcul de l'entrÃĐe
      double fiboRange = swingHigh - bosLow;
      double fibo_886 = bosLow + fiboRange * 0.886;
      double fibo_79  = bosLow + fiboRange * 0.79;
      double fibo_705 = bosLow + fiboRange * 0.705;
      double fibo_50  = bosLow + fiboRange * 0.50; // EntrÃĐe
      
      entry = fibo_50;
      stopLoss = bosLow - (swingHigh - swingLow) * 0.1;
      double riskInPips = (entry - stopLoss) / SymbolInfoDouble(_Symbol, SYMBOL_POINT);
      takeProfit = entry + (riskInPips * 5 * SymbolInfoDouble(_Symbol, SYMBOL_POINT));
      
      dirColor = clrGreen;
      entryColor = clrLime;
      
      // === TRACER SETUP HAUSSIER ===
      
      // 1. BOS - Ligne pointillÃĐe du break of structure
      string bosLine = "SMC_PRED_BOS_LINE";
      ObjectCreate(0, bosLine, OBJ_TREND, 0, timeStart, bosLow, timeEnd, bosLow);
      ObjectSetInteger(0, bosLine, OBJPROP_COLOR, clrOrange);
      ObjectSetInteger(0, bosLine, OBJPROP_STYLE, STYLE_DASH);
      ObjectSetInteger(0, bosLine, OBJPROP_WIDTH, 2);
      ObjectSetInteger(0, bosLine, OBJPROP_BACK, true);
      
      string bosLabel = "SMC_PRED_BOS_LABEL";
      ObjectCreate(0, bosLabel, OBJ_TEXT, 0, timeStart + PeriodSeconds(PERIOD_M1) * 10, bosLow - (swingHigh - swingLow) * 0.02);
      ObjectSetString(0, bosLabel, OBJPROP_TEXT, "BOS");
      ObjectSetInteger(0, bosLabel, OBJPROP_COLOR, clrOrange);
      ObjectSetInteger(0, bosLabel, OBJPROP_FONTSIZE, 9);
      
      // 2. CHoCH - Zone de changement de caractÃĻre
      string chochZone = "SMC_PRED_CHOCH_ZONE";
      ObjectCreate(0, chochZone, OBJ_RECTANGLE, 0, 
                   timeStart + PeriodSeconds(PERIOD_M1) * 30, chochLevel - (swingHigh - swingLow) * 0.02,
                   timeStart + PeriodSeconds(PERIOD_M1) * 50, chochLevel + (swingHigh - swingLow) * 0.02);
      ObjectSetInteger(0, chochZone, OBJPROP_COLOR, clrPurple);
      ObjectSetInteger(0, chochZone, OBJPROP_BGCOLOR, C'150,100,200');
      ObjectSetInteger(0, chochZone, OBJPROP_FILL, true);
      ObjectSetInteger(0, chochZone, OBJPROP_BACK, true);
      
      string chochLabel = "SMC_PRED_CHOCH_LABEL";
      ObjectCreate(0, chochLabel, OBJ_TEXT, 0, timeStart + PeriodSeconds(PERIOD_M1) * 35, chochLevel + (swingHigh - swingLow) * 0.05);
      ObjectSetString(0, chochLabel, OBJPROP_TEXT, "CHoCH");
      ObjectSetInteger(0, chochLabel, OBJPROP_COLOR, clrPurple);
      ObjectSetInteger(0, chochLabel, OBJPROP_FONTSIZE, 9);
      
      // 3. Order Block - Zone de liquidity
      string obZone = "SMC_PRED_OB_ZONE";
      ObjectCreate(0, obZone, OBJ_RECTANGLE, 0, 
                   timeStart + PeriodSeconds(PERIOD_M1) * 50, orderBlockLow,
                   timeStart + PeriodSeconds(PERIOD_M1) * 80, orderBlockHigh);
      ObjectSetInteger(0, obZone, OBJPROP_COLOR, clrSkyBlue);
      ObjectSetInteger(0, obZone, OBJPROP_BGCOLOR, C'173,216,230');
      ObjectSetInteger(0, obZone, OBJPROP_FILL, true);
      ObjectSetInteger(0, obZone, OBJPROP_BACK, true);
      
      string obLabel = "SMC_PRED_OB_LABEL";
      ObjectCreate(0, obLabel, OBJ_TEXT, 0, timeStart + PeriodSeconds(PERIOD_M1) * 65, (orderBlockLow + orderBlockHigh) / 2);
      ObjectSetString(0, obLabel, OBJPROP_TEXT, "Order Block");
      ObjectSetInteger(0, obLabel, OBJPROP_COLOR, clrSkyBlue);
      ObjectSetInteger(0, obLabel, OBJPROP_FONTSIZE, 8);
      
      // 4. Zones Fibonacci - Lignes de retracÃĐs
      DrawFibonacciLevelsForPrediction(timeStart, timeEnd, bosLow, fibo_886, "886", clrGray);
      DrawFibonacciLevelsForPrediction(timeStart, timeEnd, bosLow, fibo_79, "79", clrGray);
      DrawFibonacciLevelsForPrediction(timeStart, timeEnd, bosLow, fibo_705, "705", clrGray);
      
      // 5. M5 TREND ENTRY POINT - Ligne de tendance haussiÃĻre
      double m5TrendSlope = (swingHigh - bosLow) / 100.0; // Pente modÃĐrÃĐe
      string m5TrendLine = "SMC_PRED_M5_TREND_LINE";
      ObjectCreate(0, m5TrendLine, OBJ_TREND, 0, 
                   timeStart + PeriodSeconds(PERIOD_M1) * 80, bosLow,
                   timeEnd, bosLow + m5TrendSlope * 120);
      ObjectSetInteger(0, m5TrendLine, OBJPROP_COLOR, clrYellow);
      ObjectSetInteger(0, m5TrendLine, OBJPROP_STYLE, STYLE_SOLID);
      ObjectSetInteger(0, m5TrendLine, OBJPROP_WIDTH, 2);
      ObjectSetInteger(0, m5TrendLine, OBJPROP_BACK, false);
      
      string m5TrendLabel = "SMC_PRED_M5_TREND_LABEL";
      ObjectCreate(0, m5TrendLabel, OBJ_TEXT, 0, timeStart + PeriodSeconds(PERIOD_M1) * 100, 
                   bosLow + m5TrendSlope * 40);
      ObjectSetString(0, m5TrendLabel, OBJPROP_TEXT, "M5 TREND ENTRY");
      ObjectSetInteger(0, m5TrendLabel, OBJPROP_COLOR, clrYellow);
      ObjectSetInteger(0, m5TrendLabel, OBJPROP_FONTSIZE, 9);
      ObjectSetInteger(0, m5TrendLabel, OBJPROP_BACK, false);
      
      // 5b. ENTRY au 50%
      string entryZone = "SMC_PRED_ENTRY_ZONE";
      ObjectCreate(0, entryZone, OBJ_RECTANGLE, 0, 
                   timeStart + PeriodSeconds(PERIOD_M1) * 80, entry - (swingHigh - swingLow) * 0.01,
                   timeStart + PeriodSeconds(PERIOD_M1) * 100, entry + (swingHigh - swingLow) * 0.01);
      ObjectSetInteger(0, entryZone, OBJPROP_COLOR, entryColor);
      ObjectSetInteger(0, entryZone, OBJPROP_BGCOLOR, C'144,238,144');
      ObjectSetInteger(0, entryZone, OBJPROP_FILL, true);
      ObjectSetInteger(0, entryZone, OBJPROP_BACK, true);
      
      string entryLine = "SMC_PRED_ENTRY_LINE";
