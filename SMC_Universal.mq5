//| ROTATION AUTOMATIQUE DES POSITIONS - Évite de rester bloqué sur un symbole |
void AutoRotatePositions()
{
   int totalPositions = CountPositionsOurEA();
   
   // Si on n'est pas à la limite de positions, pas besoin de rotation
   if(totalPositions < MaxPositionsTerminal)
   {
      return;
   }
   
   // Si on est à la limite, vérifier s'il y a des opportunités sur d'autres symboles
   Print("?? ROTATION AUTO - Positions: ", totalPositions, "/", MaxPositionsTerminal, " - Vérification opportunités...");
   
   // Chercher la position la plus ancienne ou la moins performante
   ulong oldestTicket = 0;
   datetime oldestTime = TimeCurrent();
   double worstProfit = 999999;
   ulong worstTicket = 0;
   string worstSymbol = "";
   
   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      if(!posInfo.SelectByIndex(i)) continue;
      if(posInfo.Magic() != InpMagicNumber) continue;
      
      string symbol = posInfo.Symbol();
      double profit = posInfo.Profit() + posInfo.Swap() + posInfo.Commission();
      datetime openTime = posInfo.Time();
      ulong ticket = posInfo.Ticket();
      
      // Priorité 1: Position en perte depuis longtemps
      if(profit < -0.5 && openTime < oldestTime)
      {
         oldestTime = openTime;
         oldestTicket = ticket;
      }
      
      // Priorité 2: Position avec la pire performance
      if(profit < worstProfit)
      {
         worstProfit = profit;
         worstTicket = ticket;
         worstSymbol = symbol;
      }
   }
   
   // Fermer la position la plus ancienne en perte OU la pire position
   ulong ticketToClose = (oldestTicket > 0) ? oldestTicket : worstTicket;
   
   if(ticketToClose > 0)
   {
      if(!PositionSelectByTicket(ticketToClose))
      {
         Print("?? Position déjà fermée avant rotation - ticket=", ticketToClose);
         return;
      }
      
      string symbolToClose = PositionGetString(POSITION_SYMBOL);
      double positionProfit = PositionGetDouble(POSITION_PROFIT);
      
      // Fermer seulement si c'est une position en perte ou si elle est ouverte depuis plus de 30 minutes
      datetime positionTime = (datetime)PositionGetInteger(POSITION_TIME);
      int minutesOpen = (int)(TimeCurrent() - positionTime) / 60;
      
      if(positionProfit < -0.2 || minutesOpen > 30)
      {
         Print("?? ROTATION AUTO - Fermeture position: ", symbolToClose, 
               " | Profit: ", DoubleToString(positionProfit, 2), "$",
               " | Âge: ", minutesOpen, " min");
         
         if(PositionCloseWithLog(ticketToClose, "Rotation automatique"))
         {
            Print("? ROTATION AUTO - Position fermée avec succès - Libère place pour nouvelles opportunités");
         }
         else
         {
            int err = GetLastError();
            Print("? ROTATION AUTO - Échec fermeture position: ", symbolToClose, " | Erreur: ", err);
         }
      }
      else
      {
         Print("?? ROTATION AUTO - Position conservée: ", symbolToClose, 
               " | Profit: ", DoubleToString(positionProfit, 2), "$",
               " | Âge: ", minutesOpen, " min (tôt ou profitable)");
      }
   }
   else
   {
      Print("?? ROTATION AUTO - Aucune position éligible à la fermeture");
   }
}

//+------------------------------------------------------------------+
//| FONCTIONS DE DÉTECTION SPIKES SANS IA                           |
//+------------------------------------------------------------------+

// Détection de spike de volume
bool IsVolumeSpikeDetected()
{
   return IsVolumeSpikeDetectedForSymbol(_Symbol);
}

// Détection de spike de prix
bool IsPriceSpikeDetected()
{
   return IsPriceSpikeDetectedForSymbol(_Symbol);
}

// Détection de spike de volume (multi-symbole)
bool IsVolumeSpikeDetectedForSymbol(const string symbol)
{
   SymbolSelect(symbol, true);
   double recentVolume = (double)iVolume(symbol, PERIOD_M1, 0);
   if(recentVolume <= 0) return false;

   double avgVolume = 0.0;
   for(int i = 1; i <= 20; i++)
   {
      double v = (double)iVolume(symbol, PERIOD_M1, i);
      if(v <= 0) return false;
      avgVolume += v;
   }
   avgVolume /= 20.0;

   bool spikeDetected = (recentVolume > avgVolume * SpikeVolumeMultiplier);

   if(DebugSpikeDetection)
   {
      Print("📊 Volume Spike [", symbol, "] - Actuel: ", NormalizeDouble(recentVolume, 0),
            " | Moyenne: ", NormalizeDouble(avgVolume, 0),
            " | Spike: ", spikeDetected ? "OUI" : "NON");
   }

   return spikeDetected;
}

// Détection de spike de prix (multi-symbole)
bool IsPriceSpikeDetectedForSymbol(const string symbol)
{
   SymbolSelect(symbol, true);
   double hi = iHigh(symbol, PERIOD_M1, 0);
   double lo = iLow(symbol, PERIOD_M1, 0);
   if(hi == 0.0 && lo == 0.0) return false;

   double currentRange = hi - lo;
   double atr = iATR(symbol, PERIOD_M1, 20);
   if(atr <= 0.0) return false;

   double mult = SpikePriceMultiplier;
   // Crash: abaisser légèrement le seuil car les ticks sont parfois peu volumétriques et le range est plus "saccadé"
   if(IsCrashSymbol(symbol))
      mult = MathMin(mult, 1.2);

   // Ajuster le seuil en fonction de la confluence cumulative
   double confluenceFactor = GetSpikeConfluenceFactor(symbol);
   double adjustedMult = mult * confluenceFactor;
   bool spikeDetected = (currentRange > atr * adjustedMult);

   // Enregistrer l'heure du spike de marché détecté (pour fermeture persistante des positions)
   if(spikeDetected)
   {
      datetime now = TimeCurrent();
      if(IsBoomSymbol(symbol) || IsWeltradeGainSynthSymbol(symbol))
         g_lastBoomMarketSpikeDetectedTime = now;
      else if(IsCrashSymbol(symbol) || IsWeltradePainSynthSymbol(symbol))
         g_lastCrashMarketSpikeDetectedTime = now;
   }

   if(DebugSpikeDetection)
   {
      Print("📈 Prix Spike [", symbol, "] - Range: ", NormalizeDouble(currentRange, 5),
            " | ATR: ", NormalizeDouble(atr, 5),
            " | Spike: ", spikeDetected ? "OUI" : "NON");
   }

   return spikeDetected;
}

// Range M1 anormal sur bougie en cours (0) OU bougie clôturée (1) — souvent la capture se voit sur la clôture
bool IsBoomCrashM1SpikeRangeBars01(const string symbol)
{
   SymbolSelect(symbol, true);
   double atr = iATR(symbol, PERIOD_M1, 20);
   if(atr <= 0.0)
      return false;
   double mult = SpikePriceMultiplier;
   if(mult <= 0.0)
      mult = 1.5;
   if(IsCrashSymbol(symbol))
      mult = MathMin(mult, 1.2);

   // Ajuster le seuil en fonction de la confluence cumulative
   double confluenceFactor = GetSpikeConfluenceFactor(symbol);
   double adjustedMult = mult * confluenceFactor;
   double thr = atr * adjustedMult;

   double h0 = iHigh(symbol, PERIOD_M1, 0), l0 = iLow(symbol, PERIOD_M1, 0);
   double h1 = iHigh(symbol, PERIOD_M1, 1), l1 = iLow(symbol, PERIOD_M1, 1);
   double r0 = (h0 > 0 && l0 > 0) ? (h0 - l0) : 0.0;
   double r1 = (h1 > 0 && l1 > 0) ? (h1 - l1) : 0.0;
   bool spikeDetected = (r0 > thr || r1 > thr);

   // Enregistrer l'heure du spike de marché détecté
   if(spikeDetected)
   {
      datetime now = TimeCurrent();
      if(IsBoomSymbol(symbol) || IsWeltradeGainSynthSymbol(symbol))
         g_lastBoomMarketSpikeDetectedTime = now;
      else if(IsCrashSymbol(symbol) || IsWeltradePainSynthSymbol(symbol))
         g_lastCrashMarketSpikeDetectedTime = now;
   }

   return spikeDetected;
}

// Détection de confluence cumulative pour ajuster dynamiquement les seuils de spike
// Combine: range M1, volume, compression ATR pour abaisser les seuils en zone de forte confluence
// Retourne un facteur de réduction (0.7 = seuil réduit de 30%, 1.0 = pas de réduction)
double GetSpikeConfluenceFactor(const string symbol)
{
   SymbolSelect(symbol, true);
   double atr = iATR(symbol, PERIOD_M1, 20);
   if(atr <= 0.0) return 1.0;

   // 1. Vérifier le range M1 actuel vs ATR
   double h0 = iHigh(symbol, PERIOD_M1, 0), l0 = iLow(symbol, PERIOD_M1, 0);
   double h1 = iHigh(symbol, PERIOD_M1, 1), l1 = iLow(symbol, PERIOD_M1, 1);
   double r0 = (h0 > 0 && l0 > 0) ? (h0 - l0) : 0.0;
   double r1 = (h1 > 0 && l1 > 0) ? (h1 - l1) : 0.0;
   double maxRange = MathMax(r0, r1);
   double rangeRatio = (atr > 0.0) ? (maxRange / atr) : 0.0;

   // 2. Vérifier le volume actuel vs moyenne
   double recentVolume = (double)iVolume(symbol, PERIOD_M1, 0);
   double avgVolume = 0.0;
   for(int i = 1; i <= 20; i++)
   {
      double v = (double)iVolume(symbol, PERIOD_M1, i);
      if(v <= 0) continue;
      avgVolume += v;
   }
   avgVolume /= 20.0;
   double volumeRatio = (avgVolume > 0.0) ? (recentVolume / avgVolume) : 0.0;

   // 3. Vérifier la compression ATR
   double atrCurrent = iATR(symbol, PERIOD_M1, 1);
   double atrAvg = 0.0;
   for(int i = 2; i <= 21; i++)
   {
      atrAvg += iATR(symbol, PERIOD_M1, i);
   }
   atrAvg /= 20.0;
   bool compression = (atrCurrent < atrAvg * SpikeCompressionThreshold);

   // Calculer le facteur de confluence
   // Plus le ratio range est proche du seuil, plus le volume est élevé, plus on réduit le seuil
   double confluenceScore = 0.0;

   // Range proche du seuil (0.8-1.2 du SpikePriceMultiplier)
   if(rangeRatio >= 0.8 * SpikePriceMultiplier && rangeRatio <= 1.2 * SpikePriceMultiplier)
      confluenceScore += 0.3;
   else if(rangeRatio >= 0.6 * SpikePriceMultiplier)
      confluenceScore += 0.15;

   // Volume élevé
   if(volumeRatio >= 1.5 * SpikeVolumeMultiplier)
      confluenceScore += 0.35;
   else if(volumeRatio >= SpikeVolumeMultiplier)
      confluenceScore += 0.2;

   // Compression présente
   if(compression)
      confluenceScore += 0.35;

   // Facteur de réduction: 0.6 (très forte confluence) à 1.0 (pas de confluence)
   double confluenceFactor = 1.0 - (confluenceScore * 0.4); // Réduction max 40%
   confluenceFactor = MathMax(0.6, confluenceFactor); // Minimum 0.6

   if(DebugSpikeDetection)
   {
      Print("🎯 Confluence [", symbol, "] - RangeRatio: ", DoubleToString(rangeRatio, 2),
            " | VolumeRatio: ", DoubleToString(volumeRatio, 2),
            " | Compression: ", compression ? "OUI" : "NON",
            " | Score: ", DoubleToString(confluenceScore, 2),
            " | Facteur: ", DoubleToString(confluenceFactor, 2));
   }

   return confluenceFactor;
}

// Détection de séquence de spikes (pattern escalier comme sur RSI)
// Détecte si plusieurs bougies consécutives montrent des signaux de spike dans la même direction
bool IsSpikeSequenceDetected(const string symbol, const ENUM_POSITION_TYPE posType, int maxBars = 3)
{
   SymbolSelect(symbol, true);
   double atr = iATR(symbol, PERIOD_M1, 20);
   if(atr <= 0.0) return false;

   double mult = SpikePriceMultiplier;
   if(mult <= 0.0) mult = 1.5;
   if(IsCrashSymbol(symbol)) mult = MathMin(mult, 1.2);
   double thr = atr * mult * 0.7; // Seuil abaissé pour détecter les mini-spikes

   int consecutiveSpikes = 0;
   bool directionOk = false;

   for(int bar = 0; bar < maxBars; bar++)
   {
      double h = iHigh(symbol, PERIOD_M1, bar);
      double l = iLow(symbol, PERIOD_M1, bar);
      if(h <= 0.0 || l <= 0.0) continue;

      double range = h - l;
      if(range < thr) continue;

      double open = iOpen(symbol, PERIOD_M1, bar);
      if(open <= 0.0) continue;

      double close = (bar == 0) ? ((posType == POSITION_TYPE_SELL) ? SymbolInfoDouble(symbol, SYMBOL_BID)
                                                                     : SymbolInfoDouble(symbol, SYMBOL_ASK))
                                : iClose(symbol, PERIOD_M1, bar);

      // Vérifier la direction du spike
      bool spikeInDirection = false;
      if(posType == POSITION_TYPE_BUY && (IsBoomSymbol(symbol) || IsWeltradeGainSynthSymbol(symbol)))
      {
         spikeInDirection = (close > open && (close - open) >= range * 0.08);
      }
      else if(posType == POSITION_TYPE_SELL && (IsCrashSymbol(symbol) || IsWeltradePainSynthSymbol(symbol)))
      {
         spikeInDirection = (close < open && (open - close) >= range * 0.08);
      }

      if(spikeInDirection)
      {
         consecutiveSpikes++;
         directionOk = true;
      }
      else
      {
         // Si on a une séquence, on peut tolérer une bougie neutre
         if(consecutiveSpikes > 0 && range >= thr * 0.5)
            consecutiveSpikes++;
         else
            break;
      }
   }

   bool sequenceDetected = (consecutiveSpikes >= 2); // Au moins 2 bougies avec spike

   if(DebugSpikeDetection && sequenceDetected)
   {
      Print("📊 Séquence Spike [", symbol, "] - Bougies consécutives: ", consecutiveSpikes,
            " | Direction OK: ", directionOk ? "OUI" : "NON");
   }

   return sequenceDetected;
}

// Spike directionnel Boom/Crash: indices synthétiques (surtout Crash) ont souvent tick volume plat ;
// le range M1 seul peut être ambigu. Ici on exige une bougie M1 (0 ou 1) grande vs ATR + corps dans le sens du trade.
bool IsDirectionalBoomCrashSpikeForPosition(const string symbol, const ENUM_POSITION_TYPE posType)
{
   if(SMC_GetSymbolCategory(symbol) != SYM_BOOM_CRASH)
      return false;

   SymbolSelect(symbol, true);
   double atr = iATR(symbol, PERIOD_M1, 20);
   if(atr <= 0.0)
      return false;

   double mult = SpikePriceMultiplier;
   if(mult <= 0.0)
      mult = 1.5;

   // Ajuster le seuil en fonction de la confluence cumulative
   double confluenceFactor = GetSpikeConfluenceFactor(symbol);
   double adjustedMult = mult * confluenceFactor;
   double thr = atr * adjustedMult;

   // Vérifier si une séquence de spikes est détectée (pattern escalier)
   bool spikeSequence = IsSpikeSequenceDetected(symbol, posType, 3);
   if(spikeSequence)
   {
      // En cas de séquence, abaisser encore le seuil pour capturer les mini-spikes
      thr = atr * mult * 0.65;
   }

   // On évite CopyRates pour réduire la charge CPU (appel fréquent dans ManageBoomCrashSpikeClose)
   for(int bar = 0; bar <= 1; bar++)
   {
      double h = iHigh(symbol, PERIOD_M1, bar);
      double l = iLow(symbol, PERIOD_M1, bar);
      if(h <= 0.0 || l <= 0.0) continue;

      double range = h - l;
      if(range < thr)
         continue;

      double open = iOpen(symbol, PERIOD_M1, bar);
      if(open <= 0.0) continue;

      // Pour la bougie en cours (bar=0), on approxime la "clôture" par Bid/Ask
      double effClose = (bar == 0)
                          ? ((posType == POSITION_TYPE_SELL) ? SymbolInfoDouble(symbol, SYMBOL_BID)
                                                             : SymbolInfoDouble(symbol, SYMBOL_ASK))
                          : iClose(symbol, PERIOD_M1, bar);

      if(posType == POSITION_TYPE_BUY && IsBoomSymbol(symbol))
      {
         if(effClose > open && (effClose - open) >= range * 0.10)
            return true;
      }
      else if(posType == POSITION_TYPE_SELL && IsCrashSymbol(symbol))
      {
         // Corps baissier OU prix déjà sous l'open sur grosse bougie (capture spike en cours)
         if(effClose < open && (open - effClose) >= range * 0.10)
            return true;
         if(effClose <= open && range >= atr * mult * 0.92)
            return true;
      }
   }

   return false;
}

// Spike adverse: petite bougie M1 contre la position (Crash: haussière vs SELL | Boom: baissière vs BUY)
bool IsAdverseBoomCrashSpikeForPosition(const string symbol, const ENUM_POSITION_TYPE posType)
{
   if(SMC_GetSymbolCategory(symbol) != SYM_BOOM_CRASH)
      return false;

   SymbolSelect(symbol, true);
   double atr = iATR(symbol, PERIOD_M1, 20);
   if(atr <= 0.0)
      return false;

   double mult = AdverseSpikeAtrMult;
   if(mult <= 0.0)
      mult = 0.35;
   double thr = atr * mult;

   double bodyFrac = AdverseSpikeMinBodyOfRange;
   if(bodyFrac <= 0.0)
      bodyFrac = 0.15;
   if(bodyFrac > 1.0)
      bodyFrac = 1.0;

   for(int bar = 0; bar <= 1; bar++)
   {
      double h = iHigh(symbol, PERIOD_M1, bar);
      double l = iLow(symbol, PERIOD_M1, bar);
      if(h <= 0.0 || l <= 0.0)
         continue;

      double range = h - l;
      if(range < thr)
         continue;

      double open = iOpen(symbol, PERIOD_M1, bar);
      if(open <= 0.0)
         continue;

      double effClose = (bar == 0)
                            ? ((posType == POSITION_TYPE_SELL) ? SymbolInfoDouble(symbol, SYMBOL_BID)
                                                               : SymbolInfoDouble(symbol, SYMBOL_ASK))
                            : iClose(symbol, PERIOD_M1, bar);

      if(posType == POSITION_TYPE_SELL && IsCrashSymbol(symbol))
      {
         if(effClose > open)
         {
            double body = effClose - open;
            if(body >= range * bodyFrac)
               return true;
         }
      }
      else if(posType == POSITION_TYPE_BUY && IsBoomSymbol(symbol))
      {
         if(effClose < open)
         {
            double body = open - effClose;
            if(body >= range * bodyFrac)
               return true;
         }
      }
   }

   return false;
}

// Détection de compression avant explosion
bool IsVolatilityCompressionDetected()
{
   double atrCurrent = iATR(_Symbol, PERIOD_M1, 1);
   double atrAvg = 0;
   
   // Calcul moyenne ATR sur 20 bougies
   for(int i = 2; i <= 21; i++)
   {
      atrAvg += iATR(_Symbol, PERIOD_M1, i);
   }
   atrAvg /= 20.0;
   
   bool compressionDetected = (atrCurrent < atrAvg * SpikeCompressionThreshold);
   
   if(DebugSpikeDetection)
   {
      Print("🗜️ Compression - ATR: ", NormalizeDouble(atrCurrent, 5),
            " | Moyenne: ", NormalizeDouble(atrAvg, 5),
            " | Compression: ", compressionDetected ? "OUI" : "NON");
   }
   
   return compressionDetected;
}

// Détection de pattern "Calm Before Storm"
bool IsCalmBeforeStorm()
{
   int calmBars = 0;
   double atr = iATR(_Symbol, PERIOD_M1, 20);
   
   // Vérifier les 5 dernières bougies
   for(int i = 1; i <= 5; i++)
   {
      double range = iHigh(_Symbol, PERIOD_M1, i) - iLow(_Symbol, PERIOD_M1, i);
      if(range < atr * 0.3) calmBars++;
   }
   
   bool calmDetected = (calmBars >= SpikeCalmBarsMin);
   
   if(DebugSpikeDetection)
   {
      Print("🌊 Calm Before Storm - Barres calmes: ", calmBars, "/", SpikeCalmBarsMin,
            " | Pattern: ", calmDetected ? "OUI" : "NON");
   }
   
   return calmDetected;
}

// Détection de zones SMC propices aux spikes
bool IsSMCSpikeZone()
{
   bool inDiscount = IsInDiscountZone();
   bool inPremium = IsInPremiumZone();
   bool nearSupport = IsNearSupport();
   bool nearResistance = IsNearResistance();
   
   bool spikeZone = false;
   
   if(StringFind(_Symbol, "Boom") >= 0)
   {
      // Boom: spike probable en sortie de Discount vers support
      spikeZone = inDiscount && nearSupport;
   }
   else if(StringFind(_Symbol, "Crash") >= 0)
   {
      // Crash: spike probable en sortie de Premium vers résistance
      spikeZone = inPremium && nearResistance;
   }
   
   if(DebugSpikeDetection)
   {
      Print("🎯 Zone SMC Spike - Discount: ", inDiscount ? "OUI" : "NON",
            " | Premium: ", inPremium ? "OUI" : "NON",
            " | Support: ", nearSupport ? "OUI" : "NON",
            " | Résistance: ", nearResistance ? "OUI" : "NON",
            " | Zone Spike: ", spikeZone ? "OUI" : "NON");
   }
   
   return spikeZone;
}

// Détection de momentum accélérant
bool IsAcceleratingMomentum()
{
   int rsiHandle = iRSI(_Symbol, PERIOD_M1, 14, PRICE_CLOSE);
   if(rsiHandle == INVALID_HANDLE) return false;
   
   double rsiBuffer[2];
   if(CopyBuffer(rsiHandle, 0, 0, 2, rsiBuffer) < 2) return false;
   
   double rsiCurrent = rsiBuffer[0];
   double rsiPrevious = rsiBuffer[1];
   
   double rsiChange = MathAbs(rsiCurrent - rsiPrevious);
   bool momentumDetected = (rsiChange > SpikeMomentumChange);
   
   if(DebugSpikeDetection)
   {
      Print("🚀 Momentum Accélérant - RSI: ", NormalizeDouble(rsiCurrent, 1),
            " | Précédent: ", NormalizeDouble(rsiPrevious, 1),
            " | Changement: ", NormalizeDouble(rsiChange, 1),
            " | Momentum: ", momentumDetected ? "OUI" : "NON");
   }
   
   return momentumDetected;
}

//+------------------------------------------------------------------+
//| RSI 14 IMPULSION - Divergence / Compression Breakout / Reversal  |
//| Les configurations chartistes du RSI 14 prédisent les impulsions |
//| (spikes) avant qu'elles ne se produisent sur le prix.           |
//+------------------------------------------------------------------+

// Récupérer le buffer RSI 14 M1 sur N barres (ArraySetAsSeries=true)
bool GetRSIBuffer14M1(double &rsiOut[], int count)
{
   ArraySetAsSeries(rsiOut, true);
   if(rsi14M1 == INVALID_HANDLE) return false;
   if(CopyBuffer(rsi14M1, 0, 0, count, rsiOut) < count) return false;
   return true;
}

// --- DIVERGENCE BULLISH RSI ---
// Le prix fait un lower low mais le RSI fait un higher low → impulsion haussière imminente
bool IsRSIDivergenceBullish(double &rsiBuf[], MqlRates &rates[], int lookback, double minSwingPips)
{
   int len = ArraySize(rsiBuf);
   if(len < lookback) return false;
   double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   if(point <= 0) return false;
   double minSwingPrice = minSwingPips * point;

   // Chercher 2 swing lows récents dans le lookback
   int swingIdx1 = -1, swingIdx2 = -1;
   double swingLow1 = 0, swingLow2 = 0;
   double rsiLow1 = 0, rsiLow2 = 0;

   for(int i = 2; i < lookback - 2 && i < len - 2; i++)
   {
      bool isSwingLow = (rates[i].low < rates[i-1].low && rates[i].low < rates[i+1].low &&
                         rates[i].low < rates[i-2].low && rates[i].low < rates[i+2].low);
      if(isSwingLow)
      {
         if(swingIdx1 < 0)
         {
            swingIdx1 = i; swingLow1 = rates[i].low; rsiLow1 = rsiBuf[i];
         }
         else if(swingIdx2 < 0 && i != swingIdx1)
         {
            swingIdx2 = i; swingLow2 = rates[i].low; rsiLow2 = rsiBuf[i];
            break;
         }
      }
   }

   if(swingIdx1 < 0 || swingIdx2 < 0) return false;

   // S'assurer que swingIdx2 est plus ancien (index plus grand = plus ancien en series)
   if(swingIdx2 < swingIdx1) { int t=swingIdx2; swingIdx2=swingIdx1; swingIdx1=t;
                                double td=swingLow2; swingLow2=swingLow1; swingLow1=td;
                                double tr=rsiLow2; rsiLow2=rsiLow1; rsiLow1=tr; }

   // Divergence bullish: prix lower low (swingLow1 < swingLow2) mais RSI higher low (rsiLow1 > rsiLow2)
   bool priceLowerLow = (swingLow1 < swingLow2 - minSwingPrice);
   bool rsiHigherLow  = (rsiLow1 > rsiLow2 + 1.0); // au moins 1 pt RSI de hausse

   return (priceLowerLow && rsiHigherLow);
}

// --- DIVERGENCE BEARISH RSI ---
// Le prix fait un higher high mais le RSI fait un lower high → impulsion baissière imminente
bool IsRSIDivergenceBearish(double &rsiBuf[], MqlRates &rates[], int lookback, double minSwingPips)
{
   int len = ArraySize(rsiBuf);
   if(len < lookback) return false;
   double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   if(point <= 0) return false;
   double minSwingPrice = minSwingPips * point;

   int swingIdx1 = -1, swingIdx2 = -1;
   double swingHigh1 = 0, swingHigh2 = 0;
   double rsiHigh1 = 0, rsiHigh2 = 0;

   for(int i = 2; i < lookback - 2 && i < len - 2; i++)
   {
      bool isSwingHigh = (rates[i].high > rates[i-1].high && rates[i].high > rates[i+1].high &&
                          rates[i].high > rates[i-2].high && rates[i].high > rates[i+2].high);
      if(isSwingHigh)
      {
         if(swingIdx1 < 0)
         {
            swingIdx1 = i; swingHigh1 = rates[i].high; rsiHigh1 = rsiBuf[i];
         }
         else if(swingIdx2 < 0 && i != swingIdx1)
         {
            swingIdx2 = i; swingHigh2 = rates[i].high; rsiHigh2 = rsiBuf[i];
            break;
         }
      }
   }

   if(swingIdx1 < 0 || swingIdx2 < 0) return false;

   if(swingIdx2 < swingIdx1) { int t=swingIdx2; swingIdx2=swingIdx1; swingIdx1=t;
                                double td=swingHigh2; swingHigh2=swingHigh1; swingHigh1=td;
                                double tr=rsiHigh2; rsiHigh2=rsiHigh1; rsiHigh1=tr; }

   // Divergence bearish: prix higher high mais RSI lower high
   bool priceHigherHigh = (swingHigh1 > swingHigh2 + minSwingPrice);
   bool rsiLowerHigh    = (rsiHigh1 < rsiHigh2 - 1.0);

   return (priceHigherHigh && rsiLowerHigh);
}

// --- COMPRESSION BREAKOUT BULLISH ---
// RSI reste dans un range étroit pendant N barres puis casse à la hausse → impulsion haussière
bool IsRSICompressionBreakoutBullish(double &rsiBuf[], int lookback, double maxRange, int minBars)
{
   int len = ArraySize(rsiBuf);
   if(len < lookback || len < minBars + 2) return false;

   // Vérifier que les dernières bougies étaient en compression (RSI dans un range étroit)
   int compressBars = 0;
   double rsiMin = 100.0, rsiMax = 0.0;

   // Scanner depuis la barre 2 (on laisse barre 0 = breakout potentiel)
   for(int i = 2; i < MathMin(lookback, len) && compressBars < minBars + 5; i++)
   {
      double range = rsiMax - rsiMin;
      if(compressBars > 0 && range > maxRange)
         break; // La compression est cassée → on arrête

      double r = rsiBuf[i];
      if(r < rsiMin) rsiMin = r;
      if(r > rsiMax) rsiMax = r;
      compressBars++;
   }

   double compressionRange = rsiMax - rsiMin;
   bool wasCompressed = (compressBars >= minBars && compressionRange <= maxRange);

   // Barre 0 (actuelle) doit casser à la hausse hors du range de compression
   bool breakoutUp = (rsiBuf[0] > rsiMax + 1.0);

   return (wasCompressed && breakoutUp);
}

// --- COMPRESSION BREAKOUT BEARISH ---
// RSI reste dans un range étroit pendant N barres puis casse à la baisse → impulsion baissière
bool IsRSICompressionBreakoutBearish(double &rsiBuf[], int lookback, double maxRange, int minBars)
{
   int len = ArraySize(rsiBuf);
   if(len < lookback || len < minBars + 2) return false;

   int compressBars = 0;
   double rsiMin = 100.0, rsiMax = 0.0;

   for(int i = 2; i < MathMin(lookback, len) && compressBars < minBars + 5; i++)
   {
      double range = rsiMax - rsiMin;
      if(compressBars > 0 && range > maxRange)
         break;

      double r = rsiBuf[i];
      if(r < rsiMin) rsiMin = r;
      if(r > rsiMax) rsiMax = r;
      compressBars++;
   }

   double compressionRange = rsiMax - rsiMin;
   bool wasCompressed = (compressBars >= minBars && compressionRange <= maxRange);

   bool breakoutDown = (rsiBuf[0] < rsiMin - 1.0);

   return (wasCompressed && breakoutDown);
}

// --- REVERSAL BULLISH (Double Bottom sur RSI) ---
// RSI forme 2 creux proches en valeur → pattern de retournement haussier
bool IsRSIReversalBullish(double &rsiBuf[], int lookback, double tolerance)
{
   int len = ArraySize(rsiBuf);
   if(len < lookback) return false;

   // Chercher 2 creux RSI dans le lookback
   int trough1Idx = -1, trough2Idx = -1;
   double trough1Val = 0, trough2Val = 0;

   for(int i = 1; i < lookback - 1 && i < len - 1; i++)
   {
      bool isTrough = (rsiBuf[i] < rsiBuf[i-1] && rsiBuf[i] < rsiBuf[i+1] && rsiBuf[i] < 45.0);
      if(isTrough)
      {
         if(trough1Idx < 0)
         {
            trough1Idx = i; trough1Val = rsiBuf[i];
         }
         else if(trough2Idx < 0 && i != trough1Idx && MathAbs(i - trough1Idx) >= 3)
         {
            trough2Idx = i; trough2Val = rsiBuf[i];
            break;
         }
      }
   }

   if(trough1Idx < 0 || trough2Idx < 0) return false;

   // Double bottom: les 2 creux sont proches en valeur (tolerance)
   bool isDoubleBottom = (MathAbs(trough1Val - trough2Val) <= tolerance);

   // Le RSI actuel doit être au-dessus des creux (confirmation du retournement)
   bool rsiRising = (rsiBuf[0] > MathMax(trough1Val, trough2Val) + 2.0);

   return (isDoubleBottom && rsiRising);
}

// --- REVERSAL BEARISH (Double Top sur RSI) ---
// RSI forme 2 pics proches en valeur → pattern de retournement baissier
bool IsRSIReversalBearish(double &rsiBuf[], int lookback, double tolerance)
{
   int len = ArraySize(rsiBuf);
   if(len < lookback) return false;

   int peak1Idx = -1, peak2Idx = -1;
   double peak1Val = 0, peak2Val = 0;

   for(int i = 1; i < lookback - 1 && i < len - 1; i++)
   {
      bool isPeak = (rsiBuf[i] > rsiBuf[i-1] && rsiBuf[i] > rsiBuf[i+1] && rsiBuf[i] > 55.0);
      if(isPeak)
      {
         if(peak1Idx < 0)
         {
            peak1Idx = i; peak1Val = rsiBuf[i];
         }
         else if(peak2Idx < 0 && i != peak1Idx && MathAbs(i - peak1Idx) >= 3)
         {
            peak2Idx = i; peak2Val = rsiBuf[i];
            break;
         }
      }
   }

   if(peak1Idx < 0 || peak2Idx < 0) return false;

   bool isDoubleTop = (MathAbs(peak1Val - peak2Val) <= tolerance);
   bool rsiFalling = (rsiBuf[0] < MathMin(peak1Val, peak2Val) - 2.0);

   return (isDoubleTop && rsiFalling);
}

// --- FONCTION PRINCIPALE: Détection du pattern RSI Impulsion ---
// Retourne le type d'impulsion détecté et un détail textuel
ENUM_RSI_IMPULSE_TYPE DetectRSIImpulsePattern(string &detailOut)
{
   detailOut = "";

   if(!UseRSIImpulseFilter)
      return RSI_IMPULSE_NONE;

   int lb = RSIImpulseLookback;
   int count = lb + 5;

   // Récupérer le buffer RSI 14 M1
   double rsiBuf[];
   if(!GetRSIBuffer14M1(rsiBuf, count))
      return RSI_IMPULSE_NONE;

   // Récupérer les rates M1 pour la divergence
   MqlRates rates[];
   ArraySetAsSeries(rates, true);
   if(CopyRates(_Symbol, PERIOD_M1, 0, count, rates) < count)
      return RSI_IMPULSE_NONE;

   int bullishSignals = 0;
   int bearishSignals = 0;
   string bullDetail = "";
   string bearDetail = "";

   // 1) Divergence
   if(IsRSIDivergenceBullish(rsiBuf, rates, lb, RSIDivergenceMinSwingPips))
   { bullishSignals++; bullDetail += "DIV_BULL "; }
   if(IsRSIDivergenceBearish(rsiBuf, rates, lb, RSIDivergenceMinSwingPips))
   { bearishSignals++; bearDetail += "DIV_BEAR "; }

   // 2) Compression Breakout
   if(IsRSICompressionBreakoutBullish(rsiBuf, lb, RSICompressionMaxRange, RSICompressionMinBars))
   { bullishSignals++; bullDetail += "COMP_BULL "; }
   if(IsRSICompressionBreakoutBearish(rsiBuf, lb, RSICompressionMaxRange, RSICompressionMinBars))
   { bearishSignals++; bearDetail += "COMP_BEAR "; }

   // 3) Reversal (double top/bottom sur RSI)
   if(IsRSIReversalBullish(rsiBuf, lb, RSIReversalTolerance))
   { bullishSignals++; bullDetail += "REV_BULL "; }
   if(IsRSIReversalBearish(rsiBuf, lb, RSIReversalTolerance))
   { bearishSignals++; bearDetail += "REV_BEAR "; }

   // Décision: nécessite au moins 1 signal dans une direction et aucun signal contraire
   // OU au moins 2 signaux dans la même direction (prioritaire même si 1 signal contraire)
   if(bullishSignals >= 2 || (bullishSignals >= 1 && bearishSignals == 0))
   {
      detailOut = "RSI_IMPULSE_BULL(" + bullDetail + ") RSI=" + DoubleToString(rsiBuf[0], 1);
      return RSI_IMPULSE_BULLISH;
   }
   if(bearishSignals >= 2 || (bearishSignals >= 1 && bullishSignals == 0))
   {
      detailOut = "RSI_IMPULSE_BEAR(" + bearDetail + ") RSI=" + DoubleToString(rsiBuf[0], 1);
      return RSI_IMPULSE_BEARISH;
   }

   return RSI_IMPULSE_NONE;
}

// Fonction principale de détection de spike imminent
bool IsSpikeImminentWithoutAI()
{
   if(!UseSpikeDetectionWithoutAI) return false;
   
   int signalCount = 0;
   
   if(IsVolumeSpikeDetected()) signalCount++;
   if(IsPriceSpikeDetected()) signalCount++;
   if(IsVolatilityCompressionDetected()) signalCount++;
   if(IsCalmBeforeStorm()) signalCount++;
   if(IsSMCSpikeZone()) signalCount++;
   if(IsAcceleratingMomentum()) signalCount++;
   if(RSIImpulseAsSpikeSignal)
   {
      string rsiImpDetail = "";
      ENUM_RSI_IMPULSE_TYPE rsiImp = DetectRSIImpulsePattern(rsiImpDetail);
      if(rsiImp != RSI_IMPULSE_NONE) signalCount++;
   }
   
   bool spikeImminent = (signalCount >= SpikeDetectionMinSignals);
   
   if(DebugSpikeDetection)
   {
      Print("🎯 DÉTECTION SPIKE SANS IA - Signaux: ", signalCount, "/", SpikeDetectionMinSignals,
            " | Spike Imminent: ", spikeImminent ? "OUI" : "NON");
   }
   
   return spikeImminent;
}

// Vérification et exécution de trade spike
void CheckAndExecuteSpikeTrade()
{
   // NOUVEAU: Sur Boom/Crash + Weltrade synthétiques, n'autoriser les entrées que dans les zones OTE
   // pour éviter les contre-tendances
   ENUM_SYMBOL_CATEGORY cat = SMC_GetSymbolCategory(_Symbol);
   if(cat == SYM_BOOM_CRASH || cat == SYM_WELTRADE_SYNTH)
   {
      // Vérifier si une zone OTE valide existe pour la direction attendue
      string expectedDir = "";
      if(IsBoomSymbol(_Symbol) || IsWeltradeGainSynthSymbol(_Symbol))
         expectedDir = "BUY";
      else if(IsCrashSymbol(_Symbol) || IsWeltradePainSynthSymbol(_Symbol))
         expectedDir = "SELL";
      
      if(expectedDir != "")
      {
         double zLow, zHigh;
         if(!GetCurrentOTEZoneBounds(expectedDir, zLow, zHigh))
         {
            if(DebugSpikeDetection)
               Print("🚫 SPIKE BLOQUÉ - Pas de zone OTE valide pour ", expectedDir, " sur ", _Symbol);
            return;
         }
      }
   }
   
   // Nouvelle discipline: sur Boom/Crash + PAINX/GAINX, n'autoriser les entrées spike
   // que dans une zone de confluence "cluster" active.
   bool isSpikeFamily = (cat == SYM_BOOM_CRASH || cat == SYM_WELTRADE_SYNTH);
   if(isSpikeFamily)
   {
      if(!IsSpikeClusterZoneActive(_Symbol))
      {
         if(DebugSpikeDetection)
            Print("🚫 SPIKE BLOQUÉ - Spike Cluster Zone non active | score=",
                  DoubleToString(g_spikeClusterScore, 2),
                  " | spikes=", IntegerToString(g_spikeClusterSpikeBars));
         return;
      }
   }

   // 1. Vérifier si IA est suffisamment forte
   if(g_lastAIConfidence >= MinAIConfidencePercent)
   {
      if(DebugSpikeDetection)
         Print("🤖 IA FORTE - Utilisation logique IA normale (", 
               NormalizeDouble(g_lastAIConfidence, 1), "% ≥ ", 
               NormalizeDouble(MinAIConfidencePercent, 1), "%)");
      return; // Utiliser logique IA normale
   }
   
   // 2. Si IA faible -> Vérifier détection spike
   if(UseSpikeDetectionWithoutAI && IsSpikeImminentWithoutAI())
   {
      Print("🚨 SPIKE DÉTECTÉ SANS IA - Confiance IA: ", 
            NormalizeDouble(g_lastAIConfidence, 1), "% < ", 
            NormalizeDouble(MinAIConfidencePercent, 1), "%");
      
      // Vérifier protections capital et positions
      if(!IsMaxPositionsReached())
      {
         ExecuteSpikeTrade();
      }
      else
      {
         Print("🚫 SPIKE BLOQUÉ - Maximum positions atteintes");
      }
   }
}

// Exécution de trade spike
void ExecuteSpikeTrade()
{
   if(IsInEquilibriumCorrectionZone() && !SpikeAllowInCorrectionZone)
   {
      Print("🚫 SPIKE ANNULÉ - Zone de correction autour de l'équilibre sur ", _Symbol);
      return;
   }

   string direction = "";
   
   // Déterminer direction selon symbole et zones SMC
   if(IsBoomSymbol(_Symbol))
   {
      if(IsInDiscountZone())
      {
         direction = "BUY";
         Print("📈 SPIKE BUY BOOM - Zone Discount détectée");
      }
   }
   else if(IsCrashSymbol(_Symbol))
   {
      if(IsInPremiumZone())
      {
         direction = "SELL";
         Print("📉 SPIKE SELL CRASH - Zone Premium détectée");
      }
   }
   
   if(direction == "")
   {
      Print("🚫 SPIKE ANNULÉ - Direction non déterminée");
      return;
   }

   if(!IsDirectionAllowedForBoomCrash(_Symbol, direction))
   {
      Print("🚫 SPIKE ANNULÉ - Direction interdite sur ", _Symbol, " : ", direction);
      return;
   }

   if(!IsBoomCrashDirectionAllowedByIA(_Symbol, direction))
   {
      Print("🚫 SPIKE ANNULÉ - Direction vs IA (Boom/Crash) sur ", _Symbol, " : ", direction);
      return;
   }

   if(!IsSpreadAcceptable()) return;
   if(IsEntryCooldownActive()) return;
   if(!IsLastCandleConfirmingDirection(direction)) return;

   // Confiance IA minimum globale (75%)
   if(!IsAIConfidenceAtLeast(0.75, "SPIKE TRADE"))
      return;

   // Règle de duplication par catégorie/symbole
   if(!CanOpenAdditionalPositionForSymbol(_Symbol, direction))
   {
      Print("🚫 SPIKE ANNULÉ - duplication interdite sur ", _Symbol, " | dir=", direction);
      return;
   }
   
   // Exécuter ordre au marché
   MqlTradeRequest req = {};
   MqlTradeResult  res = {};
   
   req.action = TRADE_ACTION_DEAL;
   req.symbol = _Symbol;
   req.volume = GetOptimalLotSize();
   req.magic = InpMagicNumber;
   req.comment = "SPIKE_DETECTION_AI_" + IntegerToString((int)g_lastAIConfidence);
   
   double pointSpk = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   double slDistSpk = (double)MathMax(1, BoomCrashFixedSlPoints) * pointSpk;
   double tpDistSpk = (double)MathMax(1, BoomCrashFixedTpPoints) * pointSpk;
   if(direction == "BUY")
   {
      req.type = ORDER_TYPE_BUY;
      req.price = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
      req.sl = req.price - slDistSpk;
      req.tp = req.price + tpDistSpk;
   }
   else
   {
      req.type = ORDER_TYPE_SELL;
      req.price = SymbolInfoDouble(_Symbol, SYMBOL_BID);
      req.sl = req.price + slDistSpk;
      req.tp = req.price - tpDistSpk;
   }

   // Respect du stop-level broker (sinon "Invalid stops" sur certains indices/synth)
   {
      double sl = req.sl;
      double tp = req.tp;
      ValidateAndAdjustStopLossTakeProfit(direction, req.price, sl, tp);
      EnforceMinBoomCrashStopLossDollarRisk(_Symbol, direction, req.price, req.volume, sl);
      sl = NormalizeDouble(sl, _Digits);
      tp = NormalizeDouble(tp, _Digits);

      double tickSize = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_SIZE);
      double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
      if(tickSize <= 0) tickSize = point;
      if(tickSize > 0)
      {
         sl = MathRound(sl / tickSize) * tickSize;
         tp = MathRound(tp / tickSize) * tickSize;
         sl = NormalizeDouble(sl, _Digits);
         tp = NormalizeDouble(tp, _Digits);
      }
      req.sl = sl;
      req.tp = tp;
   }

   // Sécurité cohérence direction SL/TP (évite rejets supplémentaires)
   if(direction == "BUY")
   {
      if(req.sl >= req.price || req.tp <= req.price)
      {
         Print("❌ SPIKE invalid SL/TP (BUY) - skip sur ", _Symbol,
               " sl=", DoubleToString(req.sl, _Digits),
               " tp=", DoubleToString(req.tp, _Digits),
               " price=", DoubleToString(req.price, _Digits));
         return;
      }
   }
   else // SELL
   {
      if(req.sl <= req.price || req.tp >= req.price)
      {
         Print("❌ SPIKE invalid SL/TP (SELL) - skip sur ", _Symbol,
               " sl=", DoubleToString(req.sl, _Digits),
               " tp=", DoubleToString(req.tp, _Digits),
               " price=", DoubleToString(req.price, _Digits));
         return;
      }
   }

   if(!IsMinimumProfitPotentialMet(req.price, req.tp, direction, req.volume))
      return;
   
   if(OrderSend(req, res))
   {
      g_lastEntryTimeForSymbol = TimeCurrent();
      Print("✅ SPIKE EXÉCUTÉ - ", direction, " sur ", _Symbol, 
            " | Ticket: ", res.order, " | Confiance IA: ", 
            NormalizeDouble(g_lastAIConfidence, 1), "%");
      // Marquer le temps du dernier spike (utilisé par la recovery exceptionnelle Boom/Crash)
      string dirUpper = direction;
      StringToUpper(dirUpper);
      datetime now = TimeCurrent();
      if(IsBoomSymbol(_Symbol) && dirUpper == "BUY")
      {
         g_lastBoomSpikeTime = now;
         g_boomSellEntryArmed = false;
         g_boomSellEntryArmedTouchTime = 0;
      }
      else if(IsCrashSymbol(_Symbol) && dirUpper == "SELL")
      {
         g_lastCrashSpikeTime = now;
         g_crashBuyEntryArmed = false;
         g_crashBuyEntryArmedTouchTime = 0;
      }
      
      NotifyTradeEvent("✅ POSITION SPIKE OUVERTE - ORDRE MARCHÉ EXÉCUTÉ " + direction + " " + _Symbol +
                       " | Ticket: " + IntegerToString((int)res.order) +
                       " | IA: " + DoubleToString(g_lastAIConfidence, 1) + "%", EntryTradeSoundFile);
   }
   else
   {
      Print("❌ ÉCHEC SPIKE - ", direction, " sur ", _Symbol, 
            " | Code: ", res.retcode, " | Confiance IA: ", 
            NormalizeDouble(g_lastAIConfidence, 1), "%");

      if(res.retcode == TRADE_RETCODE_INVALID_STOPS)
      {
         // Retry unique avec recalcul strict SL/TP sur prix courant broker.
         double retryPrice = (direction == "BUY") ? SymbolInfoDouble(_Symbol, SYMBOL_ASK)
                                                  : SymbolInfoDouble(_Symbol, SYMBOL_BID);
         double pointSpk2 = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
         double slD2 = (double)MathMax(1, BoomCrashFixedSlPoints) * pointSpk2;
         double tpD2 = (double)MathMax(1, BoomCrashFixedTpPoints) * pointSpk2;
         double retrySL = (direction == "BUY") ? (retryPrice - slD2) : (retryPrice + slD2);
         double retryTP = (direction == "BUY") ? (retryPrice + tpD2) : (retryPrice - tpD2);

         ValidateAndAdjustStopLossTakeProfit(direction, retryPrice, retrySL, retryTP);
         retrySL = NormalizeDouble(retrySL, _Digits);
         retryTP = NormalizeDouble(retryTP, _Digits);

         req.price = retryPrice;
         req.sl = retrySL;
         req.tp = retryTP;

         MqlTradeResult retryRes = {};
         if(OrderSend(req, retryRes) && retryRes.retcode == TRADE_RETCODE_DONE)
         {
            g_lastEntryTimeForSymbol = TimeCurrent();
            Print("✅ SPIKE EXÉCUTÉ APRÈS RETRY STOPS - ", direction, " sur ", _Symbol,
                  " | Ticket: ", retryRes.order);
            if(UseNotifications)
            {
               NotifyTradeEvent("✅ POSITION SPIKE OUVERTE (RETRY) - " + direction + " " + _Symbol +
                                " | Ticket: " + IntegerToString((int)retryRes.order), EntryTradeSoundFile);
            }
         }
         else
         {
            Print("❌ SPIKE RETRY ÉCHEC - ", direction, " sur ", _Symbol,
                  " | Code: ", retryRes.retcode, " | ", retryRes.comment);
         }
      }
   }
}

// ------------------------------------------------------------------
// Recovery exceptionnel Boom/Crash (sur touch Entry M5 + petites bougies M1)
// ------------------------------------------------------------------
bool IsAIHoldOrSellForBoomExceptional()
{
   string a = g_lastAIAction;
   StringToUpper(a);
   return (a == "HOLD" || a == "SELL");
}

bool IsAIHoldOrBuyForCrashExceptional()
{
   string a = g_lastAIAction;
   StringToUpper(a);
   return (a == "HOLD" || a == "BUY");
}

// Compte les "petites bougies" M1 depuis `fromTime` (range < ATR(20 M1)*0.3), bougies CLÔTURÉES uniquement — par symbole.
int CountSmallM1CandlesSinceForSymbol(const string sym, datetime fromTime)
{
   if(fromTime <= 0 || sym == "") return 0;

   int hAtr = iATR(sym, PERIOD_M1, 20);
   if(hAtr == INVALID_HANDLE) return 0;
   double atrBuf[];
   ArraySetAsSeries(atrBuf, true);
   int got = CopyBuffer(hAtr, 0, 0, 2, atrBuf);
   IndicatorRelease(hAtr);
   if(got < 1) return 0;
   double atr = atrBuf[0];
   if(atr <= 0) return 0;

   MqlRates rates[];
   ArraySetAsSeries(rates, true);
   int copied = CopyRates(sym, PERIOD_M1, 0, 250, rates);
   if(copied < 50) return 0;

   int count = 0;
   for(int i = 1; i < copied; i++)
   {
      if(rates[i].time <= fromTime) break;

      double range = rates[i].high - rates[i].low;
      if(range < atr * 0.3)
         count++;
   }
   return count;
}

int CountSmallM1CandlesSince(datetime fromTime)
{
   return CountSmallM1CandlesSinceForSymbol(_Symbol, fromTime);
}

bool HasEnoughSmallM1AfterLastSpikeForM5Touch(const string symbol, const string direction, const int minSmallCandles, const int maxSmallCandles)
{
   string d = direction;
   StringToUpper(d);
   int needMin = MathMax(1, minSmallCandles);
   int needMax = MathMax(needMin, maxSmallCandles);
   datetime lastSpikeTime = 0;

   if(IsBoomSymbol(symbol) && d == "BUY")
      lastSpikeTime = g_lastBoomSpikeTime;
   else if(IsCrashSymbol(symbol) && d == "SELL")
      lastSpikeTime = g_lastCrashSpikeTime;
   else
      return true; // Pas de contrainte spike->small candles pour les autres cas.

   if(lastSpikeTime <= 0)
      return true; // Aucun spike de référence: ne pas bloquer.

   int smallCount = CountSmallM1CandlesSinceForSymbol(symbol, lastSpikeTime);
   if(smallCount < needMin || smallCount > needMax)
   {
      Print("🚫 M5 TOUCH BLOQUÉ - Fenêtre petites M1 invalide après spike | ", symbol,
            " | dir=", d, " | petites=", smallCount, " (attendu ", needMin, "..", needMax, ")");
      return false;
   }
   return true;
}

bool ExecuteExceptionalBoomCrashRecoveryOrder(const string direction, const string commentTag)
{
   if(!IsTrendAlignedEntry(direction))
   {
      Print("🚫 EXC_RECOVERY BLOQUÉ - Filtre de tendance SMC sur ", _Symbol, " : ", direction,
            " | ", commentTag);
      return false;
   }

   if(!EnableBoomCrashRecoveryTrades)
      return false; // Recovery trades (SELL Boom / BUY Crash) désactivés
   if(direction != "BUY" && direction != "SELL") return false;
   if(IsInEquilibriumCorrectionZone())
   {
      Print("🚫 EXC_RECOVERY BLOQUÉ - Zone de correction autour de l'équilibre sur ", _Symbol,
            " | ", commentTag);
      return false;
   }

   // Confiance IA minimum globale (75%)
   if(!IsAIConfidenceAtLeast(0.75, commentTag))
      return false;

   // Anti-duplication sécurité
   if(CountPositionsForSymbol(_Symbol) > 0) return false;

   if(!TryAcquireOpenLock()) return false;

   double lot = GetOptimalLotSize();
   if(lot <= 0.0) { ReleaseOpenLock(); return false; }

   double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   double price = (direction == "BUY") ? SymbolInfoDouble(_Symbol, SYMBOL_ASK) : SymbolInfoDouble(_Symbol, SYMBOL_BID);

   double slFixR = (double)MathMax(1, BoomCrashFixedSlPoints) * point;
   double tpFixR = (double)MathMax(1, BoomCrashFixedTpPoints) * point;
   double sl = 0.0, tp = 0.0;
   if(direction == "BUY")
   {
      sl = price - slFixR;
      tp = price + tpFixR;
   }
   else
   {
      sl = price + slFixR;
      tp = price - tpFixR;
   }

   // IMPORTANT: corrige les distances SL/TP selon le stop-level broker.
   // Sinon on obtient souvent "Invalid stops" sur certains synth indices.
   ValidateAndAdjustStopLossTakeProfit(direction, price, sl, tp);
   EnforceMinBoomCrashStopLossDollarRisk(_Symbol, direction, price, lot, sl);
   sl = NormalizeDouble(sl, _Digits);
   tp = NormalizeDouble(tp, _Digits);

   // IMPORTANT: aligner SL/TP sur le tick size (sinon certains brokers rejettent).
   // tick size peut être différent de SYMBOL_POINT selon le symbole.
   double tickSize = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_SIZE);
   if(tickSize <= 0) tickSize = point;
   if(tickSize > 0)
   {
      // Arrondir au tick le plus proche
      sl = MathRound(sl / tickSize) * tickSize;
      tp = MathRound(tp / tickSize) * tickSize;

      sl = NormalizeDouble(sl, _Digits);
      tp = NormalizeDouble(tp, _Digits);

      // Re-valider après arrondi pour garantir la distance minimale.
      ValidateAndAdjustStopLossTakeProfit(direction, price, sl, tp);
      sl = NormalizeDouble(sl, _Digits);
      tp = NormalizeDouble(tp, _Digits);
   }

   // Double-check explicite avec SYMBOL_TRADE_STOPS_LEVEL (au cas où le helper
   // applique une logique trop conservatrice / non idéale selon symbole)
   long stopsLevelPoints = SymbolInfoInteger(_Symbol, SYMBOL_TRADE_STOPS_LEVEL);
   // NB: conversion en distance prix via tickSize (sinon mismatch unit -> Invalid stops)
   if(tickSize <= 0) tickSize = point;
   double minDist = (double)stopsLevelPoints * tickSize;
   if(minDist > 0.0)
   {
      if(direction == "BUY")
      {
         if(price - sl < minDist) sl = price - minDist;
         if(tp - price < minDist * 2.0) tp = price + minDist * 2.0;
      }
      else
      {
         if(sl - price < minDist) sl = price + minDist;
         if(price - tp < minDist * 2.0) tp = price - minDist * 2.0;
      }
      sl = NormalizeDouble(sl, _Digits);
      tp = NormalizeDouble(tp, _Digits);
   }

   // Sécurité : cohérence direction SL/TP
   if(direction == "BUY")
   {
      if(sl >= price || tp <= price)
      {
         Print("? EXC_RECOVERY invalid SL/TP (BUY) - sl=", DoubleToString(sl, _Digits),
               " tp=", DoubleToString(tp, _Digits), " price=", DoubleToString(price, _Digits),
               " | ", commentTag, " | ", _Symbol);
         ReleaseOpenLock();
         return false;
      }
   }
   else // SELL
   {
      if(sl <= price || tp >= price)
      {
         Print("? EXC_RECOVERY invalid SL/TP (SELL) - sl=", DoubleToString(sl, _Digits),
               " tp=", DoubleToString(tp, _Digits), " price=", DoubleToString(price, _Digits),
               " | ", commentTag, " | ", _Symbol);
         ReleaseOpenLock();
         return false;
      }
   }

   bool ok = false;
   if(direction == "BUY")  ok = trade.Buy(lot, _Symbol, 0.0, sl, tp, commentTag);
   else                     ok = trade.Sell(lot, _Symbol, 0.0, sl, tp, commentTag);

   if(ok)
   {
      Print("?? EXC_RECOVERY ordre OK - ", commentTag, " | ", direction, " sur ", _Symbol);
      NotifyTradeEvent("🚀 RECOVERY " + direction + " " + _Symbol + " (" + commentTag + ")", EntryTradeSoundFile);
   }
   else
      Print("? EXC_RECOVERY ordre KO - ", commentTag, " | ", direction, " sur ", _Symbol,
            " | Retcode: ", trade.ResultRetcode(), " - ", trade.ResultRetcodeDescription());

   // Debug addition si broker rejette les stops (aide à vérifier les distances calculées)
   if(!ok)
   {
      long stopsLevelPoints2 = SymbolInfoInteger(_Symbol, SYMBOL_TRADE_STOPS_LEVEL);
      double minDist2 = (double)stopsLevelPoints2 * point;
      double slDist = 0.0, tpDist = 0.0;
      if(direction == "BUY")
      {
         slDist = price - sl;
         tpDist = tp - price;
      }
      else
      {
         slDist = sl - price;
         tpDist = price - tp;
      }

      Print("? EXC_RECOVERY debug stops - ",
            "price=", DoubleToString(price, _Digits),
            " sl=", DoubleToString(sl, _Digits),
            " tp=", DoubleToString(tp, _Digits),
            " slDist=", DoubleToString(slDist, _Digits),
            " tpDist=", DoubleToString(tpDist, _Digits),
            " stopsLevelPoints=", stopsLevelPoints2,
            " minDist=", DoubleToString(minDist2, _Digits),
            " tickSize=", DoubleToString(SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_SIZE), _Digits),
            " | ", commentTag);
   }

   ReleaseOpenLock();
   return ok;
}

// Déclenche l'entrée recovery exceptionnelle si:
// - touch Entry M5 déjà enregistré (armed)
// - après dernier spike: au moins BoomCrashSmallM1CandlesBeforeEntry petites bougies M1 comptées
// - IA status: HOLD ou SELL/BUY selon cas
void CheckAndExecuteExceptionalBoomCrashRecoveryEntries()
{
   if(!EnableBoomCrashRecoveryTrades) return;
   int needSmall = BoomCrashSmallM1CandlesBeforeEntry;
   if(needSmall < 1) needSmall = 1;
   // Si IA pas encore reçue, laisser le mécanisme armer mais pas déclencher
   if(g_lastAIAction == "") return;

   // BOOM: SELL recovery
   if(IsBoomSymbol(_Symbol))
   {
      if(g_boomSellEntryArmed && g_lastBoomSpikeTime > 0)
      {
         // Vérifier que le touch a bien eu lieu après ce spike
         if(g_boomSellEntryArmedTouchTime >= g_lastBoomSpikeTime)
         {
            if(IsAIHoldOrSellForBoomExceptional())
            {
               int smallCount = CountSmallM1CandlesSince(g_lastBoomSpikeTime);
               if(smallCount >= needSmall)
               {
                  // Une position max par symbole: éviter d'empiler
                  if(CountPositionsForSymbol(_Symbol) == 0)
                  {
                     bool ok = ExecuteExceptionalBoomCrashRecoveryOrder("SELL", "EXC_RECOVERY_BOOM_SELL");
                     if(ok) g_boomSellEntryArmed = false;
                  }
                  else
                  {
                     g_boomSellEntryArmed = false;
                  }
               }
            }
         }
         else
         {
            // Touch avant spike => invalider arming
            g_boomSellEntryArmed = false;
         }
      }
   }

   // CRASH: BUY recovery
   if(IsCrashSymbol(_Symbol))
   {
      if(g_crashBuyEntryArmed && g_lastCrashSpikeTime > 0)
      {
         if(g_crashBuyEntryArmedTouchTime >= g_lastCrashSpikeTime)
         {
            if(IsAIHoldOrBuyForCrashExceptional())
            {
               int smallCount = CountSmallM1CandlesSince(g_lastCrashSpikeTime);
               if(smallCount >= needSmall)
               {
                  if(CountPositionsForSymbol(_Symbol) == 0)
                  {
                     bool ok = ExecuteExceptionalBoomCrashRecoveryOrder("BUY", "EXC_RECOVERY_CRASH_BUY");
                     if(ok) g_crashBuyEntryArmed = false;
                  }
                  else
                  {
                     g_crashBuyEntryArmed = false;
                  }
               }
            }
         }
         else
         {
            g_crashBuyEntryArmed = false;
         }
      }
   }
}

// Réentrée spike après fermeture spike :
// - mode 1: proba spike imminente → 2 petites bougies M1 puis 1 tentative
// - mode 2: chaîne OTE+IA → N petites bougies M1, bypass flèche/touch, réessaie si filtres bloquent
// - mode 3: réentrée systématique même sans proba/OTE (même sens que la position fermée), retry si filtres bloquent
void CheckAndExecuteSecondSpikeReentry()
{
   if(!g_secondSpikeReentryArmed) return;
   if(!UseSpikeAutoClose)
   {
      g_secondSpikeReentryArmed = false;
      g_secondSpikeReentryMode = 0;
      return;
   }
   if(!IsBoomSymbol(_Symbol) && !IsCrashSymbol(_Symbol) &&
      !IsWeltradeGainSynthSymbol(_Symbol) && !IsWeltradePainSynthSymbol(_Symbol))
   {
      g_secondSpikeReentryArmed = false;
      g_secondSpikeReentryMode = 0;
      return;
   }

   int timeoutSec = 900;
   if(g_secondSpikeReentryMode == 2 && OteSpikeChainReentryTimeoutSec > 0)
      timeoutSec = OteSpikeChainReentryTimeoutSec;
   else if(g_secondSpikeReentryMode == 3)
   {
      int t3 = AlwaysReentryAfterSpikeCloseTimeoutSec;
      if(t3 <= 0) t3 = 900;
      timeoutSec = t3;
   }

   if(g_secondSpikeReentryArmTime > 0 && (TimeCurrent() - g_secondSpikeReentryArmTime) > timeoutSec)
   {
      g_secondSpikeReentryArmed = false;
      g_secondSpikeReentryDirection = "";
      g_secondSpikeReentryMode = 0;
      return;
   }

   if(CountPositionsForSymbol(_Symbol) > 0) return;

   string dir = g_secondSpikeReentryDirection;
   if(dir == "")
      dir = (IsBoomSymbol(_Symbol) || IsWeltradeGainSynthSymbol(_Symbol)) ? "BUY" : "SELL";

   if(g_secondSpikeReentryMode == 2)
   {
      if(!UseOteSpikeScalpChain ||
         !HasActiveValidOTESetupForDirection(dir) ||
         !IsBoomCrashDirectionAllowedByIA(_Symbol, dir) ||
         (g_lastAIConfidence * 100.0 < OteSpikeChainMinAIConfidencePct))
      {
         g_secondSpikeReentryArmed = false;
         g_secondSpikeReentryDirection = "";
         g_secondSpikeReentryMode = 0;
         Print("🔗 Chaîne OTE+IA désarmée (setup OTE invalide / IA HOLD / confiance)");
         return;
      }
   }

   int needSmall = 2;
   if(g_secondSpikeReentryMode == 2)
      needSmall = MathMax(1, OteSpikeChainMinSmallM1AfterClose);
   else if(g_secondSpikeReentryMode == 3)
      needSmall = MathMax(1, AlwaysReentryAfterSpikeCloseMinSmallM1);

   int smallCount = CountSmallM1CandlesSince(g_secondSpikeReentryArmTime);
   if(smallCount < needSmall) return;

   Print("🚀 Réentrée spike | ", _Symbol, " | mode=", g_secondSpikeReentryMode,
         " | dir=", dir, " | petitesM1=", smallCount);
   int beforePos = CountPositionsForSymbol(_Symbol);
   g_oteSpikeChainEntry = (g_secondSpikeReentryMode == 2);
   ExecuteSpikeTrade(dir);
   g_oteSpikeChainEntry = false;

   int afterPos = CountPositionsForSymbol(_Symbol);

   if((g_secondSpikeReentryMode == 2 || g_secondSpikeReentryMode == 3) && afterPos <= beforePos)
   {
      g_secondSpikeReentryArmTime = TimeCurrent();
      Print("Réentrée spike reportée (filtres) — nouveau délai petites M1 | ", _Symbol,
            " | mode=", g_secondSpikeReentryMode, " | dir=", dir);
      return;
   }

   g_secondSpikeReentryArmed = false;
   g_secondSpikeReentryDirection = "";
   g_secondSpikeReentryMode = 0;
   if(afterPos <= beforePos)
      Print("⚠️ Réentrée spike non exécutée | ", _Symbol, " | dir=", dir);
}

// Fonctions utilitaires pour la détection de spikes
bool IsNearSupport()
{
   double currentPrice = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double supportLevel = GetSupportLevel(20); // Support sur 20 barres
   double distance = MathAbs(currentPrice - supportLevel);
   double atr = iATR(_Symbol, PERIOD_M1, 20);
   
   return (distance <= atr * 0.5); // À moins de 0.5 ATR du support
}

bool IsNearResistance()
{
   double currentPrice = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double resistanceLevel = GetResistanceLevel(20); // Résistance sur 20 barres
   double distance = MathAbs(currentPrice - resistanceLevel);
   double atr = iATR(_Symbol, PERIOD_M1, 20);
   
   return (distance <= atr * 0.5); // À moins de 0.5 ATR de la résistance
}

double GetOptimalLotSize()
{
   // Politique demandée: toujours utiliser le lot minimum broker.
   double minLot = GetMinLotForSymbol(_Symbol);
   if(minLot <= 0.0)
      return 0.0;
   return NormalizeVolumeForSymbol(minLot);
}

//+------------------------------------------------------------------+
//| FONCTIONS POUR LIGNES D'ENTRÉE M5 ET EXÉCUTION M1               |
//+------------------------------------------------------------------+

// Variables globales pour les niveaux d'entrée M5
static double g_m5BuyEntryLevel = 0.0;
static double g_m5SellEntryLevel = 0.0;
static datetime g_m5LevelsLastUpdate = 0;
static bool g_m5BuyLevelActive = false;
static bool g_m5SellLevelActive = false;
static bool g_crashSellPostCorrectionArmed = false;
static datetime g_crashSellPostCorrectionArmTime = 0;

bool ReadEMAValue(const ENUM_TIMEFRAMES tf, const int period, double &valueOut)
{
   valueOut = 0.0;
   int h = iMA(_Symbol, tf, period, 0, MODE_EMA, PRICE_CLOSE);
   if(h == INVALID_HANDLE) return false;
   double b[];
   ArraySetAsSeries(b, true);
   bool ok = (CopyBuffer(h, 0, 0, 1, b) >= 1);
   if(ok) valueOut = b[0];
   IndicatorRelease(h);
   return ok && valueOut > 0.0;
}

bool IsStrongM1M5TrendByEMAs(const string direction)
{
   double e9m1=0,e21m1=0,e50m1=0,e9m5=0,e21m5=0,e50m5=0;
   if(!ReadEMAValue(PERIOD_M1, 9, e9m1) || !ReadEMAValue(PERIOD_M1, 21, e21m1) || !ReadEMAValue(PERIOD_M1, 50, e50m1))
      return false;
   if(!ReadEMAValue(PERIOD_M5, 9, e9m5) || !ReadEMAValue(PERIOD_M5, 21, e21m5) || !ReadEMAValue(PERIOD_M5, 50, e50m5))
      return false;

   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   string dir = direction; StringToUpper(dir);
   if(dir == "BUY")
      return (bid > e9m1 && e9m1 > e21m1 && e21m1 > e50m1 && bid > e9m5 && e9m5 > e21m5 && e21m5 > e50m5);
   if(dir == "SELL")
      return (bid < e9m1 && e9m1 < e21m1 && e21m1 < e50m1 && bid < e9m5 && e9m5 < e21m5 && e21m5 < e50m5);
   return false;
}

//+------------------------------------------------------------------+
//| Confirmation OTE: patterns chandeliers + BOS sur M15/M5          |
//+------------------------------------------------------------------+
bool IsOTECandlestickConfirmationOnTF(const string direction, const ENUM_TIMEFRAMES tf)
{
   MqlRates rates[];
   ArraySetAsSeries(rates, true);
   if(CopyRates(_Symbol, tf, 0, 5, rates) < 5)
      return false;

   string dir = direction;
   StringToUpper(dir);
   if(dir != "BUY" && dir != "SELL")
      return false;

   double o1 = rates[1].open, c1 = rates[1].close, h1 = rates[1].high, l1 = rates[1].low;
   double o2 = rates[2].open, c2 = rates[2].close, h2 = rates[2].high, l2 = rates[2].low;
   double o3 = rates[3].open, c3 = rates[3].close;
   double body1 = MathAbs(c1 - o1);
   double range1 = h1 - l1;
   double body2 = MathAbs(c2 - o2);
   if(range1 <= 0.0)
      return false;

   if(dir == "BUY")
   {
      bool engulf = (c2 < o2 && c1 > o1 && c1 >= o2 && o1 <= c2);
      bool hammer = ((MathMin(o1, c1) - l1) >= body1 * 1.5 && (h1 - MathMax(o1, c1)) <= body1 * 0.6);
      bool dojiBull = (body1 <= range1 * 0.12 && c1 > o1);
      bool morningStar = (c3 < o3 && body2 < MathAbs(c3 - o3) * 0.5 && c1 > o1 && c1 > ((o3 + c3) * 0.5));
      bool bullishBreak = (c1 > h2 && c1 > o1);
      if(engulf)
         return true;
      if(!OTE_AllowExtendedCandlestickPatterns)
         return false;
      return (hammer || dojiBull || morningStar || bullishBreak);
   }

   bool engulf = (c2 > o2 && c1 < o1 && c1 <= o2 && o1 >= c2);
   bool shootingStar = ((h1 - MathMax(o1, c1)) >= body1 * 1.5 && (MathMin(o1, c1) - l1) <= body1 * 0.6);
   bool dojiBear = (body1 <= range1 * 0.12 && c1 < o1);
   bool eveningStar = (c3 > o3 && body2 < MathAbs(c3 - o3) * 0.5 && c1 < o1 && c1 < ((o3 + c3) * 0.5));
   bool bearishBreak = (c1 < l2 && c1 < o1);
   if(engulf)
      return true;
   if(!OTE_AllowExtendedCandlestickPatterns)
      return false;
   return (shootingStar || dojiBear || eveningStar || bearishBreak);
}

bool HasConfirmedBOSForOTE(const string direction, const ENUM_TIMEFRAMES tf, const int lookbackBars)
{
   int lb = MathMax(8, lookbackBars);
   MqlRates rates[];
   ArraySetAsSeries(rates, true);
   if(CopyRates(_Symbol, tf, 0, lb + 5, rates) < lb + 5)
      return false;

   string dir = direction;
   StringToUpper(dir);
   if(dir != "BUY" && dir != "SELL")
      return false;

   double close1 = rates[1].close;
   double recentHigh = -DBL_MAX;
   double recentLow = DBL_MAX;
   for(int i = 2; i < lb + 2; i++)
   {
      if(rates[i].high > recentHigh) recentHigh = rates[i].high;
      if(rates[i].low < recentLow) recentLow = rates[i].low;
   }

   if(dir == "BUY")
      return (close1 > recentHigh);
   return (close1 < recentLow);
}

bool HasOTEBOSConfirmationM15OrM5(const string direction)
{
   if(!OTE_RequireBOSConfirmation)
      return true;

   bool bosM15 = HasConfirmedBOSForOTE(direction, PERIOD_M15, OTE_BOSLookbackBars);
   bool bosM5 = HasConfirmedBOSForOTE(direction, PERIOD_M5, OTE_BOSLookbackBars);
   bool ok = (bosM15 || bosM5);
   if(ok)
      Print("✅ BOS OTE confirmé (", (bosM15 ? "M15" : "M5"), ") pour ", direction, " sur ", _Symbol);
   return ok;
}

bool IsOTEEntryConfirmedOnM15OrM5(const string direction)
{
   if(!OTE_RequireM5CandlestickConfirmation && !OTE_RequireM15OrM5ConfirmationBeforeM1)
      return true;

   bool m15 = IsOTECandlestickConfirmationOnTF(direction, PERIOD_M15);
   bool m5 = IsOTECandlestickConfirmationOnTF(direction, PERIOD_M5);
   bool ok = (m15 || m5);
   if(ok)
      Print("✅ Confirmation candlestick OTE validée (", (m15 ? "M15" : "M5"), ") pour ", direction, " sur ", _Symbol);
   return ok;
}

// Compatibilité: l'ancien gate M5 délègue vers le nouveau moteur multi-pattern.
bool IsM5CandlestickConfirmation(const string direction)
{
   return IsOTECandlestickConfirmationOnTF(direction, PERIOD_M5);
}

bool IsStairEma13M1AndEma21M5TouchReady(const string direction)
{
   string dir = direction; StringToUpper(dir);
   if(dir != "BUY")
      return true;

   const bool targetedSymbol = (IsBoomSymbol(_Symbol) || IsWeltradeGainSynthSymbol(_Symbol));
   if(!targetedSymbol || !StairEntryRequireEma13M1AndEma21M5TouchForBoomGainBuy)
      return true;

   double ema13m1 = 0.0, ema21m5 = 0.0;
   if(!ReadEMAValue(PERIOD_M1, 13, ema13m1) || !ReadEMAValue(PERIOD_M5, 21, ema21m5))
      return false;

   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   double price = (ask > 0.0) ? ask : bid;
   if(price <= 0.0)
      return false;

   double atr = GetCurrentATRValue();
   if(atr <= 0.0) atr = price * 0.0008;

   double tolPct = MathMax(0.0, StairEntryEmaTouchMaxDistancePct);
   double tolAbsPct = price * (tolPct / 100.0);
   double tolAbsAtr = MathMax(0.0, StairEntryEmaTouchAtrMult) * atr;
   double tolAbs = MathMax(tolAbsPct, tolAbsAtr);
   if(tolAbs <= 0.0) tolAbs = SymbolInfoDouble(_Symbol, SYMBOL_POINT) * 15.0;

   bool touchEma13M1 = (MathAbs(price - ema13m1) <= tolAbs) || (bid <= ema13m1 && ask >= ema13m1);
   double tolM5 = tolAbs * MathMax(1.0, StairEntryEma21M5ConfluenceMult);
   bool nearEma21M5 = (MathAbs(price - ema21m5) <= tolM5);

   if(StairEntryEmaTouchDebug)
   {
      static datetime lastDbg = 0;
      datetime now = TimeCurrent();
      if(now - lastDbg >= 10)
      {
         Print("STAIR EMA TOUCH ", _Symbol,
               " | BUY touch13=", (touchEma13M1 ? "YES" : "NO"),
               " near21M5=", (nearEma21M5 ? "YES" : "NO"),
               " | price=", DoubleToString(price, _Digits),
               " ema13M1=", DoubleToString(ema13m1, _Digits),
               " ema21M5=", DoubleToString(ema21m5, _Digits),
               " tol=", DoubleToString(tolAbs, _Digits),
               " tolM5=", DoubleToString(tolM5, _Digits));
         lastDbg = now;
      }
   }

   return (touchEma13M1 && nearEma21M5);
}

bool IsRecentDirectionalSpikeForStair(const string direction, const int windowSec)
{
   if(windowSec <= 0) return false;
   datetime now = TimeCurrent();
   string dir = direction; StringToUpper(dir);

   if((IsBoomSymbol(_Symbol) || IsWeltradeGainSynthSymbol(_Symbol)) && dir == "BUY")
      return (g_lastBoomSpikeTime > 0 && (now - g_lastBoomSpikeTime) <= windowSec);

   if((IsCrashSymbol(_Symbol) || IsWeltradePainSynthSymbol(_Symbol)) && dir == "SELL")
      return (g_lastCrashSpikeTime > 0 && (now - g_lastCrashSpikeTime) <= windowSec);

   return false;
}

// Prix entry + SL/TP pour LIMIT « IA HOLD » entre prix courant et Entry M5 (identique au placement).
bool ComputeIAHoldLimitEntryAndStops(const string direction, double &entryOut, double &slOut, double &tpOut, string &srcOut)
{
   entryOut = 0.0;
   slOut = 0.0;
   tpOut = 0.0;
   srcOut = "";

   string dir = direction;
   StringToUpper(dir);
   if(dir != "BUY" && dir != "SELL")
      return false;

   if(dir == "BUY" && !g_m5BuyLevelActive) return false;
   if(dir == "SELL" && !g_m5SellLevelActive) return false;

   // Même source que SyncMovingEntryPointLimitOrders : priorité au prix des lignes OBJ sur le graphique.
   double m5BuyRef = g_m5BuyEntryLevel;
   double m5SellRef = g_m5SellEntryLevel;
   if(ObjectFind(0, "M5_ENTRY_BUY_LINE") >= 0)
      m5BuyRef = ObjectGetDouble(0, "M5_ENTRY_BUY_LINE", OBJPROP_PRICE);
   if(ObjectFind(0, "M5_ENTRY_SELL_LINE") >= 0)
      m5SellRef = ObjectGetDouble(0, "M5_ENTRY_SELL_LINE", OBJPROP_PRICE);

   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   double pt  = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   if(pt <= 0.0) pt = _Point;
   if(bid <= 0.0 || ask <= 0.0 || pt <= 0.0)
      return false;

   double atr = GetCurrentATRValue();
   if(atr <= 0.0) atr = bid * 0.001;
   if(atr <= 0.0) return false;

   double entry = 0.0;
   if(dir == "BUY")
      entry = GetClosestBuyLevel(bid, atr, IA_HoldLimitMaxDistanceATR, srcOut);
   else
      entry = GetClosestSellLevel(ask, atr, IA_HoldLimitMaxDistanceATR, srcOut);

   if(entry <= 0.0) return false;

   double minOff = MathMax(pt * 3.0, SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_SIZE));
   if(minOff <= 0.0) minOff = pt * 3.0;

   if(dir == "BUY")
   {
      double floorLevel = m5BuyRef + (pt * 2.0);
      double ceilLevel  = bid - minOff;
      if(ceilLevel <= floorLevel) return false;
      if(entry < floorLevel) entry = floorLevel;
      if(entry > ceilLevel)  return false;
   }
   else
   {
      double ceilLevel  = m5SellRef - (pt * 2.0);
      double floorLevel = ask + minOff;
      if(ceilLevel <= floorLevel) return false;
      if(entry > ceilLevel) entry = ceilLevel;
      if(entry < floorLevel) return false;
   }

   entry = NormalizeDouble(entry, _Digits);

   double sl = 0.0, tp = 0.0;
   if(dir == "BUY")
   {
      sl = entry - atr * MathMax(0.5, IA_HoldLimitSL_ATR);
      tp = entry + atr * MathMax(0.8, IA_HoldLimitTP_ATR);
   }
   else
   {
      sl = entry + atr * MathMax(0.5, IA_HoldLimitSL_ATR);
      tp = entry - atr * MathMax(0.8, IA_HoldLimitTP_ATR);
   }

   sl = NormalizeDouble(sl, _Digits);
   tp = NormalizeDouble(tp, _Digits);

   ValidateAndAdjustStopLossTakeProfit(dir, entry, sl, tp);
   entryOut = entry;
   slOut = sl;
   tpOut = tp;
   return true;
}

void SyncIAHoldLimitWithM5Entry()
{
   if(!IA_HoldLimitFollowM5Entry || !IA_HoldPlaceLimitBeforeM5Entry || !EnableTrading || BlockAllTrades)
      return;

   static datetime s_lastSync = 0;
   datetime now = TimeCurrent();
   int refreshSec = MathMax(1, IA_HoldLimitFollowRefreshSeconds);
   if(s_lastSync > 0 && (now - s_lastSync) < refreshSec)
      return;
   s_lastSync = now;

   // Toujours tenter un recalcul : UpdateM5EntryLevelsAndLines() est déjà throttlé par M5EntryLevelsRefreshSeconds.
   UpdateM5EntryLevelsAndLines();

   double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   if(point <= 0.0) point = _Point;
   if(point <= 0.0) point = 0.0001;

   for(int i = OrdersTotal() - 1; i >= 0; i--)
   {
      ulong tk = OrderGetTicket(i);
      if(tk == 0 || !OrderSelect(tk)) continue;
      if(OrderGetInteger(ORDER_MAGIC) != InpMagicNumber) continue;
      if(OrderGetString(ORDER_SYMBOL) != _Symbol) continue;

      string oc = OrderGetString(ORDER_COMMENT);
      if(StringFind(oc, "IA_HOLD_LIMIT_") < 0) continue;

      ENUM_ORDER_TYPE ot = (ENUM_ORDER_TYPE)OrderGetInteger(ORDER_TYPE);
      if(ot != ORDER_TYPE_BUY_LIMIT && ot != ORDER_TYPE_SELL_LIMIT) continue;

      string dir = (ot == ORDER_TYPE_BUY_LIMIT) ? "BUY" : "SELL";

      double newEntry = 0.0, newSl = 0.0, newTp = 0.0;
      string src = "";
      if(!ComputeIAHoldLimitEntryAndStops(dir, newEntry, newSl, newTp, src))
      {
         MqlTradeRequest delReq = {};
         MqlTradeResult  delRes = {};
         delReq.action = TRADE_ACTION_REMOVE;
         delReq.order  = tk;
         delReq.symbol = _Symbol;
         delReq.magic  = InpMagicNumber;
         if(OrderSend(delReq, delRes))
            Print("🧹 IA_HOLD_LIMIT supprimé (zone Entry M5 invalide) | ", _Symbol, " | ", dir);
         continue;
      }

      double oldPrice = OrderGetDouble(ORDER_PRICE_OPEN);
      double moveThreshold = (double)MathMax(1, IA_HoldLimitFollowMoveThresholdPoints) * point;
      if(MathAbs(oldPrice - newEntry) < moveThreshold)
         continue;

      if(!ValidateAndAdjustLimitPrice(newEntry, newSl, newTp, ot))
         continue;

      MqlTradeRequest modReq = {};
      MqlTradeResult  modRes = {};
      modReq.action = TRADE_ACTION_MODIFY;
      modReq.order  = tk;
      modReq.symbol = _Symbol;
      modReq.magic  = InpMagicNumber;
      modReq.price  = NormalizeDouble(newEntry, _Digits);
      modReq.sl     = NormalizeDouble(newSl, _Digits);
      modReq.tp     = NormalizeDouble(newTp, _Digits);
      if(OrderSend(modReq, modRes))
         Print("🔁 IA_HOLD_LIMIT actualisé (Entry M5) | ", _Symbol, " | ", dir,
               " | ", DoubleToString(oldPrice, _Digits), " -> ", DoubleToString(newEntry, _Digits));
   }
}

// Scalp marché: LIMIT robot encore actif, aucune position, flèche pure Boom/Crash + IA ≥ seuil (alignement IA/flèche).
void CheckAndExecutePendingLimitPureArrowScalp()
{
   if(!UsePendingLimitPureArrowScalp || !EnableTrading || BlockAllTrades)
      return;
   if(SMC_GetSymbolCategory(_Symbol) != SYM_BOOM_CRASH)
      return;

   if(CountPositionsForSymbol(_Symbol) > 0)
      return;
   if(CountOpenLimitOrdersForSymbol(_Symbol) <= 0)
      return;

   double minU = PendingLimitArrowScalpMinAIConfidence;
   if(minU > 1.0) minU /= 100.0;
   if(minU < 0.0 || minU > 1.0) minU = 0.90;
   if(NormalizeAIConfidenceUnit() + 1e-9 < minU)
      return;

   if(UseAIServer && (g_lastAIAction == "HOLD" || g_lastAIAction == "hold"))
      return;

   string wantDir = "";
   if(IsBoomSymbol(_Symbol) && ChartHasPureColorArrowForBoomCrashDir("BUY"))
      wantDir = "BUY";
   else if(IsCrashSymbol(_Symbol) && ChartHasPureColorArrowForBoomCrashDir("SELL"))
      wantDir = "SELL";
   else
      return;

   string iaAct = g_lastAIAction;
   StringToUpper(iaAct);
   if(iaAct != wantDir)
      return;

   if(!IsDirectionAllowedForBoomCrash(_Symbol, wantDir))
      return;
   if(!IsBoomCrashDirectionAllowedByIA(_Symbol, wantDir))
      return;
   if(!IsSpreadAcceptable())
      return;
   if(IsInEquilibriumCorrectionZone())
      return;
   if(PendingLimitArrowScalpUseTrendFilter && !IsTrendAlignedEntry(wantDir))
      return;
   if(IsEntryCooldownActive())
      return;
   if(CheckSymbolLossProtection())
      return;
   if(IsMaxPositionsReached())
      return;

   static datetime s_lastPl = 0;
   datetime now = TimeCurrent();
   int cd = MathMax(1, PendingLimitArrowScalpCooldownSec);
   if(s_lastPl > 0 && (now - s_lastPl) < cd)
      return;

   datetime arrT = 0;
   if(!GetLatestColoredSignalArrowTimeForBoomCrashDir(wantDir, arrT))
      arrT = now;
   static string s_lastKey = "";
   string k = _Symbol + "_" + wantDir + "_" + TimeToString(arrT, TIME_MINUTES);
   if(s_lastKey == k && (now - s_lastPl) < 180)
      return;

   if(!TryAcquireOpenLock())
      return;

   bool isBoom = IsBoomSymbol(_Symbol);
   bool isCrash = IsCrashSymbol(_Symbol);
   bool isWeltradeSynth = IsWeltradeGainSynthSymbol(_Symbol) || IsWeltradePainSynthSymbol(_Symbol);

   MqlRates r[];
   ArraySetAsSeries(r, true);
   if(CopyRates(_Symbol, PERIOD_CURRENT, 0, 1, r) < 1)
   {
      ReleaseOpenLock();
      return;
   }
   double currentPrice = r[0].close;

   long stopsLevel = SymbolInfoInteger(_Symbol, SYMBOL_TRADE_STOPS_LEVEL);
   double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   double tickSize = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_SIZE);
   if(tickSize <= 0.0) tickSize = point;

   double minStopDistance = (double)stopsLevel * point;
   if(minStopDistance <= 0.0)
   {
      if(isCrash || isBoom || isWeltradeSynth)
         minStopDistance = MathMax(1.0, BoomCrashSlMinPointsFloor) * point;
      else
         minStopDistance = 20.0 * point;
   }
   else if(isCrash || isBoom || isWeltradeSynth)
      minStopDistance = MathMax(minStopDistance, MathMax(1.0, BoomCrashSlBrokerFloorPoints) * point);

   double bcSlMult3 = BoomCrashSlSafeDistanceMult;
   if(bcSlMult3 < 1.01) bcSlMult3 = 1.01;
   double safeDistance = minStopDistance * ((isCrash || isBoom || isWeltradeSynth) ? bcSlMult3 : 2.0);

   double stopLoss;
   double takeProfit;
   if(wantDir == "BUY")
   {
      stopLoss = currentPrice - safeDistance;
      takeProfit = currentPrice + (safeDistance * 2.0);
   }
   else
   {
      stopLoss = currentPrice + safeDistance;
      takeProfit = currentPrice - (safeDistance * 2.0);
   }

   double askPrice = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   double bidPrice = SymbolInfoDouble(_Symbol, SYMBOL_BID);

   if(wantDir == "BUY")
   {
      if(askPrice - stopLoss < safeDistance)
         stopLoss = askPrice - safeDistance;
      if(takeProfit - askPrice < safeDistance)
         takeProfit = askPrice + (safeDistance * 2.0);
   }
   else
   {
      if(stopLoss - bidPrice < safeDistance)
         stopLoss = bidPrice + safeDistance;
      if(bidPrice - takeProfit < safeDistance)
         takeProfit = bidPrice - (safeDistance * 2.0);
   }

   if(wantDir == "BUY")
   {
      stopLoss = MathFloor(stopLoss / tickSize) * tickSize;
      takeProfit = MathCeil(takeProfit / tickSize) * tickSize;
   }
   else
   {
      stopLoss = MathCeil(stopLoss / tickSize) * tickSize;
      takeProfit = MathFloor(takeProfit / tickSize) * tickSize;
   }
   stopLoss = NormalizeDouble(stopLoss, _Digits);
   takeProfit = NormalizeDouble(takeProfit, _Digits);

   double lotBase = CalculateLotSize();
   double fact = PendingLimitArrowScalpLotFactor;
   if(fact <= 0.0) fact = 0.40;
   double lotToTrade = NormalizeVolumeForSymbol(lotBase * fact);
   if(lotToTrade <= 0.0)
   {
      ReleaseOpenLock();
      return;
   }

   MqlTradeRequest request = {};
   MqlTradeResult result = {};
   request.action = TRADE_ACTION_DEAL;
   request.symbol = _Symbol;
   request.volume = lotToTrade;
   request.type = (wantDir == "BUY") ? ORDER_TYPE_BUY : ORDER_TYPE_SELL;
   if(!IsOrderTypeAllowedForBoomCrash(_Symbol, request.type))
   {
      ReleaseOpenLock();
      return;
   }
   request.price = (wantDir == "BUY") ? askPrice : bidPrice;
   EnforceMinBoomCrashStopLossDollarRisk(_Symbol, wantDir, request.price, request.volume, stopLoss);
   request.sl = stopLoss;
   request.tp = takeProfit;
   request.deviation = 20;
   request.magic = InpMagicNumber;
   request.comment = "PEND_LIM_PURE_ARROW " + wantDir;

   if(!IsMinimumProfitPotentialMet(request.price, takeProfit, wantDir, lotToTrade))
   {
      ReleaseOpenLock();
      return;
   }

   if(OrderSend(request, result) && (result.retcode == TRADE_RETCODE_DONE || result.retcode == 10009))
   {
      g_lastEntryTimeForSymbol = TimeCurrent();
      s_lastPl = now;
      s_lastKey = k;
      Print("✅ PEND_LIM_PURE_ARROW exécuté | ", _Symbol, " | ", wantDir,
            " | lot=", DoubleToString(lotToTrade, 2),
            " | ticket=", result.order);
      NotifyTradeEvent("✅ SCALP LIMIT+FLÈCHE " + wantDir + " " + _Symbol +
                       " | ticket=" + IntegerToString((int)result.order), EntryTradeSoundFile);
   }
   else
      Print("❌ PEND_LIM_PURE_ARROW échec | ", _Symbol, " | ret=", result.retcode, " ", result.comment);

   ReleaseOpenLock();
}

bool PlaceHoldLimitBeforeM5Entry(const string direction, const double confUnit)
{
   static datetime s_lastHoldLimitUtc = 0;
   EnsureSinglePendingLimitOrderForSymbol(_Symbol);
   datetime now = TimeCurrent();
   if(IA_HoldLimitCooldownSeconds > 0 && s_lastHoldLimitUtc > 0 &&
      (now - s_lastHoldLimitUtc) < IA_HoldLimitCooldownSeconds)
      return false;

   string dir = direction; StringToUpper(dir);
   if(dir != "BUY" && dir != "SELL")
      return false;

   // Exiger que les lignes M5 soient actives (sinon on ne sait pas ce que "avant Entry M5" signifie)
   if(dir == "BUY" && !g_m5BuyLevelActive) return false;
   if(dir == "SELL" && !g_m5SellLevelActive) return false;

   // Eviter duplication: max 1 pending LIMIT pour ce symbole
   if(CountOpenLimitOrdersForSymbol(_Symbol) > 0)
      return false;

   string src = "";
   double entry = 0.0, sl = 0.0, tp = 0.0;
   if(!ComputeIAHoldLimitEntryAndStops(dir, entry, sl, tp, src))
      return false;

   MqlTradeRequest req = {};
   MqlTradeResult  res = {};
   req.action = TRADE_ACTION_PENDING;
   req.symbol = _Symbol;
   req.magic  = InpMagicNumber;
   req.volume = NormalizeVolumeForSymbol(GetOptimalLotSize());
   req.price  = entry;
   req.sl     = sl;
   req.tp     = tp;
   req.type   = (dir == "BUY") ? ORDER_TYPE_BUY_LIMIT : ORDER_TYPE_SELL_LIMIT;
   req.type_filling = ORDER_FILLING_FOK;
   req.type_time = ORDER_TIME_GTC;
   req.comment = "IA_HOLD_LIMIT_" + dir;

   // Validation pending (évite Invalid stops / tick size)
   if(!ValidateAndAdjustLimitPrice(req.price, req.sl, req.tp, req.type))
      return false;

   bool ok = OrderSend(req, res);
   if(ok && (res.retcode == TRADE_RETCODE_DONE || res.retcode == 10009))
   {
      s_lastHoldLimitUtc = now;
      Print("✅ IA HOLD => LIMIT placé | ", _Symbol,
            " | dir=", dir,
            " | entry=", DoubleToString(req.price, _Digits),
            " | SL=", DoubleToString(req.sl, _Digits),
            " | TP=", DoubleToString(req.tp, _Digits),
            " | src=", src,
            " | conf=", DoubleToString(confUnit * 100.0, 1), "%");
      return true;
   }

   Print("❌ IA HOLD => LIMIT échec | ", _Symbol,
         " | ret=", res.retcode, " ", res.comment,
         " | dir=", dir,
         " | entry=", DoubleToString(req.price, _Digits),
         " | src=", src);
   return false;
}

string StairPostLossGvKeyBase(const string sym)
{
   string s = sym;
   StringReplace(s, "#", "_");
   StringReplace(s, ".", "_");
   StringReplace(s, "/", "_");
   StringReplace(s, "\\", "_");
   if(StringLen(s) > 24)
      s = StringSubstr(s, 0, 24);
   return "STPL_" + s + "_";
}

void StairPostLossClearSrMode(const string symbol)
{
   string b = StairPostLossGvKeyBase(symbol);
   GlobalVariableDel(b + "T");
   GlobalVariableDel(b + "B");
   GlobalVariableDel(b + "C");
   GlobalVariableDel(b + "L");
}

void StairPostLossArmSrMode(const string symbol, const datetime closeTime)
{
   if(!StairPostLossUseSrLimitInsteadOfMarket)
      return;
   string b = StairPostLossGvKeyBase(symbol);
   GlobalVariableSet(b + "T", (double)closeTime);
   GlobalVariableSet(b + "B", (double)g_lastBoomSpikeTime);
   GlobalVariableSet(b + "C", (double)g_lastCrashSpikeTime);
   Print("📌 STAIR post-perte | mode LIMIT SR (plus de marché STAIR) | sym=", symbol,
         " | close=", TimeToString(closeTime, TIME_DATE | TIME_SECONDS),
         " | boomSpikeSnap=", (long)g_lastBoomSpikeTime,
         " | crashSpikeSnap=", (long)g_lastCrashSpikeTime);
}

bool HistoryPositionHadStairEntry(const ulong positionId)
{
   if(!HistorySelectByPosition(positionId))
      return false;
   const int n = HistoryDealsTotal();
   for(int i = 0; i < n; i++)
   {
      ulong t = HistoryDealGetTicket(i);
      if(t == 0)
         continue;
      if((ENUM_DEAL_ENTRY)HistoryDealGetInteger(t, DEAL_ENTRY) != DEAL_ENTRY_IN)
         continue;
      string c = HistoryDealGetString(t, DEAL_COMMENT);
      if(StringFind(c, "STAIR_ENTRY") >= 0)
         return true;
   }
   return false;
}

bool StairPostLossSrModeActive(const string symbol)
{
   if(!StairPostLossUseSrLimitInsteadOfMarket)
      return false;
   string b = StairPostLossGvKeyBase(symbol);
   if(!GlobalVariableCheck(b + "T"))
      return false;
   datetime tclose = (datetime)GlobalVariableGet(b + "T");
   if(StairPostLossSrLimitExpireMinutes > 0)
   {
      if((TimeCurrent() - tclose) > StairPostLossSrLimitExpireMinutes * 60)
      {
         StairPostLossClearSrMode(symbol);
         return false;
      }
   }
   datetime boomSnap = GlobalVariableCheck(b + "B") ? (datetime)GlobalVariableGet(b + "B") : (datetime)0;
   datetime crashSnap = GlobalVariableCheck(b + "C") ? (datetime)GlobalVariableGet(b + "C") : (datetime)0;

   if(IsBoomSymbol(symbol) || IsWeltradeGainSynthSymbol(symbol))
   {
      if(g_lastBoomSpikeTime > boomSnap)
      {
         StairPostLossClearSrMode(symbol);
         return false;
      }
   }
   if(IsCrashSymbol(symbol) || IsWeltradePainSynthSymbol(symbol))
   {
      if(g_lastCrashSpikeTime > crashSnap)
      {
         StairPostLossClearSrMode(symbol);
         return false;
      }
   }
   return true;
}

bool PickStairPostLossSrLimitEntryPrice(const string direction, const double m5RefIn, double &entryOut)
{
   string dir = direction;
   StringToUpper(dir);
   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   double pt = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   if(pt <= 0.0)
      pt = _Point;
   if(bid <= 0.0 || ask <= 0.0 || pt <= 0.0)
      return false;

   double m5Ref = m5RefIn;
   if(dir == "BUY")
   {
      if(m5Ref <= 0.0 && g_m5BuyLevelActive)
         m5Ref = g_m5BuyEntryLevel;
      if(m5Ref <= 0.0)
         m5Ref = bid - 80.0 * pt;
   }
   else
   {
      if(m5Ref <= 0.0 && g_m5SellLevelActive)
         m5Ref = g_m5SellEntryLevel;
      if(m5Ref <= 0.0)
         m5Ref = ask + 80.0 * pt;
   }

   double cand[8];
   int n = 0;
   cand[n++] = GetSupportLevelTF(PERIOD_M5, 20);
   cand[n++] = GetSupportLevelTF(PERIOD_M15, 24);
   cand[n++] = GetSupportLevelTF(PERIOD_M5, 40);
   cand[n++] = GetResistanceLevelTF(PERIOD_M5, 20);
   cand[n++] = GetResistanceLevelTF(PERIOD_M15, 24);
   cand[n++] = GetResistanceLevelTF(PERIOD_M5, 40);

   double best = 0.0;
   double bestDist = DBL_MAX;
   const double minOff = MathMax(pt * 3.0, SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_SIZE));

   if(dir == "BUY")
   {
      const double maxBuy = bid - minOff;
      for(int i = 0; i < n; i++)
      {
         const double v = cand[i];
         if(v <= 0.0 || v >= maxBuy)
            continue;
         const double dist = MathAbs(v - m5Ref);
         if(dist < bestDist)
         {
            bestDist = dist;
            best = v;
         }
      }
   }
   else
   {
      const double minSell = ask + minOff;
      for(int i = 0; i < n; i++)
      {
         const double v = cand[i];
         if(v <= 0.0 || v <= minSell)
            continue;
         const double dist = MathAbs(v - m5Ref);
         if(dist < bestDist)
         {
            bestDist = dist;
            best = v;
         }
      }
   }

   if(best <= 0.0 || bestDist >= DBL_MAX)
   {
      double atr = GetCurrentATRValue();
      if(atr <= 0.0)
         atr = bid * 0.001;
      if(dir == "BUY")
      {
         best = m5Ref - atr * 0.35;
         if(best >= bid - minOff)
            best = bid - MathMax(minOff, atr * 0.2);
      }
      else
      {
         best = m5Ref + atr * 0.35;
         if(best <= ask + minOff)
            best = ask + MathMax(minOff, atr * 0.2);
      }
   }

   if(dir == "BUY" && best >= bid - pt * 2.0)
      return false;
   if(dir == "SELL" && best <= ask + pt * 2.0)
      return false;

   entryOut = NormalizeDouble(best, _Digits);
   return (entryOut > 0.0);
}

bool TryPlaceStairPostLossSrRecoveryLimit(const string direction, const bool quiet)
{
   string dir = direction;
   StringToUpper(dir);
   if(dir != "BUY" && dir != "SELL")
      return false;

   EnsureSinglePendingLimitOrderForSymbol(_Symbol);
   if(CountOpenLimitOrdersForSymbol(_Symbol) > 0)
      return true;

   string b = StairPostLossGvKeyBase(_Symbol);
   if(StairPostLossSrLimitCooldownSeconds > 0 && GlobalVariableCheck(b + "L"))
   {
      datetime lp = (datetime)GlobalVariableGet(b + "L");
      if((TimeCurrent() - lp) < StairPostLossSrLimitCooldownSeconds)
         return false;
   }

   double m5Ref = (dir == "BUY") ? (g_m5BuyLevelActive ? g_m5BuyEntryLevel : 0.0)
                                 : (g_m5SellLevelActive ? g_m5SellEntryLevel : 0.0);
   double entry = 0.0;
   if(!PickStairPostLossSrLimitEntryPrice(dir, m5Ref, entry))
   {
      if(!quiet)
         Print("🚫 STAIR SR recovery — aucun prix LIMIT valide (SR/M5) | ", _Symbol, " | dir=", dir);
      return false;
   }

   double atr = GetCurrentATRValue();
   if(atr <= 0.0)
      atr = SymbolInfoDouble(_Symbol, SYMBOL_BID) * 0.001;
   if(atr <= 0.0)
      return false;

   double sl = 0.0, tp = 0.0;
   if(dir == "BUY")
   {
      sl = entry - atr * MathMax(0.5, IA_HoldLimitSL_ATR);
      tp = entry + atr * MathMax(0.8, IA_HoldLimitTP_ATR);
   }
   else
   {
      sl = entry + atr * MathMax(0.5, IA_HoldLimitSL_ATR);
      tp = entry - atr * MathMax(0.8, IA_HoldLimitTP_ATR);
   }
   sl = NormalizeDouble(sl, _Digits);
   tp = NormalizeDouble(tp, _Digits);
   ValidateAndAdjustStopLossTakeProfit(dir, entry, sl, tp);

   MqlTradeRequest req = {};
   MqlTradeResult res = {};
   req.action = TRADE_ACTION_PENDING;
   req.symbol = _Symbol;
   req.magic = InpMagicNumber;
   req.volume = NormalizeVolumeForSymbol(GetOptimalLotSize());
   req.price = entry;
   req.sl = sl;
   req.tp = tp;
   req.type = (dir == "BUY") ? ORDER_TYPE_BUY_LIMIT : ORDER_TYPE_SELL_LIMIT;
   req.type_filling = ORDER_FILLING_FOK;
   req.type_time = ORDER_TIME_GTC;
   req.comment = "STAIR_SR_RECOVERY_" + dir;

   if(!ValidateAndAdjustLimitPrice(req.price, req.sl, req.tp, req.type))
   {
      if(!quiet)
         Print("🚫 STAIR SR recovery — validation broker LIMIT | ", _Symbol);
      return false;
   }

   if(!TryAcquireOpenLock())
   {
      if(!quiet)
         Print("🚫 STAIR SR recovery — lock ouverture | ", _Symbol);
      return false;
   }
   bool ok = OrderSend(req, res);
   ReleaseOpenLock();
   if(ok && (res.retcode == TRADE_RETCODE_DONE || res.retcode == 10009))
   {
      GlobalVariableSet(b + "L", (double)TimeCurrent());
      Print("✅ STAIR post-perte — LIMIT SR placé | ", _Symbol,
            " | dir=", dir,
            " | entry=", DoubleToString(req.price, _Digits),
            " | SL=", DoubleToString(req.sl, _Digits),
            " | TP=", DoubleToString(req.tp, _Digits));
      return true;
   }
   if(!quiet)
      Print("❌ STAIR SR recovery — OrderSend | ", _Symbol, " | ret=", res.retcode, " ", res.comment);
   return false;
}

double GetFibEquilibriumFromRecentSwing(const ENUM_TIMEFRAMES tf, const int lookback)
{
   if(lookback < 5)
      return 0.0;
   MqlRates r[];
   ArraySetAsSeries(r, true);
   if(CopyRates(_Symbol, tf, 0, lookback, r) < lookback)
      return 0.0;
   double hi = r[0].high;
   double lo = r[0].low;
   for(int i = 1; i < lookback; i++)
   {
      if(r[i].high > hi)
         hi = r[i].high;
      if(r[i].low < lo)
         lo = r[i].low;
   }
   if(hi <= lo)
      return 0.0;
   return NormalizeDouble((hi + lo) * 0.5, _Digits);
}

bool PassOteFibSwingEquilibriumFilter(const string direction, const double refPrice)
{
   if(!OTE_UseFibSwingEquilibriumFilter)
      return true;
   double eq = GetFibEquilibriumFromRecentSwing(OTE_FibSwingEquilibriumTF, OTE_FibSwingEquilibriumLookback);
   if(eq <= 0.0 || refPrice <= 0.0)
      return true;
   double pt = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   if(pt <= 0.0)
      pt = _Point;
   const double tol = (double)OTE_FibSwingEquilibriumTolPts * pt;

   string d = direction;
   StringToUpper(d);
   if(d == "BUY" && refPrice > eq + tol)
   {
      Print("🚫 OTE Fib 0.5 — BUY refusé au-dessus équilibre range | ", _Symbol,
            " | ref=", DoubleToString(refPrice, _Digits),
            " | eq=", DoubleToString(eq, _Digits));
      return false;
   }
   if(d == "SELL" && refPrice < eq - tol)
   {
      Print("🚫 OTE Fib 0.5 — SELL refusé sous équilibre range | ", _Symbol,
            " | ref=", DoubleToString(refPrice, _Digits),
            " | eq=", DoubleToString(eq, _Digits));
      return false;
   }
   return true;
}

bool IsWeakScissorChannelContext()
{
   double e9m1=0,e21m1=0,e50m1=0,e9m5=0,e21m5=0,e50m5=0;
   if(!ReadEMAValue(PERIOD_M1, 9, e9m1) || !ReadEMAValue(PERIOD_M1, 21, e21m1) || !ReadEMAValue(PERIOD_M1, 50, e50m1))
      return false;
   if(!ReadEMAValue(PERIOD_M5, 9, e9m5) || !ReadEMAValue(PERIOD_M5, 21, e21m5) || !ReadEMAValue(PERIOD_M5, 50, e50m5))
      return false;

   double price = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double atr = GetCurrentATRValue();
   if(atr <= 0.0 && price > 0.0) atr = price * 0.001;
   if(atr <= 0.0) return false;

   double spreadM1 = MathAbs(e9m1 - e21m1) + MathAbs(e21m1 - e50m1);
   double spreadM5 = MathAbs(e9m5 - e21m5) + MathAbs(e21m5 - e50m5);
   bool compressed = (spreadM1 <= atr * 0.9 && spreadM5 <= atr * 1.2);

   bool mixedOrder =
      ((e9m1 > e21m1 && e21m1 < e50m1) || (e9m1 < e21m1 && e21m1 > e50m1) ||
       (e9m5 > e21m5 && e21m5 < e50m5) || (e9m5 < e21m5 && e21m5 > e50m5));

   return compressed || mixedOrder;
}

double SelectAggressiveEMAEntry(const string direction, const double currentPrice)
{
   double e9m1=0,e21m1=0,e50m1=0,e9m5=0,e21m5=0,e50m5=0;
   if(!ReadEMAValue(PERIOD_M1, 9, e9m1) || !ReadEMAValue(PERIOD_M1, 21, e21m1) || !ReadEMAValue(PERIOD_M1, 50, e50m1))
      return 0.0;
   if(!ReadEMAValue(PERIOD_M5, 9, e9m5) || !ReadEMAValue(PERIOD_M5, 21, e21m5) || !ReadEMAValue(PERIOD_M5, 50, e50m5))
      return 0.0;

   double emas[6] = {e9m1, e21m1, e50m1, e9m5, e21m5, e50m5};
   string dir = direction; StringToUpper(dir);
   double selected = 0.0;

   if(dir == "BUY")
   {
      for(int i = 0; i < 6; i++)
      {
         if(emas[i] <= 0.0 || emas[i] > currentPrice) continue;
         if(selected == 0.0 || emas[i] > selected) selected = emas[i];
      }
   }
   else if(dir == "SELL")
   {
      for(int i = 0; i < 6; i++)
      {
         if(emas[i] <= 0.0 || emas[i] < currentPrice) continue;
         if(selected == 0.0 || emas[i] < selected) selected = emas[i];
      }
   }
   return selected;
}

//+------------------------------------------------------------------+
//| Met à jour les niveaux d'entrée M5 et dessine les lignes épaisses |
//+------------------------------------------------------------------+
void UpdateM5EntryLevelsAndLines()
{
   // Mettre à jour régulièrement selon input (lignes ENTRY plus dynamiques)
   static datetime lastM5Update = 0;
   datetime currentTime = TimeCurrent();

   int refreshSec = MathMax(1, M5EntryLevelsRefreshSeconds);
   if(currentTime - lastM5Update < refreshSec) return;
   lastM5Update = currentTime;
   
   // Récupérer les données M5
   MqlRates m5Rates[];
   ArraySetAsSeries(m5Rates, true);
   
   if(CopyRates(_Symbol, PERIOD_M5, 0, 100, m5Rates) < 50)
   {
      Print("❌ Erreur: Impossible de récupérer les données M5 pour les niveaux d'entrée");
      return;
   }
   
   // Calculer les niveaux de support/résistance M5
   // SR20 demandé (support/résistance calculés sur 20 bougies)
   double m5Support = GetSupportLevelTF(PERIOD_M5, 20);
   double m5Resistance = GetResistanceLevelTF(PERIOD_M5, 20);
   
   // Calculer les EMAs M5 pour confirmation
   double ema9M5 = 0.0, ema21M5 = 0.0;
   int ema9Handle = iMA(_Symbol, PERIOD_M5, 9, 0, MODE_EMA, PRICE_CLOSE);
   int ema21Handle = iMA(_Symbol, PERIOD_M5, 21, 0, MODE_EMA, PRICE_CLOSE);
   
   if(ema9Handle != INVALID_HANDLE && ema21Handle != INVALID_HANDLE)
   {
      double ema9Buf[], ema21Buf[];
      ArraySetAsSeries(ema9Buf, true);
      ArraySetAsSeries(ema21Buf, true);
      
      if(CopyBuffer(ema9Handle, 0, 0, 1, ema9Buf) >= 1) ema9M5 = ema9Buf[0];
      if(CopyBuffer(ema21Handle, 0, 0, 1, ema21Buf) >= 1) ema21M5 = ema21Buf[0];
   }
   
   double currentPrice = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   
   // Déterminer les niveaux d'entrée
   g_m5BuyEntryLevel = 0.0;
   g_m5SellEntryLevel = 0.0;
   g_m5BuyLevelActive = false;
   g_m5SellLevelActive = false;
   
   // Niveau BUY: agressif si M1+M5 très alignés, sinon support/EMA21 M5
   bool strongBuy = UseAggressiveScalpOnStrongM1M5 && IsStrongM1M5TrendByEMAs("BUY");
   bool strongSell = UseAggressiveScalpOnStrongM1M5 && IsStrongM1M5TrendByEMAs("SELL");
   double aggressiveBuyEMA = strongBuy ? SelectAggressiveEMAEntry("BUY", currentPrice) : 0.0;
   double aggressiveSellEMA = strongSell ? SelectAggressiveEMAEntry("SELL", currentPrice) : 0.0;

   if(strongBuy && aggressiveBuyEMA > 0.0 && g_lastAIConfidence * 100.0 >= StrongM1M5MinConfidencePercent)
   {
      g_m5BuyEntryLevel = aggressiveBuyEMA;
      g_m5BuyLevelActive = true;
   }
   else if(currentPrice > m5Support && m5Support > 0)
   {
      g_m5BuyEntryLevel = m5Support + SymbolInfoDouble(_Symbol, SYMBOL_POINT) * 5; // 5 pips au-dessus du support
      g_m5BuyLevelActive = true;
   }
   else if(currentPrice > ema21M5 && ema21M5 > 0)
   {
      g_m5BuyEntryLevel = ema21M5 + SymbolInfoDouble(_Symbol, SYMBOL_POINT) * 3; // 3 pips au-dessus EMA21
      g_m5BuyLevelActive = true;
   }
   
   // Niveau SELL: agressif si M1+M5 très alignés, sinon résistance/EMA21 M5
   if(strongSell && aggressiveSellEMA > 0.0 && g_lastAIConfidence * 100.0 >= StrongM1M5MinConfidencePercent)
   {
      g_m5SellEntryLevel = aggressiveSellEMA;
      g_m5SellLevelActive = true;
   }
   else if(currentPrice < m5Resistance && m5Resistance > 0)
   {
      g_m5SellEntryLevel = m5Resistance - SymbolInfoDouble(_Symbol, SYMBOL_POINT) * 5; // 5 pips sous la résistance
      g_m5SellLevelActive = true;
   }
   else if(currentPrice < ema21M5 && ema21M5 > 0)
   {
      g_m5SellEntryLevel = ema21M5 - SymbolInfoDouble(_Symbol, SYMBOL_POINT) * 3; // 3 pips sous EMA21
      g_m5SellLevelActive = true;
   }
   
   // Dessiner les lignes épaisses sur le graphique
   DrawM5EntryLines();
   DrawM1TrendLines(); // NOUVEAU: lignes de tendance M1
   
   g_m5LevelsLastUpdate = currentTime;
   
   Print("📊 NIVEAUX M5 MIS À JOUR - Buy: ", DoubleToString(g_m5BuyEntryLevel, _Digits), 
         " | Sell: ", DoubleToString(g_m5SellEntryLevel, _Digits));
}

//+------------------------------------------------------------------+
//| Dessine les lignes de tendance M1 pour identifier les entrées     |
//+------------------------------------------------------------------+
void DrawM1TrendLines()
{
   // Supprimer les anciennes lignes M1
   ObjectsDeleteAll(0, "M1_TREND_");
   
   datetime currentTime = TimeCurrent();
   datetime lineEndTime = currentTime + PeriodSeconds(PERIOD_M1) * 50; // Étendre sur 50 bougies M1
   datetime futureLabelTime = currentTime + PeriodSeconds(PERIOD_M1) * 40;
   
   // Récupérer les données M1
   MqlRates m1Rates[];
   ArraySetAsSeries(m1Rates, true);
   if(CopyRates(_Symbol, PERIOD_M1, 0, 30, m1Rates) < 20)
      return;
   
   // Calculer la tendance M1 simple (régression linéaire sur 20 bougies)
   double sumX = 0, sumY = 0, sumXY = 0, sumX2 = 0;
   int lookback = 20;
   
   for(int i = 0; i < lookback; i++)
   {
      double x = i;
      double y = m1Rates[i].close;
      sumX += x;
      sumY += y;
      sumXY += x * y;
      sumX2 += x * x;
   }
   
   double slope = (lookback * sumXY - sumX * sumY) / (lookback * sumX2 - sumX * sumY);
   double intercept = (sumY - slope * sumX) / lookback;
   
   // Calculer les prix de tendance actuels et futurs
   double currentTrendPrice = intercept; // x = 0 pour la bougie actuelle
   double futureTrendPrice = intercept + slope * 10; // x = 10 pour 10 bougies dans le futur
   
   // Déterminer la direction de la tendance
   bool bullishTrend = (slope > 0);
   
   // Ligne de tendance M1 BUY (si bullish)
   if(bullishTrend)
   {
      string m1BuyTrendName = "M1_TREND_BUY_LINE";
      ObjectCreate(0, m1BuyTrendName, OBJ_TREND, 0, currentTime - PeriodSeconds(PERIOD_M1) * 20, intercept + slope * 20, currentTime + PeriodSeconds(PERIOD_M1) * 10, futureTrendPrice);
      ObjectSetInteger(0, m1BuyTrendName, OBJPROP_COLOR, clrLime);
      ObjectSetInteger(0, m1BuyTrendName, OBJPROP_WIDTH, 3);
      ObjectSetInteger(0, m1BuyTrendName, OBJPROP_STYLE, STYLE_SOLID);
      ObjectSetInteger(0, m1BuyTrendName, OBJPROP_RAY_RIGHT, true);
      ObjectSetInteger(0, m1BuyTrendName, OBJPROP_BACK, false);
      
      string m1BuyLabel = "M1_TREND_BUY_LABEL";
      ObjectCreate(0, m1BuyLabel, OBJ_TEXT, 0, futureLabelTime, futureTrendPrice);
      ObjectSetString(0, m1BuyLabel, OBJPROP_TEXT, "M1 TREND BUY " + DoubleToString(futureTrendPrice, _Digits));
      ObjectSetInteger(0, m1BuyLabel, OBJPROP_COLOR, clrLime);
      ObjectSetInteger(0, m1BuyLabel, OBJPROP_FONTSIZE, 10);
   }
   else // Trend baissier
   {
      string m1SellTrendName = "M1_TREND_SELL_LINE";
      ObjectCreate(0, m1SellTrendName, OBJ_TREND, 0, currentTime - PeriodSeconds(PERIOD_M1) * 20, intercept + slope * 20, currentTime + PeriodSeconds(PERIOD_M1) * 10, futureTrendPrice);
      ObjectSetInteger(0, m1SellTrendName, OBJPROP_COLOR, clrRed);
      ObjectSetInteger(0, m1SellTrendName, OBJPROP_WIDTH, 3);
      ObjectSetInteger(0, m1SellTrendName, OBJPROP_STYLE, STYLE_SOLID);
      ObjectSetInteger(0, m1SellTrendName, OBJPROP_RAY_RIGHT, true);
      ObjectSetInteger(0, m1SellTrendName, OBJPROP_BACK, false);
      
      string m1SellLabel = "M1_TREND_SELL_LABEL";
      ObjectCreate(0, m1SellLabel, OBJ_TEXT, 0, futureLabelTime, futureTrendPrice);
      ObjectSetString(0, m1SellLabel, OBJPROP_TEXT, "M1 TREND SELL " + DoubleToString(futureTrendPrice, _Digits));
      ObjectSetInteger(0, m1SellLabel, OBJPROP_COLOR, clrRed);
      ObjectSetInteger(0, m1SellLabel, OBJPROP_FONTSIZE, 10);
   }
}

//+------------------------------------------------------------------+
//| Dessine les lignes d'entrée M5 épaisses sur le graphique         |
//+------------------------------------------------------------------+
void DrawM5EntryLines()
{
   // Supprimer les anciennes lignes
   ObjectsDeleteAll(0, "M5_ENTRY_");
   ObjectsDeleteAll(0, "M5_TREND_ENTRY_");
   ObjectDelete(0, "M5_TREND_ENTRY_BUY_LABEL");
   ObjectDelete(0, "M5_TREND_ENTRY_SELL_LABEL");
   
   datetime currentTime = TimeCurrent();
   datetime lineEndTime = currentTime + PeriodSeconds(PERIOD_M1) * 100; // Étendre sur 100 bougies M1
   datetime futureLabelTime = currentTime + PeriodSeconds(PERIOD_M1) * 80; // Label bien en zone future
   
   // Ligne BUY ENTRY (épaisse bleue)
   if(g_m5BuyLevelActive && g_m5BuyEntryLevel > 0)
   {
      string buyLineName = "M5_ENTRY_BUY_LINE";
      ObjectCreate(0, buyLineName, OBJ_HLINE, 0, currentTime, g_m5BuyEntryLevel);
      ObjectSetInteger(0, buyLineName, OBJPROP_COLOR, clrDodgerBlue);
      ObjectSetInteger(0, buyLineName, OBJPROP_WIDTH, 6); // Très épaisse
      ObjectSetInteger(0, buyLineName, OBJPROP_STYLE, STYLE_SOLID);
      ObjectSetInteger(0, buyLineName, OBJPROP_BACK, false);
      ObjectSetString(0, buyLineName, OBJPROP_TEXT, "BUY ENTRY M5");

      // Alias "Trend Entry" demandé
      string buyTrendLineName = "M5_TREND_ENTRY_BUY_LINE";
      double buyTrendPrice = g_m5BuyEntryLevel + SymbolInfoDouble(_Symbol, SYMBOL_POINT) * 12.0;
      ObjectCreate(0, buyTrendLineName, OBJ_HLINE, 0, currentTime, buyTrendPrice);
      ObjectSetInteger(0, buyTrendLineName, OBJPROP_COLOR, clrDodgerBlue);
      ObjectSetInteger(0, buyTrendLineName, OBJPROP_WIDTH, 6);
      ObjectSetInteger(0, buyTrendLineName, OBJPROP_STYLE, STYLE_DASHDOT);
      ObjectSetInteger(0, buyTrendLineName, OBJPROP_BACK, false);
      ObjectSetString(0, buyTrendLineName, OBJPROP_TEXT, "BUY TREND ENTRY M5");

      string buyTrendLabel = "M5_TREND_ENTRY_BUY_LABEL";
      ObjectCreate(0, buyTrendLabel, OBJ_TEXT, 0, futureLabelTime, buyTrendPrice);
      ObjectSetString(0, buyTrendLabel, OBJPROP_TEXT, "M5 TREND BUY " + DoubleToString(buyTrendPrice, _Digits));
      ObjectSetInteger(0, buyTrendLabel, OBJPROP_COLOR, clrDodgerBlue);
      ObjectSetInteger(0, buyTrendLabel, OBJPROP_FONTSIZE, 11);
      
      // Label pour la ligne BUY
      string buyLabel = "M5_ENTRY_BUY_LABEL";
      ObjectCreate(0, buyLabel, OBJ_TEXT, 0, futureLabelTime, g_m5BuyEntryLevel);
      ObjectSetString(0, buyLabel, OBJPROP_TEXT,
                      "BUY ENTRY POINT  " + DoubleToString(g_m5BuyEntryLevel, _Digits));
      ObjectSetInteger(0, buyLabel, OBJPROP_COLOR, clrDodgerBlue);
      ObjectSetInteger(0, buyLabel, OBJPROP_FONTSIZE, 12);
      ObjectSetInteger(0, buyLabel, OBJPROP_BACK, false);
      ObjectSetInteger(0, buyLabel, OBJPROP_ANCHOR, ANCHOR_LEFT);
   }
   
   // Ligne SELL ENTRY (épaisse jaune)
   if(g_m5SellLevelActive && g_m5SellEntryLevel > 0)
   {
      string sellLineName = "M5_ENTRY_SELL_LINE";
      ObjectCreate(0, sellLineName, OBJ_HLINE, 0, currentTime, g_m5SellEntryLevel);
      ObjectSetInteger(0, sellLineName, OBJPROP_COLOR, clrYellow);
      ObjectSetInteger(0, sellLineName, OBJPROP_WIDTH, 6); // Très épaisse
      ObjectSetInteger(0, sellLineName, OBJPROP_STYLE, STYLE_SOLID);
      ObjectSetInteger(0, sellLineName, OBJPROP_BACK, false);
      ObjectSetString(0, sellLineName, OBJPROP_TEXT, "SELL ENTRY M5");

      // Alias "Trend Entry" demandé
      string sellTrendLineName = "M5_TREND_ENTRY_SELL_LINE";
      double sellTrendPrice = g_m5SellEntryLevel - SymbolInfoDouble(_Symbol, SYMBOL_POINT) * 12.0;
      ObjectCreate(0, sellTrendLineName, OBJ_HLINE, 0, currentTime, sellTrendPrice);
      ObjectSetInteger(0, sellTrendLineName, OBJPROP_COLOR, clrYellow);
      ObjectSetInteger(0, sellTrendLineName, OBJPROP_WIDTH, 6);
      ObjectSetInteger(0, sellTrendLineName, OBJPROP_STYLE, STYLE_DASHDOT);
      ObjectSetInteger(0, sellTrendLineName, OBJPROP_BACK, false);
      ObjectSetString(0, sellTrendLineName, OBJPROP_TEXT, "SELL TREND ENTRY M5");

      string sellTrendLabel = "M5_TREND_ENTRY_SELL_LABEL";
      ObjectCreate(0, sellTrendLabel, OBJ_TEXT, 0, futureLabelTime, sellTrendPrice);
      ObjectSetString(0, sellTrendLabel, OBJPROP_TEXT, "M5 TREND SELL " + DoubleToString(sellTrendPrice, _Digits));
      ObjectSetInteger(0, sellTrendLabel, OBJPROP_COLOR, clrYellow);
      ObjectSetInteger(0, sellTrendLabel, OBJPROP_FONTSIZE, 11);
      
      // Label pour la ligne SELL
      string sellLabel = "M5_ENTRY_SELL_LABEL";
      ObjectCreate(0, sellLabel, OBJ_TEXT, 0, futureLabelTime, g_m5SellEntryLevel);
      ObjectSetString(0, sellLabel, OBJPROP_TEXT,
                      "SELL ENTRY POINT " + DoubleToString(g_m5SellEntryLevel, _Digits));
      ObjectSetInteger(0, sellLabel, OBJPROP_COLOR, clrYellow);
      ObjectSetInteger(0, sellLabel, OBJPROP_FONTSIZE, 12);
      ObjectSetInteger(0, sellLabel, OBJPROP_BACK, false);
      ObjectSetInteger(0, sellLabel, OBJPROP_ANCHOR, ANCHOR_LEFT);
   }
}

//+------------------------------------------------------------------+
//| LIMIT suiveur sur BUY/SELL ENTRY POINT (M5_ENTRY_*)              |
//+------------------------------------------------------------------+
void SyncMovingEntryPointLimitOrders()
{
   if(!UseMovingEntryPointLimitOrders || !EnableTrading || BlockAllTrades)
      return;

   static datetime s_lastSync = 0;
   datetime now = TimeCurrent();
   int refreshSec = MathMax(1, MovingEntryPointLimitRefreshSeconds);
   if(s_lastSync > 0 && (now - s_lastSync) < refreshSec)
      return;
   s_lastSync = now;

   // Toujours tenter un recalcul : UpdateM5EntryLevelsAndLines() est déjà throttlé par M5EntryLevelsRefreshSeconds.
   UpdateM5EntryLevelsAndLines();

   double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   if(point <= 0.0) point = _Point;
   if(point <= 0.0) point = 0.0001;

   string ia = g_lastAIAction;
   StringToUpper(ia);

   // Source prioritaire: prix des lignes affichées, pour suivre les mouvements en temps réel.
   double buyEntryNow = g_m5BuyEntryLevel;
   double sellEntryNow = g_m5SellEntryLevel;
   if(ObjectFind(0, "M5_ENTRY_BUY_LINE") >= 0)
      buyEntryNow = ObjectGetDouble(0, "M5_ENTRY_BUY_LINE", OBJPROP_PRICE);
   if(ObjectFind(0, "M5_ENTRY_SELL_LINE") >= 0)
      sellEntryNow = ObjectGetDouble(0, "M5_ENTRY_SELL_LINE", OBJPROP_PRICE);

   bool allowBuy = (buyEntryNow > 0.0);
   bool allowSell = (sellEntryNow > 0.0);

   if(M5EntryLimitRequirePatternValidation)
   {
      // N'autoriser les LIMIT suiveurs que si la validation pattern est alignée.
      allowBuy = allowBuy && IsChartPatternValidatedForDirection("BUY", 35.0);
      allowSell = allowSell && IsChartPatternValidatedForDirection("SELL", 35.0);
   }

   if(MovingEntryPointLimitFollowIAOnly)
   {
      if(ia == "BUY")
         allowSell = false;
      else if(ia == "SELL")
         allowBuy = false;
      else
      {
         // IA neutre/HOLD: ne pas garder de LIMIT suiveur pour éviter les entrées non voulues.
         allowBuy = false;
         allowSell = false;
      }
   }

   struct LimitPlan
   {
      string dir;
      ENUM_ORDER_TYPE type;
      string comment;
      bool allow;
      double entry;
   };

   LimitPlan plans[2];
   plans[0].dir = "BUY";  plans[0].type = ORDER_TYPE_BUY_LIMIT;  plans[0].comment = "M5_ENTRY_TRACK_BUY";  plans[0].allow = allowBuy;  plans[0].entry = buyEntryNow;
   plans[1].dir = "SELL"; plans[1].type = ORDER_TYPE_SELL_LIMIT; plans[1].comment = "M5_ENTRY_TRACK_SELL"; plans[1].allow = allowSell; plans[1].entry = sellEntryNow;

   for(int pi = 0; pi < 2; pi++)
   {
      string dir = plans[pi].dir;
      ENUM_ORDER_TYPE orderType = plans[pi].type;
      string cmt = plans[pi].comment;
      bool allow = plans[pi].allow;
      double entry = plans[pi].entry;

      ulong existingTicket = 0;
      double existingPrice = 0.0;
      for(int i = OrdersTotal() - 1; i >= 0; i--)
      {
         ulong tk = OrderGetTicket(i);
         if(tk == 0 || !OrderSelect(tk)) continue;
         if(OrderGetInteger(ORDER_MAGIC) != InpMagicNumber) continue;
         if(OrderGetString(ORDER_SYMBOL) != _Symbol) continue;
         if((ENUM_ORDER_TYPE)OrderGetInteger(ORDER_TYPE) != orderType) continue;
         string oc = OrderGetString(ORDER_COMMENT);
         if(StringFind(oc, cmt) < 0) continue;
         existingTicket = tk;
         existingPrice = OrderGetDouble(ORDER_PRICE_OPEN);
         break;
      }

      // Si la direction n'est plus autorisée, supprimer le pending suiveur existant.
      if(!allow)
      {
         if(existingTicket > 0)
         {
            MqlTradeRequest delReq = {};
            MqlTradeResult  delRes = {};
            delReq.action = TRADE_ACTION_REMOVE;
            delReq.order  = existingTicket;
            delReq.symbol = _Symbol;
            delReq.magic  = InpMagicNumber;
            if(OrderSend(delReq, delRes))
               Print("🧹 LIMIT ENTRY TRACK supprimé (direction non autorisée) | ", _Symbol, " | ", dir);
         }
         continue;
      }

      double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
      double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
      if(ask <= 0.0 || bid <= 0.0)
         continue;

      // Respecter la sémantique LIMIT.
      if(orderType == ORDER_TYPE_BUY_LIMIT && entry >= ask)
         continue;
      if(orderType == ORDER_TYPE_SELL_LIMIT && entry <= bid)
         continue;

      double sl = 0.0, tp = 0.0;
      double slFix = (double)MathMax(1, BoomCrashFixedSlPoints) * point;
      double tpFix = (double)MathMax(1, BoomCrashFixedTpPoints) * point;
      if(orderType == ORDER_TYPE_BUY_LIMIT)
      {
         sl = entry - slFix;
         tp = entry + tpFix;
      }
      else
      {
         sl = entry + slFix;
         tp = entry - tpFix;
      }

      if(!ValidateLimitPriceExactEntry(entry, sl, tp, orderType))
         continue;

      double lot = NormalizeVolumeForSymbol(GetMinLotForSymbol(_Symbol));
      if(lot <= 0.0)
         continue;

      if(existingTicket > 0)
      {
         double moveThreshold = (double)MathMax(1, MovingEntryPointLimitMoveThresholdPoints) * point;
         if(MathAbs(existingPrice - entry) < moveThreshold)
            continue;

         // Suppression de l'ancien ordre au lieu de le modifier
         MqlTradeRequest delReq = {};
         MqlTradeResult  delRes = {};
         delReq.action = TRADE_ACTION_REMOVE;
         delReq.order  = existingTicket;
         delReq.symbol = _Symbol;
         
         if(OrderSend(delReq, delRes))
         {
            Print("🗑️ LIMIT ENTRY TRACK ancien supprimé (remplacement) | ", _Symbol, " | ", dir);
         }
         else
         {
            Print("❌ LIMIT ENTRY TRACK suppression échouée | ", _Symbol, " | erreur: ", delRes.retcode);
            continue; // Si on ne peut pas supprimer, on abandonne pour ce tick
         }
         // L'ordre sera recréé dans la suite de la boucle (qui traite la création quand il n'y a pas d'existingTicket)
      }

      if(CountPositionsForSymbol(_Symbol) > 0)
         continue;

      MqlTradeRequest req = {};
      MqlTradeResult  res = {};
      req.action = TRADE_ACTION_PENDING;
      req.symbol = _Symbol;
      req.magic  = InpMagicNumber;
      req.type   = orderType;
      req.price  = NormalizeDouble(entry, _Digits);
      req.sl     = NormalizeDouble(sl, _Digits);
      req.tp     = NormalizeDouble(tp, _Digits);
      req.volume = lot;
      req.deviation = 20;
      req.type_time = ORDER_TIME_GTC;
      req.comment   = cmt;

      if(OrderSend(req, res))
      {
         Print("✅ LIMIT ENTRY TRACK placé | ", _Symbol, " | ", dir,
               " @ ", DoubleToString(entry, _Digits), " | ticket=", (string)res.order);
      }
   }
}

//+------------------------------------------------------------------+
//| Vérifie si le prix M1 touche les niveaux d'entrée M5 et exécute  |
//+------------------------------------------------------------------+
void CheckAndExecuteM5TouchEntryTrade()
{
   int minSmallBc = 1;
   int maxSmallBc = 3;
   int needSmallBc = MathMax(1, BoomCrashSmallM1CandlesBeforeEntry);

   // Vérifier si les niveaux M5 sont à jour
   if(g_m5LevelsLastUpdate == 0 || (TimeCurrent() - g_m5LevelsLastUpdate) > 300) // 5 minutes max
   {
      UpdateM5EntryLevelsAndLines();
   }
   
   double currentBid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double currentAsk = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   // Tolérance de touch: élargie pour éviter de rater l'ENTRY M5 sur spikes rapides.
   double touchTolerance = point * 5;
   if(SMC_GetSymbolCategory(_Symbol) == SYM_BOOM_CRASH && M5TouchTolerancePointsBoomCrash > 0)
      touchTolerance = point * (double)M5TouchTolerancePointsBoomCrash;

   bool inCorrectionNow = IsInEquilibriumCorrectionZone();

   // Crash SELL: si la correction est active mais que le prix touche proprement SELL ENTRY M5,
   // on "arme" la réentrée pour tirer dès la sortie de correction (évite entrée tardive).
   if(CrashPostCorrectionEmaReentryEnabled &&
      IsCrashSymbol(_Symbol) &&
      g_m5SellLevelActive && g_m5SellEntryLevel > 0.0)
   {
      double armTol = touchTolerance;
      if(MathAbs(currentBid - g_m5SellEntryLevel) <= armTol)
      {
         g_crashSellPostCorrectionArmed = true;
         g_crashSellPostCorrectionArmTime = TimeCurrent();
      }
   }

   if(inCorrectionNow)
   {
      static datetime lastCorrTouchLog = 0;
      datetime now = TimeCurrent();
      if(now - lastCorrTouchLog >= 15)
      {
         Print("🚫 M5 TOUCH BLOQUÉ - Prix en zone de correction sur ", _Symbol,
               " | aucune entrée BUY/SELL tant que la zone est active.");
         lastCorrTouchLog = now;
      }
      return;
   }

   // Exécuter immédiatement la réentrée SELL armée après sortie de correction (fenêtre courte).
   if(CrashPostCorrectionEmaReentryEnabled &&
      IsCrashSymbol(_Symbol) &&
      g_crashSellPostCorrectionArmed)
   {
      int armWindow = MathMax(10, CrashPostCorrectionArmWindowSec);
      if((TimeCurrent() - g_crashSellPostCorrectionArmTime) <= armWindow)
      {
         bool nearSell = (g_m5SellLevelActive && g_m5SellEntryLevel > 0.0 &&
                         MathAbs(currentBid - g_m5SellEntryLevel) <= touchTolerance * 1.4);
         bool emaOk = (!CrashPostCorrectionRequireStrongEMA || IsStrongM1M5TrendByEMAs("SELL"));
         if(nearSell && emaOk)
         {
            if(ExecuteM5TouchOrder("SELL", "CRASH_POST_CORR_EMA_REENTRY"))
            {
               Print("⚡ CRASH REENTRY EXÉCUTÉ - sortie correction + touch EMA/M5 propre sur ", _Symbol);
               g_crashSellPostCorrectionArmed = false;
               return;
            }
         }
      }
      else
      {
         g_crashSellPostCorrectionArmed = false;
      }
   }
   
   // DEBUG: Afficher les niveaux actuels et prix
   static datetime lastDebugLog = 0;
   if(TimeCurrent() - lastDebugLog >= 30) // Log toutes les 30 secondes
   {
      lastDebugLog = TimeCurrent();
      Print("🔍 SURVEILLANCE TOUCH M5 - Bid: ", DoubleToString(currentBid, _Digits), 
            " | Ask: ", DoubleToString(currentAsk, _Digits));
      if(g_m5BuyLevelActive)
         Print("   🟢 BUY ENTRY M5: ", DoubleToString(g_m5BuyEntryLevel, _Digits), 
               " | Distance: ", DoubleToString(MathAbs(currentAsk - g_m5BuyEntryLevel) / point, 1), " pips");
      if(g_m5SellLevelActive)
         Print("   🔴 SELL ENTRY M5: ", DoubleToString(g_m5SellEntryLevel, _Digits), 
               " | Distance: ", DoubleToString(MathAbs(currentBid - g_m5SellEntryLevel) / point, 1), " pips");
   }
   
   // Vérifier le touch du niveau BUY ENTRY
   if(g_m5BuyLevelActive && g_m5BuyEntryLevel > 0)
   {
      // Pour BUY, on vérifie si l'Ask touche le niveau
      if(MathAbs(currentAsk - g_m5BuyEntryLevel) <= touchTolerance)
      {
         g_lastM5BuyTouchTime = TimeCurrent();
         g_lastM5BuyTouchPrice = currentAsk;

         // Recovery exceptionnel: Crash => BUY recovery sur touch BUY Entry M5
         if(IsCrashSymbol(_Symbol))
         {
            if(!EnableBoomCrashRecoveryTrades)
            {
               g_m5BuyLevelActive = false;
               return;
            }
            datetime touchTime = TimeCurrent();
            if(g_lastCrashSpikeTime > 0 && touchTime >= g_lastCrashSpikeTime)
            {
               // Ne pas armer si on est déjà en position sur le symbole
               if(CountPositionsForSymbol(_Symbol) > 0) return;

               g_crashBuyEntryArmed = true;
               g_crashBuyEntryArmedTouchTime = touchTime;
               Print("?? EXC_RECOVERY arm (Crash BUY) - touch BUY Entry M5 après spike | Symbole=", _Symbol);

               // Déclenchement immédiat si assez de petites bougies M1 déjà comptées (voir BoomCrashSmallM1CandlesBeforeEntry)
               int smallCount = CountSmallM1CandlesSince(g_lastCrashSpikeTime);
               if(IsAIHoldOrBuyForCrashExceptional() && smallCount >= needSmallBc)
               {
                  bool ok = ExecuteExceptionalBoomCrashRecoveryOrder("BUY", "EXC_RECOVERY_CRASH_BUY");
                  if(ok) g_crashBuyEntryArmed = false;
               }

               // Désactiver le niveau pour éviter les répétitions (l'entrée finale se fait via arming + compteur)
               g_m5BuyLevelActive = false;
               return;
            }
         }

         // Filtre IA serveur fort (direction + confiance) avant toute exécution
         // Boom: si le touch M5 n'aboutit pas (blocage IA/duplication), armer un rattrapage scalp sur flèche verte.
         if(IsBoomSymbol(_Symbol))
         {
            g_lastBoomM5BuyTouchTime = TimeCurrent();
            g_boomM5BuyArrowRecoveryArmed = true;
            g_m5BuyLevelActive = false; // consommer le touch même si on rate l'exécution immédiate
            Print("?? RECOVERY ARM - Boom touch BUY ENTRY M5 => rattrapage flèche BUY | level=",
                  DoubleToString(g_m5BuyEntryLevel, _Digits));
         }

         if(RequireAIConfirmation && !IsBoomSymbol(_Symbol) && !IsCrashSymbol(_Symbol))
         {
            if(g_lastAIConfidence < 0.80)
               return;

            string aiDir = g_lastAIAction;
            StringToUpper(aiDir);
            if(aiDir != "BUY")
               return;
         }

         if(!HasEnoughSmallM1AfterLastSpikeForM5Touch(_Symbol, "BUY", minSmallBc, maxSmallBc))
            return;

         // Autoriser entrée initiale ou duplication selon profit IA/conditions
         bool canOpen = CanOpenAdditionalPositionForSymbol(_Symbol, "BUY");
         if(!canOpen)
         {
            Print("⚠️ TOUCH BUY ENTRY M5 IGNORÉ - Conditions duplication/IA non remplies sur ", _Symbol);
            return;
         }

         // Vérifier s'il y a un setup OTE avec forte probabilité
         double oteProbability = CalculateOTESetupProbability("BUY");
         if(oteProbability >= 75.0)
         {
            Print("🎯 OTE SETUP HAUTE PROBABILITÉ DÉTECTÉ - BUY");
            Print("   📊 Probabilité: ", DoubleToString(oteProbability, 1), "%");
            Print("   ⚡ ENTRÉE RAPIDE pour capturer spikes");
            
            // FERMER POSITIONS EXISTANTES AVANT NOUVELLE ENTRÉE
            CheckAndClosePositionsBeforeNewEntry();
            
            // Calculer SL/TP pour l'entrée OTE
            double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
            double slPtsO = IsBoomCrashOrWeltradeDirectionalSynth(_Symbol) ? (double)MathMax(1, BoomCrashFixedSlPoints) : 300.0;
            double tpPtsO = IsBoomCrashOrWeltradeDirectionalSynth(_Symbol) ? (double)MathMax(1, BoomCrashFixedTpPoints) : 600.0;
            double stopLoss = g_m5BuyEntryLevel - (slPtsO * point);
            double takeProfit = g_m5BuyEntryLevel + (tpPtsO * point);
            
            // Exécuter l'entrée immédiatement
            ExecutePreOTESpikeEntry("BUY", g_m5BuyEntryLevel, stopLoss, takeProfit);
         }
         else
         {
            Print("🚀 TOUCH BUY ENTRY M5 DÉTECTÉ - Prix Ask: ", DoubleToString(currentAsk, _Digits), 
                  " | Niveau: ", DoubleToString(g_m5BuyEntryLevel, _Digits));
            Print("   💥 EXÉCUTION AUTOMATIQUE AU MARCHÉ - BUY sur ", _Symbol);
            
            // FERMER POSITIONS EXISTANTES AVANT NOUVELLE ENTRÉE
            CheckAndClosePositionsBeforeNewEntry();
         }
         
         // Exécuter l'ordre BUY au marché
         bool okBuy = ExecuteM5TouchOrder("BUY");
         if(okBuy)
            g_boomM5BuyArrowRecoveryArmed = false;
         
         // Marquer le point de touch sur le graphique
         DrawM5TouchMarker("BUY", g_m5BuyEntryLevel);
      }
   }
   
   // Vérifier le touch du niveau SELL ENTRY
   if(g_m5SellLevelActive && g_m5SellEntryLevel > 0)
   {
      // Pour SELL, on vérifie si le Bid touche le niveau
      if(MathAbs(currentBid - g_m5SellEntryLevel) <= touchTolerance)
      {
         g_lastM5SellTouchTime = TimeCurrent();
         g_lastM5SellTouchPrice = currentBid;

         // Recovery exceptionnel: Boom => SELL recovery sur touch SELL Entry M5
         if(IsBoomSymbol(_Symbol))
         {
            if(!EnableBoomCrashRecoveryTrades)
            {
               g_m5SellLevelActive = false;
               return;
            }
            datetime touchTime = TimeCurrent();
            if(g_lastBoomSpikeTime > 0 && touchTime >= g_lastBoomSpikeTime)
            {
               // Ne pas armer si on est déjà en position sur le symbole
               if(CountPositionsForSymbol(_Symbol) > 0) return;

               g_boomSellEntryArmed = true;
               g_boomSellEntryArmedTouchTime = touchTime;
               Print("?? EXC_RECOVERY arm (Boom SELL) - touch SELL Entry M5 après spike | Symbole=", _Symbol);

               int smallCount = CountSmallM1CandlesSince(g_lastBoomSpikeTime);
               if(IsAIHoldOrSellForBoomExceptional() && smallCount >= needSmallBc)
               {
                  bool ok = ExecuteExceptionalBoomCrashRecoveryOrder("SELL", "EXC_RECOVERY_BOOM_SELL");
                  if(ok) g_boomSellEntryArmed = false;
               }

               // Désactiver le niveau pour éviter les répétitions (l'entrée finale se fait via arming + compteur)
               g_m5SellLevelActive = false;
               return;
            }
         }

         // Filtre IA serveur fort (direction + confiance) avant toute exécution
         if(RequireAIConfirmation && !IsBoomSymbol(_Symbol) && !IsCrashSymbol(_Symbol))
         {
            if(g_lastAIConfidence < 0.80)
               return;

            string aiDir = g_lastAIAction;
            StringToUpper(aiDir);
            if(aiDir != "SELL")
               return;
         }

         if(!HasEnoughSmallM1AfterLastSpikeForM5Touch(_Symbol, "SELL", minSmallBc, maxSmallBc))
            return;

         // Autoriser entrée initiale ou duplication selon profit IA/conditions
         bool canOpen = CanOpenAdditionalPositionForSymbol(_Symbol, "SELL");
         if(!canOpen)
         {
            Print("⚠️ TOUCH SELL ENTRY M5 IGNORÉ - Conditions duplication/IA non remplies sur ", _Symbol);
            return;
         }

         // Vérifier s'il y a un setup OTE avec forte probabilité
         double oteProbability = CalculateOTESetupProbability("SELL");
         if(oteProbability >= 75.0)
         {
            Print("🎯 OTE SETUP HAUTE PROBABILITÉ DÉTECTÉ - SELL");
            Print("   📊 Probabilité: ", DoubleToString(oteProbability, 1), "%");
            Print("   ⚡ ENTRÉE RAPIDE pour capturer spikes");
            
            // FERMER POSITIONS EXISTANTES AVANT NOUVELLE ENTRÉE
            CheckAndClosePositionsBeforeNewEntry();
            
            // Calculer SL/TP pour l'entrée OTE
            double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
            double slPtsO2 = IsBoomCrashOrWeltradeDirectionalSynth(_Symbol) ? (double)MathMax(1, BoomCrashFixedSlPoints) : 300.0;
            double tpPtsO2 = IsBoomCrashOrWeltradeDirectionalSynth(_Symbol) ? (double)MathMax(1, BoomCrashFixedTpPoints) : 600.0;
            double stopLoss = g_m5SellEntryLevel + (slPtsO2 * point);
            double takeProfit = g_m5SellEntryLevel - (tpPtsO2 * point);
            
            // Exécuter l'entrée immédiatement
            ExecutePreOTESpikeEntry("SELL", g_m5SellEntryLevel, stopLoss, takeProfit);
         }
         else
         {
            Print("🚀 TOUCH SELL ENTRY M5 DÉTECTÉ - Prix Bid: ", DoubleToString(currentBid, _Digits), 
                  " | Niveau: ", DoubleToString(g_m5SellEntryLevel, _Digits));
            Print("   💥 EXÉCUTION AUTOMATIQUE AU MARCHÉ - SELL sur ", _Symbol);
            
            // FERMER POSITIONS EXISTANTES AVANT NOUVELLE ENTRÉE
            CheckAndClosePositionsBeforeNewEntry();
         }
         
         // Exécuter l'ordre SELL au marché
         ExecuteM5TouchOrder("SELL");
         
         // Désactiver temporairement ce niveau pour éviter répétitions
         g_m5SellLevelActive = false;
         
         // Marquer le point de touch sur le graphique
         DrawM5TouchMarker("SELL", g_m5SellEntryLevel);
      }
   }
}

//+------------------------------------------------------------------+
//| Dessin setup STAIR (style OTE) — 1× par bougie M1 si pattern + IA |
//+------------------------------------------------------------------+
void UpdateStairSetupChartDisplay()
{
   if(!ShowChartGraphics || !ShowStairSetupOnChart) return;
   ENUM_SYMBOL_CATEGORY cat = SMC_GetSymbolCategory(_Symbol);
   if(cat != SYM_BOOM_CRASH && cat != SYM_WELTRADE_SYNTH) return;
   if(!IsBoomCrashOrWeltradeDirectionalSynth(_Symbol)) return;

   string dir = "";
   if(IsBoomSymbol(_Symbol) || IsWeltradeGainSynthSymbol(_Symbol))
      dir = "BUY";
   else if(IsCrashSymbol(_Symbol) || IsWeltradePainSynthSymbol(_Symbol))
      dir = "SELL";
   else
   {
      ObjectsDeleteAll(0, "STAIR_SETUP_");
      return;
   }

   if(!IsSyntheticStairPatternM1(dir))
   {
      ObjectsDeleteAll(0, "STAIR_SETUP_");
      return;
   }

   if(UseAIServer)
   {
      double minD = StairChartSignalMinAIConfidencePct;
      if(minD <= 0.0)
      {
         minD = StairEntryPatternNotifyMinAIConfidencePct;
         if(minD <= 0.0)
            minD = StairEntryEffectiveMinAiPctForSymbol(_Symbol);
      }
      if(g_lastAIConfidence * 100.0 < minD)
      {
         ObjectsDeleteAll(0, "STAIR_SETUP_");
         return;
      }
   }

   if(!ShouldNotifyOncePerBar("STAIR_CHART_" + _Symbol + "_" + dir, _Symbol, PERIOD_M1))
      return;

   double atrVal = 0.0;
   double av[];
   ArraySetAsSeries(av, true);
   if(atrM1 != INVALID_HANDLE && CopyBuffer(atrM1, 0, 0, 1, av) >= 1)
      atrVal = av[0];
   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   if(atrVal <= 0.0 && bid > 0.0)
      atrVal = bid * 0.0008;

   double entry = (dir == "BUY") ? ask : bid;
   double sl = (dir == "BUY") ? (entry - atrVal * 2.0) : (entry + atrVal * 2.0);
   double tp = (dir == "BUY") ? (entry + atrVal * 4.0) : (entry - atrVal * 4.0);
   DrawStairSetupLikeOTE(entry, sl, tp, dir);
}

//+------------------------------------------------------------------+
//| Mode escalier : helpers (niveau A = même logique que stair marché) |
//+------------------------------------------------------------------+
bool StairEscLevelASetupOkForChart(const string dir)
{
   if(StairEntryUseM1StairDetector && !IsSyntheticStairPatternM1(dir))
      return false;
   if(StairEntryRequireStrongM1M5EMA && !IsStrongM1M5TrendByEMAs(dir))
      return false;
   if(!IsBoomCrashDirectionAllowedByIA(_Symbol, dir))
      return false;
   double mn = StairEntryEffectiveMinAiPctForSymbol(_Symbol);
   if(g_lastAIConfidence * 100.0 < mn)
      return false;
   return true;
}

bool StairEscIaStrongAgainstDir(const string dir, const double minPct)
{
   if(!UseAIServer)
      return false;
   string ia = g_lastAIAction;
   StringToUpper(ia);
   if(g_lastAIConfidence * 100.0 < minPct)
      return false;
   string d = dir;
   StringToUpper(d);
   if(d == "BUY" && ia == "SELL")
      return true;
   if(d == "SELL" && ia == "BUY")
      return true;
   return false;
}

//+------------------------------------------------------------------+
//| Niveau B : une limite pullback si escalier OK mais pas niveau A    |
//+------------------------------------------------------------------+
void CheckAndPlaceStairEscalierLimitOrder()
{
   if(!UseStairEscalierMode || !StairEscPlaceLimitLevelB)
      return;
   if(!UseStairEntry || !EnableTrading || BlockAllTrades)
      return;

   ENUM_SYMBOL_CATEGORY cat = SMC_GetSymbolCategory(_Symbol);
   if(cat != SYM_BOOM_CRASH && cat != SYM_WELTRADE_SYNTH)
      return;

   string dir = "";
   if(IsBoomSymbol(_Symbol))
      dir = "BUY";
   else if(IsCrashSymbol(_Symbol))
      dir = "SELL";
   else if(IsWeltradeGainSynthSymbol(_Symbol))
      dir = "BUY";
   else if(IsWeltradePainSynthSymbol(_Symbol))
      dir = "SELL";
   else
      return;

   if(!IsDirectionAllowedForBoomCrash(_Symbol, dir))
      return;
   if(!IsSyntheticStairPatternM1(dir))
      return;

   string iaAct = g_lastAIAction;
   StringToUpper(iaAct);
   if(iaAct == "HOLD")
   {
      // En mode exception HOLD stair, on privilégie le marché (niveau A), pas une LIMIT niveau B.
      return;
   }

   // Si EMA M1+M5 sont alignées, le niveau A (marché) doit primer: ne pas fallback en LIMIT niveau B.
   if(IsStrongM1M5TrendByEMAs(dir))
      return;

   if(StairEscIaStrongAgainstDir(dir, StairEscLimitBlockIAAgainstMinPct))
      return;

   if(StairEscLevelASetupOkForChart(dir))
      return;

   if(CountPositionsForSymbol(_Symbol) > 0)
      return;
   if(CountOpenLimitOrdersForSymbol(_Symbol) > 0)
      return;

   static datetime s_lastEscLimUtc = 0;
   if(StairEscLimitCooldownSeconds > 0 && s_lastEscLimUtc > 0 &&
      (TimeCurrent() - s_lastEscLimUtc) < StairEscLimitCooldownSeconds)
      return;

   if(!IsTradingAllowedForGainPreservation())
      return;
   if(!CanOpenAdditionalPositionForSymbol(_Symbol, dir))
      return;
   if(!IsSpreadAcceptable())
      return;
   if(IsEntryCooldownActive())
      return;

   double atr = 0.0;
   double ab[];
   ArraySetAsSeries(ab, true);
   if(atrM1 != INVALID_HANDLE && CopyBuffer(atrM1, 0, 0, 1, ab) >= 1)
      atr = ab[0];
   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   if(atr <= 0.0 && bid > 0.0)
      atr = bid * 0.0008;
   if(atr <= 0.0 || bid <= 0.0 || ask <= 0.0)
      return;

   double pm = StairEscLimitPullbackATRMult;
   if(pm <= 0.0)
      pm = 0.35;

   double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   if(point <= 0.0)
      point = _Point;

   MqlTradeRequest req;
   MqlTradeResult res;
   ZeroMemory(req);
   ZeroMemory(res);
   req.action = TRADE_ACTION_PENDING;
   req.symbol = _Symbol;
   req.magic = InpMagicNumber;
   req.volume = NormalizeVolumeForSymbol(GetOptimalLotSize() * StairEscLimitLotMult);
   if(req.volume <= 0.0)
      return;
   req.comment = "STAIR_ESC_LIMIT";
   req.deviation = 20;

   int fillMode = (int)SymbolInfoInteger(_Symbol, SYMBOL_FILLING_MODE);
   if((fillMode & SYMBOL_FILLING_FOK) == SYMBOL_FILLING_FOK)
      req.type_filling = ORDER_FILLING_FOK;
   else if((fillMode & SYMBOL_FILLING_IOC) == SYMBOL_FILLING_IOC)
      req.type_filling = ORDER_FILLING_IOC;
   else
      req.type_filling = ORDER_FILLING_RETURN;

   double slFix2 = (double)MathMax(1, BoomCrashFixedSlPoints) * point;
   double tpFix2 = (double)MathMax(1, BoomCrashFixedTpPoints) * point;
   if(dir == "BUY")
   {
      req.type = ORDER_TYPE_BUY_LIMIT;
      req.price = bid - atr * pm;
      if(req.price >= bid)
         req.price = bid - 10.0 * point;
      req.sl = req.price - slFix2;
      req.tp = req.price + tpFix2;
   }
   else
   {
      req.type = ORDER_TYPE_SELL_LIMIT;
      req.price = ask + atr * pm;
      if(req.price <= ask)
         req.price = ask + 10.0 * point;
      req.sl = req.price + slFix2;
      req.tp = req.price - tpFix2;
   }

   req.price = NormalizeDouble(req.price, _Digits);
   double slW = req.sl;
   double tpW = req.tp;
   ValidateAndAdjustStopLossTakeProfit(dir, req.price, slW, tpW);
   EnforceMinBoomCrashStopLossDollarRisk(_Symbol, dir, req.price, req.volume, slW);
   req.sl = NormalizeDouble(slW, _Digits);
   req.tp = NormalizeDouble(tpW, _Digits);

   double tickSize = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_SIZE);
   if(tickSize <= 0.0)
      tickSize = point;
   if(tickSize > 0.0)
   {
      req.sl = NormalizeDouble(MathRound(req.sl / tickSize) * tickSize, _Digits);
      req.tp = NormalizeDouble(MathRound(req.tp / tickSize) * tickSize, _Digits);
   }

   if(dir == "BUY")
   {
      if(req.sl >= req.price || req.tp <= req.price)
      {
         Print("🚫 STAIR_ESC_LIMIT BUY — SL/TP invalides après validation | ", _Symbol);
         return;
      }
   }
   else
   {
      if(req.sl <= req.price || req.tp >= req.price)
      {
         Print("🚫 STAIR_ESC_LIMIT SELL — SL/TP invalides après validation | ", _Symbol);
         return;
      }
   }

   if(StairEscLimitExpireMinutes > 0)
   {
      req.type_time = ORDER_TIME_SPECIFIED;
      req.expiration = TimeCurrent() + (datetime)StairEscLimitExpireMinutes * 60;
   }
   else
      req.type_time = ORDER_TIME_GTC;

   SymbolSelect(_Symbol, true);

   if(!OrderSend(req, res))
   {
      Print("🚫 STAIR_ESC_LIMIT échec OrderSend | ", _Symbol, " | ", res.retcode, " ", res.comment);
      return;
   }
   if(res.retcode != TRADE_RETCODE_DONE && res.retcode != TRADE_RETCODE_PLACED)
   {
      Print("🚫 STAIR_ESC_LIMIT retcode | ", _Symbol, " | ", res.retcode, " ", res.comment);
      return;
   }

   s_lastEscLimUtc = TimeCurrent();
   Print("📌 STAIR ESC niveau B — ", dir, " LIMIT @ ", DoubleToString(req.price, _Digits),
         " | vol=", DoubleToString(req.volume, 2), " | ", _Symbol,
         " (escalier OK, attente alignement IA/EMA comme niveau A)");
}

//+------------------------------------------------------------------+
//| Trailing ATR + sorties structure / IA sur positions STAIR         |
//+------------------------------------------------------------------+
void ManageStairEscalierTrailingAndExit()
{
   if(!UseStairEscalierMode)
      return;
   if(PositionsTotal() == 0)
      return;

   static datetime s_lastStairEscManage = 0;
   datetime now = TimeCurrent();
   if(s_lastStairEscManage > 0 && (now - s_lastStairEscManage) < 2)
      return;
   s_lastStairEscManage = now;

   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      if(!posInfo.SelectByIndex(i))
         continue;
      if(posInfo.Magic() != InpMagicNumber)
         continue;
      if(posInfo.Symbol() != _Symbol)
         continue;

      string cmt = posInfo.Comment();
      if(StringFind(cmt, "STAIR_ENTRY") < 0 && StringFind(cmt, "STAIR_ESC_LIMIT") < 0)
         continue;

      ENUM_SYMBOL_CATEGORY pcat = SMC_GetSymbolCategory(_Symbol);
      if(pcat != SYM_BOOM_CRASH && pcat != SYM_WELTRADE_SYNTH)
         continue;

      ulong ticket = posInfo.Ticket();
      int secOpen = (int)(now - posInfo.Time());
      if(secOpen < StairEscMinSecondsBeforeExit)
         continue;

      string posDir = (posInfo.PositionType() == POSITION_TYPE_BUY) ? "BUY" : "SELL";

      if(StairEscExitOnIAAgainst && StairEscIaStrongAgainstDir(posDir, StairEscExitIAAgainstMinPct))
      {
         PositionCloseWithLog(ticket, "Stair escalier — IA fortement contre le sens");
         continue;
      }

      if(StairEscExitOnEMABreak && !IsStrongM1M5TrendByEMAs(posDir))
      {
         PositionCloseWithLog(ticket, "Stair escalier — fin pile EMA M1+M5 (sortie avant correction)");
         continue;
      }

      if(!StairEscTrailTighten || StairEscTrailATRMult <= 0.0)
         continue;

      double atr = 0.0;
      double atrBuf[];
      ArraySetAsSeries(atrBuf, true);
      if(atrM1 != INVALID_HANDLE && CopyBuffer(atrM1, 0, 0, 1, atrBuf) >= 1)
         atr = atrBuf[0];
      if(atr <= 0.0)
         continue;

      double dist = atr * StairEscTrailATRMult;
      double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
      double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
      double pt = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
      if(pt <= 0.0)
         pt = _Point;
      int stopsLvl = (int)SymbolInfoInteger(_Symbol, SYMBOL_TRADE_STOPS_LEVEL);
      double minDist = (double)stopsLvl * pt;

      double curSL = posInfo.StopLoss();
      double curTP = posInfo.TakeProfit();

      if(posInfo.PositionType() == POSITION_TYPE_BUY)
      {
         double newSL = NormalizeDouble(bid - dist, _Digits);
         if(newSL <= 0.0 || newSL >= bid)
            continue;
         if(minDist > 0.0 && (bid - newSL) < minDist)
            continue;
         if(curSL > 0.0 && newSL <= curSL)
            continue;
         if(!trade.PositionModify(ticket, newSL, curTP))
            continue;
      }
      else
      {
         double newSL = NormalizeDouble(ask + dist, _Digits);
         if(newSL <= 0.0 || newSL <= ask)
            continue;
         if(minDist > 0.0 && (newSL - ask) < minDist)
            continue;
         if(curSL > 0.0 && newSL >= curSL)
            continue;
         if(!trade.PositionModify(ticket, newSL, curTP))
            continue;
      }
   }
}

//+------------------------------------------------------------------+
//| Debug stair (refus silencieux → visible dans Experts)             |
//+------------------------------------------------------------------+
void StairEntryLogSkip(const string reason)
{
   if(!StairEntryDebugLog) return;
   static datetime s_lastStairDbg = 0;
   datetime n = TimeCurrent();
   if(s_lastStairDbg > 0 && (n - s_lastStairDbg) < 20)
      return;
   s_lastStairDbg = n;
   Print("🪜 STAIR skip | ", _Symbol, " | ", reason);
}

//+------------------------------------------------------------------+
//| Push mobile MT5 quand pattern escalier M1 détecté (signal visuel)  |
//| MT5 n’envoie pas de SMS opérateur : c’est la notif MetaQuotes ID.  |
//+------------------------------------------------------------------+
void NotifyStairPatternOnM1IfDetected()
{
   if(!StairEntryPushOnPatternM1 || !UseNotifications) return;
   if(!UseStairEntry || !EnableTrading || BlockAllTrades) return;
   ENUM_SYMBOL_CATEGORY ncat = SMC_GetSymbolCategory(_Symbol);
   if(ncat != SYM_BOOM_CRASH && ncat != SYM_WELTRADE_SYNTH) return;

   string dir = "";
   if(IsBoomSymbol(_Symbol))
      dir = "BUY";
   else if(IsCrashSymbol(_Symbol))
      dir = "SELL";
   else if(IsWeltradeGainSynthSymbol(_Symbol))
      dir = "BUY";
   else if(IsWeltradePainSynthSymbol(_Symbol))
      dir = "SELL";
   else
      return;

   if(!IsDirectionAllowedForBoomCrash(_Symbol, dir)) return;
   bool stairPatternDetected = IsSyntheticStairPatternM1(dir);
   bool fastEmaTouchContext = (UseStairEmaTouchScalpEntry &&
                               (IsBoomSymbol(_Symbol) || IsWeltradeGainSynthSymbol(_Symbol)) &&
                               IsStrongM1M5TrendByEMAs(dir) &&
                               IsStairEma13M1AndEma21M5TouchReady(dir));
   // Eviter les signaux tardifs "fin d'impulsion":
   // sur Boom/GAINX, si le touch EMA13(M1)+EMA21(M5) est déjà là, autoriser le signal sans attendre
   // la confirmation stair plus lente.
   if(!stairPatternDetected && !fastEmaTouchContext) return;

   if(StairEntryPushMatchExecution)
   {
      if(StairEntryCooldownSeconds > 0 && g_stairEntryLastExecUtc > 0 &&
         (TimeCurrent() - g_stairEntryLastExecUtc) < StairEntryCooldownSeconds)
         return;
      if(StairEntryRequireStrongM1M5EMA && !IsStrongM1M5TrendByEMAs(dir)) return;
      if(StairEntryUseM1StairDetector && !stairPatternDetected && !fastEmaTouchContext) return;
      if(!IsStairEma13M1AndEma21M5TouchReady(dir)) return;
      double stairMinAi = StairEntryEffectiveMinAiPctForSymbol(_Symbol);
      if(g_lastAIConfidence * 100.0 < stairMinAi) return;
      if(!IsTradingAllowedForGainPreservation()) return;
      if(!CanOpenAdditionalPositionForSymbol(_Symbol, dir)) return;
      if(!ExecuteM5TouchOrder(dir, "STAIR_ENTRY", true)) return;
      if(!ShouldNotifyOncePerBar("STAIR_PATTERN_PUSH_" + _Symbol + "_" + dir, _Symbol, PERIOD_M1))
         return;
      string msgOk = "📶 STAIR ENTRY — prêt " + dir + " " + _Symbol +
                     " | IA " + g_lastAIAction + " " + DoubleToString(g_lastAIConfidence * 100.0, 1) +
                     "% | filtres identiques à l’ordre STAIR_ENTRY";
      NotifyTradeEvent(msgOk, EntryTradeSoundFile);
      return;
   }

   // STAIR: on ne filtre plus la notification par le statut IA (direction/HOLD/confiance).

   if(!ShouldNotifyOncePerBar("STAIR_PATTERN_PUSH_" + _Symbol + "_" + dir, _Symbol, PERIOD_M1))
      return;

   bool emaStack = IsStrongM1M5TrendByEMAs(dir);
   string hint = "";
   if(StairEntryRequireStrongM1M5EMA && !emaStack)
      hint = " | ⚠️ EMA M1+M5 pas pile — l’EA peut ne pas entrer (manuel possible)";
   else if(emaStack)
      hint = " | EMA alignées";

   string patt = "";
   if(ChartPatternNotifyInSignals)
      patt = " | FIG: " + GetChartPatternShortLabel();
   string msg = "📶 SIGNAL STAIR M1 — " + dir + " " + _Symbol +
                " | IA " + g_lastAIAction + " " + DoubleToString(g_lastAIConfidence * 100.0, 1) + "%" + hint + patt;
   NotifyTradeEvent(msg, EntryTradeSoundFile);

   // Exécution immédiate demandée: après push STAIR, si EMA alignées, tenter l'entrée marché.
   if(StairEntryExecuteMarketOnPushWhenEMAAligned && emaStack)
   {
      // Si la notification indique "EMA alignées", l'entrée marché doit être prioritaire et immédiate.
      // On n'applique pas ici les pré-filtres de cooldown/protection gains/capacité position:
      // la validation finale se fait dans ExecuteM5TouchOrder et la réponse broker.
      CheckAndClosePositionsBeforeNewEntry();
      if(ExecuteM5TouchOrder(dir, "STAIR_ENTRY"))
      {
         g_stairEntryLastExecUtc = TimeCurrent();
         Print("⚡ STAIR ENTRY marché exécuté après push (EMA alignées) | ", _Symbol, " | dir=", dir);
      }
   }
}

//+------------------------------------------------------------------+
//| Entrée scalp EMA touch: Boom/GAINX BUY (EMA13 M1 + EMA21 M5)    |
//+------------------------------------------------------------------+
void CheckAndExecuteStairEmaTouchScalpEntry()
{
   if(!UseStairEmaTouchScalpEntry || !UseStairEntry || !EnableTrading || BlockAllTrades)
      return;

   if(IsInEquilibriumCorrectionZone() && !StairEntryBypassEquilibriumCorrectionZone)
      return;

   // Ciblage demandé: escalier montant sur Boom et GAINX uniquement.
   if(!IsBoomSymbol(_Symbol) && !IsWeltradeGainSynthSymbol(_Symbol))
      return;

   const string dir = "BUY";
   if(!IsDirectionAllowedForBoomCrash(_Symbol, dir))
      return;
   bool stairPatternDetected = IsSyntheticStairPatternM1(dir);
   bool strongStack = IsStrongM1M5TrendByEMAs(dir);
   if(StairEntryRequireStrongM1M5EMA && !strongStack)
      return;
   bool emaTouchReady = IsStairEma13M1AndEma21M5TouchReady(dir);
   if(!emaTouchReady)
      return;
   // Si l'EMA-touch est valide avec pile EMA forte, ne pas attendre le stair "3 spikes" (souvent tardif).
   if(StairEntryUseM1StairDetector && !stairPatternDetected && !strongStack)
      return;

   int cd = MathMax(1, StairEmaTouchScalpCooldownSeconds);
   datetime now = TimeCurrent();
   if(g_stairEmaTouchScalpLastExecUtc > 0 && (now - g_stairEmaTouchScalpLastExecUtc) < cd)
      return;

   if(!IsTradingAllowedForGainPreservation())
      return;
   if(!PassFutureDirectionConfidenceGate(dir, "STAIR_EMA_SCALP", false))
      return;
   if(!CanOpenAdditionalPositionForSymbol(_Symbol, dir))
      return;

   CheckAndClosePositionsBeforeNewEntry();
   if(ExecuteM5TouchOrder(dir, "STAIR_ENTRY"))
   {
      g_stairEmaTouchScalpLastExecUtc = now;
      g_stairEntryLastExecUtc = now;
      Print("⚡ STAIR EMA TOUCH SCALP exécuté | ", _Symbol, " | dir=BUY (EMA13 M1 + EMA21 M5)");
   }
}

//+------------------------------------------------------------------+
//| stairEntry — Boom BUY / Crash SELL (escalier M1 + M1/M5, hors OTE) |
//+------------------------------------------------------------------+
void CheckAndExecuteStairEntry()
{
   if(!UseStairEntry || !EnableTrading || BlockAllTrades)
   {
      StairEntryLogSkip("UseStairEntry/EnableTrading/BlockAllTrades");
      return;
   }

   if(IsInEquilibriumCorrectionZone() && !StairEntryBypassEquilibriumCorrectionZone)
   {
      StairEntryLogSkip("zone d'équilibre/correction (StairEntryBypassEquilibriumCorrectionZone=false)");
      return;
   }
   // Règle stricte: une seule exécution active par symbole (STAIR/OTE inclus).
   if(HasAnyExposureForSymbol(_Symbol))
   {
      StairEntryLogSkip("exposition déjà active sur le symbole");
      return;
   }
   ENUM_SYMBOL_CATEGORY stairCat = SMC_GetSymbolCategory(_Symbol);
   if(stairCat != SYM_BOOM_CRASH && stairCat != SYM_WELTRADE_SYNTH)
   {
      StairEntryLogSkip("pas Boom/Crash ni Weltrade synth");
      return;
   }

   string dir = "";
   if(IsBoomSymbol(_Symbol))
      dir = "BUY";
   else if(IsCrashSymbol(_Symbol))
      dir = "SELL";
   else if(IsWeltradeGainSynthSymbol(_Symbol))
      dir = "BUY";
   else if(IsWeltradePainSynthSymbol(_Symbol))
      dir = "SELL";
   else
   {
      StairEntryLogSkip("symbole ni Boom/Crash ni GainX/PainX");
      return;
   }

   if(!IsDirectionAllowedForBoomCrash(_Symbol, dir))
   {
      StairEntryLogSkip("direction interdite (Boom/Crash/Weltrade)");
      return;
   }

   bool fastAfterSpike = IsRecentDirectionalSpikeForStair(dir, StairEntryFastTrackAfterSpikeSeconds);
   if(fastAfterSpike && StairEntryDebugLog)
      Print("⚡ STAIR fast-track actif après spike | ", _Symbol, " | dir=", dir);

   if(StairEntryCooldownSeconds > 0 && g_stairEntryLastExecUtc > 0 &&
      (TimeCurrent() - g_stairEntryLastExecUtc) < StairEntryCooldownSeconds)
   {
      if(!(fastAfterSpike && StairEntryFastTrackBypassCooldown))
      {
         StairEntryLogSkip("cooldown actif");
         return;
      }
   }

   if(StairEntryRequireStrongM1M5EMA && !IsStrongM1M5TrendByEMAs(dir))
   {
      StairEntryLogSkip("EMA M1+M5 pas empilées (StairEntryRequireStrongM1M5EMA)");
      return;
   }

   if(StairEntryUseM1StairDetector && !IsSyntheticStairPatternM1(dir))
   {
      StairEntryLogSkip("IsSyntheticStairPatternM1=false (classique / early / forming — inputs BoomCrashTrend* et Stair*)");
      return;
   }

   if(!(fastAfterSpike && StairEntryFastTrackBypassEmaTouch) &&
      !IsStairEma13M1AndEma21M5TouchReady(dir))
   {
      StairEntryLogSkip("attente retouche EMA13 M1 + confluence EMA21 M5 (Boom/GAINX BUY)");
      return;
   }

   // STAIR: on ne bloque plus l'entrée par la confiance IA.

   if(!IsTradingAllowedForGainPreservation())
   {
      StairEntryLogSkip("protection gains");
      return;
   }

   if(!CanOpenAdditionalPositionForSymbol(_Symbol, dir))
   {
      StairEntryLogSkip("CanOpenAdditionalPositionForSymbol");
      return;
   }

   CheckAndClosePositionsBeforeNewEntry();

   if(!ExecuteM5TouchOrder(dir, "STAIR_ENTRY"))
   {
      StairEntryLogSkip("ExecuteM5TouchOrder a refusé (tendance ICT, zone correction, spread, cooldown entrée, bougie M1, MinProfitPotential, etc.) — voir logs 🚫 STAIR ENTRY");
      return;
   }

   g_stairEntryLastExecUtc = TimeCurrent();
}

//+------------------------------------------------------------------+
//| Exécute un ordre au marché lors du touch M5 (ou stairEntry)       |
//+------------------------------------------------------------------+
void CheckAndExecuteEMAPullbackAndSweepReclaim()
{
   if(!EnableTrading || BlockAllTrades)
      return;
   if(CountPositionsForSymbol(_Symbol) > 0)
      return;

   string su = _Symbol;
   StringToUpper(su);
   bool isXau = (StringFind(su, "XAU") >= 0 || StringFind(su, "GOLD") >= 0);
   ENUM_SYMBOL_CATEGORY cat = SMC_GetSymbolCategory(_Symbol);
   bool isVolFamily = (cat == SYM_VOLATILITY || cat == SYM_WELTRADE_SYNTH);

   datetime now = TimeCurrent();
   static datetime s_lastEmaAttempt = 0;
   static datetime s_lastSweepAttempt = 0;

   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   if(point <= 0.0) point = _Point;

   MqlRates m1[];
   ArraySetAsSeries(m1, true);
   if(CopyRates(_Symbol, PERIOD_M1, 0, 8, m1) < 5)
      return;

   double atrM1 = GetATRValue(PERIOD_M1, 14);
   if(atrM1 <= 0.0)
      atrM1 = MathAbs(m1[1].high - m1[1].low);
   if(atrM1 <= 0.0)
      atrM1 = point * 20.0;

   // Tendance structurelle H1 + M15 (optionnelle).
   double e50h1 = GetEMA(_Symbol, PERIOD_H1, 50);
   double e200h1 = GetEMA(_Symbol, PERIOD_H1, 200);
   double e50m15 = GetEMA(_Symbol, PERIOD_M15, 50);
   double e200m15 = GetEMA(_Symbol, PERIOD_M15, 200);
   bool trendBuy = (e50h1 > 0.0 && e200h1 > 0.0 && e50m15 > 0.0 && e200m15 > 0.0 && e50h1 > e200h1 && e50m15 > e200m15);
   bool trendSell = (e50h1 > 0.0 && e200h1 > 0.0 && e50m15 > 0.0 && e200m15 > 0.0 && e50h1 < e200h1 && e50m15 < e200m15);

   // 1) Pullback EMA dynamique (touch/rejet EMA 21/50) UNIQUEMENT en tendance forte
   //    -> jamais en correction ou en range.
   if(!isXau && UseEMAPullbackDynamicEntry && (s_lastEmaAttempt == 0 || (now - s_lastEmaAttempt) >= MathMax(1, EMAPullbackCooldownSeconds)))
   {
      if(isVolFamily && !EMAPullbackAllowOnVolatility)
      {
         // Sur Step/Volatility: laisser Sweep+Reclaim décider, éviter EMA seul.
      }
      else
      {
         s_lastEmaAttempt = now;
         double tol = MathMax(point * 5.0, atrM1 * MathMax(0.05, EMAPullbackMaxDistanceATRMult));
         double aiConfPct = AIConfidencePercent();
         if(EMAPullbackMinAIConfidencePercent <= 0.0 || aiConfPct + 1e-9 >= EMAPullbackMinAIConfidencePercent)
         {
            double e21m1 = 0.0, e50m1 = 0.0, e21m5 = 0.0, e50m5 = 0.0;
            bool has21m1 = ReadEMAValue(PERIOD_M1, 21, e21m1);
            bool has50m1 = ReadEMAValue(PERIOD_M1, 50, e50m1);
            bool has21m5 = ReadEMAValue(PERIOD_M5, 21, e21m5);
            bool has50m5 = ReadEMAValue(PERIOD_M5, 50, e50m5);

            double body = MathAbs(m1[1].close - m1[1].open);
            double lowWick = MathMax(0.0, MathMin(m1[1].open, m1[1].close) - m1[1].low);
            double upWick = MathMax(0.0, m1[1].high - MathMax(m1[1].open, m1[1].close));
            bool bullReject = (m1[1].close > m1[1].open) && (lowWick >= body * 0.30);
            bool bearReject = (m1[1].close < m1[1].open) && (upWick >= body * 0.30);

            bool touchBuy = false;
            bool touchSell = false;
            if(has21m1) { touchBuy = touchBuy || (m1[1].low <= e21m1 + tol && m1[1].close >= e21m1 - tol); touchSell = touchSell || (m1[1].high >= e21m1 - tol && m1[1].close <= e21m1 + tol); }
            if(has50m1) { touchBuy = touchBuy || (m1[1].low <= e50m1 + tol && m1[1].close >= e50m1 - tol); touchSell = touchSell || (m1[1].high >= e50m1 - tol && m1[1].close <= e50m1 + tol); }
            if(has21m5) { touchBuy = touchBuy || (ask <= e21m5 + tol); touchSell = touchSell || (bid >= e21m5 - tol); }
            if(has50m5) { touchBuy = touchBuy || (ask <= e50m5 + tol); touchSell = touchSell || (bid >= e50m5 - tol); }

            bool inCorrection = IsInEquilibriumCorrectionZone();
            bool inRange = IsMarketInConsolidation(PERIOD_M1, 20) || IsMarketInConsolidation(PERIOD_M5, 20);
            bool strongTrendBuy = trendBuy && IsStrongM1M5TrendByEMAs("BUY");
            bool strongTrendSell = trendSell && IsStrongM1M5TrendByEMAs("SELL");

            if(inCorrection || inRange)
            {
               static datetime s_lastEmaBlockLog = 0;
               if(now - s_lastEmaBlockLog >= 20)
               {
                  Print("🚫 EMA PULLBACK DYN BLOQUÉ - marché en correction/range | ", _Symbol,
                        " | correction=", (inCorrection ? "oui" : "non"),
                        " | range=", (inRange ? "oui" : "non"));
                  s_lastEmaBlockLog = now;
               }
            }
            else if(touchBuy && bullReject && strongTrendBuy && (!EMAPullbackRequireTrendH1M15 || trendBuy))
            {
               if(ExecuteM5TouchOrder("BUY", "EMA_PULLBACK_DYN"))
               {
                  Print("⚡ EMA PULLBACK DYN EXÉCUTÉ - BUY ", _Symbol,
                        " | tol=", DoubleToString(tol, _Digits));
                  return;
               }
            }
            else if(touchSell && bearReject && strongTrendSell && (!EMAPullbackRequireTrendH1M15 || trendSell))
            {
               if(ExecuteM5TouchOrder("SELL", "EMA_PULLBACK_DYN"))
               {
                  Print("⚡ EMA PULLBACK DYN EXÉCUTÉ - SELL ", _Symbol,
                        " | tol=", DoubleToString(tol, _Digits));
                  return;
               }
            }
         }
      }
   }

   // 2) Liquidity sweep + reclaim (capturer les retournements rapides hors OTE)
   // En mode Boom/Crash OTE+EMA-only: on désactive ce chemin pour rester strict.
   bool allowSweepReclaim = true;
   if(BoomCrashOnlyOTEAndEMAPullback && cat == SYM_BOOM_CRASH)
      allowSweepReclaim = false;
   if(allowSweepReclaim && UseLiquiditySweepReclaimEntry &&
      (s_lastSweepAttempt == 0 || (now - s_lastSweepAttempt) >= MathMax(1, SweepReclaimCooldownSeconds)))
   {
      s_lastSweepAttempt = now;

      string lsType = "";
      int barsAgo = 99;
      if(SMC_DetectLiquiditySweepEx(_Symbol, PERIOD_M5, lsType, barsAgo))
      {
         MqlRates m5[];
         ArraySetAsSeries(m5, true);
         int copied = CopyRates(_Symbol, PERIOD_M5, 0, 20, m5);
         if(copied > (barsAgo + 1) && barsAgo >= 1)
         {
            double tolRec = MathMax(point * (double)MathMax(1, SweepReclaimTolerancePoints), atrM1 * 0.10);
            bool bullCandle = (m1[1].close > m1[1].open);
            bool bearCandle = (m1[1].close < m1[1].open);

            if(lsType == "SSL")
            {
               // Sweep de liquidité vendeuse (low balayé) -> reclaim haussier attendu.
               double reclaimLevel = m5[barsAgo + 1].low;
               bool reclaimed = (ask >= reclaimLevel + tolRec);
               if(reclaimed && bullCandle && (!SweepReclaimRequireTrendFilter || trendBuy))
               {
                  if(ExecuteM5TouchOrder("BUY", "SWEEP_RECLAIM"))
                  {
                     Print("🧲 SWEEP+RECLAIM EXÉCUTÉ - BUY ", _Symbol,
                           " | level=", DoubleToString(reclaimLevel, _Digits),
                           " | tol=", DoubleToString(tolRec, _Digits));
                     return;
                  }
               }
            }
            else if(lsType == "BSL")
            {
               // Sweep de liquidité acheteuse (high balayé) -> reclaim baissier attendu.
               double reclaimLevel = m5[barsAgo + 1].high;
               bool reclaimed = (bid <= reclaimLevel - tolRec);
               if(reclaimed && bearCandle && (!SweepReclaimRequireTrendFilter || trendSell))
               {
                  if(ExecuteM5TouchOrder("SELL", "SWEEP_RECLAIM"))
                  {
                     Print("🧲 SWEEP+RECLAIM EXÉCUTÉ - SELL ", _Symbol,
                           " | level=", DoubleToString(reclaimLevel, _Digits),
                           " | tol=", DoubleToString(tolRec, _Digits));
                     return;
                  }
               }
            }
         }
      }
   }
}

bool ExecuteM5TouchOrder(string direction, string commentCore, bool dryRun)
{
   if(!IsHighVolatilityCapitalGatePassed(_Symbol, "M5 TOUCH"))
      return false;

   // Etat persistant de l'exception STAIR en mode IA=HOLD:
   // on autorise dans zone discount/premium, puis on verrouille dès entrée en zone d'équilibre
   // tant que l'IA reste HOLD.
   static bool   s_stairHoldZoneLockUntilIARelease = false;
   static bool   s_stairHoldZoneRunArmed = false;
   static string s_stairHoldZoneDir = "";

   const bool isStairEntry = (commentCore == "STAIR_ENTRY");
   const bool isOteCurTouchFor = (commentCore == "OTE_CUR_TOUCH_FOR");
   const bool isEmaPullbackDyn = (StringFind(commentCore, "EMA_PULLBACK") >= 0);
   const bool isSweepReclaim = (StringFind(commentCore, "SWEEP_RECLAIM") >= 0);
   const bool isCrashPostCorrReentry = (StringFind(commentCore, "CRASH_POST_CORR_EMA") >= 0);
   const bool fastScalpByDesign = (isStairEntry || isOteCurTouchFor || isEmaPullbackDyn || isSweepReclaim || isCrashPostCorrReentry);

   string logPfx = "M5 TOUCH";
   if(isStairEntry)
      logPfx = "STAIR ENTRY";
   else if(isOteCurTouchFor)
      logPfx = "OTE CUR TOUCH FOR";
   else if(isEmaPullbackDyn)
      logPfx = "EMA PULLBACK DYN";
   else if(isSweepReclaim)
      logPfx = "SWEEP RECLAIM";
   else if(isCrashPostCorrReentry)
      logPfx = "CRASH POST-CORR EMA REENTRY";
   const bool quiet = dryRun;
   if(isOteCurTouchFor)
   {
      if(!HasOTEBOSConfirmationM15OrM5(direction))
      {
         if(!quiet) Print("🚫 OTE CUR TOUCH FOR BLOQUÉ - BOS non confirmé (M15/M5) | ", _Symbol, " | dir=", direction);
         return false;
      }
      if(!IsOTEEntryConfirmedOnM15OrM5(direction))
      {
         if(!quiet) Print("🚫 OTE CUR TOUCH FOR BLOQUÉ - confirmation candlestick M15/M5 absente | ", _Symbol, " | dir=", direction);
         return false;
      }
   }
   if(isOteCurTouchFor)
   {
      // Priorité scalping OTE courant: si un pending bloque, le supprimer puis exécuter au marché.
      if(CountPositionsForSymbol(_Symbol) > 0)
      {
         if(!quiet)
            Print("🚫 ", logPfx, " annulé - position déjà active sur ", _Symbol, " | dir=", direction);
         return false;
      }
      if(CountPendingOrdersForSymbol(_Symbol) > 0)
      {
         if(!quiet)
            Print("🧹 ", logPfx, " nettoyage pending avant exécution marché | ", _Symbol);
         CancelAllPendingLimitOrdersForSymbol(_Symbol);
         if(CountPendingOrdersForSymbol(_Symbol) > 0)
         {
            if(!quiet)
               Print("🚫 ", logPfx, " annulé - pending restant après tentative d'annulation | ", _Symbol);
            return false;
         }
      }
   }
   else if(!CanOpenAdditionalPositionForSymbol(_Symbol, direction))
   {
      if(!quiet)
         Print("🚫 ", logPfx, " annulé - duplication interdite / exposition active sur ", _Symbol,
               " | dir=", direction);
      return false;
   }

   // Sécurité: STAIR_ENTRY ne doit pas ouvrir en zone de correction, sauf bypass explicite.
   if(isStairEntry && IsInEquilibriumCorrectionZone() && !StairEntryBypassEquilibriumCorrectionZone)
   {
      if(!quiet)
         Print("🚫 STAIR ENTRY annulé - Zone de correction/équilibre sur ", _Symbol,
               " (activer StairEntryBypassEquilibriumCorrectionZone pour bypass)");
      return false;
   }

   // STAIR: exécution marché basée sur le setup stair (EMA alignées) → ne pas bloquer par filtres secondaires (ICT/OB/OTE, zone équilibre).
   if(!fastScalpByDesign)
   {
      if(!IsTrendAlignedEntry(direction))
      {
         if(!quiet)
            Print("🚫 ", logPfx, " BLOQUÉ - Filtre de tendance SMC sur ", _Symbol, " : ", direction);
         return false;
      }

      if(IsInEquilibriumCorrectionZone())
      {
         if(!quiet)
            Print("🚫 ", logPfx, " annulé - Zone de correction autour de l'équilibre sur ", _Symbol);
         return false;
      }
   }

   // Filtre IA:
   // - M5_TOUCH (hors STAIR): logique historique inchangée.
   // - STAIR_ENTRY: exécuter seulement si IA dans le bon sens avec confiance >= 70%.
   //   Si IA=HOLD, placer un LIMIT (si activé) au lieu d'ouvrir au marché.
   if(isStairEntry)
   {
      string iaAct = g_lastAIAction;
      StringToUpper(iaAct);
      double iaConfU = NormalizeAIConfidenceUnit();

      if(iaAct != "HOLD")
      {
         // L'IA n'est plus HOLD: on réarme la logique spéciale pour un prochain cycle.
         s_stairHoldZoneLockUntilIARelease = false;
         s_stairHoldZoneRunArmed = false;
         s_stairHoldZoneDir = "";
      }

      if(iaAct == "HOLD")
      {
         bool holdBypassRecentSpike = false;
         if(StairEntryAllowHoldOnRecentSpike)
         {
            bool recentDirSpike = IsRecentDirectionalSpikeForStair(direction, StairEntryFastTrackAfterSpikeSeconds);
            double localSpike = CalculateSpikeProbability();
            double effectiveSpike = MathMax(localSpike, g_lastChartTechSpikeProbability);
            if(recentDirSpike && effectiveSpike + 1e-9 >= StairEntryHoldSpikeMinProbability)
            {
               holdBypassRecentSpike = true;
               s_stairHoldZoneLockUntilIARelease = false;
               s_stairHoldZoneRunArmed = false;
               s_stairHoldZoneDir = direction;
               if(!quiet)
                  Print("⚡ STAIR ENTRY HOLD bypass spike récent - exécution marché autorisée | ", _Symbol,
                        " | dir=", direction,
                        " | spikeLocal=", DoubleToString(localSpike * 100.0, 1), "%",
                        " | spikeEndpoint=", DoubleToString(g_lastChartTechSpikeProbability * 100.0, 1), "%");
            }
         }

         if(!holdBypassRecentSpike && StairEntryHoldZoneSpikeException)
         {
            bool isBuyDir = (direction == "BUY");
            bool zoneOk = isBuyDir ? IsInDiscountZone() : IsInPremiumZone();
            bool inEq = IsInEquilibriumCorrectionZone();

            if(s_stairHoldZoneDir != "" && s_stairHoldZoneDir != direction)
            {
               s_stairHoldZoneRunArmed = false;
               s_stairHoldZoneLockUntilIARelease = false;
               s_stairHoldZoneDir = direction;
            }
            else if(s_stairHoldZoneDir == "")
               s_stairHoldZoneDir = direction;

            if(s_stairHoldZoneLockUntilIARelease || (s_stairHoldZoneRunArmed && inEq))
            {
               s_stairHoldZoneLockUntilIARelease = true;
               s_stairHoldZoneRunArmed = false;
               if(!quiet)
                  Print("⛔ STAIR ENTRY HOLD bloqué - zone d'équilibre atteinte, attente fin HOLD | ", _Symbol, " | dir=", direction);
               return false;
            }

            if(zoneOk && !inEq)
            {
               s_stairHoldZoneRunArmed = true;
               if(!quiet)
                  Print("✅ STAIR ENTRY HOLD exception - exécution marché autorisée en zone ",
                        (isBuyDir ? "DISCOUNT (achat)" : "PREMIUM (vente)"),
                        " | ", _Symbol, " | dir=", direction);
               // Exception demandée: continuer vers exécution marché sans forcer IA direction/conf.
            }
            else
            {
               if(!quiet)
                  Print("🚫 STAIR ENTRY HOLD bloqué - hors zone ",
                        (isBuyDir ? "DISCOUNT" : "PREMIUM"),
                        " ou déjà en équilibre | ", _Symbol, " | dir=", direction);
               return false;
            }
         }
         else if(IA_HoldPlaceLimitBeforeM5Entry && EnableTrading && !BlockAllTrades)
         {
            PlaceHoldLimitBeforeM5Entry(direction, iaConfU);
            if(!quiet)
               Print("⏸️ STAIR ENTRY marché annulé - IA=HOLD, LIMIT placé (si conditions valides) | ", _Symbol, " | dir=", direction);
            return false;
         }
         else
         {
            if(!quiet)
               Print("🚫 STAIR ENTRY annulé - IA=HOLD et mode HOLD-limit désactivé | ", _Symbol, " | dir=", direction);
            return false;
         }
      }
      else if(!IsBoomCrashDirectionAllowedByIA(_Symbol, direction))
      {
         if(!quiet)
            Print("🚫 STAIR ENTRY annulé - IA non alignée avec la direction | ", _Symbol,
                  " | dir=", direction, " | IA=", g_lastAIAction);
         return false;
      }

      double stairMinConfU = StairEntryMinAIConfidencePercent;
      if(stairMinConfU > 1.0) stairMinConfU /= 100.0;
      if(stairMinConfU <= 0.0) stairMinConfU = 0.60;
      if(iaAct != "HOLD" && iaConfU + 1e-9 < stairMinConfU)
      {
         if(!quiet)
            Print("🚫 STAIR ENTRY annulé - confiance IA insuffisante: ",
                  DoubleToString(iaConfU * 100.0, 1), "% < ", DoubleToString(stairMinConfU * 100.0, 1), "% | ", _Symbol, " | dir=", direction);
         return false;
      }
   }
   else if(isOteCurTouchFor)
   {
      if(!IsIAStatusForDirection(direction))
      {
         if(!quiet)
            Print("🚫 OTE CUR TOUCH FOR annulé - IA non FOR/dir ou confiance insuffisante | ", _Symbol,
                  " | dir=", direction, " | IA=", g_lastAIAction, " ", DoubleToString(NormalizeAIConfidenceUnit() * 100.0, 1), "%");
         return false;
      }
   }
   else
   {
      if(!IsBoomCrashDirectionAllowedByIA(_Symbol, direction))
      {
         if(!quiet)
            Print("🚫 ", logPfx, " annulé - Direction vs IA (Boom/Crash) sur ", _Symbol, " : ", direction);
         return false;
      }

      double minAiConfPct = GetCategoryMinAIConfidencePercent(_Symbol);
      double minAiConfUnit = (minAiConfPct > 1.0) ? (minAiConfPct / 100.0) : minAiConfPct;
      if(!IsAIConfidenceAtLeast(minAiConfUnit, "M5 TOUCH", true, quiet))
         return false;
   }

   if(!isOteCurTouchFor && !PassReflectiveEntryGate(direction, commentCore, quiet))
      return false;

   // Après une perte STAIR sans nouveau spike: ne plus envoyer au marché — tenter 1 LIMIT au SR proche de la ligne M5.
   if(isStairEntry && !dryRun && StairPostLossSrModeActive(_Symbol))
   {
      if(TryPlaceStairPostLossSrRecoveryLimit(direction, quiet))
         return true;
      if(StairEntryFallbackMarketIfPostLossLimitFails)
      {
         if(!quiet)
            Print("⚠️ STAIR ENTRY — LIMIT post-perte non placé, fallback marché autorisé | ", _Symbol, " | dir=", direction);
      }
      else
      {
         if(!quiet)
            Print("🚫 STAIR ENTRY — mode post-perte SR: LIMIT non placé, marché désactivé | ", _Symbol, " | dir=", direction);
         return false;
      }
   }

   // STAIR: ne pas bloquer l'entrée marché sur spread/cooldown/dernière bougie confirmante.
   if(!fastScalpByDesign)
   {
      if(!IsSpreadAcceptable()) return false;
      if(IsEntryCooldownActive()) return false;
      if(!IsLastCandleConfirmingDirection(direction)) return false;
   }

   double lotSize = GetOptimalLotSize();
   if(SMC_GetSymbolCategory(_Symbol) == SYM_WELTRADE_SYNTH)
   {
      // Verrou explicite PAINX/GAINX: toujours lot minimum broker.
      lotSize = NormalizeVolumeForSymbol(GetMinLotForSymbol(_Symbol));
      if(lotSize <= 0.0)
      {
         if(!quiet)
            Print("❌ ", logPfx, " lot minimum indisponible pour ", _Symbol);
         return false;
      }
   }
   double price = (direction == "BUY") ? SymbolInfoDouble(_Symbol, SYMBOL_ASK) : SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   bool prudentScalp = (UsePrudentScalpInWeakScissorChannel && IsWeakScissorChannelContext());
   // STAIR: ne pas bloquer/réduire par le mode prudent (le setup stair est la décision).
   if(fastScalpByDesign)
      prudentScalp = false;

   if(prudentScalp)
   {
      double setupScoreNow = ComputeSetupScoreValue(direction);
      if(setupScoreNow < PrudentScalpMinSetupScore)
      {
         if(!quiet)
            Print("🚫 ", logPfx, " prudent bloqué - setup faible en canal ciseau: ",
                  DoubleToString(setupScoreNow, 1), " < ", DoubleToString(PrudentScalpMinSetupScore, 1));
         return false;
      }
      lotSize *= PrudentScalpLotMultiplier;
      lotSize = NormalizeVolumeForSymbol(lotSize);
      if(!quiet)
         Print("⚖️ ", logPfx, " mode PRUDENT actif - canal peu prononcé détecté | lot ajusté=", DoubleToString(lotSize, 2));
   }
   
   // Calculer SL/TP selon la direction (Boom/Crash & synth Weltrade: inputs BoomCrashFixed*)
   const bool bcM5TouchSynth = IsBoomCrashOrWeltradeDirectionalSynth(_Symbol);
   double slNormPts = bcM5TouchSynth ? (double)MathMax(1, BoomCrashFixedSlPoints) : 300.0;
   double tpNormPts = bcM5TouchSynth ? (double)MathMax(1, BoomCrashFixedTpPoints) : 600.0;
   double slPrudPts = bcM5TouchSynth ? MathMax(1.0, slNormPts * (250.0 / 300.0)) : 250.0;
   double tpPrudPts = bcM5TouchSynth ? MathMax(1.0, tpNormPts * (350.0 / 600.0)) : 350.0;
   double stopLoss = 0.0;
   double takeProfit = 0.0;
   
   if(direction == "BUY")
   {
      stopLoss = price - (slNormPts * point);
      takeProfit = price + (tpNormPts * point);
      if(prudentScalp)
      {
         stopLoss = price - (slPrudPts * point);
         takeProfit = price + (tpPrudPts * point);
      }
   }
   else // SELL
   {
      stopLoss = price + (slNormPts * point);
      takeProfit = price - (tpNormPts * point);
      if(prudentScalp)
      {
         stopLoss = price + (slPrudPts * point);
         takeProfit = price - (tpPrudPts * point);
      }
   }

   // Respect du stop-level broker (évite [Invalid stops] sur certains synth indices)
   ValidateAndAdjustStopLossTakeProfit(direction, price, stopLoss, takeProfit);
   EnforceMinBoomCrashStopLossDollarRisk(_Symbol, direction, price, lotSize, stopLoss);
   stopLoss = NormalizeDouble(stopLoss, _Digits);
   takeProfit = NormalizeDouble(takeProfit, _Digits);

   // Alignement tick size (certains brokers sont stricts)
   double tickSize = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_SIZE);
   if(tickSize <= 0) tickSize = point;
   if(tickSize > 0)
   {
      stopLoss = MathRound(stopLoss / tickSize) * tickSize;
      takeProfit = MathRound(takeProfit / tickSize) * tickSize;
      stopLoss = NormalizeDouble(stopLoss, _Digits);
      takeProfit = NormalizeDouble(takeProfit, _Digits);
   }

   // Cohérence direction SL/TP (sécurité supplémentaire)
   if(direction == "BUY")
   {
      if(stopLoss >= price || takeProfit <= price)
      {
         if(!quiet)
            Print("❌ EXC_M5 invalid SL/TP (BUY) - skip sur ", _Symbol,
                  " sl=", DoubleToString(stopLoss, _Digits),
                  " tp=", DoubleToString(takeProfit, _Digits),
                  " price=", DoubleToString(price, _Digits));
         return false;
      }
   }
   else // SELL
   {
      if(stopLoss <= price || takeProfit >= price)
      {
         if(!quiet)
            Print("❌ EXC_M5 invalid SL/TP (SELL) - skip sur ", _Symbol,
                  " sl=", DoubleToString(stopLoss, _Digits),
                  " tp=", DoubleToString(takeProfit, _Digits),
                  " price=", DoubleToString(price, _Digits));
         return false;
      }
   }
   
   // Filtre anti "position timide" pour setups rapides (STAIR/OTE_CUR/EMA_PULLBACK/SWEEP_RECLAIM)
   if(fastScalpByDesign)
   {
      double slPts = MathAbs(price - stopLoss) / point;
      double tpPts = MathAbs(takeProfit - price) / point;
      double rr = (slPts > 0.0 ? (tpPts / slPts) : 0.0);

      if(slPts < (double)MathMax(1, FastSetupMinSLPoints))
      {
         if(!quiet)
            Print("🚫 ", logPfx, " BLOQUÉ - SL trop court (timide): ",
                  DoubleToString(slPts, 1), " pts < ", IntegerToString(FastSetupMinSLPoints), " pts");
         return false;
      }
      if(tpPts < (double)MathMax(1, FastSetupMinTPPoints))
      {
         if(!quiet)
            Print("🚫 ", logPfx, " BLOQUÉ - TP trop court (timide): ",
                  DoubleToString(tpPts, 1), " pts < ", IntegerToString(FastSetupMinTPPoints), " pts");
         return false;
      }
      if(rr + 1e-9 < MathMax(0.1, FastSetupMinRR))
      {
         if(!quiet)
            Print("🚫 ", logPfx, " BLOQUÉ - RR trop faible (timide): ",
                  DoubleToString(rr, 2), " < ", DoubleToString(FastSetupMinRR, 2));
         return false;
      }

      double tickVal = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_VALUE);
      double tickSz = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_SIZE);
      double expectedUsd = 0.0;
      if(tickVal > 0.0 && tickSz > 0.0 && lotSize > 0.0)
         expectedUsd = (MathAbs(takeProfit - price) / tickSz) * tickVal * lotSize;
      if(expectedUsd + 1e-9 < MathMax(0.0, FastSetupMinExpectedProfitUSD))
      {
         if(!quiet)
            Print("🚫 ", logPfx, " BLOQUÉ - profit potentiel trop faible (timide): ",
                  DoubleToString(expectedUsd, 2), "$ < ", DoubleToString(FastSetupMinExpectedProfitUSD, 2), "$");
         return false;
      }
   }

   // Préparer la requête d'ordre
   MqlTradeRequest request = {};
   MqlTradeResult result = {};
   
   request.action = TRADE_ACTION_DEAL;
   request.symbol = _Symbol;
   request.volume = lotSize;
   request.type = (direction == "BUY") ? ORDER_TYPE_BUY : ORDER_TYPE_SELL;
   request.price = price;
   request.sl = stopLoss;
   request.tp = takeProfit;
   request.deviation = 10;
   request.magic = InpMagicNumber; // alignement pour profit/duplication par symbole
   request.comment = commentCore + "_" + direction;

   // STAIR: ne pas bloquer sur le filtre de profit potentiel minimum.
   if(commentCore != "STAIR_ENTRY")
   {
      if(!IsMinimumProfitPotentialMet(price, takeProfit, direction, lotSize))
         return false;
   }

   if(dryRun && commentCore == "STAIR_ENTRY" && StairPostLossSrModeActive(_Symbol))
      return true;

   if(dryRun)
      return true;

   if(!TryAcquireOpenLock())
   {
      if(!quiet)
         Print("🚫 ", logPfx, " annulé - lock ouverture indisponible (anti-duplication tick) | ", _Symbol);
      return false;
   }

   // Double sécurité juste avant OrderSend: protège des courses entre signaux du même tick.
   if(HasAnyExposureForSymbol(_Symbol))
   {
      if(!quiet)
         Print("🚫 ", logPfx, " annulé - exposition devenue active juste avant envoi | ", _Symbol);
      ReleaseOpenLock();
      return false;
   }
   
   // Exécuter l'ordrez
   bool success = OrderSend(request, result);
   
   if(success && result.retcode == TRADE_RETCODE_DONE)
   {
      g_lastEntryTimeForSymbol = TimeCurrent();
      Print("✅ ORDRE ", logPfx, " EXÉCUTÉ - ", direction, " sur ", _Symbol, 
            " | Ticket: ", result.order, " | Lot: ", DoubleToString(lotSize, 2),
            " | SL: ", DoubleToString(stopLoss, _Digits), 
            " | TP: ", DoubleToString(takeProfit, _Digits),
            " | ", request.comment);
      // Pas de push pour entrée touch M5 seule (M5_TOUCH_ENTRY)
      if(commentCore != "M5_TOUCH_ENTRY")
      {
         string pushMsg;
         if(commentCore == "STAIR_ENTRY")
            pushMsg = "📶 STAIR ENTRY — ordre marché " + direction + " " + _Symbol +
                      " | Ticket: " + IntegerToString((int)result.order);
         else
            pushMsg = "✅ POSITION OUVERTE - " + logPfx + " " + direction + " " + _Symbol +
                      " | Ticket: " + IntegerToString((int)result.order);
         NotifyTradeEvent(pushMsg, EntryTradeSoundFile);
      }
      ReleaseOpenLock();
      return true;
   }
   else
   {
      Print("❌ ÉCHEC ORDRE ", logPfx, " - Erreur: ", result.retcode, " | ", result.comment);
      if(result.retcode == TRADE_RETCODE_INVALID_STOPS)
      {
         // Retry unique: recalc sur prix courant + validation stricte broker.
         double retryPrice = (direction == "BUY") ? SymbolInfoDouble(_Symbol, SYMBOL_ASK) : SymbolInfoDouble(_Symbol, SYMBOL_BID);
         double retrySL = stopLoss;
         double retryTP = takeProfit;
         ValidateAndAdjustStopLossTakeProfit(direction, retryPrice, retrySL, retryTP);
         retrySL = NormalizeDouble(retrySL, _Digits);
         retryTP = NormalizeDouble(retryTP, _Digits);

         request.price = retryPrice;
         request.sl = retrySL;
         request.tp = retryTP;

         MqlTradeResult retryResult = {};
         bool retryOk = OrderSend(request, retryResult);
         if(retryOk && retryResult.retcode == TRADE_RETCODE_DONE)
         {
            g_lastEntryTimeForSymbol = TimeCurrent();
            Print("✅ ORDRE ", logPfx, " EXÉCUTÉ APRÈS RETRY STOPS - ", direction, " sur ", _Symbol,
                  " | Ticket: ", retryResult.order,
                  " | SL: ", DoubleToString(retrySL, _Digits),
                  " | TP: ", DoubleToString(retryTP, _Digits));
            if(commentCore != "M5_TOUCH_ENTRY" && UseNotifications)
            {
               string pushMsgRetry;
               if(commentCore == "STAIR_ENTRY")
                  pushMsgRetry = "📶 STAIR ENTRY (retry stops) — " + direction + " " + _Symbol +
                                 " | Ticket: " + IntegerToString((int)retryResult.order);
               else
                  pushMsgRetry = "✅ POSITION OUVERTE - " + logPfx + " RETRY " + direction + " " + _Symbol +
                                 " | Ticket: " + IntegerToString((int)retryResult.order);
               NotifyTradeEvent(pushMsgRetry, EntryTradeSoundFile);
            }
            ReleaseOpenLock();
            return true;
         }
         Print("❌ RETRY ", logPfx, " ÉCHEC - Erreur: ", retryResult.retcode, " | ", retryResult.comment);
      }
      ReleaseOpenLock();
      return false;
   }
}

//+------------------------------------------------------------------+
//| Dessine un marqueur au point de touch M5                          |
//+------------------------------------------------------------------+
void DrawM5TouchMarker(string direction, double price)
{
   string markerName = "M5_TOUCH_MARKER_" + direction;
   datetime currentTime = TimeCurrent();
   
   // Supprimer l'ancien marqueur
   ObjectDelete(0, markerName);
   
   // Créer une flèche au point de touch
   ObjectCreate(0, markerName, OBJ_ARROW, 0, currentTime, price);
   ObjectSetInteger(0, markerName, OBJPROP_COLOR, (direction == "BUY") ? clrLime : clrRed);
   ObjectSetInteger(0, markerName, OBJPROP_ARROWCODE, (direction == "BUY") ? 233 : 234); // Flèches haut/bas
   ObjectSetInteger(0, markerName, OBJPROP_WIDTH, 4);
   ObjectSetInteger(0, markerName, OBJPROP_BACK, false);
   ObjectSetString(0, markerName, OBJPROP_TEXT, "M5_TOUCH_" + direction);
}

//+------------------------------------------------------------------+
//| FONCTIONS DE SUPPORT/RÉSISTANCE PAR TIMEFRAME                    |
//+------------------------------------------------------------------+

//+------------------------------------------------------------------+
//| Calcule le niveau de support pour un timeframe donné             |
//+------------------------------------------------------------------+
double GetSupportLevelTF(ENUM_TIMEFRAMES tf, int bars)
{
   MqlRates rates[];
   ArraySetAsSeries(rates, true);
   
   if(CopyRates(_Symbol, tf, 0, bars, rates) < bars)
   {
      Print("❌ Erreur: Impossible de récupérer les données pour support/résistance TF: ", EnumToString(tf));
      return 0.0;
   }
   
   double support = 0.0;
   int supportCount = 0;
   
   // Chercher les plus bas significatifs (swing lows)
   for(int i = 2; i < bars - 2; i++)
   {
      // Un swing low est plus bas que les 2 barres précédentes et les 2 barres suivantes
      if(rates[i].low < rates[i-1].low && rates[i].low < rates[i-2].low &&
         rates[i].low < rates[i+1].low && rates[i].low < rates[i+2].low)
      {
         support += rates[i].low;
         supportCount++;
      }
   }
   
   if(supportCount > 0)
   {
      support = support / supportCount; // Moyenne des swing lows
   }
   else
   {
      // Fallback: utiliser le plus bas sur la période
      support = rates[0].low;
      for(int i = 1; i < bars; i++)
      {
         if(rates[i].low < support)
            support = rates[i].low;
      }
   }
   
   return support;
}

//+------------------------------------------------------------------+
//| Calcule le niveau de résistance pour un timeframe donné          |
//+------------------------------------------------------------------+
double GetResistanceLevelTF(ENUM_TIMEFRAMES tf, int bars)
{
   MqlRates rates[];
   ArraySetAsSeries(rates, true);
   
   if(CopyRates(_Symbol, tf, 0, bars, rates) < bars)
   {
      Print("❌ Erreur: Impossible de récupérer les données pour support/résistance TF: ", EnumToString(tf));
      return 0.0;
   }
   
   double resistance = 0.0;
   int resistanceCount = 0;
   
   // Chercher les plus hauts significatifs (swing highs)
   for(int i = 2; i < bars - 2; i++)
   {
      // Un swing high est plus haut que les 2 barres précédentes et les 2 barres suivantes
      if(rates[i].high > rates[i-1].high && rates[i].high > rates[i-2].high &&
         rates[i].high > rates[i+1].high && rates[i].high > rates[i+2].high)
      {
         resistance += rates[i].high;
         resistanceCount++;
      }
   }
   
   if(resistanceCount > 0)
   {
      resistance = resistance / resistanceCount; // Moyenne des swing highs
   }
   else
   {
      // Fallback: utiliser le plus haut sur la période
      resistance = rates[0].high;
      for(int i = 1; i < bars; i++)
      {
         if(rates[i].high > resistance)
            resistance = rates[i].high;
      }
   }
   
   return resistance;
}

//+------------------------------------------------------------------+
//| MODULE D'ANALYSE TECHNIQUE 360°                                  |
//+------------------------------------------------------------------+

void DiscoverSymbols360()
{
   AddSymbol360(_Symbol);
   int total = SymbolsTotal(true); 
   for(int i = 0; i < total && i < 50; i++) {
      string sym = SymbolName(i, true);
      if(sym != _Symbol && sym != "") AddSymbol360(sym);
   }
   Print("📡 360 Scanner: ", g_symbolCount360, " symbols découverts.");
}

void AddSymbol360(string sym)
{
   for(int i = 0; i < g_symbolCount360; i++) {
      if(g_symbols360[i].symbol == sym) return;
   }
   ArrayResize(g_symbols360, g_symbolCount360 + 1);
   g_symbols360[g_symbolCount360].symbol      = sym;
   g_symbols360[g_symbolCount360].initialized = false;
   g_symbols360[g_symbolCount360].last_bar_m5 = 0;
   g_symbolCount360++;
}

bool InitSymbolIndicators360(SymbolData360 &sd)
{
   string s = sd.symbol;
   sd.tf_m5.ema8    = iMA(s, PERIOD_M5,  8,  0, MODE_EMA, PRICE_CLOSE);
   sd.tf_m5.ema21   = iMA(s, PERIOD_M5,  21, 0, MODE_EMA, PRICE_CLOSE);
   sd.tf_m5.ema50   = iMA(s, PERIOD_M5,  50, 0, MODE_EMA, PRICE_CLOSE);
   sd.tf_m5.ema200  = iMA(s, PERIOD_M5,  200,0, MODE_EMA, PRICE_CLOSE);
   sd.tf_m5.rsi     = iRSI(s, PERIOD_M5, 14, PRICE_CLOSE);
   sd.tf_m5.macd    = iMACD(s, PERIOD_M5, 12, 26, 9, PRICE_CLOSE);
   sd.tf_m5.stoch   = iStochastic(s, PERIOD_M5, 5, 3, 3, MODE_SMA, STO_LOWHIGH);
   sd.tf_m5.adx     = iADX(s, PERIOD_M5, 14);
   sd.tf_m5.atr     = iATR(s, PERIOD_M5, 14);
   sd.tf_m5.bb      = iBands(s, PERIOD_M5, 20, 0, 2.0, PRICE_CLOSE);
   sd.tf_m15.ema8   = iMA(s, PERIOD_M15, 8,  0, MODE_EMA, PRICE_CLOSE);
   sd.tf_m15.ema21  = iMA(s, PERIOD_M15, 21, 0, MODE_EMA, PRICE_CLOSE);
   sd.tf_m15.ema50  = iMA(s, PERIOD_M15, 50, 0, MODE_EMA, PRICE_CLOSE);
   sd.tf_m15.ema200 = iMA(s, PERIOD_M15, 200,0, MODE_EMA, PRICE_CLOSE);
   sd.tf_m15.rsi    = iRSI(s, PERIOD_M15, 14, PRICE_CLOSE);
   sd.tf_m15.macd   = iMACD(s, PERIOD_M15, 12, 26, 9, PRICE_CLOSE);
   sd.tf_m15.stoch  = iStochastic(s, PERIOD_M15, 5, 3, 3, MODE_SMA, STO_LOWHIGH);
   sd.tf_m15.adx    = iADX(s, PERIOD_M15, 14);
   sd.tf_m15.atr    = iATR(s, PERIOD_M15, 14);
   sd.tf_m15.bb     = iBands(s, PERIOD_M15, 20, 0, 2.0, PRICE_CLOSE);
   sd.tf_h1.ema8    = iMA(s, PERIOD_H1,  8,  0, MODE_EMA, PRICE_CLOSE);
   sd.tf_h1.ema21   = iMA(s, PERIOD_H1,  21, 0, MODE_EMA, PRICE_CLOSE);
   sd.tf_h1.ema50   = iMA(s, PERIOD_H1,  50, 0, MODE_EMA, PRICE_CLOSE);
   sd.tf_h1.ema200  = iMA(s, PERIOD_H1,  200,0, MODE_EMA, PRICE_CLOSE);
   sd.tf_h1.rsi     = iRSI(s, PERIOD_H1,  14, PRICE_CLOSE);
   sd.tf_h1.macd    = iMACD(s, PERIOD_H1,  12, 26, 9, PRICE_CLOSE);
   sd.tf_h1.adx     = iADX(s, PERIOD_H1,  14);
   sd.tf_h1.atr     = iATR(s, PERIOD_H1,  14);
   sd.tf_h1.bb      = iBands(s, PERIOD_H1,  20, 0, 2.0, PRICE_CLOSE);
   sd.tf_h4.ema50   = iMA(s, PERIOD_H4,  50, 0, MODE_EMA, PRICE_CLOSE);
   sd.tf_h4.ema200  = iMA(s, PERIOD_H4,  200,0, MODE_EMA, PRICE_CLOSE);
   sd.tf_h4.rsi     = iRSI(s, PERIOD_H4,  14, PRICE_CLOSE);
   sd.tf_h4.atr     = iATR(s, PERIOD_H4,  14);
   sd.tf_h4.adx     = iADX(s, PERIOD_H4,  14);
   sd.tf_d1.ema50   = iMA(s, PERIOD_D1,  50, 0, MODE_EMA, PRICE_CLOSE);
   sd.tf_d1.ema200  = iMA(s, PERIOD_D1,  200,0, MODE_EMA, PRICE_CLOSE);
   sd.tf_d1.rsi     = iRSI(s, PERIOD_D1,  14, PRICE_CLOSE);
   sd.tf_d1.atr     = iATR(s, PERIOD_D1,  14);
   sd.initialized = true;
   return true;
}

void Init360Scanner()
{
   DiscoverSymbols360();
   for(int i = 0; i < g_symbolCount360; i++) InitSymbolIndicators360(g_symbols360[i]);
}

void Run360AnalysisScanner()
{
   static datetime lastScan = 0;
   if(TimeCurrent() - lastScan < 5) return; 
   lastScan = TimeCurrent();
   for(int i = 0; i < g_symbolCount360; i++) {
      if(!g_symbols360[i].initialized) continue;
      string sym = g_symbols360[i].symbol;
      datetime current_bar = iTime(sym, PERIOD_M5, 0);
      if(current_bar == 0) continue;
      if(current_bar != g_symbols360[i].last_bar_m5 || g_symbols360[i].last_bar_m5 == 0) {
         g_symbols360[i].last_bar_m5 = current_bar;
         string json_data = BuildAnalysisJSON360(g_symbols360[i]);
         SendToAIServer360(json_data, sym);
      }
   }
   ReadSignalsFromServer360();
}

string BuildAnalysisJSON360(SymbolData360 &sd)
{
   string s = sd.symbol;
   string tf_m5_json  = BuildTFJson360(sd.tf_m5,  s, PERIOD_M5);
   string tf_m15_json = BuildTFJson360(sd.tf_m15, s, PERIOD_M15);
   string tf_h1_json  = BuildTFJson360(sd.tf_h1,  s, PERIOD_H1);
   string tf_h4_json  = BuildTFJsonLight360(sd.tf_h4, s, PERIOD_H4);
   string tf_d1_json  = BuildTFJsonLight360(sd.tf_d1, s, PERIOD_D1);
   int conf_score = CalcConfluenceScore360(sd);
   string bias = GetDominantBias360(sd);
   string phase = GetMarketPhase360(sd);
   string session = GetCurrentSession360();
   string spread_ok = (GetSpreadPips360(s) <= 3.0) ? "true" : "false";
   string json = "{\"timestamp_utc\":\"" + TimeToString(TimeGMT(), TIME_DATE|TIME_SECONDS) + "\",\"symbol\":\"" + s + "\",\"broker\":\"" + AccountInfoString(ACCOUNT_COMPANY) + "\",\"analysis_version\":\"360v1\",\"market_phase\":\"" + phase + "\",\"session\":\"" + session + "\",\"news_risk\":\"LOW\",\"timeframes\":{\"M5\":" + tf_m5_json + ",\"M15\":" + tf_m15_json + ",\"H1\":" + tf_h1_json + ",\"H4\":" + tf_h4_json + ",\"D1\":" + tf_d1_json + "},\"meta\":{\"dominant_bias\":\"" + bias + "\",\"confluence_score\":" + IntegerToString(conf_score) + ",\"volatility_class\":\"NORMAL\",\"trade_allowed\":" + (conf_score >= 70 ? "true" : "false") + ",\"spread_filter_ok\":" + spread_ok + ",\"session_filter_ok\":true,\"market_structure\":\"" + GetMarketStructure360(s) + "\"}}";
   return json;
}

string BuildTFJson360(TFHandles360 &tfh, string sym, ENUM_TIMEFRAMES tf)
{
   double ema8_v  = GetIndicatorValue360(tfh.ema8,  0, 1);
   double ema21_v = GetIndicatorValue360(tfh.ema21, 0, 1);
   double ema50_v = GetIndicatorValue360(tfh.ema50, 0, 1);
   double ema200v = GetIndicatorValue360(tfh.ema200,0, 1);
   double rsi_v   = GetIndicatorValue360(tfh.rsi,   0, 1);
   double macd_l  = GetIndicatorValue360(tfh.macd,  0, 1);
   double macd_s  = GetIndicatorValue360(tfh.macd,  1, 1);
   double macd_h  = macd_l - macd_s;
   double stoch_k = GetIndicatorValue360(tfh.stoch, 0, 1);
   double stoch_d = GetIndicatorValue360(tfh.stoch, 1, 1);
   double adx_v   = GetIndicatorValue360(tfh.adx,   0, 1);
   double atr_v   = GetIndicatorValue360(tfh.atr,   0, 1) / SymbolInfoDouble(sym, SYMBOL_POINT) / 10;
   double bb_up   = GetIndicatorValue360(tfh.bb,    1, 1);
   double bb_mid  = GetIndicatorValue360(tfh.bb,    0, 1);
   double bb_dn   = GetIndicatorValue360(tfh.bb,    2, 1);
   double open_p  = iOpen(sym, tf, 1);
   double high_p  = iHigh(sym, tf, 1);
   double low_p   = iLow(sym, tf, 1);
   double close_p = iClose(sym, tf, 1);
   string json = "{\"open\":" + DoubleToString(open_p, 5) + ",\"high\":" + DoubleToString(high_p, 5) + ",\"low\":" + DoubleToString(low_p, 5) + ",\"close\":" + DoubleToString(close_p, 5) + ",\"spread_pips\":" + DoubleToString(GetSpreadPips360(sym), 1) + ",\"ema_8\":" + DoubleToString(ema8_v, 5) + ",\"ema_21\":" + DoubleToString(ema21_v, 5) + ",\"ema_50\":" + DoubleToString(ema50_v, 5) + ",\"ema_200\":" + DoubleToString(ema200v, 5) + ",\"ema_alignment\":\"" + GetEMAAlignment360(ema8_v, ema21_v, ema50_v) + "\",\"rsi_14\":" + DoubleToString(rsi_v, 2) + ",\"rsi_zone\":\"" + GetRSIZone360(rsi_v) + "\",\"macd_hist\":" + DoubleToString(macd_h, 5) + ",\"macd_cross\":\"" + GetMACDCross360(tfh.macd, 1) + "\",\"stoch_k\":" + DoubleToString(stoch_k, 1) + ",\"stoch_d\":" + DoubleToString(stoch_d, 1) + ",\"adx_14\":" + DoubleToString(adx_v, 1) + ",\"atr_14_pips\":" + DoubleToString(atr_v, 1) + ",\"bb_upper\":" + DoubleToString(bb_up, 5) + ",\"bb_mid\":" + DoubleToString(bb_mid, 5) + ",\"bb_lower\":" + DoubleToString(bb_dn, 5) + ",\"candle_type\":\"" + GetCandleType360(sym, tf, 1) + "\",\"candle_confirmation\":true,\"price_vs_ema21\":\"" + ((close_p > ema21_v) ? "ABOVE" : "BELOW") + "\",\"nearest_support\":" + DoubleToString(GetNearestSupport360(sym, tf), 5) + ",\"nearest_resist\":" + DoubleToString(GetNearestResist360(sym, tf), 5) + ",\"bos_detected\":" + (DetectBOS360(sym, tf) ? "true" : "false") + ",\"choch_detected\":" + (DetectCHoCH360(sym, tf) ? "true" : "false") + ",\"market_phase\":\"" + GetPhaseTF360(sym, tf) + "\"}";
   return json;
}

string BuildTFJsonLight360(TFHandles360 &tfh, string sym, ENUM_TIMEFRAMES tf)
{
   double ema50_v = GetIndicatorValue360(tfh.ema50,  0, 1);
   double ema200v = GetIndicatorValue360(tfh.ema200, 0, 1);
   double rsi_v   = GetIndicatorValue360(tfh.rsi,    0, 1);
   double adx_v   = GetIndicatorValue360(tfh.adx,    0, 1);
   double atr_v   = GetIndicatorValue360(tfh.atr,    0, 1) / SymbolInfoDouble(sym, SYMBOL_POINT) / 10;
   double close_p = iClose(sym, tf, 1);
   string align = (ema50_v > ema200v) ? "BULLISH_STACK" : "BEARISH_STACK";
   string json = "{\"close\":" + DoubleToString(close_p, 5) + ",\"ema_50\":" + DoubleToString(ema50_v, 5) + ",\"ema_200\":" + DoubleToString(ema200v, 5) + ",\"ema_alignment\":\"" + align + "\",\"rsi_14\":" + DoubleToString(rsi_v, 2) + ",\"adx_14\":" + DoubleToString(adx_v, 1) + ",\"atr_14_pips\":" + DoubleToString(atr_v, 1) + ",\"market_phase\":\"" + GetPhaseTF360(sym, tf) + "\"}";
   return json;
}

double GetIndicatorValue360(int handle, int buffer, int shift)
{
   if(handle == INVALID_HANDLE) return 0;
   double arr[]; ArraySetAsSeries(arr, true);
   if(CopyBuffer(handle, buffer, shift, 1, arr) <= 0) return 0;
   return arr[0];
}

string GetEMAAlignment360(double e8, double e21, double e50)
{
   if(e8 > e21 && e21 > e50) return "BULLISH_STACK";
   if(e8 < e21 && e21 < e50) return "BEARISH_STACK";
   return "MIXED";
}

string GetRSIZone360(double rsi)
{
   if(rsi >= 70) return "OVERBOUGHT";
   if(rsi <= 30) return "OVERSOLD";
   return "NEUTRAL";
}

string GetMACDCross360(int handle, int shift)
{
   double macd_now  = GetIndicatorValue360(handle, 0, shift);
   double sig_now   = GetIndicatorValue360(handle, 1, shift);
   double macd_prev = GetIndicatorValue360(handle, 0, shift + 1);
   double sig_prev  = GetIndicatorValue360(handle, 1, shift + 1);
   if(macd_prev < sig_prev && macd_now > sig_now) return "BULLISH_1_BAR_AGO";
   if(macd_prev > sig_prev && macd_now < sig_now) return "BEARISH_1_BAR_AGO";
   return "NEUTRAL";
}

string GetCandleType360(string sym, ENUM_TIMEFRAMES tf, int shift)
{
   double o = iOpen(sym, tf, shift); double c = iClose(sym, tf, shift);
   return (c > o) ? "BULLISH_CANDLE" : "BEARISH_CANDLE";
}

double GetNearestSupport360(string sym, ENUM_TIMEFRAMES tf)
{
   return iLow(sym, tf, iLowest(sym, tf, MODE_LOW, 20, 1));
}

double GetNearestResist360(string sym, ENUM_TIMEFRAMES tf)
{
   return iHigh(sym, tf, iHighest(sym, tf, MODE_HIGH, 20, 1));
}

bool DetectBOS360(string sym, ENUM_TIMEFRAMES tf)
{
   return iClose(sym, tf, 1) > iHigh(sym, tf, iHighest(sym, tf, MODE_HIGH, 10, 2));
}

bool DetectCHoCH360(string sym, ENUM_TIMEFRAMES tf)
{
   return iClose(sym, tf, 1) < iLow(sym, tf, iLowest(sym, tf, MODE_LOW, 10, 2));
}

bool IsCandleConfirmed360(string sym, ENUM_TIMEFRAMES tf, string candle_type) { return true; }
string GetMarketPhase360(SymbolData360 &sd) { return "UNKNOWN"; }
string GetPhaseTF360(string sym, ENUM_TIMEFRAMES tf) { return "UNKNOWN"; }
string GetMarketStructure360(string sym) { return "MIXED"; }
string GetDominantBias360(SymbolData360 &sd) { return (iClose(sd.symbol, PERIOD_H1, 1) > GetIndicatorValue360(sd.tf_h1.ema50, 0, 1)) ? "BULLISH" : "BEARISH"; }
int CalcConfluenceScore360(SymbolData360 &sd) { return 70; }
string GetCurrentSession360() { return "ACTIVE"; }
double GetSpreadPips360(string sym) { return (double)SymbolInfoInteger(sym, SYMBOL_SPREAD) / 10.0; }

void SendToAIServer360(string json_data, string sym)
{
   string filename = "analysis_" + sym + ".json";
   int fh = FileOpen(filename, FILE_WRITE | FILE_TXT | FILE_ANSI | FILE_COMMON);
   if(fh != INVALID_HANDLE) {
      FileWriteString(fh, json_data); FileClose(fh);
      Print("📡 360 Scanner: Analyse envoyée pour ", sym);
   }
}

void ReadSignalsFromServer360()
{
   if(!FileIsExist(g_signalFile360, FILE_COMMON)) return;
   int fh = FileOpen(g_signalFile360, FILE_READ | FILE_TXT | FILE_ANSI | FILE_COMMON);
   if(fh == INVALID_HANDLE) return;
   string content = ""; while(!FileIsEnding(fh)) content += FileReadString(fh);
   FileClose(fh); FileDelete(g_signalFile360, FILE_COMMON);
   if(content != "") { Print("🤖 AI SIGNAL RECEIVED: ", content); ExecuteAI360Signal(content); }
}

void ExecuteAI360Signal(string json)
{
   string status = ExtractJSONString360(json, "status");
   string sym = ExtractJSONString360(json, "symbol");
   if(sym == "") sym = _Symbol;

   // Mettre à jour les infos du symbol dans notre base 360
   for(int i = 0; i < g_symbolCount360; i++) {
      if(g_symbols360[i].symbol == sym) {
         g_symbols360[i].last_action = ExtractJSONString360(json, "action");
         g_symbols360[i].last_conf = (int)ExtractJSONDouble360(json, "confidence");
         break;
      }
   }

   if(status == "SIGNALS") {
      if(StringFind(json, "\""+sym+"\"") >= 0 || sym == _Symbol) {
         string action = ExtractJSONString360(json, "action");
         int conf = (int)ExtractJSONDouble360(json, "confidence");
         
         if(action == "HOLD") return;
         if(conf < 65) { Print("⚠️ 360 AI: Signal ignoré car confiance insuffisante (", conf, "%)"); return; }
         
         double sl = ExtractJSONDouble360(json, "stop_loss");
         double tp1 = ExtractJSONDouble360(json, "take_profit_1");
         double lot = ExtractJSONDouble360(json, "lot_size");
         if(lot <= 0) lot = GetMinLotForSymbol(sym);
         
         if(action == "BUY") {
            if(!IsDirectionAllowedForBoomCrash(sym, "BUY")) return;
            if(IsMaxPositionsReached()) return;
            trade.Buy(lot, sym, 0, sl, tp1, "AI360_SCALP");
         } else if(action == "SELL") {
            if(!IsDirectionAllowedForBoomCrash(sym, "SELL")) return;
            if(IsMaxPositionsReached()) return;
            trade.Sell(lot, sym, 0, sl, tp1, "AI360_SCALP");
         }
      }
   }
}

bool IsAI360SafetyPass(string sym, string direction)
{
   for(int i = 0; i < g_symbolCount360; i++) {
      if(g_symbols360[i].symbol == sym) {
         string ia_act = g_symbols360[i].last_action;
         int ia_conf = g_symbols360[i].last_conf;
         
         if(ia_act == "" || ia_act == "HOLD") return true; // Pas encore de données ou neutre, on laisse le SMC faire
         
         if(ia_act != direction) {
            Print("🚫 360 Safety Block: Conflit directionnel sur ", sym, " (IA: ", ia_act, " vs SMC: ", direction, ")");
            return false;
         }
         if(ia_conf < 65) {
            Print("🚫 360 Safety Block: Confiance IA trop faible sur ", sym, " (", ia_conf, "% < 65%)");
            return false;
         }
         break;
      }
   }
   return true;
}

void MonitorAndCleanLimitOrders360()
{
   for(int i = OrdersTotal() - 1; i >= 0; i--) {
      ulong ticket = OrderGetTicket(i);
      if(ticket <= 0) continue;
      if(!OrderSelect(ticket)) continue;
      
      string sym = OrderGetString(ORDER_SYMBOL);
      ENUM_ORDER_TYPE type = (ENUM_ORDER_TYPE)OrderGetInteger(ORDER_TYPE);
      
      if(type != ORDER_TYPE_BUY_LIMIT && type != ORDER_TYPE_SELL_LIMIT) continue;
      
      // Trouver les infos IA pour ce symbol
      for(int j = 0; j < g_symbolCount360; j++) {
         if(g_symbols360[j].symbol == sym) {
            string ia_act = g_symbols360[j].last_action;
            int ia_conf = g_symbols360[j].last_conf;
            
            bool cancel = false;
            if(ia_act == "HOLD" || ia_act == "") cancel = true;
            else if(ia_act == "BUY" && type == ORDER_TYPE_SELL_LIMIT) cancel = true;
            else if(ia_act == "SELL" && type == ORDER_TYPE_BUY_LIMIT) cancel = true;
            else if(ia_conf < 65) cancel = true; // Confiance minimale
            
            if(cancel) {
               Print("🛡️ 360 Safety: Annulation de l'ordre limite #", ticket, " (", sym, ") car l'IA n'est plus alignée (Action: ", ia_act, ", Conf: ", ia_conf, "%)");
               trade.OrderDelete(ticket);
            }
            break;
         }
      }
   }
}

string ExtractJSONString360(string json, string key) {
   string search = "\"" + key + "\":\""; int pos = StringFind(json, search);
   if(pos < 0) return ""; pos += StringLen(search);
   int end = StringFind(json, "\"", pos); if(end < 0) return "";
   return StringSubstr(json, pos, end - pos);
}

double ExtractJSONDouble360(string json, string key) {
   string search = "\"" + key + "\":"; int pos = StringFind(json, search);
   if(pos < 0) return 0; pos += StringLen(search);
   int end = StringFind(json, ",", pos); if(end < 0) end = StringFind(json, "}", pos);
   if(end < 0) return 0; return StringToDouble(StringSubstr(json, pos, end - pos));
}

