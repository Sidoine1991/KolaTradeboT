int GetTradingZoneIndexUTC(datetime t)
{
   MqlDateTime dt;
   TimeToStruct(t, dt);
   int h = dt.hour;

   if(h >= Zone1StartHourUTC && h < Zone1EndHourUTC) return 1;
   if(h >= Zone2StartHourUTC && h < Zone2EndHourUTC) return 2;
   if(h >= Zone3StartHourUTC && h < Zone3EndHourUTC) return 3;
   if(h >= Zone4StartHourUTC && h < Zone4EndHourUTC) return 4;
   return 0;
}

int CountTodayOpenedTradesEA(datetime dayStart, datetime nowTime)
{
   int count = 0;
   if(!HistorySelect(dayStart, nowTime)) return 0;

   int total = HistoryDealsTotal();
   for(int i = total - 1; i >= 0; i--)
   {
      ulong dealTicket = HistoryDealGetTicket(i);
      if(dealTicket == 0) continue;
      if((long)HistoryDealGetInteger(dealTicket, DEAL_MAGIC) != InpMagicNumber) continue;
      if((ENUM_DEAL_ENTRY)HistoryDealGetInteger(dealTicket, DEAL_ENTRY) != DEAL_ENTRY_IN) continue;
      ENUM_DEAL_TYPE dt = (ENUM_DEAL_TYPE)HistoryDealGetInteger(dealTicket, DEAL_TYPE);
      if(dt != DEAL_TYPE_BUY && dt != DEAL_TYPE_SELL) continue;
      count++;
   }
   return count;
}

int CountTodayOpenedTradesEASymbol(datetime dayStart, datetime nowTime, const string symbol)
{
   int count = 0;
   if(!HistorySelect(dayStart, nowTime)) return 0;

   int total = HistoryDealsTotal();
   for(int i = total - 1; i >= 0; i--)
   {
      ulong dealTicket = HistoryDealGetTicket(i);
      if(dealTicket == 0) continue;
      if((long)HistoryDealGetInteger(dealTicket, DEAL_MAGIC) != InpMagicNumber) continue;
      if((ENUM_DEAL_ENTRY)HistoryDealGetInteger(dealTicket, DEAL_ENTRY) != DEAL_ENTRY_IN) continue;
      ENUM_DEAL_TYPE dt = (ENUM_DEAL_TYPE)HistoryDealGetInteger(dealTicket, DEAL_TYPE);
      if(dt != DEAL_TYPE_BUY && dt != DEAL_TYPE_SELL) continue;
      if(HistoryDealGetString(dealTicket, DEAL_SYMBOL) != symbol) continue;
      count++;
   }
   return count;
}

int CountTodayOpenedTradesEAInZone(datetime dayStart, datetime nowTime, int zoneIndex)
{
   if(zoneIndex < 1 || zoneIndex > 4) return 0;
   int count = 0;
   if(!HistorySelect(dayStart, nowTime)) return 0;

   int total = HistoryDealsTotal();
   for(int i = total - 1; i >= 0; i--)
   {
      ulong dealTicket = HistoryDealGetTicket(i);
      if(dealTicket == 0) continue;
      if((long)HistoryDealGetInteger(dealTicket, DEAL_MAGIC) != InpMagicNumber) continue;
      if((ENUM_DEAL_ENTRY)HistoryDealGetInteger(dealTicket, DEAL_ENTRY) != DEAL_ENTRY_IN) continue;
      ENUM_DEAL_TYPE dt = (ENUM_DEAL_TYPE)HistoryDealGetInteger(dealTicket, DEAL_TYPE);
      if(dt != DEAL_TYPE_BUY && dt != DEAL_TYPE_SELL) continue;

      datetime dealTime = (datetime)HistoryDealGetInteger(dealTicket, DEAL_TIME);
      if(GetTradingZoneIndexUTC(dealTime) == zoneIndex)
         count++;
   }
   return count;
}

int CountTodayOpenedTradesEAInZoneSymbol(datetime dayStart, datetime nowTime, int zoneIndex, const string symbol)
{
   if(zoneIndex < 1 || zoneIndex > 4) return 0;
   int count = 0;
   if(!HistorySelect(dayStart, nowTime)) return 0;

   int total = HistoryDealsTotal();
   for(int i = total - 1; i >= 0; i--)
   {
      ulong dealTicket = HistoryDealGetTicket(i);
      if(dealTicket == 0) continue;
      if((long)HistoryDealGetInteger(dealTicket, DEAL_MAGIC) != InpMagicNumber) continue;
      if((ENUM_DEAL_ENTRY)HistoryDealGetInteger(dealTicket, DEAL_ENTRY) != DEAL_ENTRY_IN) continue;
      ENUM_DEAL_TYPE dt = (ENUM_DEAL_TYPE)HistoryDealGetInteger(dealTicket, DEAL_TYPE);
      if(dt != DEAL_TYPE_BUY && dt != DEAL_TYPE_SELL) continue;
      if(HistoryDealGetString(dealTicket, DEAL_SYMBOL) != symbol) continue;

      datetime dealTime = (datetime)HistoryDealGetInteger(dealTicket, DEAL_TIME);
      if(GetTradingZoneIndexUTC(dealTime) == zoneIndex)
         count++;
   }
   return count;
}

string NormalizeSymbolToken(string v)
{
   string t = v;
   StringToUpper(t);
   StringReplace(t, " ", "");
   StringReplace(t, ".", "");
   StringReplace(t, "_", "");
   StringReplace(t, "-", "");
   return t;
}

bool IsHighVolatilityRestrictedSymbol(const string symbol)
{
   string s = NormalizeSymbolToken(symbol);
   string csv = HighVolatilityBlockedSymbolsCsv;
   string parts[];
   int n = StringSplit(csv, ',', parts);
   if(n <= 0) return false;
   for(int i = 0; i < n; i++)
   {
      string k = NormalizeSymbolToken(parts[i]);
      if(k == "") continue;
      if(StringFind(s, k) >= 0)
         return true;
   }
   return false;
}

bool IsHighVolatilityCapitalGatePassed(const string symbol, const string context = "")
{
   if(!EnableHighVolatilityCapitalGate)
      return true;
   if(!IsHighVolatilityRestrictedSymbol(symbol))
      return true;

   double minCap = MinCapitalForHighVolatilitySymbols;
   if(minCap <= 0.0)
      return true;

   double eq = AccountInfoDouble(ACCOUNT_EQUITY);
   double bal = AccountInfoDouble(ACCOUNT_BALANCE);
   if(eq >= minCap || bal >= minCap)
      return true;

   string ctx = context;
   if(ctx == "") ctx = "ENTRY";
   Print("🚫 ", ctx, " BLOQUÉ - Symbole volatil restreint: ", symbol,
         " | Equity=", DoubleToString(eq, 2),
         " | Balance=", DoubleToString(bal, 2),
         " | Seuil min=", DoubleToString(minCap, 2));
   return false;
}

int GetBoomCrashGuardSlot(const string symbol, const bool createIfMissing)
{
   int freeIdx = -1;
   for(int i = 0; i < ArraySize(g_boomCrashGuardSymbols); i++)
   {
      if(g_boomCrashGuardSymbols[i] == symbol)
         return i;
      if(freeIdx < 0 && g_boomCrashGuardSymbols[i] == "")
         freeIdx = i;
   }
   if(createIfMissing && freeIdx >= 0)
   {
      g_boomCrashGuardSymbols[freeIdx] = symbol;
      g_boomCrashGuardPauseUntil[freeIdx] = 0;
      return freeIdx;
   }
   return -1;
}

bool IsBoomCrashLossGuardPaused(const string symbol, datetime &untilOut)
{
   untilOut = 0;
   int idx = GetBoomCrashGuardSlot(symbol, false);
   if(idx < 0) return false;
   datetime now = TimeCurrent();
   datetime u = g_boomCrashGuardPauseUntil[idx];
   if(u > now)
   {
      untilOut = u;
      return true;
   }
   if(u != 0 && u <= now)
      g_boomCrashGuardPauseUntil[idx] = 0;
   return false;
}

void SetBoomCrashLossGuardPause(const string symbol, const int minutes)
{
   int idx = GetBoomCrashGuardSlot(symbol, true);
   if(idx < 0) return;
   datetime now = TimeCurrent();
   g_boomCrashGuardPauseUntil[idx] = now + (datetime)(MathMax(1, minutes) * 60);
}

bool GetRecentBoomCrashLossStats(const string symbol,
                                 const int lookbackMinutes,
                                 int &consecutiveLossesOut,
                                 double &netOut)
{
   consecutiveLossesOut = 0;
   netOut = 0.0;
   if(symbol == "") return false;
   int lb = MathMax(10, lookbackMinutes);
   datetime toT = TimeCurrent();
   datetime fromT = toT - (datetime)(lb * 60);
   if(!HistorySelect(fromT, toT))
      return false;

   int total = HistoryDealsTotal();
   if(total <= 0) return true;

   bool streakOpen = true;
   for(int i = total - 1; i >= 0; i--)
   {
      ulong ticket = HistoryDealGetTicket(i);
      if(ticket == 0) continue;
      if((long)HistoryDealGetInteger(ticket, DEAL_MAGIC) != InpMagicNumber) continue;
      if(HistoryDealGetString(ticket, DEAL_SYMBOL) != symbol) continue;
      if((long)HistoryDealGetInteger(ticket, DEAL_ENTRY) != DEAL_ENTRY_OUT) continue;

      double p = HistoryDealGetDouble(ticket, DEAL_PROFIT) +
                 HistoryDealGetDouble(ticket, DEAL_SWAP) +
                 HistoryDealGetDouble(ticket, DEAL_COMMISSION);
      netOut += p;
      if(streakOpen)
      {
         if(p < 0.0) consecutiveLossesOut++;
         else streakOpen = false;
      }
   }
   return true;
}

bool IsAllowedByTradingTimeAndQuota(const string symbol, const string action)
{
   if(!IsHighVolatilityCapitalGatePassed(symbol, "CAPITAL FILTER"))
      return false;

   // Preset XAU (Deriv) scalping: 2 trades/jour max + spread max + tendance H1 obligatoire.
   bool isXau = false;
   if(XAU_DerivScalpPresetEnabled)
   {
      string su = symbol;
      StringToUpper(su);
      isXau = (StringFind(su, "XAU") >= 0 || StringFind(su, "GOLD") >= 0);
      if(isXau)
      {
         double aiConfPct = AIConfidencePercent();
         if(XAU_MinAIConfidencePercent > 0.0 && aiConfPct + 1e-9 < XAU_MinAIConfidencePercent)
         {
            Print("🚫 XAU SCALP BLOQUÉ - IA insuffisante sur ", symbol,
                  " | IA=", DoubleToString(aiConfPct, 1), "% < ", DoubleToString(XAU_MinAIConfidencePercent, 1), "%");
            return false;
         }
         if(XAU_RequireOTEActive && symbol == _Symbol)
         {
            string dTmp = "";
            double eTmp = 0.0, slTmp = 0.0, tpTmp = 0.0, hTmp = 0.0, lTmp = 0.0;
            if(!DetectActiveOTESetupOn100Bars(dTmp, eTmp, slTmp, tpTmp, hTmp, lTmp))
            {
               Print("🚫 XAU SCALP BLOQUÉ - OTE non active sur ", symbol, " (condition obligatoire)");
               return false;
            }
         }

         int spr = (int)SymbolInfoInteger(symbol, SYMBOL_SPREAD);
         if(XAU_MaxSpreadPoints > 0 && spr > XAU_MaxSpreadPoints)
         {
            Print("🚫 XAU SCALP BLOQUÉ - Spread trop élevé sur ", symbol,
                  " | spread=", spr, " pts > ", XAU_MaxSpreadPoints);
            return false;
         }
         if(XAU_EnforceH1TrendFilter)
         {
            string aU = action;
            StringToUpper(aU);
            if(aU == "BUY" || aU == "SELL")
            {
               int h50  = iMA(symbol, PERIOD_H1, 50, 0, MODE_EMA, PRICE_CLOSE);
               int h200 = iMA(symbol, PERIOD_H1, 200, 0, MODE_EMA, PRICE_CLOSE);
               double e50 = 0.0, e200 = 0.0;
               if(h50 != INVALID_HANDLE && h200 != INVALID_HANDLE)
               {
                  double b1[]; double b2[];
                  ArraySetAsSeries(b1, true);
                  ArraySetAsSeries(b2, true);
                  if(CopyBuffer(h50, 0, 0, 1, b1) >= 1) e50 = b1[0];
                  if(CopyBuffer(h200, 0, 0, 1, b2) >= 1) e200 = b2[0];
               }
               if(h50 != INVALID_HANDLE) IndicatorRelease(h50);
               if(h200 != INVALID_HANDLE) IndicatorRelease(h200);
               bool h1Up = (e50 > 0.0 && e200 > 0.0 && e50 > e200);
               bool h1Dn = (e50 > 0.0 && e200 > 0.0 && e50 < e200);
               if((aU == "BUY" && !h1Up) || (aU == "SELL" && !h1Dn))
               {
                  Print("🚫 XAU SCALP BLOQUÉ - Tendance H1 non alignée | ", symbol,
                        " | action=", aU,
                        " | EMA50=", DoubleToString(e50, _Digits),
                        " | EMA200=", DoubleToString(e200, _Digits));
                  return false;
               }
            }
         }
      }
   }

   datetime nowT = TimeCurrent();
   ENUM_SYMBOL_CATEGORY cat = SMC_GetSymbolCategory(symbol);

   // Garde-fou dédié Boom/Crash: stopper la spirale de pertes en phase défavorable.
   if(BoomCrashLossGuardEnabled && cat == SYM_BOOM_CRASH)
   {
      datetime guardUntil = 0;
      if(IsBoomCrashLossGuardPaused(symbol, guardUntil))
      {
         int secLeft = (int)(guardUntil - nowT);
         if(secLeft < 0) secLeft = 0;
         Print("⏸ BOOM/CRASH LOSS GUARD - Pause active sur ", symbol,
               " | reprise dans ", secLeft, "s");
         return false;
      }

      if(BoomCrashBlockEntriesInConsolidation && symbol == _Symbol && IsMarketInConsolidation(PERIOD_M5, 20))
      {
         Print("🚫 BOOM/CRASH LOSS GUARD - Entrée bloquée (consolidation/range M5) sur ", symbol);
         return false;
      }

      int streakLosses = 0;
      double netRecent = 0.0;
      if(GetRecentBoomCrashLossStats(symbol, BoomCrashLossGuardLookbackMinutes, streakLosses, netRecent))
      {
         bool hitStreak = (BoomCrashLossGuardMaxConsecutiveLosses > 0 &&
                           streakLosses >= BoomCrashLossGuardMaxConsecutiveLosses);
         bool hitNet = (BoomCrashLossGuardMaxNetLossUSD > 0.0 &&
                        netRecent <= -MathAbs(BoomCrashLossGuardMaxNetLossUSD));
         if(hitStreak || hitNet)
         {
            SetBoomCrashLossGuardPause(symbol, BoomCrashLossGuardPauseMinutes);
            Print("🚫 BOOM/CRASH LOSS GUARD DÉCLENCHÉ - ", symbol,
                  " | pertes consécutives=", streakLosses,
                  " | net ", BoomCrashLossGuardLookbackMinutes, "m=", DoubleToString(netRecent, 2), "$",
                  " | pause ", BoomCrashLossGuardPauseMinutes, " min");
            return false;
         }
      }
   }

   MqlDateTime md;
   TimeToStruct(nowT, md);
   md.hour = 0; md.min = 0; md.sec = 0;
   datetime dayStart = StructToTime(md);

   int totalToday = CountTodayOpenedTradesEASymbol(dayStart, nowT, symbol);
   int maxTradesToday = MaxDailyTrades;
   if(isXau && XAU_MaxDailyTrades > 0)
      maxTradesToday = MathMin(maxTradesToday, XAU_MaxDailyTrades);
   if(totalToday >= maxTradesToday)
   {
      Print("⏸ ROBOT EN PAUSE - Limite journalière atteinte pour ", symbol, ": ", totalToday, "/", maxTradesToday,
            " | Symbole=", symbol, " | Action=", action);
      return false;
   }

   // Sessions LO/NYO + zones UTC + quota par zone: actifs seulement après perte journalière >= MaxDailyLossDollars ($)
   // (équité vs début de journée, voir IsDailyLossPauseActive). Sinon le robot trade sans ces contraintes horaires.
   bool enforceSessionAndUtcTime = IsDailyLossPauseActive();

   // Exception opportunités Boom/Crash:
   // si canal ML aligné + confiance suffisante, on autorise hors sessions/zones horaires.
   string actionUpper = action;
   StringToUpper(actionUpper);
   bool allowBoomCrashMlBypass = false;
   if((SMC_GetSymbolCategory(symbol) == SYM_BOOM_CRASH || SMC_GetSymbolCategory(symbol) == SYM_WELTRADE_SYNTH) &&
      symbol == _Symbol)
   {
      double confPct = g_lastAIConfidence * 100.0;
      double mlMin = MlChannelEarlyMinConfPctForSymbol(symbol);
      double stairMin = StairEntryEffectiveMinAiPctForSymbol(symbol);
      if(UseMlChannelEarlySpikeEntry &&
         confPct >= mlMin &&
         DirectionMatchesBoomCrashOrWeltradeSynth(symbol, actionUpper) &&
         IsMlChannelTrendAlignedForBoomCrash(actionUpper))
      {
         allowBoomCrashMlBypass = true;
      }
      if(!allowBoomCrashMlBypass && UseStairEntry &&
         confPct >= stairMin &&
         DirectionMatchesBoomCrashOrWeltradeSynth(symbol, actionUpper) &&
         IsStrongM1M5TrendByEMAs(actionUpper) &&
         IsSyntheticStairPatternM1(actionUpper))
      {
         allowBoomCrashMlBypass = true;
      }
   }

   if(enforceSessionAndUtcTime)
   {
      // Fenêtres classiques LO/NYO (si activées) avant même les 4 zones personnalisées.
      if(UseSessions && !SMC_IsKillZone(LondonStart, LondonEnd, NYOStart, NYOEnd))
      {
         if(allowBoomCrashMlBypass)
         {
            static datetime lastSessionBypassLog = 0;
            if(TimeCurrent() - lastSessionBypassLog >= 30)
            {
               Print("⚡ TIME FILTER BYPASS - Opportunité Boom/Crash validée par canal ML (hors session LO/NYO autorisé) | Symbole=",
                     symbol, " | Action=", actionUpper);
               lastSessionBypassLog = TimeCurrent();
            }
         }
         else
         {
            Print("TRADE BLOQUE - Hors session LO/NYO | Symbole=", symbol, " | Action=", action);
            return false;
         }
      }

      if(!EnforceTradingTimeZones) return true;

      int zone = GetTradingZoneIndexUTC(nowT);
      if(zone == 0)
      {
         if(allowBoomCrashMlBypass)
         {
            static datetime lastZoneBypassLog = 0;
            if(TimeCurrent() - lastZoneBypassLog >= 30)
            {
               Print("⚡ TIME FILTER BYPASS - Opportunité Boom/Crash validée par canal ML (hors zones UTC autorisé) | Symbole=",
                     symbol, " | Action=", actionUpper);
               lastZoneBypassLog = TimeCurrent();
            }
         }
         else
         {
            Print("⏸ ROBOT EN PAUSE - Hors des 4 zones horaires UTC (3h) | Symbole=", symbol, " | Action=", action);
            return false;
         }
      }

      int zoneCount = CountTodayOpenedTradesEAInZoneSymbol(dayStart, nowT, zone, symbol);
      if(zoneCount >= MaxTradesPerZonePerDay)
      {
         Print("⏸ ROBOT EN PAUSE - Quota zone ", zone, " atteint pour ", symbol, ": ", zoneCount, "/", MaxTradesPerZonePerDay,
               " | Symbole=", symbol, " | Action=", action);
         return false;
      }
   }

   return true;
}

double GetCategoryMinAIConfidencePercent(const string symbol)
{
   if(!UseCategorySpecificThresholds)
      return MinAIConfidencePercent;

   ENUM_SYMBOL_CATEGORY cat = SMC_GetSymbolCategory(symbol);
   if(cat == SYM_BOOM_CRASH)
      return MinAIConfidenceBoomCrashPercent;

   return MinAIConfidenceOtherPercent;
}

double GetCategoryMinSetupScore(const string symbol)
{
   if(!UseCategorySpecificThresholds)
      return MinSetupScoreEntry;

   ENUM_SYMBOL_CATEGORY cat = SMC_GetSymbolCategory(symbol);
   if(cat == SYM_BOOM_CRASH)
      return MinSetupScoreBoomCrash;

   return MinSetupScoreOther;
}

// Structure pour suivre les setups OTE actifs
struct OTESetupTracker
{
   datetime   setupTime;
   double     entryPrice;
   double     stopLoss;
   double     takeProfit;
   string     direction;
   bool       isValid;
   ulong      orderId;     // Ordre pending associé
   int        setupId;     // ID unique du setup
   double     snapshotAIConfUnit; // Confiance IA (0..1) au moment de la pose du limite
   string     snapshotAIAction;   // Action IA au moment de la pose
   bool       limitPreTouchPassed; // Revérification pré-touch OK (ne plus annuler pour ce rapprochement)
   datetime   lastPreTouchCheckUtc;
   datetime   preTouchZoneEnterUtc; // Première fois que le cours entre dans la zone pré-touch
};
OTESetupTracker g_activeOTESetups[10]; // Maximum 10 setups actifs
int g_nextOTESetupId = 1;

// NOUVEAU: Paramètre pour contrôler la stratégie SMC_OTE complète
input bool   UseSMC_OTEStrategy    = true;  // Activer la stratégie SMC_OTE complète (3 étapes)

input group "=== SMC_OTE — MARCHÉS AUTORISÉS ==="
input bool   SMC_OTE_AllowForex         = true;
input bool   SMC_OTE_AllowMetals        = true;
input bool   SMC_OTE_AllowCommodities   = true;
input bool   SMC_OTE_AllowBoomCrash     = true;
input bool   SMC_OTE_AllowWeltradeSynth = true;  // PAINX / GAINX
input bool   SMC_OTE_AllowVolatility    = false; // Volatility indices: désactivé par défaut (peut être bruyant)

input group "=== TIMEFRAMES ==="
input ENUM_TIMEFRAMES HTF      = PERIOD_H4;  // Structure (HTF)
input ENUM_TIMEFRAMES LTF      = PERIOD_M15; // Entrée (LTF)
input bool   UsePriceActionM15Strategy = true; // 3e strategie: Price Action pure sur M15
input int    PriceActionM15LookbackBars = 40;  // Fenetre structurelle M15 (barres)
input double PriceActionM15BufferATRMult = 0.15; // Buffer breakout/retest (x ATR M15)
input double PriceActionM15RiskReward = 2.2;   // Ratio R:R pour TP
input bool   ShowPriceActionM15Visuals = true; // Afficher fleche + Entry/SL/TP Price Action M15
input bool   ShowPriceActionScenarioProjection = true; // Zone setup prix actuel + projection M15 (structure reelle)
input int    PriceActionScenarioProjectionBars = 32;   // Horizon projection (bougies M15)
input int    PriceActionScenarioStructureBars = 22;  // Fenetre analyse structure / momentum (M15)
input double PriceActionScenarioRangeATRMult = 0.95;   // Si range < ATR*ce facteur => scenario RANGE
input double PriceActionScenarioBiasATRMult = 0.28;  // Seuil delta close vs N barres (x ATR) pour BULL/BEAR
input double PriceActionScenarioMaxMoveATRMult = 3.2; // Plafond |projection - prix| (x ATR M15)
input int    PriceActionScenarioFutureZoneBars = 10; // Largeur (bougies M15) du rectangle setup en zone FUTUR
input bool   UseFutureDirectionConfidenceGate = true; // Exiger une confluence forte dans la zone de projection future avant entree
input double FutureDirectionMinScore = 80.0; // Score mini (0-100) de certitude direction future
input int    FutureDirectionMinConfirmations = 3; // Nombre mini de confirmations structure/momentum/IA
input bool   FutureDirectionRequireSweepReclaim = true; // Exiger sweep + reclaim de liquidite pour valider l'entree
input int    FutureDirectionLookbackBars = 36; // Fenetre de sweep/reclaim et stats de bougies
input int    PriceActionScenarioDisplayMaxBars = 18; // Horizon dessine depuis maintenant (M15) — reste dans la marge vide a droite
input int    HistoricalPatternLookbackBars = 1000; // Profondeur historique pour analyser les patterns passes
input int    PatternSimilarityContextBars = 24; // Taille du pattern courant compare a l'historique
input int    PatternPredictionHorizonBars = 12; // Horizon futur (M15) estime a partir des patterns similaires
input bool   EnableChartPatternDetection = true; // Détecter figures chartistes + chandeliers sur M15
input bool   ChartPatternAffectTradeDecision = true; // Utiliser les figures détectées dans le score final de setup
input bool   ChartPatternDrawProjection = true; // Dessiner des segments obliques de projection directionnelle future
input bool   ChartPatternNotifyInSignals = true; // Inclure la figure détectée dans les notifications signal
input double ChartPatternDirectionalWeight = 12.0; // Bonus/malus max appliqué au score setup selon direction figure
input bool   OnlyDrawConfirmedOBWithFibConfluence = true; // Filtrer les OB: uniquement confirmés + confluence Fibonacci OTE
input int    MaxConfirmedOBToDraw = 2; // Limiter le nombre d'OB validés affichés (anti-encombrement)
input double OBMinRRForDisplay = 3.0; // RR minimum requis pour afficher une zone OB (objectif vers dernier swing opposé)
input bool   OTECurrentZoneUseTrendFallback = true; // Si IA non FOR, autoriser entrée OTE_CURR selon tendance alignée
input bool   M5EntryLimitRequirePatternValidation = true; // LIMIT M5_ENTRY/M5_TREND_ENTRY uniquement si pattern validé
input bool   KeepScenarioObjectsPersistent = false; // Ne pas faire disparaitre les objets: mise a jour en place
input bool   KeepSMCOTEObjectsPersistent = false; // Garder OTE/FVG/5star visibles (mise a jour au lieu d'effacer)
input int    SMCOTE_LookbackBarsLTF = 500; // Profondeur bougies LTF pour swings/OTE/FVG (M15 par defaut)
input int    SMCOTE_LookbackBarsHTF = 120;  // Profondeur bougies HTF pour trend/structure (H4 par defaut)

input group "=== FVG_Kill PRO (Smart Money) ==="
input bool   UseFVGKillMode    = true;   // Activer logique FVG_Kill (EMA HTF + LS)
input int    EMA50_Period      = 50;     // EMA 50 (HTF)
input int    EMA200_Period     = 200;    // EMA 200 (HTF)
input double ATR_Mult          = 1.8;    // Multiplicateur ATR (SL FVG_Kill)
input bool   UseTrailingStructure = true; // Trailing SL sur structure (LTF bar)
input bool   BoomCrashMode     = true;   // Boom/Crash: BUY sur Boom, SELL sur Crash

input group "=== SESSIONS (heure serveur) ==="
input bool   TradeOutsideKillZone = true;  // Trader 24/7 (true = ignorer Kill Zone)
input int    LondonStart       = 8;      // London Open début
input int    LondonEnd         = 11;     // London Open fin
input int    NYOStart          = 13;     // New York Open début
input int    NYOEnd            = 16;     // New York Open fin

input group "=== NOTIFICATIONS ==="
input bool   UseNotifications  = true;   // Alert + notification push (signaux et trades)
input bool   UseSoundNotifications = true;      // Activer notification sonore locale MT5
input string EntryTradeSoundFile = "alert.wav"; // Son quand un ordre marché est exécuté (position ouverte)
input string SpikeCapturedSoundFile = "timeout.wav"; // Son thème « spike capté » (fermeture sur capture spike / DERIV / scalp)
input string TradeClosedSoundFile = "stops.wav"; // Son après clôture réussie (toujours pour cette branche de fermeture)
input bool   NotifyDerivArrowBoomCrashPush = true;   // Push mobile: flèche DERIV vert=Boom / rouge=Crash (apparition + disparition)
input int    NotifyDerivArrowDisappearHoldSec = 2;   // Secondes sans flèche avant push « disparu » (anti-clignotement SMC_DERIV_ARROW)

input group "=== BOUGIES FUTURES ==="
input int    PredictionChannelPastBars = 1000; // (interne)
input int    PredictionChannelBars = 1000;  // (interne, canal de prédiction sur 1000 bougies futures)

input group "=== CANAUX SMC MULTI-TF ==="
input bool   ShowSMCChannelsMultiTF = false;  // Afficher canaux SMC sur H1, M30, M5 (DÉSACTIVÉ POUR CLARTÉ)
input bool   ShowEMASupertrendMultiTF = false; // Afficher EMA Supertrend S/R sur H1, M30, M5 (DÉSACTIVÉ POUR CLARTÉ)

//+------------------------------------------------------------------+
//| FONCTIONS DE PRÉSERVATION DES GAINS                           |
//+------------------------------------------------------------------+

// Initialiser le système de préservation des gains
void InitializeGainPreservationSystem()
{
   g_dailyStartEquity = AccountInfoDouble(ACCOUNT_EQUITY);
   g_peakEquity = g_dailyStartEquity;
   g_protectionActive = false;
   g_protectionStartTime = 0;
   
   // Initialiser les trackers OTE
   for(int i = 0; i < ArraySize(g_activeOTESetups); i++)
   {
      g_activeOTESetups[i].isValid = false;
      g_activeOTESetups[i].setupId = 0;
      g_activeOTESetups[i].orderId = 0;
   }
   
   Print("🛡️ SYSTÈME DE PRÉSERVATION DES GAINS INITIALISÉ");
   Print("   💰 Équité de départ: ", DoubleToString(g_dailyStartEquity, 2), "$");
   Print("   🎯 Seuil de protection: ", DoubleToString(DailyGainProtectionThreshold, 2), "$");
   Print("   📉 Max drawdown après protection: ", DoubleToString(MaxDrawdownAfterProtection, 2), "$");
}

// Mettre à jour le système de préservation des gains
void UpdateGainPreservationSystem()
{
   if(!UseGainPreservationSystem) return;
   
   double currentEquity = AccountInfoDouble(ACCOUNT_EQUITY);
   double dailyProfit = currentEquity - g_dailyStartEquity;
   
   // Mettre à jour le pic d'équité
   if(currentEquity > g_peakEquity)
      g_peakEquity = currentEquity;
   
   // Vérifier si on doit activer la protection
   if(!g_protectionActive && dailyProfit >= DailyGainProtectionThreshold)
   {
      ActivateGainProtection();
   }
   
   // Si la protection est active, vérifier le drawdown
   if(g_protectionActive)
   {
      double drawdown = g_peakEquity - currentEquity;
      
      // Logs de surveillance toutes les 60 secondes
      static datetime lastLogTime = 0;
      if(TimeCurrent() - lastLogTime >= 60)
      {
         Print("🛡️ PROTECTION GAINS ACTIVE - Accumulé: ", DoubleToString(dailyProfit, 2), "$");
         Print("   📉 Drawdown actuel: ", DoubleToString(drawdown, 2), "$ / ", DoubleToString(MaxDrawdownAfterProtection, 2), "$ max");
         lastLogTime = TimeCurrent();
      }
      
      // Si le drawdown dépasse le maximum, fermer toutes les positions
      if(drawdown >= MaxDrawdownAfterProtection)
      {
         Print("🚨 PERTE MAXIMALE ATTEINTE - Drawdown: ", DoubleToString(drawdown, 2), "$ ≥ ", DoubleToString(MaxDrawdownAfterProtection, 2), "$");
         Print("   🔄 Fermeture de toutes les positions pour protéger les gains accumulés");
         
         CloseAllPositionsForGainProtection();
         DeactivateGainProtection();
      }
   }
}

// Activer la protection des gains
void ActivateGainProtection()
{
   g_protectionActive = true;
   g_protectionStartTime = TimeCurrent();
   
   double dailyProfit = AccountInfoDouble(ACCOUNT_EQUITY) - g_dailyStartEquity;
   
   Print("🛡️ PROTECTION GAINS ACTIVÉE - Gains accumulés: ", DoubleToString(dailyProfit, 2), "$ ≥ ", DoubleToString(DailyGainProtectionThreshold, 2), "$");
   Print("   💰 Sommet atteint: ", DoubleToString(g_peakEquity, 2), "$");
   Print("   🚫 Perte maximale autorisée: ", DoubleToString(MaxDrawdownAfterProtection, 2), "$");
}

// Désactiver la protection des gains
void DeactivateGainProtection()
{
   g_protectionActive = false;
   g_protectionStartTime = 0;
   g_lastProtectionCooldown = TimeCurrent();
   
   Print("✅ PROTECTION GAINS DÉSACTIVÉE - Période de refroidissement activée");
}

// Fermer toutes les positions pour la protection des gains
void CloseAllPositionsForGainProtection()
{
   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      if(PositionGetTicket(i) > 0)
      {
         string symbol = PositionGetString(POSITION_SYMBOL);
         ulong ticket = PositionGetInteger(POSITION_TICKET);
         double profit = PositionGetDouble(POSITION_PROFIT);
         
         if(PositionGetInteger(POSITION_MAGIC) == InpMagicNumber)
         {
            bool success = PositionCloseWithLog(ticket, "Protection gains accumulés - perte max atteinte");
            if(success)
            {
               Print("✅ Position fermée - ", symbol, ": ", DoubleToString(profit, 2), "$ (Protection gains accumulés)");
            }
         }
      }
   }
   
   // Annuler aussi tous les ordres pending
   CancelAllPendingOrdersForGainProtection();
}

// Annuler tous les ordres pending pour la protection
void CancelAllPendingOrdersForGainProtection()
{
   for(int i = OrdersTotal() - 1; i >= 0; i--)
   {
      if(OrderSelect(i))
      {
         if(OrderGetInteger(ORDER_MAGIC) == InpMagicNumber)
         {
            ulong ticket = OrderGetTicket(i);
            MqlTradeRequest req;
            MqlTradeResult res;
            ZeroMemory(req);
            
            req.action = TRADE_ACTION_REMOVE;
            req.order = ticket;
            
            if(OrderSend(req, res))
            {
               Print("✅ Ordre annulé - Ticket: ", ticket, " (Protection gains accumulés)");
            }
         }
      }
   }
}

// Vérifier si le trading est autorisé (protection gains)
bool IsTradingAllowedForGainPreservation()
{
   if(!UseGainPreservationSystem) return true;
   
   // Si la protection est active, bloquer les nouveaux trades
   if(g_protectionActive)
   {
      static datetime lastBlockLog = 0;
      if(TimeCurrent() - lastBlockLog >= 60) // Log toutes les minutes
      {
         Print("🚫 TRADES BLOQUÉS - Protection gains accumulés active");
         lastBlockLog = TimeCurrent();
      }
      return false;
   }
   
   // Période de refroidissement après protection
   if(g_lastProtectionCooldown > 0)
   {
      int cooldownRemaining = (int)(g_lastProtectionCooldown + ProtectionCooldownMinutes * 60 - TimeCurrent());
      if(cooldownRemaining > 0)
      {
         static datetime lastCooldownLog = 0;
         if(TimeCurrent() - lastCooldownLog >= 120) // Log toutes les 2 minutes
         {
            Print("⏳ PÉRIODE DE REFROIDISSEMENT - ", cooldownRemaining / 60, "min ", cooldownRemaining % 60, "s restantes");
            lastCooldownLog = TimeCurrent();
         }
         return false;
      }
      else
      {
         g_lastProtectionCooldown = 0; // Fin du refroidissement
         Print("✅ PÉRIODE DE REFROIDISSEMENT TERMINÉE - Trading autorisé");
      }
   }
   
   return true;
}

// Calculer l'espérance mathématique d'un trade
double CalculateTradeExpectancy(string direction, double entryPrice, double stopLoss, double takeProfit)
{
   // Calculer les ratios
   double risk = MathAbs(entryPrice - stopLoss);
   double reward = MathAbs(takeProfit - entryPrice);
   
   if(risk <= 0) return 0.0;
   
   double riskRewardRatio = reward / risk;
   
   // Estimer la probabilité de succès basée sur:
   // 1. Ratio R/R
   // 2. Confiance IA
   // 3. Alignement de tendance
   // 4. Distance OTE
   
   double baseProbability = 0.5; // 50% de base
   
   // Ajuster selon le ratio R/R
   if(riskRewardRatio >= 3.0) baseProbability += 0.15;
   else if(riskRewardRatio >= 2.0) baseProbability += 0.10;
   else if(riskRewardRatio >= 1.5) baseProbability += 0.05;
   
   // Ajuster selon la confiance IA (unité 0..1)
   double iaU = NormalizeAIConfidenceUnit();
   if(iaU >= 0.80) baseProbability += 0.10;
   else if(iaU >= 0.70) baseProbability += 0.05;
   
   // Ajuster selon l'alignement de tendance
   string trendDirection = GetCurrentTrendDirection();
   if((direction == "BUY" && trendDirection == "UPTREND") ||
      (direction == "SELL" && trendDirection == "DOWNTREND"))
   {
      baseProbability += 0.08;
   }
   
   // Limiter la probabilité entre 0.3 et 0.8
   if(baseProbability > 0.8) baseProbability = 0.8;
   if(baseProbability < 0.3) baseProbability = 0.3;
   
   // Calculer l'espérance: E = p × W - (1-p) × L
   double expectancy = baseProbability * riskRewardRatio - (1.0 - baseProbability) * 1.0;
   
   return expectancy;
}

// Fusionner avec un setup OTE déjà suivi (même sens + même niveau d'entrée). Retourne setupId ou -1.
int TryMergeOTESetupSlot(double entryPrice, double stopLoss, double takeProfit, string direction,
                         ulong pendingOrderId)
{
   double pt = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   if(pt <= 0.0) pt = _Point;
   double tol = pt * MathMax(5.0, (double)OTE_StructuralMinDistancePts * 2.0);

   for(int i = 0; i < ArraySize(g_activeOTESetups); i++)
   {
      if(!g_activeOTESetups[i].isValid) continue;
      if(g_activeOTESetups[i].direction != direction) continue;
      if(MathAbs(g_activeOTESetups[i].entryPrice - entryPrice) > tol) continue;

      g_activeOTESetups[i].stopLoss = stopLoss;
      g_activeOTESetups[i].takeProfit = takeProfit;
      if(pendingOrderId > 0 && g_activeOTESetups[i].orderId == 0)
      {
         g_activeOTESetups[i].orderId = pendingOrderId;
         g_activeOTESetups[i].snapshotAIConfUnit = NormalizeAIConfidenceUnit();
         g_activeOTESetups[i].snapshotAIAction = g_lastAIAction;
         g_activeOTESetups[i].limitPreTouchPassed = false;
         g_activeOTESetups[i].lastPreTouchCheckUtc = 0;
         g_activeOTESetups[i].preTouchZoneEnterUtc = 0;
      }
      Print("📍 SETUP OTE FUSIONNÉ - ID: ", g_activeOTESetups[i].setupId, " | ", direction,
            (pendingOrderId > 0 ? " | pending lié" : ""));
      return g_activeOTESetups[i].setupId;
   }
   return -1;
}

// Ajouter un setup OTE au suivi (évite doublon même entrée / sens)
int AddOTESetup(double entryPrice, double stopLoss, double takeProfit, string direction, ulong pendingOrderId = 0)
{
   int merged = TryMergeOTESetupSlot(entryPrice, stopLoss, takeProfit, direction, pendingOrderId);
   if(merged != -1)
      return merged;

   int slot = -1;
   for(int i = 0; i < ArraySize(g_activeOTESetups); i++)
   {
      if(!g_activeOTESetups[i].isValid)
      {
         slot = i;
         break;
      }
   }

   if(slot == -1) return -1;

   g_activeOTESetups[slot].setupTime = TimeCurrent();
   g_activeOTESetups[slot].entryPrice = entryPrice;
   g_activeOTESetups[slot].stopLoss = stopLoss;
   g_activeOTESetups[slot].takeProfit = takeProfit;
   g_activeOTESetups[slot].direction = direction;
   g_activeOTESetups[slot].isValid = true;
   g_activeOTESetups[slot].orderId = pendingOrderId;
   g_activeOTESetups[slot].setupId = g_nextOTESetupId++;
   g_activeOTESetups[slot].snapshotAIConfUnit = (pendingOrderId > 0 ? NormalizeAIConfidenceUnit() : 0.0);
   g_activeOTESetups[slot].snapshotAIAction = (pendingOrderId > 0 ? g_lastAIAction : "");
   g_activeOTESetups[slot].limitPreTouchPassed = false;
   g_activeOTESetups[slot].lastPreTouchCheckUtc = 0;
   g_activeOTESetups[slot].preTouchZoneEnterUtc = 0;

   Print("📍 SETUP OTE AJOUTÉ - ID: ", g_activeOTESetups[slot].setupId, " | ", direction);
   Print("   📍 Entry: ", DoubleToString(entryPrice, _Digits));
   Print("   🛡️ SL: ", DoubleToString(stopLoss, _Digits));
   Print("   🎯 TP: ", DoubleToString(takeProfit, _Digits));

   return g_activeOTESetups[slot].setupId;
}

// Vérifier si un setup OTE est toujours valide
bool IsOTESetupStillValid(int setupId)
{
   for(int i = 0; i < ArraySize(g_activeOTESetups); i++)
   {
      if(g_activeOTESetups[i].isValid && g_activeOTESetups[i].setupId == setupId)
      {
         // Vérifier l'âge du setup (max 2 heures)
         if(TimeCurrent() - g_activeOTESetups[i].setupTime > 7200)
         {
            Print("⏰ SETUP OTE EXPIRÉ - ID: ", setupId, " (> 2 heures)");
            g_activeOTESetups[i].isValid = false;
            return false;
         }
         
         // Vérifier si la structure SMC est toujours valide
         if(!IsSMCStructureStillValid(g_activeOTESetups[i].direction))
         {
            Print("❌ SETUP OTE INVALIDÉ - ID: ", setupId, " | Structure SMC rompue");
            g_activeOTESetups[i].isValid = false;
            return false;
         }
         
         return true;
      }
   }
   
   return false; // Setup non trouvé
}

// Vérifier si la structure SMC est toujours valide
bool IsSMCStructureStillValid(string direction)
{
   double currentPrice = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   
   // Vérifier les swing points récents
   double recentSwingHigh = 0, recentSwingLow = 0;
   datetime recentSwingHighTime = 0, recentSwingLowTime = 0;
   
   // Chercher les swing points dans les 50 dernières bougies
   if(!GetRecentSwingPoints(50, recentSwingHigh, recentSwingLow, recentSwingHighTime, recentSwingLowTime))
      return true; // Pas assez de données, considérer comme valide
   
   // Pour un setup BUY: le prix ne doit pas casser le swing low récent
   if(direction == "BUY" && recentSwingLow > 0)
   {
      if(currentPrice < recentSwingLow - SymbolInfoDouble(_Symbol, SYMBOL_POINT) * 10)
      {
         Print("🚨 STRUCTURE BUY INVALIDÉE - Prix sous swing low récent");
         return false;
      }
   }
   
   // Pour un setup SELL: le prix ne doit pas casser le swing high récent
   if(direction == "SELL" && recentSwingHigh > 0)
   {
      if(currentPrice > recentSwingHigh + SymbolInfoDouble(_Symbol, SYMBOL_POINT) * 10)
      {
         Print("🚨 STRUCTURE SELL INVALIDÉE - Prix au-dessus swing high récent");
         return false;
      }
   }
   
   return true;
}

// Au moins un setup OTE actif encore valide pour la direction (BUY Boom / SELL Crash)
bool HasActiveValidOTESetupForDirection(const string direction)
{
   string d = direction;
   StringToUpper(d);
   if(d != "BUY" && d != "SELL")
      return false;

   for(int i = 0; i < ArraySize(g_activeOTESetups); i++)
   {
      if(!g_activeOTESetups[i].isValid)
         continue;
      string sd = g_activeOTESetups[i].direction;
      StringToUpper(sd);
      if(sd != d)
         continue;
      if(IsOTESetupStillValid(g_activeOTESetups[i].setupId))
         return true;
   }
   return false;
}

// Obtenir les swing points récents
bool GetRecentSwingPoints(int lookback, double &swingHigh, double &swingLow, datetime &swingHighTime, datetime &swingLowTime)
{
   MqlRates rates[];
   ArraySetAsSeries(rates, true);
   
   if(CopyRates(_Symbol, PERIOD_CURRENT, 0, lookback, rates) < lookback)
      return false;
   
   swingHigh = 0;
   swingLow = DBL_MAX;
   swingHighTime = 0;
   swingLowTime = 0;
   
   // Identifier les swing points (simple pour l'instant)
   for(int i = 2; i < lookback - 2; i++)
   {
      // Swing High
      if(rates[i].high > rates[i-1].high && rates[i].high > rates[i-2].high &&
         rates[i].high > rates[i+1].high && rates[i].high > rates[i+2].high)
      {
         if(rates[i].high > swingHigh)
         {
            swingHigh = rates[i].high;
            swingHighTime = rates[i].time;
         }
      }
      
      // Swing Low
      if(rates[i].low < rates[i-1].low && rates[i].low < rates[i-2].low &&
         rates[i].low < rates[i+1].low && rates[i].low < rates[i+2].low)
      {
         if(rates[i].low < swingLow)
         {
            swingLow = rates[i].low;
            swingLowTime = rates[i].time;
         }
      }
   }
   
   return (swingHigh > 0 && swingLow < DBL_MAX);
}

// Exécuter une entrée avant l'OTE pour capturer les spikes
void ExecutePreOTESpikeEntry(string direction, double oteEntryPrice, double stopLoss, double takeProfit)
{
   if(!UsePreOTEEntry) return;

   if(!IsDirectionAllowedForBoomCrash(_Symbol, direction))
   {
      Print("🚫 ENTRÉE PRÉ-OTE BLOQUÉE - Direction interdite (Boom/Crash) sur ", _Symbol, " : ", direction);
      return;
   }
   if(UseAIServer && IsBoomCrashOrWeltradeDirectionalSynth(_Symbol) &&
      !IsBoomCrashDirectionAllowedByIA(_Symbol, direction))
   {
      Print("🚫 ENTRÉE PRÉ-OTE BLOQUÉE - Direction vs IA serveur sur ", _Symbol,
            " dir=", direction, " IA=", g_lastAIAction);
      return;
   }

   double currentPrice = SymbolInfoDouble(_Symbol, (direction == "BUY") ? SYMBOL_ASK : SYMBOL_BID);
   if(!PassOteFibSwingEquilibriumFilter(direction, currentPrice))
      return;
   double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   
   // VÉRIFICATION CRUCIALE : Valider l'alignement avec la tendance EMA
   string trendDirection = GetCurrentTrendDirection();
   
   // BLOQUER les entrées contre-tendance pour éviter les corrections
   if(direction == "BUY" && trendDirection == "DOWNTREND")
   {
      Print("🚫 ENTRÉE PRÉ-OTE BLOQUÉE - BUY contre tendance DOWNTREND");
      Print("   📉 Tendance actuelle: ", trendDirection);
      Print("   📍 Prix actuel: ", DoubleToString(currentPrice, _Digits));
      return;
   }
   
   if(direction == "SELL" && trendDirection == "UPTREND")
   {
      Print("🚫 ENTRÉE PRÉ-OTE BLOQUÉE - SELL contre tendance UPTREND");
      Print("   📈 Tendance actuelle: ", trendDirection);
      Print("   📍 Prix actuel: ", DoubleToString(currentPrice, _Digits));
      return;
   }
   
   // Vérification supplémentaire : le prix doit être proche de l'EMA de tendance
   double emaFast = 0.0, emaSlow = 0.0;
   if(hEmaFast != INVALID_HANDLE && hEmaSlow != INVALID_HANDLE)
   {
      double a1[], a2[];
      ArraySetAsSeries(a1, true);
      ArraySetAsSeries(a2, true);
      if(CopyBuffer(hEmaFast, 0, 0, 1, a1) >= 1 && CopyBuffer(hEmaSlow, 0, 0, 1, a2) >= 1)
      {
         emaFast = a1[0];
         emaSlow = a2[0];
      }
   }
   
   // Pour BUY : le prix doit être au-dessus de l'EMA rapide pour confirmer la tendance haussière
   if(direction == "BUY" && currentPrice < emaFast)
   {
      Print("🚫 ENTRÉE PRÉ-OTE BLOQUÉE - BUY sous EMA rapide (correction)");
      Print("   📍 Prix actuel: ", DoubleToString(currentPrice, _Digits));
      Print("   📈 EMA rapide: ", DoubleToString(emaFast, _Digits));
      Print("   ⏳ Attendre retour au-dessus de l'EMA pour entrer en BUY");
      return;
   }
   
   // Pour SELL : le prix doit être en-dessous de l'EMA rapide pour confirmer la tendance baissière
   if(direction == "SELL" && currentPrice > emaFast)
   {
      Print("🚫 ENTRÉE PRÉ-OTE BLOQUÉE - SELL au-dessus EMA rapide (correction)");
      Print("   📍 Prix actuel: ", DoubleToString(currentPrice, _Digits));
      Print("   📉 EMA rapide: ", DoubleToString(emaFast, _Digits));
      Print("   ⏳ Attendre retour en-dessous de l'EMA pour entrer en SELL");
      return;
   }
   
   if(!IsDirectionAllowedForBoomCrash(_Symbol, direction)) return;
   if(IsMaxPositionsReached()) return;

   // Calculer le prix d'entrée avant l'OTE
   double preOTEEntryPrice;
   if(direction == "BUY")
   {

      preOTEEntryPrice = oteEntryPrice - (oteEntryPrice * PreOTEEntryDistancePercent / 100.0);
      if(!OTE_PlaceLimitWhenStructuralBetter)
      {
         if(preOTEEntryPrice < currentPrice)
            preOTEEntryPrice = currentPrice + point * 5;
      }
   }
   else // SELL
   {
      preOTEEntryPrice = oteEntryPrice + (oteEntryPrice * PreOTEEntryDistancePercent / 100.0);
      if(!OTE_PlaceLimitWhenStructuralBetter)
      {
         if(preOTEEntryPrice > currentPrice)
            preOTEEntryPrice = currentPrice - point * 5;
      }
   }
   preOTEEntryPrice = NormalizeDouble(preOTEEntryPrice, _Digits);

   double execSL = stopLoss;
   double execTP = takeProfit;
   if(direction == "BUY")
      execTP = preOTEEntryPrice + (preOTEEntryPrice - execSL) * MathMax(3.0, InpRiskReward);
   else
      execTP = preOTEEntryPrice - (execSL - preOTEEntryPrice) * MathMax(3.0, InpRiskReward);
   ValidateAndAdjustStopLossTakeProfit(direction, preOTEEntryPrice, execSL, execTP);
   
   // Calculer l'espérance mathématique (prix d'exécution cible = pré-OTE ou limite)
   double expectancy = CalculateTradeExpectancy(direction, preOTEEntryPrice, execSL, execTP);
   
   if(expectancy < MinExpectancyThreshold)
   {
      Print("🚫 ENTRÉE PRÉ-OTE BLOQUÉE - Espérance: ", DoubleToString(expectancy, 3), " < ", DoubleToString(MinExpectancyThreshold, 3));
      return;
   }
   
   // VALIDATION ULTRA SÉLECTIVE : Probabilité de gain élevée obligatoire
   if(!IsTradeUltraSelective(direction, preOTEEntryPrice, execSL, execTP))
   {
      return; // La fonction affiche déjà les raisons du blocage
   }
   
   // Vérifier si le trading est autorisé
   if(!IsTradingAllowedForGainPreservation())
   {
      Print("🚫 ENTRÉE PRÉ-OTE BLOQUÉE - Protection gains active");
      return;
   }
   if(!CanOpenAdditionalPositionForSymbol(_Symbol, direction))
   {
      Print("🚫 ENTRÉE PRÉ-OTE BLOQUÉE - Position déjà prise sur ", _Symbol, " | dir=", direction);
      return;
   }
   
   double lot = NormalizeVolumeForSymbol(GetMinLotForSymbol(_Symbol));
   if(lot <= 0.0)
   {
      Print("❌ ENTRÉE PRÉ-OTE BLOQUÉE - lot minimum indisponible");
      return;
   }
   
   bool success = false;
   string comment = "PRE_OTE_SPIKE_" + direction;
   double minOff = (double)OTE_StructuralMinDistancePts * point;
   ENUM_ORDER_TYPE forcedOt = (direction == "BUY") ? ORDER_TYPE_BUY_LIMIT : ORDER_TYPE_SELL_LIMIT;
   int expMin = MathMax(0, PreOTE_LimitExpireMinutes);
   datetime expTime = (expMin > 0) ? (TimeCurrent() + expMin * 60) : 0;

   if(OTE_PlaceLimitWhenStructuralBetter && direction == "SELL" && preOTEEntryPrice > currentPrice + minOff)
   {
      double e = preOTEEntryPrice, sl = execSL, tp = execTP;
      ENUM_ORDER_TYPE ot = ORDER_TYPE_SELL_LIMIT;
      if(ValidateAndAdjustLimitPrice(e, sl, tp, ot))
         success = trade.SellLimit(lot, e, _Symbol, sl, tp, (expMin > 0 ? ORDER_TIME_SPECIFIED : ORDER_TIME_GTC), expTime, comment);
   }
   else if(OTE_PlaceLimitWhenStructuralBetter && direction == "BUY" && preOTEEntryPrice < currentPrice - minOff)
   {
      double e = preOTEEntryPrice, sl = execSL, tp = execTP;
      ENUM_ORDER_TYPE ot = ORDER_TYPE_BUY_LIMIT;
      if(ValidateAndAdjustLimitPrice(e, sl, tp, ot))
         success = trade.BuyLimit(lot, e, _Symbol, sl, tp, (expMin > 0 ? ORDER_TIME_SPECIFIED : ORDER_TIME_GTC), expTime, comment);
   }
   else if(PreOTE_LimitOnly)
   {
      // Force LIMIT (évite une entrée marché tardive au moment du spike).
      double e = preOTEEntryPrice, sl = execSL, tp = execTP;
      ENUM_ORDER_TYPE ot = forcedOt;
      if(ValidateAndAdjustLimitPrice(e, sl, tp, ot))
      {
         if(direction == "BUY")
            success = trade.BuyLimit(lot, e, _Symbol, sl, tp, (expMin > 0 ? ORDER_TIME_SPECIFIED : ORDER_TIME_GTC), expTime, comment);
         else
            success = trade.SellLimit(lot, e, _Symbol, sl, tp, (expMin > 0 ? ORDER_TIME_SPECIFIED : ORDER_TIME_GTC), expTime, comment);
      }
   }
   else if(direction == "BUY")
      success = trade.Buy(lot, _Symbol, 0.0, execSL, execTP, comment);
   else
      success = trade.Sell(lot, _Symbol, 0.0, execSL, execTP, comment);
   
   if(success)
   {
      Print("🚀 ENTRÉE PRÉ-OTE EXÉCUTÉE - ", direction, " sur ", _Symbol);
      Print("   📍 Prix OTE: ", DoubleToString(oteEntryPrice, _Digits));
      Print("   📍 Entrée: ", DoubleToString(preOTEEntryPrice, _Digits), " (", DoubleToString(PreOTEEntryDistancePercent, 1), "% avant OTE)");
      Print("   🛡️ SL: ", DoubleToString(execSL, _Digits));
      Print("   🎯 TP: ", DoubleToString(execTP, _Digits));
      Print("   📊 Espérance: ", DoubleToString(expectancy, 3));
      Print("   💰 Lot: ", DoubleToString(lot, 2));
      Print("   📈 Tendance confirmée: ", trendDirection);
      
      // Enregistrer le trade dans les statistiques
      RecordTradeInStatistics(trade.ResultOrder(), true);
   }
   else
   {
      Print("❌ ENTRÉE PRÉ-OTE ÉCHOUÉE - ", direction, " sur ", _Symbol);
      Print("   ❌ Erreur: ", trade.ResultRetcode(), " - ", trade.ResultComment());
   }
}

//+------------------------------------------------------------------+
//| GESTION DES POSITIONS EN CORRECTION CONTRE TENDANCE           |
//+------------------------------------------------------------------+

//+------------------------------------------------------------------+
//| GESTION DU TEMPS DE DÉTENTION MAXIMUM                           |
//+------------------------------------------------------------------+

// Fermer les positions qui dépassent le temps de détention maximum
void ManageMaximumHoldingTime()
{
   if(!UseUltraSelectiveMode) return;
   
   datetime currentTime = TimeCurrent();
   
   // Parcourir toutes les positions ouvertes
   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      if(PositionGetTicket(i) > 0)
      {
         string symbol = PositionGetString(POSITION_SYMBOL);
         ulong ticket = PositionGetInteger(POSITION_TICKET);
         datetime openTime = (datetime)PositionGetInteger(POSITION_TIME);
         double profit = PositionGetDouble(POSITION_PROFIT);
         string direction = (PositionGetInteger(POSITION_TYPE) == POSITION_TYPE_BUY) ? "BUY" : "SELL";
         
         if(PositionGetInteger(POSITION_MAGIC) != InpMagicNumber) continue;
         if(symbol != _Symbol) continue;
         
         int holdingTimeSeconds = (int)(currentTime - openTime);
         
         // Fermer si le temps de détention est dépassé
         if(holdingTimeSeconds >= MaxHoldingTimeSeconds)
         {
            bool success = PositionCloseWithLog(ticket, "Temps de détention maximum atteint");
            if(success)
            {
               Print("⏰ POSITION FERMÉE - Temps de détention maximum");
               Print("   📍 ", direction, " ", symbol, " - ", holdingTimeSeconds, " secondes");
               Print("   💰 P&L: ", DoubleToString(profit, 2), "$");
               Print("   ⏱️ Limite: ", MaxHoldingTimeSeconds, " secondes");
               
               // Enregistrer la fermeture dans les statistiques
               RecordTradeInStatistics(ticket, false);
            }
            else
            {
               Print("❌ ÉCHEC FERMETURE POSITION - Temps de détention maximum");
            }
         }
      }
   }
}

//+------------------------------------------------------------------+
//| SORTIE SUR INVERSION LIGNE M1 TREND                              |
//| Si la pente M1 (régression linéaire) change de sens par rapport  |
//| à la direction de la position → fermer immédiatement.           |
//| BUY + pente négative = sortie | SELL + pente positive = sortie   |
//+------------------------------------------------------------------+
void ManageM1TrendReversalExit()
{
   if(!UseM1TrendReversalExit) return;

   int lookback = M1TrendReversalLookback;

   // Récupérer les données M1 pour la régression linéaire
   MqlRates m1Rates[];
   ArraySetAsSeries(m1Rates, true);
   if(CopyRates(_Symbol, PERIOD_M1, 0, lookback + 2, m1Rates) < lookback)
      return;

   // Calculer la pente de la régression linéaire (même logique que DrawM1TrendLines)
   double sumX = 0, sumY = 0, sumXY = 0, sumX2 = 0;
   for(int i = 0; i < lookback; i++)
   {
      double x = i;
      double y = m1Rates[i].close;
      sumX  += x;
      sumY  += y;
      sumXY += x * y;
      sumX2 += x * x;
   }

   double slope = (lookback * sumXY - sumX * sumY) / (lookback * sumX2 - sumX * sumY);

   // Vérifier que la pente est significative (pas du bruit)
   if(MathAbs(slope) < M1TrendReversalMinSlope)
      return; // Pente trop faible pour confirmer un changement

   bool m1Bullish = (slope > 0);
   bool m1Bearish = (slope < 0);

   // Parcourir toutes les positions ouvertes
   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      if(PositionGetTicket(i) > 0)
      {
         string symbol = PositionGetString(POSITION_SYMBOL);
         ulong ticket = PositionGetInteger(POSITION_TICKET);
         ENUM_POSITION_TYPE posType = (ENUM_POSITION_TYPE)PositionGetInteger(POSITION_TYPE);
         datetime openTime = (datetime)PositionGetInteger(POSITION_TIME);
         double profit = PositionGetDouble(POSITION_PROFIT);

         if(PositionGetInteger(POSITION_MAGIC) != InpMagicNumber) continue;
         if(symbol != _Symbol) continue;

         // Respecter le délai minimum après ouverture
         if((int)(TimeCurrent() - openTime) < M1TrendReversalMinSeconds)
            continue;

         bool shouldClose = false;
         string reason = "";

         // Position BUY + M1 trend devenu baissier → sortir
         if(posType == POSITION_TYPE_BUY && m1Bearish)
         {
            shouldClose = true;
            reason = "M1 TREND INVERSÉ (pente " + DoubleToString(slope, _Digits) + ") contre BUY";
         }

         // Position SELL + M1 trend devenu haussier → sortir
         if(posType == POSITION_TYPE_SELL && m1Bullish)
         {
            shouldClose = true;
            reason = "M1 TREND INVERSÉ (pente +" + DoubleToString(MathAbs(slope), _Digits) + ") contre SELL";
         }

         if(shouldClose)
         {
            bool success = PositionCloseWithLog(ticket, reason);
            if(success)
            {
               Print("🔄 POSITION FERMÉE - Inversion ligne M1 trend");
               Print("   📍 ", reason);
               Print("   💰 P&L: ", DoubleToString(profit, 2), "$");
               Print("   📉 Pente M1: ", DoubleToString(slope, _Digits));
            }
         }
      }
   }
}

// Surveiller et gérer les positions qui sont en correction contre la tendance
void ManagePositionsAgainstTrendCorrection()
{
   string trendDirection = GetCurrentTrendDirection();
   double emaFast = 0.0, emaSlow = 0.0;
   
   // Obtenir les valeurs EMA actuelles
   if(hEmaFast != INVALID_HANDLE && hEmaSlow != INVALID_HANDLE)
   {
      double a1[], a2[];
      ArraySetAsSeries(a1, true);
      ArraySetAsSeries(a2, true);
      if(CopyBuffer(hEmaFast, 0, 0, 1, a1) >= 1 && CopyBuffer(hEmaSlow, 0, 0, 1, a2) >= 1)
      {
         emaFast = a1[0];
         emaSlow = a2[0];
      }
   }
   
   // Parcourir toutes les positions ouvertes
   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      if(PositionGetTicket(i) > 0)
      {
         string symbol = PositionGetString(POSITION_SYMBOL);
         ulong ticket = PositionGetInteger(POSITION_TICKET);
         double positionPrice = PositionGetDouble(POSITION_PRICE_OPEN);
         double currentPrice = SymbolInfoDouble(symbol, SYMBOL_BID);
         double profit = PositionGetDouble(POSITION_PROFIT);
         ENUM_POSITION_TYPE positionType = (ENUM_POSITION_TYPE)PositionGetInteger(POSITION_TYPE);
         
         if(PositionGetInteger(POSITION_MAGIC) != InpMagicNumber) continue;
         if(symbol != _Symbol) continue; // Se concentrer sur le symbole actuel
         
         bool shouldClosePosition = false;
         string closeReason = "";
         
         // Vérifier les positions BUY en correction
         if(positionType == POSITION_TYPE_BUY)
         {
            // Si la tendance est DOWNTREND et le prix est sous l'EMA rapide
            if(trendDirection == "DOWNTREND" && currentPrice < emaFast)
            {
               shouldClosePosition = true;
               closeReason = "BUY en correction DOWNTREND sous EMA";
            }
            // Si le prix a cassé sous l'EMA rapide (signal de correction)
            else if(currentPrice < emaFast - SymbolInfoDouble(symbol, SYMBOL_POINT) * 20)
            {
               shouldClosePosition = true;
               closeReason = "BUY cassé sous EMA rapide (correction)";
            }
         }
         
         // Vérifier les positions SELL en rallye
         if(positionType == POSITION_TYPE_SELL)
         {
            // Si la tendance est UPTREND et le prix est au-dessus de l'EMA rapide
            if(trendDirection == "UPTREND" && currentPrice > emaFast)
            {
               shouldClosePosition = true;
               closeReason = "SELL en rallye UPTREND au-dessus EMA";
            }
            // Si le prix a cassé au-dessus de l'EMA rapide (signal de rallye)
            else if(currentPrice > emaFast + SymbolInfoDouble(symbol, SYMBOL_POINT) * 20)
            {
               shouldClosePosition = true;
               closeReason = "SELL cassé au-dessus EMA rapide (rallye)";
            }
         }
         
         // Fermer la position si nécessaire
         if(shouldClosePosition)
         {
            bool success = PositionCloseWithLog(ticket, closeReason);
            if(success)
            {
               Print("🔄 POSITION FERMÉE - Correction contre tendance");
               Print("   📍 ", closeReason);
               Print("   💰 P&L: ", DoubleToString(profit, 2), "$");
               Print("   📈 Tendance: ", trendDirection);
               Print("   📊 EMA rapide: ", DoubleToString(emaFast, _Digits));
               
               // Enregistrer la fermeture dans les statistiques
               RecordTradeInStatistics(ticket, false);
            }
            else
            {
               Print("❌ ÉCHEC FERMETURE POSITION - ", closeReason);
            }
         }
      }
   }
}

// Vérifier le toucher du niveau OTE pour exécution au marché
bool IsH1ImpulseAlignedForOTE(const string direction)
{
   bool isBuy = (direction == "BUY" || direction == "buy");
   bool isSell = (direction == "SELL" || direction == "sell");
   if(!isBuy && !isSell) return false;

   double o1 = iOpen(_Symbol, PERIOD_H1, 1);
   double c1 = iClose(_Symbol, PERIOD_H1, 1);
   double h1 = iHigh(_Symbol, PERIOD_H1, 1);
   double l1 = iLow(_Symbol, PERIOD_H1, 1);
   if(o1 <= 0.0 || c1 <= 0.0 || h1 <= 0.0 || l1 <= 0.0) return false;

   double atrH1Value = iATR(_Symbol, PERIOD_H1, 14);
   if(atrH1Value <= 0.0) return false;

   double body = MathAbs(c1 - o1);
   bool impulseBody = (body >= atrH1Value * MathMax(0.10, OTE_EarlyH1BodyAtrMult));

   double ema20h1 = iMA(_Symbol, PERIOD_H1, 20, 0, MODE_EMA, PRICE_CLOSE);
   if(ema20h1 <= 0.0) ema20h1 = c1;

   if(isBuy)
      return (c1 > o1 && c1 >= ema20h1 && impulseBody);
   return (c1 < o1 && c1 <= ema20h1 && impulseBody);
}

bool IsM1EMA20EMA23ReboundForOTE(const string direction, const double tolerance)
{
   bool isBuy = (direction == "BUY" || direction == "buy");
   bool isSell = (direction == "SELL" || direction == "sell");
   if(!isBuy && !isSell) return false;

   double ema20 = iMA(_Symbol, PERIOD_M1, 20, 0, MODE_EMA, PRICE_CLOSE);
   double ema23 = iMA(_Symbol, PERIOD_M1, 23, 0, MODE_EMA, PRICE_CLOSE);
   if(ema20 <= 0.0 && ema23 <= 0.0) return false;

   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   double px = isBuy ? ask : bid;

   bool near20 = (ema20 > 0.0 && MathAbs(px - ema20) <= tolerance);
   bool near23 = (ema23 > 0.0 && MathAbs(px - ema23) <= tolerance);
   if(!near20 && !near23) return false;

   double o1 = iOpen(_Symbol, PERIOD_M1, 1);
   double c1 = iClose(_Symbol, PERIOD_M1, 1);
   double h1 = iHigh(_Symbol, PERIOD_M1, 1);
   double l1 = iLow(_Symbol, PERIOD_M1, 1);
   if(o1 <= 0.0 || c1 <= 0.0 || h1 <= 0.0 || l1 <= 0.0) return false;

   if(isBuy)
   {
      bool touch = ((ema20 > 0.0 && l1 <= ema20 + tolerance) || (ema23 > 0.0 && l1 <= ema23 + tolerance));
      return (touch && c1 > o1);
   }
   bool touch = ((ema20 > 0.0 && h1 >= ema20 - tolerance) || (ema23 > 0.0 && h1 >= ema23 - tolerance));
   return (touch && c1 < o1);
}

bool IsOTEEarlyImpulseEntrySignal(const OTESetupTracker &setup)
{
   if(!OTE_EarlyEntryOnEMA20EMA23Impulse) return false;
   if(!setup.isValid) return false;

   string dir = setup.direction;
   bool isBuy = (dir == "BUY" || dir == "buy");
   bool isSell = (dir == "SELL" || dir == "sell");
   if(!isBuy && !isSell) return false;

   // En correction: bloquer sauf si SpikeAllowInCorrectionZone + spike réel (impulsion).
   bool spikeNow = IsPriceSpikeDetectedForSymbol(_Symbol) || IsBoomCrashM1SpikeRangeBars01(_Symbol);
   if(IsInEquilibriumCorrectionZone() && !(SpikeAllowInCorrectionZone && spikeNow))
      return false;

   if(OTE_EarlyMinAIConfidencePercent > 0.0 && UseAIServer)
   {
      double confUnit = NormalizeAIConfidenceUnit();
      double confPct = confUnit * 100.0;
      string ia = g_lastAIAction;
      StringToUpper(ia);
      if(((isBuy && ia != "BUY") || (isSell && ia != "SELL")) || confPct < OTE_EarlyMinAIConfidencePercent)
         return false;
   }

   double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   if(point <= 0.0) point = _Point;
   double tol = point * MathMax(1, OTE_EarlyEMATouchTolerancePoints);

   if(!IsH1ImpulseAlignedForOTE(dir))
      return false;
   if(!IsM1EMA20EMA23ReboundForOTE(dir, tol))
      return false;

   return true;
}

void CheckAndExecuteMarketOnOTETouch()
{
   if(!ExecuteMarketOnOTETouch) return;
   // Règle stricte: tant qu'une exposition est active sur le symbole, ne pas exécuter un nouveau signal OTE.
   if(HasAnyExposureForSymbol(_Symbol)) return;
   
   double currentPrice = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double askPrice = SymbolInfoDouble(_Symbol, SYMBOL_ASK);

   // Correction zone (ICT) : on évite d'entrer au marché, mais on conserve le setup OTE actif.
   bool inCorrectionZone = false;
   if(OTE_BlockExecutionOnCorrectionZone)
      inCorrectionZone = IsInEquilibriumCorrectionZone();
   
   // Parcourir tous les setups OTE actifs
   for(int i = 0; i < ArraySize(g_activeOTESetups); i++)
   {
      if(!g_activeOTESetups[i].isValid) continue;
      
      OTESetupTracker setup = g_activeOTESetups[i];
      
      // Vérifier si le prix touche le niveau d'entrée OTE
      bool touched = false;
      if(setup.direction == "BUY" && askPrice >= setup.entryPrice)
      {
         touched = true;
      }
      else if(setup.direction == "SELL" && currentPrice <= setup.entryPrice)
      {
         touched = true;
      }
      
      bool earlyOTE = false;
      if(!touched)
         earlyOTE = IsOTEEarlyImpulseEntrySignal(setup);

      if(touched || earlyOTE)
      {
         Print("🎯 TOUCHE NIVEAU OTE DÉTECTÉ - ID: ", setup.setupId, " | ", setup.direction);
         Print("   📍 Prix: ", DoubleToString((setup.direction == "BUY") ? askPrice : currentPrice, _Digits));
         Print("   🎯 Niveau OTE: ", DoubleToString(setup.entryPrice, _Digits));
         if(earlyOTE)
            Print("⚡ OTE EARLY ENTRY - impulsion H1 + rebond EMA20/23 M1 détectés sur ", _Symbol);

         if(inCorrectionZone)
         {
            bool spikeNow = IsPriceSpikeDetectedForSymbol(_Symbol) || IsBoomCrashM1SpikeRangeBars01(_Symbol);
            // Par défaut: aucune exécution OTE au marché en correction. Exception seulement si SpikeAllowInCorrectionZone + spike réel.
            if(!(SpikeAllowInCorrectionZone && spikeNow))
            {
               static datetime lastOTEBlockLog = 0;
               if(TimeCurrent() - lastOTEBlockLog >= 30)
               {
                  Print("🚫 OTE TOUCH IGNORÉ - correction active (bande équilibre) sur ", _Symbol,
                        " | ID=", setup.setupId, " | dir=", setup.direction);
                  lastOTEBlockLog = TimeCurrent();
               }
               continue;
            }
            Print("⚡ OTE TOUCH en correction AUTORISÉ - SpikeAllowInCorrectionZone + spike réel | ", _Symbol,
                  " | ID=", setup.setupId, " | dir=", setup.direction);
         }
         
         // Exécuter l'ordre au marché
         ExecuteMarketOrderOnOTETouch(setup);
         
         // Marquer le setup comme traité
         g_activeOTESetups[i].isValid = false;

         // Dès qu'une exposition est ouverte/pending, stopper la boucle pour éviter
         // l'exécution de plusieurs setups OTE du même symbole sur le même tick.
         if(HasAnyExposureForSymbol(_Symbol))
            break;
      }
   }
}

// Exécuter l'ordre au marché au toucher OTE
void ExecuteMarketOrderOnOTETouch(OTESetupTracker &setup)
{
   // Sécurité : si appelé pendant correction, ne pas exécuter.
   if(OTE_BlockExecutionOnCorrectionZone && IsInEquilibriumCorrectionZone())
   {
      Print("🚫 EXÉCUTION OTE TOUCH BLOQUÉE - correction active sur ", _Symbol,
            " | ID=", setup.setupId, " | dir=", setup.direction);
      return;
   }

   if(!IsTradingAllowedForGainPreservation())
   {
      Print("🚫 EXÉCUTION OTE TOUCH BLOQUÉE - Protection gains active");
      return;
   }
   if(!IsDirectionAllowedForBoomCrash(_Symbol, setup.direction))
   {
      Print("🚫 OTE TOUCH BLOQUÉ - Direction interdite (Boom/Crash) sur ", _Symbol, " : ", setup.direction);
      return;
   }
   if(UseAIServer && IsBoomCrashOrWeltradeDirectionalSynth(_Symbol) &&
      !IsBoomCrashDirectionAllowedByIA(_Symbol, setup.direction))
   {
      Print("🚫 OTE TOUCH BLOQUÉ - Direction vs IA serveur sur ", _Symbol,
            " dir=", setup.direction, " IA=", g_lastAIAction);
      return;
   }
   if(!CanOpenAdditionalPositionForSymbol(_Symbol, setup.direction))
   {
      Print("🚫 OTE TOUCH BLOQUÉ - Position déjà prise sur ", _Symbol, " | dir=", setup.direction);
      return;
   }
   
   if(!HasOTEBOSConfirmationM15OrM5(setup.direction))
   {
      Print("🚫 OTE TOUCH BLOQUÉ - BOS non confirmé (M15/M5) pour ", setup.direction, " sur ", _Symbol);
      return;
   }
   if(!IsOTEEntryConfirmedOnM15OrM5(setup.direction))
   {
      Print("🚫 OTE TOUCH BLOQUÉ - Pas de confirmation candlestick M15/M5 pour ", setup.direction, " sur ", _Symbol);
      return;
   }
   
   // Vérification: Tendance forte EMA M5 (éviter contre-tendance)
   if(OTE_RequireStrongTrend)
   {
      if(!IsStrongM1M5TrendByEMAs(setup.direction))
      {
         Print("🚫 OTE TOUCH BLOQUÉ - Tendance M5 faible ou contre-tendance pour ", setup.direction, " sur ", _Symbol);
         return;
      }
      Print("✅ Tendance forte EMA M5 validée pour ", setup.direction, " sur ", _Symbol);
   }
   
   double lot = NormalizeVolumeForSymbol(GetMinLotForSymbol(_Symbol));
   if(lot <= 0.0)
   {
      Print("❌ EXÉCUTION OTE TOUCH BLOQUÉE - lot minimum indisponible");
      return;
   }
   
   // Exécuter l'ordre au marché
   bool success = false;
   string comment = "OTE_TOUCH_MARKET_" + setup.direction;
   
   if(setup.direction == "BUY")
   {
      success = trade.Buy(lot, _Symbol, 0.0, setup.stopLoss, setup.takeProfit, comment);
   }
   else
   {
      success = trade.Sell(lot, _Symbol, 0.0, setup.stopLoss, setup.takeProfit, comment);
   }
   
   if(success)
   {
      Print("✅ EXÉCUTION OTE TOUCH RÉUSSIE - ", setup.direction, " sur ", _Symbol);
      Print("   📍 Entry: ", DoubleToString(setup.entryPrice, _Digits));
      Print("   🛡️ SL: ", DoubleToString(setup.stopLoss, _Digits));
      Print("   🎯 TP: ", DoubleToString(setup.takeProfit, _Digits));
      Print("   💰 Lot: ", DoubleToString(lot, 2));
      Print("   📝 Comment: ", comment);
   }
   else
   {
      Print("❌ EXÉCUTION OTE TOUCH ÉCHOUÉE - ", setup.direction, " sur ", _Symbol);
      Print("   ❌ Erreur: ", trade.ResultRetcode(), " - ", trade.ResultComment());
   }
}

bool GetCurrentOTEZoneBounds(const string direction, double &zLow, double &zHigh)
{
   string dir = direction;
   StringToUpper(dir);
   if(dir != "BUY" && dir != "SELL")
      return false;

   const string pfxA = "SMC_OTE_CURR_";
   const string pfxB = "SMC_OTE_CUR_";
   string s62a = pfxA + dir + "_62";
   string s78a = pfxA + dir + "_786";
   string s62b = pfxB + dir + "_62";
   string s78b = pfxB + dir + "_786";

   string l62 = (ObjectFind(0, s62a) >= 0) ? s62a : s62b;
   string l78 = (ObjectFind(0, s78a) >= 0) ? s78a : s78b;
   if(ObjectFind(0, l62) < 0 || ObjectFind(0, l78) < 0)
      return false;

   double p62 = ObjectGetDouble(0, l62, OBJPROP_PRICE);
   double p78 = ObjectGetDouble(0, l78, OBJPROP_PRICE);
   if(p62 <= 0.0 || p78 <= 0.0)
      return false;

   zLow = MathMin(p62, p78);
   zHigh = MathMax(p62, p78);
   return (zHigh > zLow);
}

bool IsIAStatusForDirection(const string direction)
{
   string dir = direction;
   StringToUpper(dir);
   if(dir != "BUY" && dir != "SELL")
      return false;

   double minConf = CurrentOTETouchIAForMinConfidence;
   if(minConf > 1.0) minConf /= 100.0;
   if(minConf <= 0.0) minConf = 0.80;

   double conf = NormalizeAIConfidenceUnit();
   if(conf + 1e-9 < minConf)
      return false;

   string ia = g_lastAIAction;
   StringToUpper(ia);
   StringReplace(ia, " ", "");
   StringReplace(ia, "_", "");
   if(ia == "")
      return false;

   bool dirExact = (ia == dir);
   bool forTag = (StringFind(ia, "FOR") >= 0);
   bool dirInLabel = (StringFind(ia, dir) >= 0);

   // Accepte "BUY/SELL" forte confiance, ou labels serveur du type "FORBUY/FOR_SELL".
   return (dirExact || (forTag && dirInLabel));
}

void CheckAndExecuteMarketOnCurrentOTETouchWhenIAFor()
{
   if(!ExecuteMarketOnCurrentOTETouchWhenIAFor) return;
   if(!EnableTrading || BlockAllTrades) return;
   if(!IsTradingAllowedForGainPreservation()) return;
   if(CountPositionsForSymbol(_Symbol) > 0) return;

   static datetime s_lastBuyExec = 0;
   static datetime s_lastSellExec = 0;
   datetime now = TimeCurrent();
   int cd = MathMax(5, CurrentOTETouchCooldownSeconds);

   string dirs[2] = {"BUY", "SELL"};
   for(int i = 0; i < 2; i++)
   {
      string dir = dirs[i];
      bool iaFor = IsIAStatusForDirection(dir);
      bool trendFallback = (OTECurrentZoneUseTrendFallback && IsTrendAlignedEntry(dir) && NormalizeAIConfidenceUnit() >= 0.60);
      if(!iaFor && !trendFallback)
         continue;
      if(!IsDirectionAllowedForBoomCrash(_Symbol, dir))
         continue;

      if((dir == "BUY" && s_lastBuyExec > 0 && (now - s_lastBuyExec) < cd) ||
         (dir == "SELL" && s_lastSellExec > 0 && (now - s_lastSellExec) < cd))
         continue;

      double zLow = 0.0, zHigh = 0.0;
      if(!GetCurrentOTEZoneBounds(dir, zLow, zHigh))
         continue;

      double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
      double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
      if(bid <= 0.0 || ask <= 0.0)
         continue;
      double px = (dir == "BUY") ? ask : bid;
      bool touched = (px >= zLow && px <= zHigh);
      if(!touched)
         continue;

      Print("⚡ OTE CUR TOUCH + IA FOR détecté | ", _Symbol,
            " | dir=", dir,
            " | px=", DoubleToString(px, _Digits),
            " | zone=[", DoubleToString(zLow, _Digits), "; ", DoubleToString(zHigh, _Digits), "]",
            " | IA=", g_lastAIAction, " ", DoubleToString(NormalizeAIConfidenceUnit() * 100.0, 1), "%",
            (iaFor ? " | mode=IA_FOR" : " | mode=TREND_FALLBACK"));

      CheckAndClosePositionsBeforeNewEntry();
      if(ExecuteM5TouchOrder(dir, "OTE_CUR_TOUCH_FOR"))
      {
         if(dir == "BUY") s_lastBuyExec = now; else s_lastSellExec = now;
      }
      break; // Une seule exécution par cycle.
   }
}

// Annuler les ordres OTE si le setup disparaît
void CancelOTESetupsOnInvalidation()
{
   if(!CancelOTEOnSetupInvalidation) return;
   
   for(int i = 0; i < ArraySize(g_activeOTESetups); i++)
   {
      if(!g_activeOTESetups[i].isValid) continue;
      
      // Vérifier si le setup est encore valide
      if(!IsOTESetupStillValid(g_activeOTESetups[i].setupId))
      {
         // Si un ordre pending est associé, l'annuler
         if(g_activeOTESetups[i].orderId > 0)
         {
            MqlTradeRequest req;
            MqlTradeResult res;
            ZeroMemory(req);
            
            req.action = TRADE_ACTION_REMOVE;
            req.order = g_activeOTESetups[i].orderId;
            
            if(OrderSend(req, res))
            {
               Print("✅ ORDRE OTE ANNULÉ - Setup ID: ", g_activeOTESetups[i].setupId, " invalide");
               Print("   🎫 Ticket: ", g_activeOTESetups[i].orderId);
            }
         }
         
         g_activeOTESetups[i].isValid = false;
      }
   }
}

// Objets graphiques représentant un setup OTE / SMC OTE / confluence affichée par l'EA
bool ChartObjectNameIsOTESetupVisual(const string name)
{
   if(StringFind(name, "OTE_SETUP_") >= 0) return true;
   if(StringFind(name, "SMC_OTEIMB_") >= 0) return true;
   if(StringFind(name, "SMC_OTE_BUY_") >= 0) return true;
   if(StringFind(name, "SMC_OTE_SELL_") >= 0) return true;
   if(StringFind(name, "SMC_5STAR_") >= 0) return true;
   return false;
}

bool ChartHasAnyOTESetupVisualNow()
{
   int n = ObjectsTotal(0, -1, -1);
   for(int i = 0; i < n; i++)
   {
      string name = ObjectName(0, i, -1, -1);
      if(name == "") continue;
      if(ChartObjectNameIsOTESetupVisual(name))
         return true;
   }
   return false;
}

// Position ouverte dont le commentaire indique une entrée liée au setup OTE affiché / logique OTE
bool IsPositionCommentOTESetupLinkedTrade(const string comment)
{
   if(IsBoomCrashOteFamilyComment(comment)) return true;
   if(StringFind(comment, "PRE_OTE_SPIKE_") >= 0) return true;
   return false;
}

// Fermer les trades OTE lorsque le setup n'est plus matérialisé sur le graphique (après délai de confirmation)
void ManageOTEPositionsWhenSetupGoneFromChart()
{
   if(!CloseOTEPositionsWhenSetupGoneFromChart) return;
   if(BlockAllTrades) return;

   static bool s_sawOteVisualOnChart = false;
   static datetime s_noOteVisualSince = 0;

   bool hasVisual = ChartHasAnyOTESetupVisualNow();
   datetime now = TimeCurrent();

   if(hasVisual)
   {
      s_sawOteVisualOnChart = true;
      s_noOteVisualSince = 0;
      return;
   }

   if(!s_sawOteVisualOnChart)
      return;

   if(s_noOteVisualSince == 0)
      s_noOteVisualSince = now;

   int hold = MathMax(1, OTEChartSetupGoneCloseHoldSec);
   if((int)(now - s_noOteVisualSince) < hold)
      return;

   for(int pi = PositionsTotal() - 1; pi >= 0; pi--)
   {
      ulong ticket = PositionGetTicket(pi);
      if(ticket == 0 || !PositionSelectByTicket(ticket)) continue;
      if(PositionGetInteger(POSITION_MAGIC) != InpMagicNumber) continue;
      if(PositionGetString(POSITION_SYMBOL) != _Symbol) continue;

      string cmt = PositionGetString(POSITION_COMMENT);
      if(!IsPositionCommentOTESetupLinkedTrade(cmt)) continue;

      if(PositionCloseWithLog(ticket, "OTE setup absent du graphique"))
         Print("?? FERMETURE OTE - setup graphique absent confirmé ", hold, "s | ", _Symbol, " | ticket=", ticket);
   }

   s_sawOteVisualOnChart = false;
   s_noOteVisualSince = 0;
}

// Contexte au moment où le prix approche du niveau limite OTE : même sens IA, confiance >= snapshot, structure OK.
bool IsOTEPendingLimitContextStillValid(const OTESetupTracker &setup)
{
   if(TimeCurrent() - setup.setupTime > 7200)
      return false;
   if(!IsSMCStructureStillValid(setup.direction))
      return false;

   if(UseAIServer)
   {
      string ia = g_lastAIAction;
      StringToUpper(ia);
      if(ia == "" || ia == "HOLD")
         return false;

      string d = setup.direction;
      StringToUpper(d);
      if(ia != d)
         return false;

      double nowU = NormalizeAIConfidenceUnit();
      double snapU = setup.snapshotAIConfUnit;
      if(snapU > 1.0)
         snapU /= 100.0;
      if(nowU + 1e-9 < snapU)
         return false;

      double minAiConfPct = GetCategoryMinAIConfidencePercent(_Symbol);
      double minAiConfUnit = (minAiConfPct > 1.0) ? (minAiConfPct / 100.0) : minAiConfPct;
      if(!IsAIConfidenceAtLeast(minAiConfUnit, "OTE LIMIT PRE-TOUCH", false))
         return false;
   }

   if(UseAIServer && IsBoomCrashOrWeltradeDirectionalSynth(_Symbol) &&
      !IsBoomCrashDirectionAllowedByIA(_Symbol, setup.direction))
      return false;

   return true;
}

// Revérifie puis annule le limite si le contexte OTE s'est dégradé avant le toucher du prix.
void MonitorOTEPendingLimitPreTouch()
{
   if(LimitOrdersDisableAutoCancel) return;
   if(!OTE_LimitPreTouchRevalidate || OTE_LimitPreTouchPoints <= 0)
      return;

   double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   if(point <= 0.0)
      point = _Point;
   double zoneDist = point * (double)OTE_LimitPreTouchPoints;
   int delaySec = MathMax(0, OTE_LimitPreTouchMinDelaySeconds);
   int recheckSec = MathMax(1, OTE_LimitPreTouchRecheckSeconds);
   datetime now = TimeCurrent();
   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);

   for(int i = 0; i < ArraySize(g_activeOTESetups); i++)
   {
      if(!g_activeOTESetups[i].isValid)
         continue;
      ulong oid = g_activeOTESetups[i].orderId;
      if(oid == 0)
         continue;

      bool stillPending = false;
      for(int oi = OrdersTotal() - 1; oi >= 0; oi--)
      {
         if(!OrderSelect(oi))
            continue;
         if((ulong)OrderGetInteger(ORDER_TICKET) != oid)
            continue;
         if(OrderGetInteger(ORDER_MAGIC) != InpMagicNumber)
            break;
         if(OrderGetString(ORDER_SYMBOL) != _Symbol)
            break;
         stillPending = true;
         break;
      }
      if(!stillPending)
      {
         g_activeOTESetups[i].orderId = 0;
         g_activeOTESetups[i].isValid = false;
         continue;
      }

      if(g_activeOTESetups[i].limitPreTouchPassed)
         continue;

      string dir = g_activeOTESetups[i].direction;
      double ep = g_activeOTESetups[i].entryPrice;
      bool inZone = false;
      if(dir == "SELL")
         inZone = (bid > ep && (bid - ep) <= zoneDist);
      else if(dir == "BUY")
         inZone = (ask < ep && (ep - ask) <= zoneDist);

      if(!inZone)
      {
         g_activeOTESetups[i].preTouchZoneEnterUtc = 0;
         continue;
      }

      if(g_activeOTESetups[i].preTouchZoneEnterUtc == 0)
         g_activeOTESetups[i].preTouchZoneEnterUtc = now;
      if(delaySec > 0 && (now - g_activeOTESetups[i].preTouchZoneEnterUtc) < delaySec)
         continue;
      if(g_activeOTESetups[i].lastPreTouchCheckUtc > 0 &&
         (now - g_activeOTESetups[i].lastPreTouchCheckUtc) < recheckSec)
         continue;

      g_activeOTESetups[i].lastPreTouchCheckUtc = now;

      if(IsOTEPendingLimitContextStillValid(g_activeOTESetups[i]))
      {
         g_activeOTESetups[i].limitPreTouchPassed = true;
         Print("✅ OTE LIMITE PRÉ-VALIDÉE - ID ", g_activeOTESetups[i].setupId, " | ", dir,
               " | IA ", g_lastAIAction, " ", DoubleToString(NormalizeAIConfidenceUnit() * 100.0, 1), "%");
         continue;
      }

      MqlTradeRequest req;
      MqlTradeResult res;
      ZeroMemory(req);
      req.action = TRADE_ACTION_REMOVE;
      req.order = oid;
      if(OrderSend(req, res))
      {
         Print("🚫 OTE LIMITE ANNULÉ (contexte affaibli avant touch) - Setup ID: ", g_activeOTESetups[i].setupId,
               " | ticket=", oid, " | ", dir);
      }
      else
      {
         Print("⚠️ Échec annulation OTE limite pré-touch ticket=", oid, " retcode=", res.retcode);
      }
      g_activeOTESetups[i].isValid = false;
      g_activeOTESetups[i].orderId = 0;
   }
}

//+------------------------------------------------------------------+
input int    SMCChannelFutureBars = 5000;    // Bougies futures M1 à projeter
input int    EMAFastPeriod = 9;   // Période EMA rapide pour Supertrend
input int    EMASlowPeriod = 21;  // Période EMA lente pour Supertrend
input double ATRMultiplier = 2.0; // Multiplicateur ATR pour Supertrend

//input group "=== ORDRES LIMITES (niveau le plus proche) ==="
//input bool   UseClosestLevelForLimits = true;  // SUPPRIMÉ - Plus d'ordres limit
input double MaxDistanceLimitATR = 1.0;        // Valeur conservée pour compatibilité (les ordres limit sont désactivés)
//input bool   ShowLimitOrderLevels = true;      // SUPPRIMÉ - Plus d'affichage ordres limit

input group "=== IA SERVEUR ==="

input group "=== BOOM/CRASH ==="
input bool   BoomBuyOnly       = true;   // Boom: BUY uniquement
input bool   CrashSellOnly     = true;   // Crash: SELL uniquement
input bool   BoomCrashHardBlockTradeOnAIHold = true; // Important: ne jamais entrer si l'IA serveur est en HOLD
input bool   UseM5ChannelSpikeSeriesEntry = false; // DÉSACTIVÉ: Stratégie unique OTE + Fibo pour éviter contre-tendance
input int    M5ChSpikeSmallM1CandlesMin = 1; // Petites bougies M1 consécutives après le dernier spike (min)
input int    M5ChSpikeSmallM1CandlesMax = 3; // idem (max)
input int    M5ChSpikeLookbackM1 = 50; // Fenêtre M1 pour compter les spikes
input int    M5ChSpikeMinSpikeBars = 3; // Nb min de bougies "spike" dans la fenêtre (série en cours)
input double M5ChSpikeBarRangeAtrMult = 1.15; // Range bougie >= ATR(20 M1) * ce facteur = spike
input double M5ChSpikeSmallBodyAtrRatio = 0.42; // Corps <= ATR * ratio = petite bougie (consolidation)
input int    M5ChSpikeCooldownSec = 55; // Cooldown entre deux entrées M5-ch-spike sur le même symbole
input bool   M5ChSpikeBypassFutureProtect = true; // Ne pas exiger touch future protect si setup M5-ch validé
input bool   M5ChSpikeBypassDerivArrow = true; // Ne pas exiger flèche SMC_DERIV_ARROW si setup validé
input bool   M5ChSpikeBypassMLTrust = true; // Ne pas exiger IsMLModelTrusted si setup validé
input double M5ChSpikeMinAIConfidenceForHold = 0.42; // Confiance IA min (0..1) quand IA=HOLD et bypass structurel
input bool   M5ChSpikeRequirePremiumDiscount = true; // Crash: Premium pour SELL | Boom: Discount pour BUY
input bool   M5ChSpikeAllowInCorrectionZone = false; // Autoriser cette entrée dans la bande équilibre ICT (défaut: non)
input bool   OteSpikeChainAllowInCorrectionZone = false; // Chaîne OTE (réentrée mode 2): autoriser spike dans bande équilibre ICT
input bool   SpikeAllowInCorrectionZone = false; // true: autorise spikes + touch OTE marché en correction si spike réel (réactif / risqué)
input bool   NoSLTP_BoomCrash  = false;  // Obsolète (ignoré): SL/TP toujours posés à l’ouverture — conservé pour compatibilité .set
input bool   UseIA80ArrowAutoEntry = false; // DÉSACTIVÉ: Seul OTE+Fibo avec confirmation M5 autorisé
input double IA80ArrowAutoMinConfidence = 0.80; // Seuil confiance IA (0..1, ex. 0.80 = 80% ; si >1 traité comme %)
input int    IA80ArrowExitSmallM1Count = 4; // Après flèche verte/rouge: N petites M1 clôturées sans spike → fermeture (souvent 3–5)
input int    IA80ArrowArrowGoneHoldSec = 2; // Secondes sans flèche alignée avant fermeture IA80
input int    IA80ArrowMinSecondsBeforeExit = 3; // Délai min après ouverture avant timeouts flèche / petites M1
input int    IA80ArrowLookbackM1Bars = 12; // Détection flèche IA80: âge max (ancrage temps) en barres M1
input int    IA80ArrowMinObjWidth = 1;     // Largeur min OBJ_ARROW (1 = flèches indicateurs fines ; l’ancien filtre ≥2 les ignorait)
input bool   IA80ArrowAllowHighConfWithoutStrictAction = true; // Si IA conf ≥ seuil + flèche alignée: accepter même si action IA n’est pas exactement BUY/SELL (ex. libellés serveur atypiques)
input bool   IA80ArrowDebugLog = false;    // Log (throttlé) quand l’entrée IA80 est refusée (diagnostic)
input bool   IA80ArrowDisableWhenStairM1Pattern = true; // Boom/Crash: si escalier M1 + filtres stair OK, laisser STAIR_ENTRY exécuter (évite IA80+flèche en doublon)
input bool   IA80ArrowImmediateSpikeClose = true; // Positions IA80+flèche: sans throttle eval spike + sans attente 2e spike + délai min (voir ci-dessous)
input int    IA80ArrowSpikeCloseMinSecondsAfterEntry = 0; // IA80+flèche sur graph courant + IA ≥ seuil IA80: délai min avant close « spike ref capté » (0 = dès détection)
input double BoomCrashSpikeTP  = 0.05;   // [Référence] Fermer dès spike capté — seuil PnL non utilisé (fermeture quel que soit le gain/perte)
input double BoomCrashSpikeCloseMinProfitUSD = 0.01; // [Obsolète] La fermeture sur spike ne filtre plus sur le PnL (conservé pour compatibilité .set)
input int    BoomCrashSpikeCloseMinSecondsAfterEntry = 2; // Délai min avant fermeture "spike capté" (évite close identique tick)
input bool   UseAdverseSpikeCloseOnBoomCrash = true; // Crash SELL / Boom BUY: fermer sur M1 contre le trade (seuil plus bas que spike classique)
input double AdverseSpikeAtrMult = 0.42; // Range M1 >= ATR(20 M1) * ce facteur
input double AdverseSpikeMinBodyOfRange = 0.20; // Corps dans le sens adverse >= range * ce ratio (évite dojis)
input int    BoomCrashSpikeCloseEvalMinSeconds = 1; // Throttle CPU: réévaluer la fermeture spike max N secondes
input int    BoomCrashSpikeRefTimeToleranceSec = 5; // Tolérance temps (sec) entre g_last*SpikeTime et posInfo.Time()
input bool   BoomCrashWaitSecondSpikeOnExceptionalImpulse = false; // Désactivé par défaut: fermer dès le 1er spike capté
input double BoomCrashExceptionalImpulseAtrMult = 1.35; // Impulsion très forte si range M1 >= ATR * SpikePriceMultiplier * ce coeff
input int    BoomCrashSecondSpikeWaitTimeoutSec = 90; // Timeout sécurité avant de fermer si pas de 2e spike
input group "=== IA: EMA alignées -> marché / HOLD -> LIMIT avant Entry M5 ==="
input bool   IA_EmaAlignedExecuteMarket = true; // Si EMA M1/M5 alignées + flèche récente + conf >= seuil => exécuter directement au marché
input double IA_EmaAlignedMinConfidence = 0.80; // Seuil (0..1) pour entrée marché immédiate quand EMA alignées
input bool   IA_HoldPlaceLimitBeforeM5Entry = true; // Si IA=HOLD, placer un pending limit sur SR proche (entre prix et Entry M5)
input double IA_HoldMinConfidence = 0.55; // Seuil (0..1) minimal pour autoriser le placement limit en HOLD
input int    IA_HoldLimitCooldownSeconds = 90; // Cooldown (s) entre 2 placements HOLD-limit sur le même symbole
input double IA_HoldLimitMaxDistanceATR = 2.0; // Distance max (ATR) pour rechercher SR proche via GetClosestBuy/SellLevel
input double IA_HoldLimitSL_ATR = 1.85; // SL = distance ATR depuis entry (limit) — un peu plus serré
input double IA_HoldLimitTP_ATR = 3.4; // TP = distance ATR depuis entry (limit)
input bool   IA_HoldLimitFollowM5Entry = true; // Recalculer le pending IA_HOLD_LIMIT quand Entry M5 / zone « avant M5 » change
input int    IA_HoldLimitFollowRefreshSeconds = 1; // Fréquence de sync (s)
input int    IA_HoldLimitFollowMoveThresholdPoints = 1; // Écart mini (points) avant TRADE_MODIFY
input group "=== SCALP: LIMIT en attente + flèche pure (Boom vert / Crash rouge), IA forte ==="
input bool   UsePendingLimitPureArrowScalp = true; // Boom/Crash: LIMIT actif, 0 position → entrée marché si flèche pure + IA ≥ seuil
input double PendingLimitArrowScalpMinAIConfidence = 0.90; // Confiance IA min (0..1), ex. 0.90 = 90% (ou 90 interprété en %)
input int    PendingLimitArrowScalpCooldownSec = 15; // Cooldown (s) entre deux entrées scalp
input double PendingLimitArrowScalpLotFactor = 0.40; // Fraction du lot calculé (ex. 0.4)
input bool   PendingLimitArrowScalpUseTrendFilter = false; // Si true, exiger IsTrendAlignedEntry comme DERIV ARROW
input bool   WeltradeSpikeOnlyExit = true; // PAINX/GAINX: ne pas faire de sortie active hors spike capté (sauf perte mini ci-dessous)
input double WeltradeMinLossBeforeNonSpikeExitUSD = 1.0; // PAINX/GAINX: si pas de spike, autoriser une sortie active seulement à partir de -1$
input double BoomCrashSpikePct = 0.50;   // Pourcentage de mouvement pour détecter spike (50% - beaucoup plus élevé)
input double BoomCrashSecondSpikeImminentProb = 0.85; // Si proba spike >= seuil, fermer quand même puis armer une réentrée
input bool   UseOteSpikeScalpChain = true; // Boom/Crash: enchaîner les spikes tant qu'un setup OTE reste valide et l'IA n'est pas HOLD
input int    OTEBoomCrashCooldownSecondsAfterSpike = 45; // 0=désactivé — évite une entrée OTE immédiatement après le dernier spike détecté (anti « chase » en queue de spike)
input double OTEBoomCrashGivebackMinPeakUSD = 0.12; // Seuil de pic ($) pour activer la protection giveback sur positions OTE (souvent < SpikePeakGivebackMinProfitUSD)
input double OteSpikeChainMinAIConfidencePct = 78.0; // Confiance IA min (%) pour armer / maintenir la chaîne OTE (ex. SELL Crash)
input int    OteSpikeChainMinSmallM1AfterClose = 3; // Petites bougies M1 après fermeture spike avant réentrée (mode chaîne OTE)
input int    MinSmallM1CandlesAfterCloseOteChain = 2; // Avec chaîne OTE armée: min entre ce nombre et MinSmallM1CandlesAfterClose pour le cooldown post-close (0=désactivé)
input bool   OteSpikeChainBypassMLTrust = true; // Chaîne OTE: ne pas bloquer sur IsMLModelTrusted si IA déjà au-dessus du seuil chaîne
input int    OteSpikeChainReentryTimeoutSec = 3600; // Timeout (s) rester armé en mode chaîne OTE (le mode proba seule reste à 900s)
input bool   AlwaysReenterAfterSpikeClose = true; // Après fermeture spike: armer une réentrée même si proba/OTE n’ont pas armé
input int    AlwaysReentryAfterSpikeCloseMinSmallM1 = 2; // Petites M1 avant tentative de réentrée (mode réentrée systématique)
input int    AlwaysReentryAfterSpikeCloseTimeoutSec = 900; // Timeout (s) rester armé en mode réentrée systématique (0 = 900 appliqué dans le code)
input int    MinSmallM1CandlesAfterCloseAlwaysReentry = 1; // Avec réentrée systématique armée: min entre ce nombre et MinSmallM1CandlesAfterClose (0=désactivé)
input double TargetProfitBoomCrashUSD = 0.10; // Gain à capter ($) - réduit à 0.1$ pour fermer immédiatement après spike
input double MaxLossDollars    = 15.0;   // Fermer toute position si perte atteint ($) - augmenté pour éviter fermetures prématurées
input double TakeProfitDollars = 2.0;    // Fermer si bénéfice atteint ($) - Volatility/Forex/Commodity
input bool   UseMaxLossBoomCrashPerTrade = true; // Boom/Crash: fermer si perte par position > seuil
input double MaxLossBoomCrashPerTradeUSD = 4.0;  // Boom/Crash: perte max admise par trade ($)
input double SymbolProfitTargetUSD = 10.0; // Profit target individuel par symbole ($) - OR, ARGENT, etc.

// Filtre basé sur la probabilité de spike issue du modèle ML
input bool   UseSpikeMLFilter        = true;   // Utiliser la probabilité ML de spike pour filtrer les entrées
input double SpikeML_MinProbability  = 0.75;   // Probabilité ML minimale de spike pour autoriser le trade (75%)
input bool   SpikeUsePreSpikeOnlyForBoomCrash = true; // Boom/Crash: entrer dès le pattern pré-spike (avant le 1er spike)
input bool   SpikeRequirePreSpikePattern = true; // Mode strict: exiger le pattern pré-spike EN PLUS d'un spike récent
input double PreSpike_CompressionRatio   = 0.65;  // Pré-spike: range10 < range50 * ratio (plus haut = plus permissif)
input double PreSpike_ConsolidationPct   = 0.002; // Pré-spike: distance au MA20 (0.2% par défaut)
input double PreSpike_KeyLevelPct        = 0.002; // Pré-spike: proximité swing high/low (0.2% par défaut)

input group "=== INDICATEURS CLASSIQUES (RSI / MACD / BB / VWAP / Pivots / Ichimoku / OBV) ==="
input bool   UseClassicIndicatorsFilter = true;  // Activer le filtre combiné d'indicateurs classiques
input int    ClassicMinConfirmations    = 2;     // Nombre minimal d'indicateurs alignés avec la direction
input bool   UseBollingerFilter         = true;  // Utiliser les Bandes de Bollinger dans le filtre
input bool   UseVWAPFilter              = true;  // Utiliser le VWAP intraday
input bool   UsePivotFilter             = true;  // Utiliser les points pivots journaliers
input bool   UseIchimokuFilter          = true;  // Utiliser un résumé tendance Ichimoku H1
input bool   UseOBVFilter               = true;  // Utiliser le volume OBV comme confirmation

input group "=== RSI 14 IMPULSION (Divergence / Compression / Reversal) ==="
input bool   UseRSIImpulseFilter        = true;   // Activer le filtre RSI Impulsion pour affiner les entrées
input int    RSIImpulsePeriod           = 14;     // Période RSI (14 par défaut)
input int    RSIImpulseLookback         = 40;     // Lookback en bougies M1 pour détecter les patterns
input double RSIDivergenceMinSwingPips  = 5.0;    // Distance min (pips) entre 2 swings prix pour valider divergence
input double RSICompressionMaxRange     = 12.0;   // Range RSI max pour zone de compression (ex: 12 = RSI 44-56)
input int    RSICompressionMinBars     = 5;       // Nombre min de bougies en compression avant breakout
input double RSIReversalTolerance      = 2.0;    // Tolérance (pts RSI) pour double top/bottom sur RSI
input bool   RSIImpulseAsSpikeSignal   = true;    // Compter RSI Impulsion comme signal spike (IsSpikeImminentWithoutAI)

//| GESTION DES POSITIONS ET VARIABLES GLOBALES                    |

// Vrai si ce symbole a subi une perte récente (SL ou autre) ? réentrée soumise à conditions strictes
bool IsRecentLossOnSymbol(const string symbol)
{
   if(g_lastLossSymbol == "" || symbol == "") return false;
   if(g_lastLossSymbol != symbol) return false;
   return (TimeCurrent() - g_lastLossTime <= RECENT_LOSS_WINDOW_SEC);
}

// Autorise ou bloque une réentrée après perte récente sur ce symbole.
// spikeImminent: vrai si le contexte actuel indique un spike / setup exceptionnel (déjà calculé par l'appelant).
bool AllowReentryAfterRecentLoss(const string symbol, const string direction, bool spikeImminent)
{
   if(!IsRecentLossOnSymbol(symbol)) return true;

   string dir = direction;
   StringToUpper(dir);

   // Condition "exceptionnelle" minimale: confiance IA très forte + spike imminent
   double conf = g_lastAIConfidence;
   bool iaStrong = (conf >= 0.90) &&
                   (g_lastAIAction == "BUY" || g_lastAIAction == "buy" ||
                    g_lastAIAction == "SELL" || g_lastAIAction == "sell");

   // Si l'appelant n'a pas son propre flag spikeImminent, utiliser la proba locale
   if(!spikeImminent)
   {
      double p = CalculateSpikeProbability();
      spikeImminent = (p >= 0.80);
   }

   if(iaStrong && spikeImminent)
   {
      Print("? Réentrée après perte autorisée sur ", symbol,
            " - conditions strictes remplies (conf IA ",
            DoubleToString(conf*100, 1), "% + spike/setup fort)");
      return true;
   }

   Print("?? Réentrée après perte sur ", symbol,
         " bloquée (éviter 2e perte consécutive - exiger conf IA ?90% + spike/setup fort)");
   return false;
}

// Lot minimal broker brut pour le symbole (sans surcharge interne)
double GetMinLotForSymbol(const string symbol)
{
   double minLot = SymbolInfoDouble(symbol, SYMBOL_VOLUME_MIN);
   if(minLot <= 0.0)
   {
      Print("❌ MIN LOT INDISPONIBLE pour ", symbol, " - blocage trade pour éviter Invalid volume");
      return 0.0;
   }
   return minLot;
}

// Recovery: après une perte sur un symbole, le prochain trade sur un AUTRE symbole peut utiliser 2× le lot min broker
// pour compenser — uniquement si RecoveryLotOnlyHighConviction: confiance IA + score setup au-dessus des seuils (sinon lot normal, g_lastLossSymbol conservé).
double ApplyRecoveryLot(double baseLot, const string tradeDirection)
{
   if(baseLot <= 0.0)
      return baseLot;

   // Politique volume stricte: ne jamais dépasser le lot minimum broker.
   // Le "recovery lot" est donc désactivé pour garantir un lot toujours minimal.
   double minLot = NormalizeVolumeForSymbol(GetMinLotForSymbol(_Symbol));
   if(minLot > 0.0)
      return minLot;

   return baseLot;
}

// Vérifie si, pour ce symbole, la décision IA est suffisamment forte
// ET alignée en direction (jamais contre-tendance IA) pour autoriser
// l'ouverture d'une nouvelle position (hors Boom/Crash).
bool IsAITradeAllowedForDirection(const string direction)
{
   if(!UseAIServer) return true; // Pas d'IA requise si serveur désactivé
   
   ENUM_SYMBOL_CATEGORY cat = SMC_GetSymbolCategory(_Symbol);
   // Sur Boom/Crash, on garde la logique actuelle DERIV ARROW + règles spécifiques
   if(cat == SYM_BOOM_CRASH) return true;
   
   // Seuil FIXE à 85% pour les autres symboles :
   // on ne trade QUE si l'IA est clairement BUY ou SELL avec très forte confiance.
   double minConf = 0.85;
   if(g_lastAIAction == "" || g_lastAIConfidence < minConf)
   {
      Print("?? TRADE BLOQUÉ - Pas de décision IA forte (conf: ",
            DoubleToString(g_lastAIConfidence*100, 1), "% < ",
            DoubleToString(minConf*100, 1), "%) sur ", _Symbol);
      return false;
   }
   
   if(g_lastAIAction == "HOLD" || g_lastAIAction == "hold")
   {
      Print("?? TRADE BLOQUÉ - IA en HOLD sur ", _Symbol, " (", DoubleToString(g_lastAIConfidence*100,1), "%)");
      return false;
   }

   // Ne jamais trader CONTRE la direction IA:
   // - Si IA = BUY, seules les entrées BUY sont autorisées
   // - Si IA = SELL, seules les entrées SELL sont autorisées
   string iaDir = g_lastAIAction;
   StringToUpper(iaDir);

   // On ne laisse trader que si l'IA est clairement BUY ou SELL
   if(iaDir != "BUY" && iaDir != "SELL")
   {
      Print("?? TRADE BLOQUÉ - Décision IA non directionnelle (", iaDir,
            ") ou incompatible pour ", _Symbol,
            " (conf: ", DoubleToString(g_lastAIConfidence*100,1), "%)");
      return false;
   }

   string dir = direction;
   StringToUpper(dir);

   if((iaDir == "BUY"  && dir != "BUY") ||
      (iaDir == "SELL" && dir != "SELL"))
   {
      Print("?? TRADE BLOQUÉ - Direction '", dir,
            "' contraire au signal IA '", iaDir,
            "' (conf: ", DoubleToString(g_lastAIConfidence*100,1), "%) sur ", _Symbol);
      return false;
   }

   return true;
}

