//@version=6
indicator("OTE Zone Dynamic", overlay=true)

// === SETTINGS ===
atr_mult_up = input.float(0.3, "ATR Mult Up", minval=0.1, maxval=1.0)
atr_mult_down = input.float(0.3, "ATR Mult Down", minval=0.1, maxval=1.0)

// === CALCULATIONS ===
close_price = close
atr_value = ta.atr(14)

// OTE Zone (±ATR autour du prix actuel)
ote_high = close_price + atr_value * atr_mult_up
ote_low = close_price - atr_value * atr_mult_down

// Détection: prix est-il dans la zone?
in_zone = close_price >= ote_low and close_price <= ote_high

// === DRAWING ===
// Lignes hautes/basses
plot(ote_high, "OTE High", color=color.orange, linewidth=2, style=plot.style_dashed)
plot(ote_low, "OTE Low", color=color.orange, linewidth=2, style=plot.style_dashed)

// === ALERTS ===
alertcondition(in_zone, title="Prix dans zone OTE", message="🎯 Price in OTE Zone!")
