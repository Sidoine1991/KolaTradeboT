#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
XAUUSD Unified Report - Single consolidated message
Collecte TOUTES les données et envoie UN message WhatsApp
"""

import json
from datetime import datetime, timezone
import requests
import warnings
warnings.filterwarnings('ignore')
import sys
import os

if sys.platform == 'win32':
    os.environ['PYTHONIOENCODING'] = 'utf-8'

# === ÉTAPE 1 : Données réelles collectées ===

# Prix TradingView
price_data = {
    'symbol': 'OANDA:XAUUSD',
    'price': 4554.585,
    'open': 4554.13,
    'high': 4554.67,
    'low': 4554.095,
    'volume': 35
}

# GOM KOLA SIDO data (from Pine Script)
gom_data = {
    'vwap': 4534.882,
    'bb_sup': 4586.209,
    'bb_mid': 4560.590,
    'bb_inf': 4534.971,
    'st_line': 5368.544,
    'st_dir': 'UP',
    'fib_0': 4595.330,
    'fib_236': 4575.182,
    'fib_382': 4562.717,
    'fib_500': 4552.643,
    'fib_618': 4542.568,
    'fib_786': 4528.225,
    'fib_100': 4509.955,
    'score_buy': 4.110,
    'score_sell': 1.834,
    'spike_pct': 14.525,
    'rsi': 50.808,
    'verdict': 'BUY',
    'verdict_num': 1
}

# === ÉTAPE 2 : Données AI Server ===

print("[COLLECT] Fetching AI Server data...")

ai_server = "http://127.0.0.1:8000"
bias_data = {}
order_data = {}
ta_data = {}

try:
    resp = requests.get(f"{ai_server}/session-bias?symbol=XAUUSD", timeout=5)
    if resp.status_code == 200:
        bias_resp = resp.json()
        if bias_resp.get('success'):
            bias_data = bias_resp.get('data', {})
    print(f"  [OK] Session Bias: {bias_data.get('direction', 'N/A')} {bias_data.get('confidence', 0)*100:.0f}%")
except Exception as e:
    print(f"  [WARN] Session Bias error: {e}")

try:
    resp = requests.get(f"{ai_server}/pending-order?symbol=XAUUSD", timeout=5)
    if resp.status_code == 200:
        order_resp = resp.json()
        if order_resp.get('ok'):
            order_data = order_resp.get('order', {})
    print(f"  [OK] Pending Order: {order_data.get('action', 'NONE')}")
except Exception as e:
    print(f"  [WARN] Pending Order error: {e}")

try:
    resp = requests.get(f"{ai_server}/tradingagents/report-status?symbol=XAUUSD", timeout=5)
    if resp.status_code == 200:
        ta_resp = resp.json()
        ta_data = ta_resp
    print(f"  [OK] TradingAgents: {ta_data.get('direction', 'NONE')}")
except Exception as e:
    print(f"  [WARN] TradingAgents error: {e}")

# === ÉTAPE 3 : Construire le message ===

now_utc = datetime.now(timezone.utc)
time_str = now_utc.strftime("%H:%M")
date_str = now_utc.strftime("%d/%m")

# Déterminer positions
price = price_data['price']
vwap = gom_data['vwap']
price_vs_vwap = "AU-DESSUS" if price > vwap else "EN-DESSOUS"

bb_inf = gom_data['bb_inf']
bb_mid = gom_data['bb_mid']
bb_sup = gom_data['bb_sup']

if price > bb_sup:
    bb_pos = "AU-DESSUS sup"
elif price > bb_mid:
    bb_pos = "ENTRE mid/sup"
elif price > bb_inf:
    bb_pos = "ENTRE inf/mid"
else:
    bb_pos = "EN-DESSOUS inf"

st_line = gom_data['st_line']
price_vs_st = "AU-DESSUS" if price > st_line else "EN-DESSOUS"

# Fib zone
if price >= gom_data['fib_0']:
    fib_zone = "Au-dessus 0%"
elif price >= gom_data['fib_236']:
    fib_zone = "Zone 23.6%"
elif price >= gom_data['fib_382']:
    fib_zone = "Zone 38.2%"
elif price >= gom_data['fib_500']:
    fib_zone = "Zone 50%"
elif price >= gom_data['fib_618']:
    fib_zone = "Zone 61.8%"
elif price >= gom_data['fib_786']:
    fib_zone = "Zone 78.6%"
else:
    fib_zone = "En-dessous 100%"

# Emojis
verdict_emoji = "🟢" if gom_data['verdict'] == "BUY" else "🔴" if gom_data['verdict'] == "SELL" else "⚪"
bias_emoji = "🟢" if bias_data.get('direction') == "BUY" else "🔴" if bias_data.get('direction') == "SELL" else "⚪"
order_emoji = "🟢" if order_data.get('action') == "BUY" else "🔴" if order_data.get('action') == "SELL" else "⚪"
ta_emoji = "🟢" if ta_data.get('direction') == "BUY" else "🔴" if ta_data.get('direction') == "SELL" else "📭"

# Confluence
confluence = 0
conf_details = []
if gom_data['verdict'] == "BUY":
    confluence += 1
    conf_details.append("GOM:BUY")
if bias_data.get('direction') == "BUY":
    confluence += 1
    conf_details.append("BIAS:BUY")
if order_data.get('action') == "BUY":
    confluence += 1
    conf_details.append("ORDER:BUY")
if ta_data.get('direction') == "BUY":
    confluence += 1
    conf_details.append("TA:BUY")

# Construire message
msg = f"""📊 TradBOT [{time_str} UTC]

*XAUUSD — Suivi 20min* | {date_str} {time_str} UTC
━━━━━━━━━━━━━━━━━━━━
💰 *Prix live :* ${price:.2f}
📍 VWAP : ${vwap:.2f} → prix {price_vs_vwap}
📊 BB : [${bb_inf:.2f} / ${bb_mid:.2f} / ${bb_sup:.2f}] → {bb_pos}
⚡ Supertrend : ${st_line:.2f} (↑) → prix {price_vs_st}
📐 Fibo : {fib_zone}
━━━━━━━━━━━━━━━━━━━━
{verdict_emoji} *Verdict GOM KOLA : {gom_data['verdict']}*
   Score BUY={gom_data['score_buy']:.1f}  SELL={gom_data['score_sell']:.1f}  Spike={gom_data['spike_pct']:.1f}%
   RSI={gom_data['rsi']:.0f} | ST=↑
━━━━━━━━━━━━━━━━━━━━
{bias_emoji} *Biais session :* {bias_data.get('direction', '⚠️ AI server')} {bias_data.get('confidence', 0)*100:.0f}% | {'✅' if bias_data.get('valid') else '❌'} valide {bias_data.get('expires_in_hours', 0):.1f}h
━━━━━━━━━━━━━━━━━━━━
{order_emoji} *Ordre EA :* """

if order_data.get('action'):
    msg += f"""{order_data['action']} @ ${order_data.get('entry_price', 'N/A'):.2f} ({order_data.get('gom_verdict', 'N/A')})
━━━━━━━━━━━━━━━━━━━━
"""
else:
    msg += f"""📭 Aucun ordre EA actif
━━━━━━━━━━━━━━━━━━━━
"""

# TradingAgents
if ta_data.get('ok'):
    msg += f"""{ta_emoji} *Rapport TradingAgents :* {ta_data['direction']} {ta_data['confidence']*100:.0f}% | Age: {ta_data['age_minutes']:.0f}min | Expire: {ta_data['expires_in_minutes']:.0f}min
   Entry: ${ta_data.get('entry_price', 'N/A')}
"""
else:
    msg += f"""{ta_emoji} *Rapport TradingAgents :* Aucun rapport actif
"""

msg += """━━━━━━━━━━━━━━━━━━━━
🔬 *Analyse croisee*
  """

if confluence >= 2:
    msg += f"✅ Confluence {confluence}/4: {', '.join(conf_details)}\n"
    msg += """🎯 *Decision scalping*
  BUY - EXECUTE
"""
elif confluence == 1:
    msg += f"⚠️ Confluence faible {confluence}/4: {', '.join(conf_details)}\n"
    msg += """🎯 *Decision scalping*
  WAIT - Enter on confirmation
"""
else:
    msg += f"❌ Pas de confluence\n"
    msg += """🎯 *Decision scalping*
  WAIT - Hold
"""

msg += """━━━━━━━━━━━━━━━━━━━━
_Prochain check dans 20 min_"""

# === ÉTAPE 4 : Sauvegarder et Envoyer ===

print("\n[MESSAGE] Saving locally...")
with open("D:\\Dev\\TradBOT\\xauusd_unified_report.txt", "w", encoding="utf-8") as f:
    f.write(msg)
print("  [OK] D:\\Dev\\TradBOT\\xauusd_unified_report.txt")

print("\n[SEND] Sending via WhatsApp...")

phone = "+2290196911346"
psychobot_url = "https://psychobot-1si7.onrender.com/send-message"

payload = {
    "phone": phone,
    "message": msg
}

try:
    resp = requests.post(psychobot_url, json=payload, timeout=10, verify=False)
    if resp.status_code in [200, 201, 202]:
        print(f"  [SUCCESS] Message sent! (HTTP {resp.status_code})")
    else:
        print(f"  [ERROR] HTTP {resp.status_code}")
        with open("D:\\Dev\\TradBOT\\whatsapp_alerts.log", "a", encoding="utf-8") as f:
            f.write(f"\n[{now_utc.isoformat()}] [FALLBACK]\n{msg}\n")
except Exception as e:
    print(f"  [ERROR] {e}")
    with open("D:\\Dev\\TradBOT\\whatsapp_alerts.log", "a", encoding="utf-8") as f:
        f.write(f"\n[{now_utc.isoformat()}] [FALLBACK]\n{msg}\n")

print("\n[COMPLETE] Done!")
